{
    "name": "bpp",
    "displayName": "B++",
    "description": "Syntax highlighting for the B++ programming language (.bpp and .bsm files).",
    "version": "0.1.0",
    "publisher": "bangdev",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "bpp",
                "aliases": [
                    "B++",
                    "bpp"
                ],
                "extensions": [
                    ".bpp",
                    ".bsm"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "bpp",
                "scopeName": "source.bpp",
                "path": "./syntaxes/bpp.tmLanguage.json"
            }
        ]
    }
}
