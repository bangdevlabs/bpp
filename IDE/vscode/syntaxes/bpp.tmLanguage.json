{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "B++",
    "scopeName": "source.bpp",
    "fileTypes": ["bpp", "bsm"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#imports" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#type-hints" },
        { "include": "#builtins" },
        { "include": "#constants" },
        { "include": "#function-definition" },
        { "include": "#function-call" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.bpp",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.bpp",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.bpp",
                            "match": "\\\\(n|t|r|0|\\\\|\"|x[0-9a-fA-F]{2})"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.bpp",
                    "match": "'(\\\\(n|t|r|0|\\\\|'|x[0-9a-fA-F]{2})|[^'])'"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.bpp",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.float.bpp",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.decimal.bpp",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.bpp",
                    "match": "\\b(if|else|while|for|return|break|continue)\\b"
                },
                {
                    "name": "keyword.declaration.bpp",
                    "match": "\\b(auto|struct|enum|const|extrn|sizeof)\\b"
                }
            ]
        },
        "type-hints": {
            "patterns": [
                {
                    "comment": "Type hints after a colon: auto x: byte, field: half float",
                    "match": ":\\s*(half|quarter|byte)?\\s*(word|float|ptr|long)\\b",
                    "captures": {
                        "1": { "name": "storage.modifier.slice.bpp" },
                        "2": { "name": "support.type.base.bpp" }
                    }
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.memory.bpp",
                    "match": "\\b(malloc|free|realloc|memcpy|peek|poke|str_peek)\\b"
                },
                {
                    "name": "support.function.builtin.io.bpp",
                    "match": "\\b(putchar|putchar_err|getchar)\\b"
                },
                {
                    "name": "support.function.builtin.meta.bpp",
                    "match": "\\b(fn_ptr|call|assert|shr|argc_get|argv_get)\\b"
                },
                {
                    "name": "support.function.builtin.syscall.bpp",
                    "match": "\\b(sys_read|sys_write|sys_open|sys_close|sys_exit|sys_fork|sys_execve|sys_waitpid|sys_socket|sys_connect|sys_ioctl|sys_lseek|sys_fchmod|sys_getdents|sys_mkdir|sys_unlink|sys_ptrace|sys_nanosleep|sys_usleep|sys_clock_gettime)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "comment": "Compiler internal constants: token kinds, AST nodes, types",
                    "name": "constant.language.compiler.bpp",
                    "match": "\\b(TK_KW|TK_IMP|TK_ID|TK_NUM|TK_HEX|TK_STR|TK_OP|TK_PUNCT|TK_FLOAT|T_LIT|T_VAR|T_BINOP|T_UNARY|T_ASSIGN|T_MEMLD|T_MEMST|T_CALL|T_IF|T_WHILE|T_RET|T_DECL|T_NOP|T_BREAK|T_ADDR|TY_UNK|TY_WORD|TY_WORD_H|TY_WORD_Q|TY_WORD_B|TY_FLOAT|TY_FLOAT_H|TY_FLOAT_Q|TY_FLOAT_B|TY_PTR|TY_STRUCT)\\b"
                },
                {
                    "comment": "Input keys from stbinput.bsm",
                    "name": "constant.language.input.bpp",
                    "match": "\\b(KEY_UP|KEY_DOWN|KEY_LEFT|KEY_RIGHT|KEY_W|KEY_A|KEY_S|KEY_D|KEY_SPACE|KEY_ENTER|KEY_ESC|KEY_TAB|KEY_SHIFT|KEY_E|KEY_R|KEY_Z|KEY_X|KEY_G|KEY_C|KEY_N|KEY_T|KEY_0|KEY_1|KEY_2|KEY_3|KEY_4|KEY_5|KEY_6|KEY_7|KEY_8|KEY_9|KEY_F5|KEY_F6|KEY_F9|KEY_F10|KEY_PERIOD|KEY_BACKSPACE|MOUSE_LEFT|MOUSE_RIGHT|MOUSE_MIDDLE)\\b"
                },
                {
                    "comment": "Color constants from stbcolor.bsm",
                    "name": "constant.language.color.bpp",
                    "match": "\\b(BLACK|WHITE|RED|GREEN|BLUE|YELLOW|ORANGE|PURPLE|GRAY|DARKGRAY)\\b"
                },
                {
                    "comment": "Boolean-like literals",
                    "name": "constant.language.bpp",
                    "match": "\\b(NULL)\\b"
                }
            ]
        },
        "imports": {
            "patterns": [
                {
                    "comment": "import \"path.bsm\";",
                    "match": "\\b(import)\\s+\"([^\"]+)\"",
                    "captures": {
                        "1": { "name": "keyword.control.import.bpp" },
                        "2": { "name": "string.quoted.double.include.bpp" }
                    }
                }
            ]
        },
        "function-definition": {
            "patterns": [
                {
                    "comment": "Function definition: name at start of line, followed by (",
                    "match": "^([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.bpp" }
                    }
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "comment": "Function call: identifier followed by (",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.call.bpp" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.bpp",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.logical.bpp",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.bpp",
                    "match": "(&|\\||\\^|~|<<|>>)"
                },
                {
                    "name": "keyword.operator.assignment.bpp",
                    "match": "(\\+=|-=|\\*=|/=|%=|=)"
                },
                {
                    "name": "keyword.operator.arithmetic.bpp",
                    "match": "(\\+|-|\\*|/|%)"
                }
            ]
        }
    }
}
