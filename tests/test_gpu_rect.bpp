// Test: GPU rectangle rendering via Metal.
// Draws colored rectangles and a movable player. Smoke test that
// exercises the GPU path (init + clear + N rects + present).
//
// Auto-exits after 30 frames (~0.5 s at 60 fps) so the test runner
// can drive it unattended. ESC also breaks the loop early. For
// interactive play, raise MAX_FRAMES.

import "stbgame.bsm";
import "stbrender.bsm";

const MAX_FRAMES = 30;

main() {
    auto px, py, frames;
    game_init(320, 180, "GPU Rect Test (WASD move, ESC quit)", 60);
    render_init();
    px = 144;
    py = 74;
    frames = 0;

    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }
        if (key_down(KEY_W)) { py -= 2; }
        if (key_down(KEY_S)) { py += 2; }
        if (key_down(KEY_A)) { px -= 2; }
        if (key_down(KEY_D)) { px += 2; }

        render_begin();
        render_clear(DARKGRAY);
        render_rect(10, 10, 60, 40, RED);
        render_rect(80, 10, 60, 40, GREEN);
        render_rect(150, 10, 60, 40, BLUE);
        render_rect(220, 10, 60, 40, YELLOW);
        render_rect(px, py, 32, 32, WHITE);
        render_end();

        frames++;
        if (frames >= MAX_FRAMES) { break; }
    }
    game_end();
    return 0;
}
