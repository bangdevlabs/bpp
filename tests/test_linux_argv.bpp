// argc/argv test for Linux x86_64.
// Compile: ./bpp --linux64 tests/test_linux_argv.bpp -o build/test_argv_linux
// Test:    docker exec bpp-linux /bpp/build/test_argv_linux foo bar baz
// Expected output:
//   argc=4
//   argv[0]=/bpp/build/test_argv_linux
//   argv[1]=foo
//   argv[2]=bar
//   argv[3]=baz

// Prints a string by walking bytes until null.
putstr(s) {
    auto i, c;
    i = 0;
    c = peek(s + i);
    while (c != 0) {
        putchar(c);
        i = i + 1;
        c = peek(s + i);
    }
}

// Prints an integer (positive only).
putnum(n) {
    auto buf, len, d;
    buf = malloc(32);
    len = 0;
    if (n == 0) {
        putchar(48);
        free(buf);
        return 0;
    }
    while (n > 0) {
        d = n - (n / 10) * 10;
        poke(buf + len, d + 48);
        len = len + 1;
        n = n / 10;
    }
    while (len > 0) {
        len = len - 1;
        putchar(peek(buf + len));
    }
    free(buf);
    return 0;
}

main() {
    auto ac, i, arg;

    ac = argc_get();
    putstr("argc=");
    putnum(ac);
    putchar(10);

    for (i = 0; i < ac; i = i + 1) {
        putstr("argv[");
        putnum(i);
        putstr("]=");
        arg = argv_get(i);
        putstr(arg);
        putchar(10);
    }

    return 0;
}
