import "defs.bsm";
import "bpp_internal.bsm";
import "bpp_import.bsm";
import "bpp_parser.bsm";
import "bpp_lexer.bsm";
import "bpp_types.bsm";
import "bpp_dispatch.bsm";
import "bpp_emitter.bsm";
import "aarch64/a64_enc.bsm";
import "aarch64/a64_codegen.bsm";

print_hex8(v) {
    auto nibble;
    nibble = (v >> 4) & 0xF;
    if (nibble < 10) { putchar('0' + nibble); } else { putchar('a' + nibble - 10); }
    nibble = v & 0xF;
    if (nibble < 10) { putchar('0' + nibble); } else { putchar('a' + nibble - 10); }
    return 0;
}

main() {
    auto arg_len, arg_ptr, i;

    init_defs();
    init_internal();
    init_import();
    init_parser();
    init_lexer();
    init_types();
    init_dispatch();
    init_emitter();
    init_enc_arm64();
    init_codegen_arm64();

    arg_ptr = argv_get(1);
    arg_len = copy_cstr(pathbuf, arg_ptr);
    process_file(pathbuf, arg_len);

    src = outbuf;
    src_len = outbuf_len;
    lex_all();
    parse_program();
    run_types();
    run_dispatch();

    a64_bin_mode = 1;
    emit_all_arm64();

    // Dump enc_buf contents as hex.
    out("enc_pos = "); a64_print_dec(enc_pos); putchar('\n');
    out("code bytes: ");
    i = 0;
    while (i < enc_pos) {
        print_hex8(peek(enc_buf + i));
        putchar(' ');
        i = i + 1;
    }
    putchar('\n');

    return 0;
}
