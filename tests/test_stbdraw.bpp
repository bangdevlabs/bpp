import "stbdraw.bsm";
import "stbfont.bsm";
import "stbio.bsm";

// Stub: _stb_present is a built-in, but for testing without a window
// we just define a no-op so the code compiles.
_stb_present() { return 0; }

main() {
    // Set up a tiny framebuffer (16x16).
    _stb_w = 16; _stb_h = 16;
    _stb_fb = malloc(16 * 16 * 4);
    init_draw();
    init_font();

    // Test 1: clear fills every pixel.
    clear(0x111111FF);
    if (read_u32(_stb_fb, 0) != 0x111111FF) { print_msg("FAIL clear"); return 1; }
    if (read_u32(_stb_fb, 60) != 0x111111FF) { print_msg("FAIL clear mid"); return 2; }

    // Test 2: put_px writes single pixel.
    put_px(5, 5, 0xFF0000FF);
    if (read_u32(_stb_fb, (5*16+5)*4) != 0xFF0000FF) { print_msg("FAIL put_px"); return 3; }

    // Test 3: put_px bounds check.
    put_px(0 - 1, 0, 0xDEAD);
    put_px(16, 0, 0xDEAD);
    // Should not have written anything outside.

    // Test 4: draw_rect.
    clear(0);
    draw_rect(2, 2, 3, 3, 0xAABBCCDD);
    if (read_u32(_stb_fb, (2*16+2)*4) != 0xAABBCCDD) { print_msg("FAIL rect tl"); return 4; }
    if (read_u32(_stb_fb, (4*16+4)*4) != 0xAABBCCDD) { print_msg("FAIL rect br"); return 5; }
    if (read_u32(_stb_fb, (1*16+2)*4) != 0) { print_msg("FAIL rect outside"); return 6; }

    // Test 5: draw_bar.
    clear(0);
    draw_bar(4, 4, 8, 2, 50, 100, RED);
    // Should have black border and red fill of 4px wide.
    if (read_u32(_stb_fb, (4*16+4)*4) == 0) { print_msg("FAIL bar fill"); return 7; }

    // Test 6: draw_line.
    clear(0);
    draw_line(0, 0, 15, 0, WHITE);
    if (read_u32(_stb_fb, 0) != WHITE) { print_msg("FAIL line start"); return 8; }
    if (read_u32(_stb_fb, 15*4) != WHITE) { print_msg("FAIL line end"); return 9; }

    // Test 7: font loaded (check 'A' glyph is not all zeros).
    if (_stb_font == 0) { print_msg("FAIL font null"); return 10; }
    auto glyph_a;
    glyph_a = _stb_font + ('A' - 32) * 8;
    if (peek(glyph_a) == 0) { print_msg("FAIL font A"); return 11; }

    // Test 8: draw_text renders something (check pixel under 'A').
    _stb_w = 64; _stb_h = 16;
    free(_stb_fb);
    _stb_fb = malloc(64 * 16 * 4);
    clear(0);
    draw_text("AB", 0, 0, 1, WHITE);
    // 'A' first row = 24 (0b00011000) → pixels 3,4 should be set.
    if (read_u32(_stb_fb, 3*4) == 0) { print_msg("FAIL text pixel"); return 12; }

    // Test 9: measure_text.
    if (measure_text("Hello", 1) != 40) { print_msg("FAIL measure"); return 13; }
    if (measure_text("Hi", 2) != 32) { print_msg("FAIL measure 2x"); return 14; }

    // Test 10: draw_end calls _stb_present (our stub).
    draw_end();

    free(_stb_fb);
    print_msg("stbdraw: all tests passed");
    return 0;
}
