import "defs.bsm";
import "bpp_internal.bsm";
import "bpp_import.bsm";
import "bpp_parser.bsm";
import "bpp_lexer.bsm";

main() {
    auto arg_ptr, arg_len, ch, i;

    init_defs();
    init_internal();
    init_import();
    putchar('1');

    arg_ptr = argv_get(1);
    putchar('2');

    // Manual copy_cstr to debug
    i = 0;
    ch = str_peek(arg_ptr, 0);
    putchar('3');
    poke(pathbuf, ch);
    putchar('4');

    arg_len = copy_cstr(pathbuf, arg_ptr);
    putchar('5');
    putchar('\n');
    return arg_len;
}
