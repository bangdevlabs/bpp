// test_audio_tone.bpp — Proof-of-life for the stbaudio bring-up.
//
// Diagnostic version. Runs the 440 Hz tone for two seconds, then dumps
// (a) every resolved FFI pointer (index 0 = framework handle, 1-6 =
// AudioQueue function pointers), and (b) the callback invocation
// count. A healthy run shows seven non-zero pointers and a non-zero
// callback count (roughly 86 for 2s at 1024 frames / 44100 Hz) and
// plays an audible square wave. Zero callback count with a successful
// rc means CoreAudio accepted the setup but never invoked the
// callback — the bug is in the queue configuration or the function
// pointer handed to AudioQueueNewOutput.

import "bpp_io.bsm";
import "stbaudio.bsm";

main() {
    auto i, p, rc;

    // Lower the volume before the tone plays. dB scale matches how
    // plugin UIs and mixers think — each -6 dB halves the amplitude,
    // so values stack intuitively:
    //   0 dB   = full scale (loud)
    //   -12 dB = quarter amplitude (the old 8000 default)
    //   -24 dB = 1/16 amp (comfortable background)
    //   -36 dB = 1/64 amp (quiet)
    //   -48 dB = 1/256 amp (very quiet)
    // Swap to audio_set_volume(N) for a linear percent knob, or
    // audio_set_amplitude(N) for raw s16 amplitude.
    audio_set_volume_db(0 - 36);

    print_msg("starting tone...\n");
    rc = audio_tone_test(440, 2000);
    print_msg("audio_tone_test rc = ");
    print_int(rc);
    print_ln();

    print_msg("ffi probes:\n");
    for (i = 0; i < 7; i = i + 1) {
        p = _stb_audio_fn_probe(i);
        print_msg("  [");
        print_int(i);
        print_msg("] = ");
        if (p == 0) { print_msg("NULL (unresolved)"); }
        else { print_int(p); }
        print_ln();
    }

    print_msg("callback invocations = ");
    print_int(_stb_audio_cb_count());
    print_ln();

    return rc;
}
