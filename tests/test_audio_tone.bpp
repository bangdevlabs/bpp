// test_audio_tone.bpp — Proof-of-life for the stbaudio direct-tone path.
//
// Verifies end-to-end that the AudioQueue setup, the FFI symbol resolver,
// and the realtime callback wiring all work, while emitting a brief
// audible blip so a human listening can confirm by ear. Programmatic
// assertions catch the failure modes that ear cannot:
//
//   1. audio_tone_test returns rc == 0 (CoreAudio accepted the queue)
//   2. _stb_audio_fn_probe(0..6) all resolve non-zero (every FFI symbol
//      bound; framework loaded; callback function pointer captured)
//   3. _stb_audio_cb_count() > 0 (the realtime thread actually invoked
//      the callback after AudioQueueStart, not just during priming)
//
// The tone path is the mixer-free siblings of test_audio_pipe (which
// covers the mixer + SPSC ring layer). Together they pin both paths
// the audio stack supports.
//
// Audible — but quiet. Raw amplitude 1000 is ~3% of s16 full scale
// (about -30 dB below peak). Long enough at 250 ms to perceive the
// pitch, short enough that a startled engineer can shrug it off, and
// quiet enough on a system at moderate volume to sound like a tap on
// a cup rather than a buzz. To run an interactive audible version,
// raise TEST_AMP towards 8000 (~ -12 dB) and TEST_MS to 2000 ms.

import "bpp_io.bsm";
import "stbaudio.bsm";

const TEST_AMP = 1000;
const TEST_MS  = 250;

main() {
    auto i, p, rc, cb;

    audio_set_amplitude(TEST_AMP);

    rc = audio_tone_test(440, TEST_MS);
    if (rc != 0) {
        putmsg("FAIL: audio_tone_test rc = ");
        putnum(rc);
        putline();
        return rc;
    }

    // Every FFI probe must be non-zero. Index 0 is the framework
    // handle, 1..6 are the AudioQueue function pointers.
    for (i = 0; i < 7; i++) {
        p = _stb_audio_fn_probe(i);
        if (p == 0) {
            putmsg("FAIL: ffi probe ");
            putnum(i);
            putmsg(" unresolved");
            putline();
            return 10 + i;
        }
    }

    // The callback fires once per buffer; with 1024-frame buffers at
    // 44100 Hz the rate is ~43 Hz, so 250 ms of runtime should yield
    // at least 8 invocations. Anything less means CoreAudio took the
    // queue but never drained from it.
    cb = _stb_audio_cb_count();
    if (cb < 8) {
        putmsg("FAIL: cb_count = ");
        putnum(cb);
        putmsg(" (expected >= 8)");
        putline();
        return 20;
    }

    return 0;
}
