// Test stbarena.bsm — arena allocator correctness.

import "bpp_arena.bsm";

// Print a pass/fail line for a single check.
check(name, ok) {
    auto i;
    if (ok) {
        putchar('O'); putchar('K'); putchar(' ');
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(' ');
    }
    i = 0;
    while (str_peek(name, i) != 0) {
        putchar(str_peek(name, i));
        i++;
    }
    putchar(10);
    return ok;
}

main() {
    auto a, p1, p2, p3, p4, pass;
    pass = 1;

    a = arena_new(256);

    // Basic allocation returns non-null.
    p1 = arena_alloc(a, 64);
    pass = check("alloc returns non-null", p1 != 0) * pass;

    // Second allocation is 64 bytes ahead (aligned).
    p2 = arena_alloc(a, 64);
    pass = check("second alloc is 64 ahead", p2 == p1 + 64) * pass;

    // Alignment: allocating 5 bytes rounds up to 8.
    p3 = arena_alloc(a, 5);
    pass = check("align 5 -> 8 bytes", p3 == p2 + 64) * pass;

    p4 = arena_alloc(a, 8);
    pass = check("next after 5 is +8", p4 == p3 + 8) * pass;

    // Overflow: arena is 256 bytes, we used 64+64+8+8 = 144, asking 200 more.
    pass = check("overflow returns 0", arena_alloc(a, 200) == 0) * pass;

    // Reset recycles memory.
    arena_reset(a);
    p3 = arena_alloc(a, 64);
    pass = check("reset recycles address", p3 == p1) * pass;

    // Clean up.
    arena_free(a);

    // Final verdict.
    putchar(10);
    if (pass) {
        putchar('A'); putchar('L'); putchar('L'); putchar(' ');
        putchar('O'); putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar('E'); putchar('D'); putchar(10);
    }

    return 0;
}
