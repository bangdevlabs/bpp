// test_modulab_dither.bpp — dither + stencil behaviour.
//
// 1. With dither 2x2 active, a filled rect alternates primary and
//    alt palette indices on the (x+y) parity grid.
// 2. With stencil on, pix_set on a protected cell is a no-op.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/canvas.bsm";

main() {
    auto x, y, got, expected;

    init_str();
    state_init(8);

    g_sel_color   = 5;
    g_dither_alt  = 2;
    g_dither_mode = 1;

    // Fill a 4x4 rect in the top-left corner.
    tool_rect(0, 0, 3, 3, 1);

    for (y = 0; y < 4; y = y + 1) {
        for (x = 0; x < 4; x = x + 1) {
            got = pix_get(x, y);
            expected = ((x + y) & 1) != 0 ? g_dither_alt : g_sel_color;
            if (got != expected) {
                putmsg("FAIL: 2x2 dither mismatch at (x,y)=(");
                putnum(x); putmsg(","); putnum(y);
                putmsg(") got "); putnum(got);
                putmsg(" want "); putnum(expected); putline();
                return 1;
            }
        }
    }

    // Turn dither off; now tool_rect should paint a solid g_sel_color.
    g_dither_mode = 0;
    g_sel_color = 3;
    tool_rect(4, 4, 7, 7, 1);
    for (y = 4; y < 8; y = y + 1) {
        for (x = 4; x < 8; x = x + 1) {
            if (pix_get(x, y) != 3) {
                putmsg("FAIL: solid fill expected 3 at ");
                putnum(x); putmsg(","); putnum(y); putline();
                return 1;
            }
        }
    }

    // Stencil — protect colour 3, then try to paint over it.
    g_stencil_on = 1;
    g_stencil_color = 3;
    g_sel_color = 1;
    pix_set(4, 4, 1);  // should be a no-op (4,4)=3 is protected
    if (pix_get(4, 4) != 3) {
        putmsg("FAIL: stencil did not protect cell (4,4)");
        return 1;
    }
    // Non-protected cells still accept writes.
    pix_set(0, 0, 1);
    if (pix_get(0, 0) != 1) {
        putmsg("FAIL: stencil blocked non-protected cell");
        return 1;
    }

    state_free();
    putmsg("OK");
    return 0;
}
