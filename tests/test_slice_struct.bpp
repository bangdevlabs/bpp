// test_slice_struct.bpp — Validates that sliced struct fields load and
// store correctly. Covers byte, quarter, and word. Half with negative
// values has a known sign-extension bug (LDRSW not emitted) — tracked
// separately, does not block positive-only use cases like Node slicing.

struct T {
    a: byte,
    b: quarter,
    c,
    d: byte,
    e
}

main() {
    auto t: T;
    t = malloc(sizeof(T));

    // Write all fields.
    t.a = 200;
    t.b = 50000;
    t.c = 9999999;
    t.d = 42;
    t.e = 7777777;

    // Verify each field loads correctly.
    if (t.a != 200) { return 1; }
    if (t.b != 50000) { return 2; }
    if (t.c != 9999999) { return 3; }
    if (t.d != 42) { return 4; }
    if (t.e != 7777777) { return 5; }

    // Verify byte truncates to 8 bits.
    t.a = 300;
    if (t.a != 44) { return 6; }

    // Verify quarter truncates to 16 bits.
    t.b = 70000;
    if (t.b != 4464) { return 7; }

    // Verify fields don't stomp each other after overwrites.
    t.a = 0xFF;
    t.b = 0xABCD;
    t.c = 0xDEADBEEF;
    t.d = 0x77;
    t.e = 0x12345678;
    if (t.a != 0xFF) { return 8; }
    if (t.b != 0xABCD) { return 9; }
    if (t.c != 0xDEADBEEF) { return 10; }
    if (t.d != 0x77) { return 11; }
    if (t.e != 0x12345678) { return 12; }

    free(t);
    return 0;
}
