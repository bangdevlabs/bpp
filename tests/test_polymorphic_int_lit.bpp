// test_polymorphic_int_lit.bpp — Excalibur Arc Feature 1 Session 1.B.
//
// Session 1.B introduces polymorphic numeric literals for the
// most common case: a SHAPE_INT literal (decimal integer like
// `42`, NOT hex like `0xFF`) passed to a `: float` parameter
// silently widens to float. Pre-arc this tripped E240; the
// widening is lossless and matches Jai / Zig / Odin / C
// conventions.
//
// What this test pins:
//   - The widening produces the exact value (42 → 42.0, not
//     41.99, NaN, or a reinterpreted bit pattern).
//   - It applies to a range of int literals (positive, zero,
//     small, max-int-fits-in-float).
//   - It composes with float arithmetic on the receiving side.
//   - Float literal paths are untouched (3.14 still works as
//     before — the promotion path is a fallback, not a rewrite).
//   - A more complex argument (typed int local, T_BINOP) still
//     requires explicit float typing — this test only exercises
//     the literal path. The error-side cases live in the negative
//     suite (compile-must-fail tests, not in this file).

void check_eq(label, got: float, want: float) {
    auto diff: float;
    diff = got - want;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff > 0.0001) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putfloat(got);
        putstr(" want="); putfloat(want);
        putline();
        sys_exit(1);
    }
}

// Param is `: float`. Arguments will be promoted from int
// literals on the call sites below.
take_float(x: float)@base {
    return x;
}

// Two-axis: confirm the promoted literal flows through the rest
// of float arithmetic unscathed.
double_it(x: float)@base {
    return x * 2.0;
}

main() {
    // Direct round-trip: int literal → float param → return value.
    check_eq("zero",      take_float(0),      0.0);
    check_eq("one",       take_float(1),      1.0);
    check_eq("forty_two", take_float(42),    42.0);
    check_eq("hundred",   take_float(100),  100.0);

    // Float literal path stays untouched.
    check_eq("three_pi",  take_float(3.14),  3.14);

    // Promoted literal participates in float arithmetic.
    check_eq("doubled",   double_it(7),     14.0);
    check_eq("doubled_f", double_it(2.5),    5.0);

    putstr("OK\n");
}
