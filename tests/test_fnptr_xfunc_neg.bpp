// xfail-warn: W028
// V3 Session 4 negative gate (single origin). Registration helper sees
// one caller registering a func(float) target, but the call site passes
// a word — W028 fires via cross-function flow analysis.
import "bpp_io.bsm";
extrn _cb_global;

void cb_float(x: float) { putmsg("never"); }

void register_handler(name, cb) {
    _cb_global = cb;
}

main() {
    register_handler("frame", fn_ptr(cb_float));
    auto i; i = 16;
    call(_cb_global, i);   // W028: cb_float wants float, got word
    return 0;
}
