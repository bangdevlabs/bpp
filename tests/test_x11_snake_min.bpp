// test_x11_snake_min.bpp — minimal snake to isolate the input bug.
//
// Identical to snake_cpu.bpp except: no stbecs, no stbarena, no stbpool,
// no particles. If arrow keys work here, one of those three modules is
// corrupting _stb_keys in the full snake. If input still fails, the bug
// is in snake's own code.

import "stbgame.bsm";

const W = 320;
const H = 180;
const CELL = 10;
const FPS = 5;

const DIR_UP = 0;
const DIR_RIGHT = 1;
const DIR_DOWN = 2;
const DIR_LEFT = 3;

auto head_x, head_y;
auto facing, dead;

main() {
    game_init(W, H, "Snake Minimal", FPS);
    head_x = W / 2;
    head_y = H / 2;
    facing = DIR_RIGHT;
    dead = 0;

    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }

        // Input.
        if (key_down(KEY_UP))    { if (facing != DIR_DOWN)  { facing = DIR_UP; } }
        if (key_down(KEY_RIGHT)) { if (facing != DIR_LEFT)  { facing = DIR_RIGHT; } }
        if (key_down(KEY_DOWN))  { if (facing != DIR_UP)    { facing = DIR_DOWN; } }
        if (key_down(KEY_LEFT))  { if (facing != DIR_RIGHT) { facing = DIR_LEFT; } }

        // Move.
        if (dead == 0) {
            if (facing == DIR_UP)    { head_y = head_y - CELL; }
            if (facing == DIR_RIGHT) { head_x = head_x + CELL; }
            if (facing == DIR_DOWN)  { head_y = head_y + CELL; }
            if (facing == DIR_LEFT)  { head_x = head_x - CELL; }

            if (head_x < 0)  { dead = 1; }
            if (head_x >= W) { dead = 1; }
            if (head_y < 0)  { dead = 1; }
            if (head_y >= H) { dead = 1; }
        }

        // Draw.
        clear(DARKGRAY);
        if (dead) { draw_rect(head_x, head_y, CELL - 1, CELL - 1, RED); }
        else      { draw_rect(head_x, head_y, CELL - 1, CELL - 1, WHITE); }
        draw_text("facing=", 4, 4, 1, WHITE);
        draw_number(60, 4, 1, YELLOW, facing);

        // Debug: print facing to stderr every 30 frames.
        putchar_err('f'); putchar_err('=');
        if (facing == 0) { putchar_err('U'); }
        if (facing == 1) { putchar_err('R'); }
        if (facing == 2) { putchar_err('D'); }
        if (facing == 3) { putchar_err('L'); }
        putchar_err(10);

        draw_end();
    }
    game_end();
    return 0;
}
