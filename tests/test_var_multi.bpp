import "stbio.bsm";

struct Vec2 { x, y }
struct Rect { x, y, w, h }

main() {
    auto scalar;
    var pos: Vec2;
    var vel: Vec2;
    var box: Rect;

    // Test that multiple stack structs coexist in the same frame.
    scalar = 42;
    pos.x = 100;
    pos.y = 200;
    vel.x = 3;
    vel.y = 5;
    box.x = 10;
    box.y = 20;
    box.w = 64;
    box.h = 48;

    // Verify all values are independent and correct.
    if (scalar != 42)  { print_msg("FAIL scalar"); return 1; }
    if (pos.x != 100)  { print_msg("FAIL pos.x"); return 2; }
    if (pos.y != 200)  { print_msg("FAIL pos.y"); return 3; }
    if (vel.x != 3)    { print_msg("FAIL vel.x"); return 4; }
    if (vel.y != 5)    { print_msg("FAIL vel.y"); return 5; }
    if (box.x != 10)   { print_msg("FAIL box.x"); return 6; }
    if (box.y != 20)   { print_msg("FAIL box.y"); return 7; }
    if (box.w != 64)   { print_msg("FAIL box.w"); return 8; }
    if (box.h != 48)   { print_msg("FAIL box.h"); return 9; }

    // Test arithmetic mixing stack structs and scalars.
    scalar = pos.x + vel.x;
    if (scalar != 103) { print_msg("FAIL arith"); return 10; }

    print_msg("var multi: OK");
    return 0;
}
