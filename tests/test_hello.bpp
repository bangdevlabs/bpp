auto gl;

print_str(s) {
    auto i, ch;
    i = 0; ch = str_peek(s, i);
    while (ch != 0) { putchar(ch); i = i + 1; ch = str_peek(s, i); }
    return 0;
}

add(a, b) { return a + b; }

main() {
    auto x, y, i;
    print_str("Hello B++");
    putchar('\n');
    x = 3; y = 4;
    gl = add(x, y);
    i = 0;
    while (i < gl) { putchar('0' + i); i = i + 1; }
    putchar('\n');
    if (gl == 7) { putchar('Y'); } else { putchar('N'); }
    putchar('\n');
    auto buf;
    buf = malloc(16);
    poke(buf, 'A');
    poke(buf + 1, 'B');
    putchar(peek(buf));
    putchar(peek(buf + 1));
    putchar('\n');
    *(buf + 0) = 9999;
    if (*(buf + 0) == 9999) { putchar('Y'); } else { putchar('N'); }
    putchar('\n');
    return 0;
}
