// test_newtype.bpp — Excalibur Feature 3 (Phase 3) — struct newtype.
//
// Pins the canonical newtype declaration syntax `struct WorldPos as
// Vec2;` and the zero-cost claim: a newtype value is byte-identical
// to its base, every field reads/writes flow through the inherited
// layout without ceremony, and dot access on the newtype reaches the
// same offsets as on the base.
//
// What this test pins:
//   - Newtype declaration parses and compiles
//   - Field access on a newtype hits the SAME byte offsets as the base
//   - Newtype values can be passed through extern-style boundaries
//     (auto-unwrap is automatic since byte layout is identical)
//   - sizeof(newtype) == sizeof(base)
//   - A struct used as both raw base and newtype produces identical
//     byte sequences when initialized to the same values

struct Vec2 {
    x: float,
    y: float
}

struct WorldPos as Vec2;
struct GridPos  as Vec2;

void check_eq(label, got: float, want: float) {
    auto diff: float;
    diff = got - want;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff > 0.0001) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putfloat(got);
        putstr(" want="); putfloat(want);
        putline();
        sys_exit(1);
    }
}

void check_int(label, got, want) {
    if (got != want) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putnum(got);
        putstr(" want="); putnum(want);
        putline();
        sys_exit(1);
    }
}

main() {
    // Size parity. Excalibur Feature 3 zero-cost claim.
    check_int("sizeof_worldpos_eq_vec2", sizeof(WorldPos), sizeof(Vec2));
    check_int("sizeof_gridpos_eq_vec2",  sizeof(GridPos),  sizeof(Vec2));

    // Field access. WorldPos and Vec2 share offsets — a write through
    // one type and a read through the other should see the same byte.
    auto wp: WorldPos;
    wp = malloc(sizeof(WorldPos));
    wp.x = 1.5;
    wp.y = 2.5;
    check_eq("wp_x", wp.x, 1.5);
    check_eq("wp_y", wp.y, 2.5);

    // Distinct newtype, same layout. Independent allocations don't
    // cross-contaminate; layout-share is at the schema level only.
    auto gp: GridPos;
    gp = malloc(sizeof(GridPos));
    gp.x = 10.0;
    gp.y = 20.0;
    check_eq("gp_x", gp.x, 10.0);
    check_eq("gp_y", gp.y, 20.0);

    // Original Vec2 still works — newtype declarations don't shadow
    // or wrap the base type.
    auto v: Vec2;
    v = malloc(sizeof(Vec2));
    v.x = 7.0;
    v.y = 8.0;
    check_eq("v_x", v.x, 7.0);
    check_eq("v_y", v.y, 8.0);

    // Cross-type byte-aliasing. Reading the WorldPos buffer as a Vec2
    // should see the same bytes — auto-unwrap at FFI / extern call
    // boundaries is "free" because nothing has to be copied or
    // converted; the bytes are already in the right shape.
    auto v2: Vec2;
    v2 = wp;
    check_eq("alias_x", v2.x, 1.5);
    check_eq("alias_y", v2.y, 2.5);

    free(wp);
    free(gp);
    free(v);

    putstr("OK\n");
    return 0;
}
