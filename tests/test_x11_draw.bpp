// test_x11_draw.bpp — Phase 2 test: draw colored shapes via XPutImage.
//
// Opens a 320x180 window and animates rectangles, a circle, and text.
// Tests the RGBA→BGRX conversion and single-request PutImage path.
//
// Build: ./bpp --linux64 tests/test_x11_draw.bpp -o /tmp/test_x11_draw
// Run:   docker run --rm -e DISPLAY=host.docker.internal:0 \
//            -v /tmp:/tmp ubuntu:22.04 /tmp/test_x11_draw

import "stbgame.bsm";

main() {
    auto frame;
    game_init(320, 180, "X11 Draw Test", 30);
    frame = 0;
    while (game_should_quit() == 0) {
        game_frame_begin();
        clear(rgba(20, 20, 40, 255));

        // Animated red rectangle scrolling horizontally.
        draw_rect(frame % 280, 60, 40, 40, RED);
        // Animated green rectangle bouncing vertically.
        draw_rect(100, frame % 140, 30, 30, GREEN);
        // Static blue circle in the center.
        draw_circle(160, 90, 30, BLUE);
        // Large text label at the top.
        draw_text("Hello X11!", 100, 10, 2, WHITE);

        draw_end();
        frame++;
    }
    game_end();
    return 0;
}
