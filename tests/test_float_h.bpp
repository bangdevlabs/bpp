// Test FLOAT_H (half float = 32-bit single precision) codegen.
// Each sub-test prints a character to verify correctness.
// Expected output: 5457Y9

// Test 1: Basic FLOAT_H arithmetic.
test_arith() {
    auto x: half float;
    auto y: half float;
    x = 3.14;
    y = 2.0;
    auto sum: half float;
    sum = x + y;
    auto i;
    i = sum;
    putchar(48 + i);
    return 0;
}

// Test 2: Mixed ops — FLOAT_H + TY_FLOAT promotes to TY_FLOAT.
test_mixed() {
    auto a: half float;
    auto b: float;
    a = 1.5;
    b = 2.5;
    auto c: float;
    c = a + b;
    auto i;
    i = c;
    putchar(48 + i);
    return 0;
}

// Test 3: Function call with FLOAT_H params.
add_half(a: half float, b: half float) {
    return a + b;
}

test_call() {
    auto x: half float;
    x = add_half(1.5, 3.5);
    auto i;
    i = x;
    putchar(48 + i);
    return 0;
}

// Test 4: FLOAT_H return value from annotated function.
get_seven(): half float {
    return 7.0;
}

test_ret() {
    auto x: half float;
    x = get_seven();
    auto i;
    i = x;
    putchar(48 + i);
    return 0;
}

// Test 5: FLOAT_H comparison.
test_cmp() {
    auto x: half float;
    x = 3.14;
    if (x > 2.0) {
        putchar('Y');
    } else {
        putchar('N');
    }
    return 0;
}

// Test 6: FLOAT_H global variable.
auto gf: half float;

test_global() {
    gf = 9.0;
    auto i;
    i = gf;
    putchar(48 + i);
    return 0;
}

main() {
    test_arith();
    test_mixed();
    test_call();
    test_ret();
    test_cmp();
    test_global();
    putchar(10);
    return 0;
}
