// Test stbecs.bsm — entity-component system correctness.

import "stbecs.bsm";

// Print a pass/fail line for a single check.
check(name, ok) {
    auto i;
    if (ok) {
        putchar('O'); putchar('K'); putchar(' ');
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(' ');
    }
    i = 0;
    while (str_peek(name, i) != 0) {
        putchar(str_peek(name, i));
        i = i + 1;
    }
    putchar(10);
    return ok;
}

main() {
    auto w, a, b, c, pass;
    pass = 1;

    w = ecs_new(100);
    pass = check("new count is 0", ecs_count(w) == 0) * pass;

    // Spawn two entities.
    a = ecs_spawn(w);
    pass = check("spawn a", a >= 0) * pass;
    pass = check("a is alive", ecs_alive(w, a) == 1) * pass;
    pass = check("count is 1", ecs_count(w) == 1) * pass;

    b = ecs_spawn(w);
    pass = check("spawn b != a", b != a) * pass;
    pass = check("count is 2", ecs_count(w) == 2) * pass;

    // Set and read position.
    ecs_set_pos(w, a, 50000, 80000);
    pass = check("get_x a", ecs_get_x(w, a) == 50000) * pass;
    pass = check("get_y a", ecs_get_y(w, a) == 80000) * pass;

    // Set and read velocity.
    ecs_set_vel(w, a, 2000, 0 - 1000);
    pass = check("get_vx a", ecs_get_vx(w, a) == 2000) * pass;
    pass = check("get_vy a", ecs_get_vy(w, a) == 0 - 1000) * pass;

    // Physics: 500ms step. pos += vel * 500 / 1000 = vel / 2.
    ecs_physics(w, 500);
    pass = check("physics x: 50000+1000", ecs_get_x(w, a) == 51000) * pass;
    pass = check("physics y: 80000-500", ecs_get_y(w, a) == 79500) * pass;

    // B should not have moved (vel = 0).
    pass = check("b unmoved x", ecs_get_x(w, b) == 0) * pass;
    pass = check("b unmoved y", ecs_get_y(w, b) == 0) * pass;

    // Flags.
    ecs_set_flags(w, a, 7);
    pass = check("flags a", ecs_get_flags(w, a) == 7) * pass;

    // Kill b and verify.
    ecs_kill(w, b);
    pass = check("b is dead", ecs_alive(w, b) == 0) * pass;
    pass = check("count is 1", ecs_count(w) == 1) * pass;

    // Spawn c — should recycle b's ID.
    c = ecs_spawn(w);
    pass = check("recycled ID", c == b) * pass;
    pass = check("c is alive", ecs_alive(w, c) == 1) * pass;
    pass = check("count is 2", ecs_count(w) == 2) * pass;

    // C should have zeroed components.
    pass = check("c pos_x is 0", ecs_get_x(w, c) == 0) * pass;
    pass = check("c vel_x is 0", ecs_get_vx(w, c) == 0) * pass;

    // Final verdict.
    putchar(10);
    if (pass) {
        putchar('A'); putchar('L'); putchar('L'); putchar(' ');
        putchar('O'); putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar('E'); putchar('D'); putchar(10);
    }

    return 0;
}
