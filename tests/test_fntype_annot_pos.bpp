// V3 Session 3 positive gate. Annotation matches the call site's
// arg types exactly — no diagnostic.
import "bpp_io.bsm";

void cb_float(x: float) { putmsg("ok"); putline(); }

main() {
    auto fp: func(float) -> void;
    fp = fn_ptr(cb_float);
    auto v: float; v = 1.0;
    call(fp, v);
    return 0;
}
