// test_ecs_component.bpp — custom component helpers over parallel arrays.

import "stbecs.bsm";

// Game-defined component. 16 bytes packed.
struct RhythmNote {
    beat_time: float,       // 8
    lane: half float,       // 4
    hit: byte,              // 1
    missed: byte,           // 1
    // 2 padding
}

main() {
    auto w, notes, a, b, c, na: RhythmNote, nb: RhythmNote, nc: RhythmNote;

    w = ecs_new(16);
    notes = ecs_component_new(w, sizeof(RhythmNote));

    a = ecs_spawn(w);
    b = ecs_spawn(w);
    c = ecs_spawn(w);

    na = ecs_component_at(notes, a, sizeof(RhythmNote));
    na.beat_time = 1.5;
    na.lane = 0.25;
    na.hit = 0;

    nb = ecs_component_at(notes, b, sizeof(RhythmNote));
    nb.beat_time = 2.0;
    nb.lane = 0.5;
    nb.hit = 1;

    nc = ecs_component_at(notes, c, sizeof(RhythmNote));
    nc.beat_time = 3.14;
    nc.lane = 0.75;
    nc.hit = 0;

    // Read back from a fresh pointer — verifies the parallel-array
    // layout survives round-trip through ecs_component_at.
    auto check: RhythmNote;
    check = ecs_component_at(notes, a, sizeof(RhythmNote));
    if (check.lane != 0.25) {
        print_msg("FAIL: a.lane did not round-trip");
        return 1;
    }
    if (check.hit != 0) {
        print_msg("FAIL: a.hit should be 0");
        return 1;
    }

    check = ecs_component_at(notes, b, sizeof(RhythmNote));
    if (check.hit != 1) {
        print_msg("FAIL: b.hit should be 1");
        return 1;
    }

    // Word-sized component: plain malloc + subscript still works.
    auto hp;
    hp = ecs_component_new(w, 8);
    hp[a] = 100;
    hp[b] = 50;
    hp[c] = 10;
    if (hp[a] != 100) {
        print_msg("FAIL: hp[a] should be 100");
        return 1;
    }
    if (hp[c] != 10) {
        print_msg("FAIL: hp[c] should be 10");
        return 1;
    }

    print_msg("stbecs: ecs_component_new + ecs_component_at passed");
    return 0;
}
