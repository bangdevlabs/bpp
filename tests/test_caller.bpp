// test_caller.bpp — Validates the Phase 6.2c caller introspection
// builtins. Each function checks that:
//
//   caller_pc(0)  resolves to its OWN name
//   caller_pc(1)  resolves to the function that CALLED it
//   caller_pc(2)  resolves to the function two frames up
//
// The depth-1 and depth-2 cases exercise the chip-specific
// FP-chain walk in `_a64_emit_caller_pc` / `_x64_emit_caller_pc`.
// Without this test, only `caller_pc(0)` (the trivial PC-load
// case) was covered by the original verification probe.

import "bpp_runtime.bsm";

// Compare a packed name reference (from caller_name) against a
// literal C string. Returns 1 on match, 0 otherwise. Done with
// peek() so the test stays free of internal-only helpers.
static name_eq(packed, lit, lit_len) {
    auto addr, n, i;
    if (packed == 0) { return 0; }
    n = _runtime_name_len(packed);
    if (n != lit_len) { return 0; }
    addr = _runtime_name_addr(packed);
    for (i = 0; i < lit_len; i++) {
        if (peek(addr + i) != peek(lit + i)) { return 0; }
    }
    return 1;
}

// Innermost helper. Should see itself, deep_b, deep_a in turn.
static deep_c() {
    if (name_eq(caller_name(caller_pc(0)), "deep_c", 6) == 0) { return 30; }
    if (name_eq(caller_name(caller_pc(1)), "deep_b", 6) == 0) { return 31; }
    if (name_eq(caller_name(caller_pc(2)), "deep_a", 6) == 0) { return 32; }
    return 0;
}

static deep_b() {
    auto rc;
    if (name_eq(caller_name(caller_pc(0)), "deep_b", 6) == 0) { return 20; }
    if (name_eq(caller_name(caller_pc(1)), "deep_a", 6) == 0) { return 21; }
    rc = deep_c();
    return rc;
}

static deep_a() {
    auto rc;
    if (name_eq(caller_name(caller_pc(0)), "deep_a", 6) == 0) { return 10; }
    rc = deep_b();
    return rc;
}

main() {
    auto rc;

    // caller_pc(0) inside main must resolve to "main".
    if (name_eq(caller_name(caller_pc(0)), "main", 4) == 0) { return 1; }

    // Walk three frames deep: main -> deep_a -> deep_b -> deep_c.
    rc = deep_a();
    if (rc != 0) { return rc; }

    return 0;
}
