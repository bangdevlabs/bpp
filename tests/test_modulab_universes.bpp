// test_modulab_universes.bpp — universe switching.
//
// Asserts that universe_apply wipes the canvas, resizes (if the
// new universe has a different default), installs the expected
// palette colour count, and clamps state fields (g_sel_color,
// g_stencil_color) to the new palette range.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";

main() {
    auto i, argb0, argb1;

    init_str();
    state_init(16);

    // Baseline — MCU universe, 8 colours, canvas 16x16.
    if (g_canvas_n != 16) {
        putmsg("FAIL: MCU default canvas size not 16");
        return 1;
    }
    if (g_pal_n != 8) {
        putmsg("FAIL: MCU palette count not 8");
        return 1;
    }

    // Paint something so dirty triggers, then switch to NKOTC. The
    // 4-color universe also shrinks the canvas to 8x8.
    pix_set(2, 3, 5);
    if (g_dirty == 0) {
        putmsg("FAIL: dirty flag did not raise");
        return 1;
    }

    // Push g_sel_color past the NKOTC palette size on purpose so
    // we can confirm the clamp runs.
    g_sel_color = 6;
    g_stencil_color = 5;

    universe_apply(UNIVERSE_NKOTC);
    if (g_canvas_n != 8) {
        putmsg("FAIL: NKOTC should resize to 8x8, got ");
        putnum(g_canvas_n); putline();
        return 1;
    }
    if (g_pal_n != 4) {
        putmsg("FAIL: NKOTC palette count not 4, got ");
        putnum(g_pal_n); putline();
        return 1;
    }
    if (g_sel_color >= g_pal_n) {
        putmsg("FAIL: g_sel_color not clamped to new palette");
        return 1;
    }
    if (g_dirty != 0) {
        putmsg("FAIL: dirty not cleared after universe_apply");
        return 1;
    }

    // Canvas should be empty — the old painted cell is gone with
    // the resize.
    for (i = 0; i < 8 * 8; i++) {
        if (peek(g_frame_data + i) != 0) {
            putmsg("FAIL: canvas not cleared after universe switch");
            return 1;
        }
    }

    // Switch to CB — 32x32, 32 colours.
    universe_apply(UNIVERSE_CB);
    if (g_canvas_n != 32) {
        putmsg("FAIL: CB should resize to 32x32");
        return 1;
    }
    if (g_pal_n != 32) {
        putmsg("FAIL: CB palette count not 32");
        return 1;
    }

    // Back to MCU — verify the palette restored MCU-8 colours.
    // Index 4 is orange in MCU (0xFFFFA500); CB has a different
    // color at slot 4 (brown 0xFF3A1F00).
    universe_apply(UNIVERSE_MCU);
    argb0 = *(g_palette + 4 * 8);
    if (argb0 != 0xFFFFA500) {
        putmsg("FAIL: MCU palette slot 4 not restored");
        return 1;
    }

    state_free();
    putmsg("OK");
    return 0;
}
