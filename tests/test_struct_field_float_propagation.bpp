// Regression: reading a `: float` struct field through a heap pointer
// must propagate the float type into call-site checks. Mirrors the
// wolf3d.bpp pattern where `auto p: FPSBody; p = player;` loads from
// the heap-allocated player. Without the T_MEMLD field-hint
// propagation in bpp_types.bsm, this case raised E240 because p.x
// was typed as int and expects_float wanted float.

struct Pt {
    x: float,
    y: float
}

static expects_float(v: float) {
    return v;
}

main() {
    auto p: Pt;
    p = malloc(16);
    p.x = 3.5;
    p.y = 2.5;
    auto r: float;
    r = expects_float(p.x);
    free(p);
    if (r > 3.0) {
        if (r < 4.0) { return 0; }
    }
    return 1;
}
