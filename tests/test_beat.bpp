// test_beat.bpp — Smoke test for bpp_beat.bsm.
// Verifies that init_beat() captures a zero point, that beat_now_ms()
// is monotonic, and that the unit conversions return values in the
// expected order of magnitude. Returns 0 on success.

import "bpp_beat.bsm";

main() {
    auto t0, t1, t2, frames, samples, beats, i, sink;

    init_beat();

    // First reading should be small (we just initialized).
    t0 = beat_now_ms();
    if (t0 < 0) { return 1; }
    if (t0 > 100) { return 2; }

    // Burn a little CPU so the clock advances.
    sink = 0;
    for (i = 0; i < 100000; i = i + 1) { sink = sink + i; }

    // Second reading should be >= first reading (monotonic).
    t1 = beat_now_ms();
    if (t1 < t0) { return 3; }

    // Burn more time and verify advance.
    for (i = 0; i < 100000; i = i + 1) { sink = sink + i; }
    t2 = beat_now_ms();
    if (t2 < t1) { return 4; }

    // Unit conversions: us = ms * 1000, ns = ms * 1000000.
    if (beat_now_us() < beat_now_ms()) { return 5; }
    if (beat_now_ns() < beat_now_us()) { return 6; }

    // 60 fps for ~zero ms should give ~zero frames.
    frames = beat_now_frames(60);
    if (frames < 0) { return 7; }

    // 44100 Hz audio for ~zero ms should give ~zero samples.
    samples = beat_now_samples(44100);
    if (samples < 0) { return 8; }

    // 120 BPM for ~zero ms should give ~zero beats.
    beats = beat_now_in_bpm(120);
    if (beats < 0) { return 9; }

    // beat_reset() should bring t back near zero.
    beat_reset();
    if (beat_now_ms() > 100) { return 10; }

    return 0;
}
