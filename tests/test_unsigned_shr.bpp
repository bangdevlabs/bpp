// `: u_word` annotation routes >> through the logical-shift chip
// primitive (LSR / SHR). Without the annotation, the high bit
// is replicated (sign-extending right shift). With the annotation,
// the high bit fills with zero so right-shifting a -1 pattern by
// 32 bits yields 0x00000000FFFFFFFF.

main() {
    auto signed_x, signed_s;
    signed_x = 0xFFFFFFFFFFFFFFFF;
    signed_s = signed_x >> 32;
    if (signed_s != 0xFFFFFFFFFFFFFFFF) { return 1; }

    auto unsigned_x: u_word, unsigned_s;
    unsigned_x = 0xFFFFFFFFFFFFFFFF;
    unsigned_s = unsigned_x >> 32;
    if (unsigned_s != 0x00000000FFFFFFFF) { return 2; }

    return 0;
}
