// test_hash.bpp — Smoke test for stbhash.bsm.
// Exercises both the word-keyed Hash and the byte-keyed HashStr APIs
// through insert, lookup, update, delete, resize, and clear.
// Returns 0 on success or a unique non-zero code identifying the
// first failed assertion.

import "stbhash.bsm";
import "stbio.bsm";

main() {
    auto h, hs, i;

    // ── Word-keyed: empty state ─────────────────────────────
    h = hash_new(8);
    if (hash_count(h) != 0) { print_msg("FAIL word: empty count"); return 1; }
    if (hash_has(h, 42) != 0) { print_msg("FAIL word: empty has"); return 2; }
    if (hash_get(h, 42) != 0) { print_msg("FAIL word: empty get"); return 3; }

    // ── Word-keyed: basic insert and lookup ─────────────────
    hash_set(h, 42, 1000);
    hash_set(h, 17, 2000);
    hash_set(h, 99, 3000);
    if (hash_count(h) != 3)        { print_msg("FAIL word: count after 3"); return 4; }
    if (hash_get(h, 42) != 1000)   { print_msg("FAIL word: get 42"); return 5; }
    if (hash_get(h, 17) != 2000)   { print_msg("FAIL word: get 17"); return 6; }
    if (hash_get(h, 99) != 3000)   { print_msg("FAIL word: get 99"); return 7; }
    if (hash_has(h, 42) != 1)      { print_msg("FAIL word: has present"); return 8; }
    if (hash_has(h, 1234) != 0)    { print_msg("FAIL word: has absent"); return 9; }

    // ── Word-keyed: update existing key ─────────────────────
    hash_set(h, 42, 9999);
    if (hash_get(h, 42) != 9999)   { print_msg("FAIL word: update value"); return 10; }
    if (hash_count(h) != 3)        { print_msg("FAIL word: update count"); return 11; }

    // ── Word-keyed: delete and tombstone semantics ──────────
    if (hash_del(h, 17) != 1)      { print_msg("FAIL word: del present"); return 12; }
    if (hash_has(h, 17) != 0)      { print_msg("FAIL word: has after del"); return 13; }
    if (hash_count(h) != 2)        { print_msg("FAIL word: count after del"); return 14; }
    if (hash_get(h, 99) != 3000)   { print_msg("FAIL word: lookup after del"); return 15; }
    if (hash_del(h, 17) != 0)      { print_msg("FAIL word: del absent"); return 16; }

    // ── Word-keyed: resize stress ───────────────────────────
    // Insert 100 keys to force several resize cycles, then verify all
    // remain retrievable. Exercises rehashing and tombstone cleanup.
    i = 0;
    while (i < 100) { hash_set(h, i * 7 + 1, i * 13); i = i + 1; }
    i = 0;
    while (i < 100) {
        if (hash_get(h, i * 7 + 1) != i * 13) {
            print_msg("FAIL word: resize stress at i=");
            print_int(i);
            print_ln();
            return 17;
        }
        i = i + 1;
    }

    // ── Word-keyed: clear preserves capacity, drops entries ─
    hash_clear(h);
    if (hash_count(h) != 0)        { print_msg("FAIL word: clear count"); return 18; }
    if (hash_has(h, 42) != 0)      { print_msg("FAIL word: clear lookup"); return 19; }
    hash_set(h, 5, 50);
    if (hash_get(h, 5) != 50)      { print_msg("FAIL word: post-clear insert"); return 20; }

    hash_free(h);

    // ── Byte-keyed: empty state ─────────────────────────────
    hs = hash_str_new(8);
    if (hash_str_count(hs) != 0)        { print_msg("FAIL str: empty count"); return 30; }
    if (hash_str_has(hs, "x", 1) != 0)  { print_msg("FAIL str: empty has"); return 31; }
    if (hash_str_get(hs, "x", 1) != 0)  { print_msg("FAIL str: empty get"); return 32; }

    // ── Byte-keyed: basic insert and lookup ─────────────────
    hash_str_set(hs, "main",   4, 1);
    hash_str_set(hs, "init",   4, 2);
    hash_str_set(hs, "update", 6, 3);
    hash_str_set(hs, "render", 6, 4);
    if (hash_str_count(hs) != 4)              { print_msg("FAIL str: count after 4"); return 33; }
    if (hash_str_get(hs, "main",   4) != 1)   { print_msg("FAIL str: get main"); return 34; }
    if (hash_str_get(hs, "init",   4) != 2)   { print_msg("FAIL str: get init"); return 35; }
    if (hash_str_get(hs, "update", 6) != 3)   { print_msg("FAIL str: get update"); return 36; }
    if (hash_str_get(hs, "render", 6) != 4)   { print_msg("FAIL str: get render"); return 37; }

    // ── Byte-keyed: prefix is not a key ─────────────────────
    // "ma" must not match the entry "main" — length matters.
    if (hash_str_get(hs, "ma", 2) != 0)       { print_msg("FAIL str: prefix mismatch"); return 38; }
    if (hash_str_get(hs, "main", 4) != 1)     { print_msg("FAIL str: prefix unaffected"); return 39; }

    // ── Byte-keyed: update existing key ─────────────────────
    hash_str_set(hs, "main", 4, 99);
    if (hash_str_get(hs, "main", 4) != 99)    { print_msg("FAIL str: update value"); return 40; }
    if (hash_str_count(hs) != 4)              { print_msg("FAIL str: update count"); return 41; }

    // ── Byte-keyed: delete and tombstone semantics ──────────
    if (hash_str_del(hs, "init", 4) != 1)     { print_msg("FAIL str: del present"); return 42; }
    if (hash_str_has(hs, "init", 4) != 0)     { print_msg("FAIL str: has after del"); return 43; }
    if (hash_str_count(hs) != 3)              { print_msg("FAIL str: count after del"); return 44; }
    if (hash_str_get(hs, "render", 6) != 4)   { print_msg("FAIL str: lookup after del"); return 45; }
    if (hash_str_del(hs, "init", 4) != 0)     { print_msg("FAIL str: del absent"); return 46; }

    // ── Byte-keyed: clear releases owned key buffers ────────
    hash_str_clear(hs);
    if (hash_str_count(hs) != 0)              { print_msg("FAIL str: clear count"); return 47; }
    if (hash_str_has(hs, "main", 4) != 0)     { print_msg("FAIL str: clear lookup"); return 48; }
    hash_str_set(hs, "test", 4, 1);
    if (hash_str_get(hs, "test", 4) != 1)     { print_msg("FAIL str: post-clear insert"); return 49; }

    hash_str_free(hs);

    print_msg("test_hash: all PASS");
    print_ln();
    return 0;
}
