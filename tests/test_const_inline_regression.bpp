// test_const_inline_regression.bpp — confirm the storage-class
// sidequest did NOT change the existing `const X = N;` parser-
// level literal-substitution path. A bare `const` (no qualifier)
// still inlines the value at every use site and emits no symbol
// into the data section. Most constants in the codebase use this
// form; breaking it would cascade across stb cartridges + games.

const CELL = 16;
const PI   = 3.14159;

main() {
    auto px;
    px = CELL * 4;
    if (px != 64) { return 1; }

    auto f: float;
    f = PI;
    // PI inlined as SHAPE_DECIMAL literal — bits preserved through
    // the float fast path that ships in `parse_const`.
    if (f < 3.14) { return 2; }
    if (f > 3.15) { return 3; }
    return 0;
}
