import "stbio.bsm";

struct Vec2 { x, y }

main() {
    var a: Vec2;
    var b: Vec2;

    // Set values on a.
    a.x = 10;
    a.y = 20;

    // Copy a to b.
    b = a;

    // Verify copy happened.
    if (b.x != 10) { print_msg("FAIL copy x"); return 1; }
    if (b.y != 20) { print_msg("FAIL copy y"); return 2; }

    // Modify a — b should be independent.
    a.x = 999;
    if (b.x != 10) { print_msg("FAIL independence"); return 3; }
    if (a.x != 999) { print_msg("FAIL original"); return 4; }

    print_msg("var copy: OK");
    return 0;
}
