// test_modulab_anim_playback.bpp — testbed animation stepping.
//
// Builds a character with a 4-frame walk animation at 10 fps
// (100 ms period). Starts playback, feeds incremental dt to
// testbed_anim_tick, asserts the reported frame index advances
// in lockstep, loops on wraparound, and that fetching the
// source frame index resolves through the animation's frame
// list (not the host's g_frame_idx).

import "stbgame.bsm";
import "stbforge.bsm";
load "../tools/modulab/core.bsm";

main() {
    auto cp, c: Character, a: Animation, ap;
    auto frames, first_frame_idx, source;

    init_str();
    state_init(16);

    cp = character_new();
    c  = cp;
    c.hit_x = 0; c.hit_y = 0; c.hit_w = 1; c.hit_h = 1;
    testbed_init(cp);

    // Register a "walk" animation using frame indices 0..3.
    ap = character_add_animation(cp, "walk", 10, 1);   // 10 fps, looping
    frames = malloc(4 * 8);
    *(frames + 0 * 8) = 0;
    *(frames + 1 * 8) = 1;
    *(frames + 2 * 8) = 2;
    *(frames + 3 * 8) = 3;
    character_set_frames(ap, frames, 4);
    free(frames);

    // Lookup by name resolves the freshly added animation.
    if (testbed_find_animation("walk") != 0) {
        print_msg("FAIL: find_animation did not return 0 for 'walk'\n");
        return 1;
    }

    // Before play, tb_anim_idx reports -1 and the source frame
    // resolves to the host's active frame.
    if (tb_anim_idx() != 0 - 1) {
        print_msg("FAIL: anim_idx not -1 before play\n"); return 1;
    }

    testbed_play_animation(0);
    if (tb_anim_idx() != 0) {
        print_msg("FAIL: anim_idx not 0 after play\n"); return 1;
    }
    if (tb_anim_frame() != 0) {
        print_msg("FAIL: anim_frame not 0 after play\n"); return 1;
    }
    if (tb_current_frame_idx() != 0) {
        print_msg("FAIL: current_frame_idx not frames[0]=0 at start\n");
        return 1;
    }

    // Sub-period tick — nothing advances.
    testbed_anim_tick(50);
    if (tb_anim_frame() != 0) {
        print_msg("FAIL: anim stepped before period\n"); return 1;
    }

    // Cross the 100 ms threshold — frame 1.
    testbed_anim_tick(50);
    if (tb_anim_frame() != 1) {
        print_msg("FAIL: did not land on frame 1 at 100 ms\n");
        return 1;
    }
    if (tb_current_frame_idx() != 1) {
        print_msg("FAIL: current_frame_idx != frames[1]=1\n"); return 1;
    }

    // Big-dt jump: 350 ms = 3 more periods → frame (1+3)%4 = 0.
    testbed_anim_tick(350);
    if (tb_anim_frame() != 0) {
        print_msg("FAIL: loop wraparound failed (got ");
        print_int(tb_anim_frame()); print_msg(")\n");
        return 1;
    }

    // Stop playback — source frame falls back to g_frame_idx.
    testbed_play_animation(0 - 1);
    if (tb_anim_idx() != 0 - 1) {
        print_msg("FAIL: anim_idx not -1 after stop\n"); return 1;
    }
    if (tb_current_frame_idx() != frame_idx()) {
        print_msg("FAIL: stopped playback did not fall back to host frame\n");
        return 1;
    }

    // Non-looping animation clamps at the last frame.
    ap = character_add_animation(cp, "attack", 20, 0); // 20 fps, one-shot
    frames = malloc(3 * 8);
    *(frames + 0 * 8) = 0;
    *(frames + 1 * 8) = 1;
    *(frames + 2 * 8) = 2;
    character_set_frames(ap, frames, 3);
    free(frames);
    testbed_play_animation(1);
    // Period at 20 fps = 50 ms. 500 ms is 10 periods — way past
    // the last frame. Clamp expected.
    testbed_anim_tick(500);
    if (tb_anim_frame() != 2) {
        print_msg("FAIL: non-loop did not clamp (got ");
        print_int(tb_anim_frame()); print_msg(")\n");
        return 1;
    }

    testbed_free();
    character_free(cp);
    state_free();
    print_msg("OK");
    return 0;
}
