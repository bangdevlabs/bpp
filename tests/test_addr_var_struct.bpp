// Regression: T_ADDR on a `var: T` stack-struct local must emit
// valid C. Pre-fix the C emitter wrapped the T_VAR-stack-struct
// path's `((long long)(stk))` with `&`, producing `&((long long)(stk))`
// — invalid because `&` cannot apply to an rvalue cast. Now T_ADDR
// detects the stack-struct child and delegates to T_VAR directly.

struct Pt {
    x: float,
    y: float
}

main() {
    var s: Pt;
    s.x = 7.0;
    s.y = 0.0;
    auto p: Pt;
    p = &s;
    if (p.x > 6.5) {
        if (p.x < 7.5) { return 0; }
    }
    return 1;
}
