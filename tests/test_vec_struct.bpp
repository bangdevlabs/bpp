// Phase B4: struct fields typed `: double` exercise the MEMLD/MEMST
// SL_DOUBLE dispatch and the field-offset math for 16-byte slots.
// The test writes every field, reads every field back, and asserts
// the lanes match — if an offset miscalculation overlaps `pos` with
// `vel` (the B3 spill_base bug class), this test catches it.

import "bpp_io.bsm";
import "bpp_mem.bsm";

struct Particle {
    pos: double,     // 128 bits, offset 0
    vel: double,     // 128 bits, offset 16
    mass: half,      //  32 bits, offset 32
    id               //  64 bits, offset 40 (8-byte aligned after half)
}

main() {
    auto p: Particle;
    auto lane;

    p = malloc(sizeof(Particle));

    // Write every field. pos and vel sit on adjacent 16-byte slots —
    // if `vel`'s field offset is wrong (e.g. 8 instead of 16) the
    // writes interleave and the readback below will not match.
    p.pos = vec_splat4(7.0);
    p.vel = vec_splat4(11.0);
    p.mass = 42;
    p.id = 99;

    // Read pos back: all four lanes must be 7.
    auto vp: double;
    vp = p.pos;
    lane = vec_get4(vp, 0); putchar('0' + lane);
    lane = vec_get4(vp, 1); putchar('0' + lane);
    lane = vec_get4(vp, 2); putchar('0' + lane);
    lane = vec_get4(vp, 3); putchar('0' + lane);
    putchar('\n');

    // Read vel back: all four lanes must be 11 → print "11" four times.
    auto vv: double;
    vv = p.vel;
    lane = vec_get4(vv, 0); putchar('0' + lane / 10); putchar('0' + lane % 10);
    lane = vec_get4(vv, 1); putchar('0' + lane / 10); putchar('0' + lane % 10);
    lane = vec_get4(vv, 2); putchar('0' + lane / 10); putchar('0' + lane % 10);
    lane = vec_get4(vv, 3); putchar('0' + lane / 10); putchar('0' + lane % 10);
    putchar('\n');

    // Scalar fields: mass must still be 42, id must still be 99.
    putchar('0' + p.mass / 10); putchar('0' + p.mass % 10);
    putchar('0' + p.id / 10); putchar('0' + p.id % 10);
    putchar('\n');

    free(p);
    return 0;
}
