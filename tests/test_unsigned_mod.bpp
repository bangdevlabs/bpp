// `: u_word` annotation routes modulo through the unsigned chip
// primitive (UDIV+MSUB / xor+DIV+mov). For signed -1 % 100, the
// remainder keeps the dividend's sign (-1). For the same bits
// treated as unsigned, the result is the high-bit-pattern
// remainder 15 (0xFFFFFFFFFFFFFFFF % 100).

main() {
    auto signed_x, signed_r;
    signed_x = 0xFFFFFFFFFFFFFFFF;
    signed_r = signed_x % 100;
    if (signed_r != 0xFFFFFFFFFFFFFFFF) { return 1; }

    auto unsigned_x: u_word, unsigned_r;
    unsigned_x = 0xFFFFFFFFFFFFFFFF;
    unsigned_r = unsigned_x % 100;
    if (unsigned_r != 15) { return 2; }

    return 0;
}
