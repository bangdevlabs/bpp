// test_safe_annotation.bpp — Phase annotation collapse step 1.
//
// Pins the canonical post-collapse annotation `@safe`. The compiler
// accepts the new spelling and enforces it identically to `@time`:
// callees must be `@base` (verified pure) or `@safe` / `@time`.
// Anything that touches HEAP / IO / GPU through the call graph
// triggers W026.
//
// This program intentionally stays inside the safe envelope so it
// compiles clean. The negative case (W026 firing on `@safe` reaching
// IO) is exercised by the C suite's compile-must-fail harness in a
// future session — the positive smoke is enough to pin that the
// parser accepts the new keyword and the validator routes it through
// the same enforcement path as `@time`.

// Pure computation — worker-safe, callable by `@safe`.
static _double(x)@base { return x + x; }

// Bounded path — no malloc, no IO, no GPU. The migration sweep
// renames `@time` audio callbacks to `@safe`; this test pins that
// the new spelling parses + propagates without warnings.
safe_compute(buf, n)@safe {
    auto i, sum;
    sum = 0;
    for (i = 0; i < n; i++) {
        poke(buf + i, _double(i));
        sum = sum + i;
    }
    return sum;
}

main() {
    auto buf, total;
    buf = malloc(16);
    total = safe_compute(buf, 16);
    free(buf);
    if (total != 120) {
        putstr("FAIL total=");
        putnum(total);
        putline();
        return 1;
    }
    putstr("OK\n");
    return 0;
}
