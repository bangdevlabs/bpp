import "stbcol.bsm";

main() {
    // ── rect_overlap ──────────────────────────────────────────

    // Test 1: Two overlapping rectangles.
    if (rect_overlap(0, 0, 10, 10, 5, 5, 10, 10) != 1) { return 1; }

    // Test 2: Non-overlapping — second rect is to the right.
    if (rect_overlap(0, 0, 10, 10, 20, 0, 10, 10) != 0) { return 2; }

    // Test 3: Non-overlapping — second rect is below.
    if (rect_overlap(0, 0, 10, 10, 0, 20, 10, 10) != 0) { return 3; }

    // Test 4: Touching edges (x1+w1 == x2) should NOT overlap.
    if (rect_overlap(0, 0, 10, 10, 10, 0, 10, 10) != 0) { return 4; }

    // Test 5: Touching edges vertically should NOT overlap.
    if (rect_overlap(0, 0, 10, 10, 0, 10, 10, 10) != 0) { return 5; }

    // Test 6: One rectangle fully inside the other.
    if (rect_overlap(0, 0, 100, 100, 10, 10, 5, 5) != 1) { return 6; }

    // Test 7: Same rectangle overlaps itself.
    if (rect_overlap(5, 5, 10, 10, 5, 5, 10, 10) != 1) { return 7; }

    // Test 8: Non-overlapping — second rect is to the left.
    if (rect_overlap(20, 0, 10, 10, 0, 0, 10, 10) != 0) { return 8; }

    // ── circle_overlap ────────────────────────────────────────

    // Test 9: Two overlapping circles (distance=5, radii sum=10).
    if (circle_overlap(0, 0, 5, 3, 4, 5) != 1) { return 9; }

    // Test 10: Non-overlapping circles (distance=10, radii sum=6).
    if (circle_overlap(0, 0, 3, 10, 0, 3) != 0) { return 10; }

    // Test 11: Touching circles (distance squared = radii sum squared).
    // Circles at (0,0) r=5 and (10,0) r=5: dist=10, sum=10 → touching = overlap.
    if (circle_overlap(0, 0, 5, 10, 0, 5) != 1) { return 11; }

    // Test 12: Same position, same radius — full overlap.
    if (circle_overlap(5, 5, 3, 5, 5, 3) != 1) { return 12; }

    // Test 13: One circle inside the other.
    if (circle_overlap(0, 0, 100, 1, 1, 2) != 1) { return 13; }

    // ── rect_contains ─────────────────────────────────────────

    // Test 14: Point inside rectangle.
    if (rect_contains(0, 0, 10, 10, 5, 5) != 1) { return 14; }

    // Test 15: Point outside rectangle (to the right).
    if (rect_contains(0, 0, 10, 10, 15, 5) != 0) { return 15; }

    // Test 16: Point on top-left corner — inside (>=).
    if (rect_contains(0, 0, 10, 10, 0, 0) != 1) { return 16; }

    // Test 17: Point on bottom-right edge — outside (<).
    if (rect_contains(0, 0, 10, 10, 10, 10) != 0) { return 17; }

    // Test 18: Point on right edge — outside.
    if (rect_contains(0, 0, 10, 10, 10, 5) != 0) { return 18; }

    // Test 19: Point above the rectangle.
    if (rect_contains(0, 10, 10, 10, 5, 5) != 0) { return 19; }

    // ── circle_contains ───────────────────────────────────────

    // Test 20: Point at center — inside.
    if (circle_contains(5, 5, 10, 5, 5) != 1) { return 20; }

    // Test 21: Point far away — outside.
    if (circle_contains(0, 0, 3, 10, 10) != 0) { return 21; }

    // Test 22: Point on the edge (dist squared = r squared) — inside (<=).
    if (circle_contains(0, 0, 5, 3, 4) != 1) { return 22; }

    // Test 23: Point just outside (dist_sq=50 > r_sq=49).
    if (circle_contains(0, 0, 7, 5, 5) != 0) { return 23; }

    // Test 24: Point at origin of circle — inside.
    if (circle_contains(100, 200, 1, 100, 200) != 1) { return 24; }

    // All 24 tests passed.
    return 0;
}
