// test_vec2_float_roundtrip.bpp — confirm Vec2 fields preserve
// IEEE 754 bits across write → read cycles.
//
// Vec2 fields are typed `: float` (May 2026 promotion). Same
// class of regression as `test_json_float`: if a struct field
// ever loses its float annotation and demotes to int, the value
// `0.1` round-trips as `0` and consumers downstream get
// catastrophically wrong math without any compile-time signal.
//
// Tolerance is 0.0 — bit-exact match required, since a typed
// float slot stores the exact double bits with no conversion.

void check_exact(label, got: float, want: float) {
    if (got != want) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putfloat(got);
        putstr(" want="); putfloat(want);
        putline();
        sys_exit(1);
    }
}

main() {
    auto v: Vec2;
    auto x: float, y: float;

    // Fractional values that demote-to-int as zero — the
    // canonical signal for "float bits got lost somewhere".
    x = 0.1;
    y = 0.0009765625;     // 2⁻¹⁰ — exact in IEEE 754

    v = vec2_new(x, y);
    check_exact("ctor.x", v.x, x);
    check_exact("ctor.y", v.y, y);

    // Direct field assign (the path the AI scratch uses).
    v.x = 3.14159;
    v.y = 0.0 - 2.71828;     // negative
    check_exact("write.x", v.x, 3.14159);
    check_exact("write.y", v.y, 0.0 - 2.71828);

    // Round-trip via vec2_add (mutator path).
    auto out;
    out = vec2_new(0.0, 0.0);
    vec2_add(out, v, v);
    auto vo: Vec2;
    vo = out;
    check_exact("add.x", vo.x, 3.14159 + 3.14159);
    check_exact("add.y", vo.y, (0.0 - 2.71828) + (0.0 - 2.71828));

    putstr("OK\n");
}
