// V3 Session 1 gate test (positive). Confirms that Fn-types parse and
// intern in every grammatical position. Session 1 has no semantic
// checking — these all compile and the program runs to print "ok".
//
// Session 2 will add Fn-vs-Fn shape matching and E246/W028 diagnostics
// against this same file as a regression baseline.
import "bpp_io.bsm";

void some_handler() {
    putmsg("some_handler called");
    putline();
}

void register_thing(cb: func(float) -> word) {
    putmsg("register_thing parsed Fn arg");
    putline();
}

// Function param + return type. The return type itself is a fn-type;
// the outer function uses `->` (the canonical fn-def return separator
// since 2026-05-13), the inner fn-type also uses `->` per Rule 21.
make_handler() -> func(float) -> word {
    auto inner: func(float) -> word;
    return inner;
}

// Struct field with fn-type. Hash-cons should dedup the on_click/on_hover
// signatures across every Handlers instance.
struct Handlers {
    on_click: func() -> word,
    on_hover: func(word, word) -> word
}

global g_cb: func(float) -> word;

main() {
    auto cb1: func(float) -> word;
    auto cb2: func() -> word;
    auto cb3: func(word, float, word) -> word;
    auto cb4: func(func() -> word) -> word;       // higher-order arg
    auto cb5: func() -> func(float) -> word;      // higher-order return
    auto cb6: func() -> void;                   // void return canonical

    // Hash-cons dedup: a and b carry the same signature, so the parser
    // must intern them to the same fn-type id. Session 1 only proves
    // the encoding round-trips; Session 2's checker will read the id
    // to verify call-site shape.
    auto a: func(float) -> word;
    auto b: func(float) -> word;

    var h: Handlers;
    // NOTE: struct-field fn_ptr assignment (`h.on_click = fn_ptr(...)`)
    // is a pre-existing codegen gap that predates V3. The plan listed
    // it as a gate case, but verification on the unmodified compiler
    // shows the same "internal error: fn_ptr target not found after
    // validate" — independent of fn-type work. Session 1 only proves
    // the type-expression parses; struct-field fn_ptr is its own
    // (separate) backlog item.
    auto direct_fp;
    direct_fp = fn_ptr(some_handler);

    register_thing(g_cb);
    putmsg("ok");
    putline();
    return 0;
}
