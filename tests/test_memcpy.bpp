// test_memcpy.bpp — Validate memcpy and realloc builtins.
// Compile: ./bpp tests/test_memcpy.bpp -o /tmp/test_memcpy
// Expected: prints "MEMCPY OK" and "REALLOC OK", exits 0.

main() {
    auto src, dst, i, ok;

    // Test memcpy: fill source buffer, copy to destination, verify.
    src = malloc(64);
    dst = malloc(64);
    for (i = 0; i < 32; i = i + 1) {
        poke(src + i, 65 + i);
    }
    memcpy(dst, src, 32);
    ok = 1;
    for (i = 0; i < 32; i = i + 1) {
        if (peek(dst + i) != peek(src + i)) { ok = 0; }
    }
    if (ok) {
        putchar('M'); putchar('E'); putchar('M'); putchar('C');
        putchar('P'); putchar('Y'); putchar(' '); putchar('O');
        putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L');
        putchar(10);
        return 1;
    }

    // Test realloc: fill buffer, realloc to larger, verify data preserved.
    src = malloc(16);
    for (i = 0; i < 16; i = i + 1) {
        poke(src + i, 48 + i);
    }
    dst = realloc(src, 16, 64);
    ok = 1;
    for (i = 0; i < 16; i = i + 1) {
        if (peek(dst + i) != 48 + i) { ok = 0; }
    }
    if (ok) {
        putchar('R'); putchar('E'); putchar('A'); putchar('L');
        putchar('L'); putchar('O'); putchar('C'); putchar(' ');
        putchar('O'); putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L');
        putchar(10);
        return 1;
    }

    return 0;
}
