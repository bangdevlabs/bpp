// test_str_ends.bpp — Coverage for str_ends.
//
// str_ends mirrors str_starts but checks the tail instead of the head.
// Every case that could trip up the caller has an explicit line here:
// matching suffix, non-matching suffix, suffix longer than string,
// empty suffix (always matches by convention), empty string.

main() {
    // Canonical path: real filename ends with real extension.
    if (str_ends("hero.modulab.json", ".modulab.json") != 1) {
        putmsg("FAIL: canonical suffix match");
        return 1;
    }

    // Simple case mirror of str_starts("hello", "he").
    if (str_ends("hello", "lo") != 1) {
        putmsg("FAIL: simple tail match");
        return 1;
    }

    // Non-matching suffix — same length as a matching one, different bytes.
    if (str_ends("hello", "la") != 0) {
        putmsg("FAIL: same-length non-match should be 0");
        return 1;
    }

    // Suffix exactly as long as the string, non-matching.
    if (str_ends("abc", "xyz") != 0) {
        putmsg("FAIL: full-length non-match should be 0");
        return 1;
    }

    // Suffix exactly as long as the string, matching (full string match).
    if (str_ends("abc", "abc") != 1) {
        putmsg("FAIL: full-string match should be 1");
        return 1;
    }

    // Suffix longer than string — cannot possibly match.
    if (str_ends("hi", "hello") != 0) {
        putmsg("FAIL: longer suffix should be 0");
        return 1;
    }

    // Empty suffix — every string ends with the empty string by convention.
    // Mirrors str_starts("anything", "") returning 1.
    if (str_ends("anything", "") != 1) {
        putmsg("FAIL: empty suffix should match");
        return 1;
    }

    // Both empty — empty ends with empty.
    if (str_ends("", "") != 1) {
        putmsg("FAIL: empty ends with empty should be 1");
        return 1;
    }

    // Empty string, non-empty suffix — cannot match.
    if (str_ends("", "x") != 0) {
        putmsg("FAIL: empty string with non-empty suffix should be 0");
        return 1;
    }

    // Realistic file-extension use case (the primary reason str_ends exists).
    if (str_ends("/Users/codes/b++/games/pathfind/assets/sprites/rat.png",
                 ".png") != 1) {
        putmsg("FAIL: full-path .png detection");
        return 1;
    }
    if (str_ends("/Users/codes/b++/games/pathfind/assets/sprites/rat.png",
                 ".json") != 0) {
        putmsg("FAIL: full-path wrong-extension detection");
        return 1;
    }

    putmsg("test_str_ends: OK");
    return 0;
}
