// test_panic.bpp — Phase 6.3 regression target.
//
// Drives a 3-deep call chain into panic("oops") so the runtime
// stack walker exercises both the native FP-chain primitive and
// the minisym name-resolution path that caller_pc / panic share.
//
// This binary is meant to fail with rc=134 (SIGABRT convention).
// The companion `tests/test_panic.sh` wrapper compiles, runs, and
// asserts that the exit code is 134 and stderr contains the
// expected `panic:` prefix plus the chain frame names.

deep_c() { panic("oops from deep_c"); }
deep_b() { deep_c(); }
deep_a() { deep_b(); }

main() {
    deep_a();
    return 0;
}
