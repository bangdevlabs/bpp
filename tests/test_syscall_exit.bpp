// Wave 18 regression: sys_exit is the first syscall lifted from the
// chip ladders to cg_builtin_dispatch via the CG_SYS portable enum.
// Calling sys_exit(0) should terminate the program with status 0.
// If sys_exit failed to terminate, the putchar_err("FAIL\n") and
// sys_exit(1) lines would run — the test runner would see exit 1
// and stderr "FAIL\n", marking the regression.
//
// The 42-variant (sys_exit returning exactly the caller's argument)
// is verified out-of-band: compile echo 'main(){sys_exit(42);}' and
// run with `./out; echo $?` — expected 42.

main() {
    sys_exit(0);
    putchar_err('F'); putchar_err('A'); putchar_err('I'); putchar_err('L'); putchar_err('\n');
    sys_exit(1);
    return 0;
}
