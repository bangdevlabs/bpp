import "bpp_io.bsm";

// Simple function to be used as a callback target.
add(a, b) {
    return a + b;
}

// Multiplier callback target.
mul(a, b) {
    return a * b;
}

// Higher-order function: applies a function pointer to two arguments.
apply(fp, x, y) {
    return call(fp, x, y);
}

main() {
    auto fp, result;

    // Test 1: fn_ptr + call directly
    fp = fn_ptr(add);
    result = call(fp, 3, 4);
    if (result != 7) { putmsg("FAIL direct call"); return 1; }

    // Test 2: fn_ptr passed through another function
    result = apply(fn_ptr(add), 10, 20);
    if (result != 30) { putmsg("FAIL apply add"); return 2; }

    // Test 3: different function pointer
    result = apply(fn_ptr(mul), 6, 7);
    if (result != 42) { putmsg("FAIL apply mul"); return 3; }

    // Test 4: store fn_ptr in variable, use later
    fp = fn_ptr(mul);
    result = call(fp, 100, 3);
    if (result != 300) { putmsg("FAIL stored ptr"); return 4; }

    putmsg("callback: all tests passed");
    return 0;
}
