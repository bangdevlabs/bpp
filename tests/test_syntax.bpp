// test_syntax.bpp — test else if, for loop, buf[i], print_int.

import "stbio.bsm";

main() {
    auto x, buf, i;

    // else if
    x = 42;
    if (x == 1) {
        print_msg("one");
    } else if (x == 42) {
        print_msg("forty-two");
    } else if (x == 100) {
        print_msg("hundred");
    } else {
        print_msg("other");
    }

    // buf[i]
    buf = malloc(40);
    buf[0] = 10;
    buf[1] = 20;
    buf[2] = 30;
    buf[3] = 40;
    buf[4] = 50;
    print_int(buf[0]);
    print_ln();
    print_int(buf[2]);
    print_ln();
    print_int(buf[0] + buf[4]);
    print_ln();

    // for loop
    for (i = 0; i < 5; i = i + 1) {
        print_int(buf[i]);
        putchar(' ');
    }
    print_ln();

    free(buf);
    return 0;
}
