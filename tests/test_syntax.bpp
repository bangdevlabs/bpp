// test_syntax.bpp — test else if, for loop, buf[i], putnum.

import "bpp_io.bsm";

main() {
    auto x, buf, i;

    // else if
    x = 42;
    if (x == 1) {
        putmsg("one");
    } else if (x == 42) {
        putmsg("forty-two");
    } else if (x == 100) {
        putmsg("hundred");
    } else {
        putmsg("other");
    }

    // buf[i]
    buf = malloc(40);
    buf[0] = 10;
    buf[1] = 20;
    buf[2] = 30;
    buf[3] = 40;
    buf[4] = 50;
    putnum(buf[0]);
    putline();
    putnum(buf[2]);
    putline();
    putnum(buf[0] + buf[4]);
    putline();

    // for loop
    for (i = 0; i < 5; i = i + 1) {
        putnum(buf[i]);
        putchar(' ');
    }
    putline();

    free(buf);
    return 0;
}
