// test_cast_builtins.bpp — Excalibur Feature 2 (Phase 2).
//
// Pins the three explicit float→int conversion builtins introduced
// to replace the typed-local-thunk pattern. Each builtin lowers to
// a chip-specific rounding+cast pair; the C emitter mirrors with
// <math.h>. This test runs under both the native and C suites and
// checks identical outputs across all backends.
//
//   floor_int(x) — round toward -inf, then int cast
//                  ARM:  FRINTM + FCVTZS
//                  x86:  ROUNDSD imm=01 + CVTTSD2SI
//                  C:    (long long)floor((double)x)
//
//   trunc_int(x) — round toward zero, then int cast (same as the
//                  implicit float→int coerce, but named for intent)
//                  ARM:  FCVTZS
//                  x86:  CVTTSD2SI
//                  C:    (long long)x
//
//   round_int(x) — round to nearest, ties to even, then int cast
//                  ARM:  FRINTN + FCVTZS
//                  x86:  CVTSD2SI (uses MXCSR, default = nearest even)
//                  C:    (long long)nearbyint((double)x)

void check(label, got, want) {
    if (got != want) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putnum(got);
        putstr(" want="); putnum(want);
        putline();
        sys_exit(1);
    }
}

main() {
    // ── floor_int ── round toward minus infinity ──────────────
    check("floor_pos_lt_half",  floor_int(2.3),       2);
    check("floor_pos_gt_half",  floor_int(2.7),       2);
    check("floor_pos_exact",    floor_int(3.0),       3);
    check("floor_zero",         floor_int(0.0),       0);
    check("floor_neg_lt_half",  floor_int(0.0 - 2.3), 0 - 3);
    check("floor_neg_gt_half",  floor_int(0.0 - 2.7), 0 - 3);
    check("floor_neg_exact",    floor_int(0.0 - 3.0), 0 - 3);

    // ── trunc_int ── round toward zero ────────────────────────
    check("trunc_pos_lt_half",  trunc_int(2.3),       2);
    check("trunc_pos_gt_half",  trunc_int(2.7),       2);
    check("trunc_pos_exact",    trunc_int(3.0),       3);
    check("trunc_zero",         trunc_int(0.0),       0);
    check("trunc_neg_lt_half",  trunc_int(0.0 - 2.3), 0 - 2);
    check("trunc_neg_gt_half",  trunc_int(0.0 - 2.7), 0 - 2);
    check("trunc_neg_exact",    trunc_int(0.0 - 3.0), 0 - 3);

    // ── round_int ── nearest, ties to even ────────────────────
    check("round_pos_lt_half",  round_int(2.3),       2);
    check("round_pos_gt_half",  round_int(2.7),       3);
    check("round_pos_exact",    round_int(3.0),       3);
    check("round_zero",         round_int(0.0),       0);
    check("round_neg_lt_half",  round_int(0.0 - 2.3), 0 - 2);
    check("round_neg_gt_half",  round_int(0.0 - 2.7), 0 - 3);
    check("round_neg_exact",    round_int(0.0 - 3.0), 0 - 3);
    // Ties-to-even cases. 2.5 → 2 (nearest even), 3.5 → 4 (nearest
    // even), 4.5 → 4 (nearest even). This is the IEEE 754 default
    // and matches every supported chip backend's rounding mode.
    check("round_half_2_to_even", round_int(2.5), 2);
    check("round_half_3_to_even", round_int(3.5), 4);
    check("round_half_4_to_even", round_int(4.5), 4);

    // Compose with arithmetic: builtin output is a normal int, can
    // be used in any int context.
    auto px;
    px = floor_int(0.5) + floor_int(0.5);
    check("compose_add", px, 0);

    putstr("OK\n");
    return 0;
}
