// File I/O test for Linux x86_64.
// Compile: ./bpp --linux64 tests/test_linux_fileio.bpp -o build/test_fileio_linux
// Test:    docker exec bpp-linux /bpp/build/test_fileio_linux
// Expected output:
//   wrote 13
//   read: Hello, file!
//   OK

// Prints a string by walking bytes until null.
putstr(s) {
    auto i, c;
    i = 0;
    c = peek(s + i);
    while (c != 0) {
        putchar(c);
        i++;
        c = peek(s + i);
    }
}

// Prints an integer (positive, or -1).
putnum(n) {
    auto buf, len, d;
    if (n < 0) { putchar(45); n = 0 - n; }
    buf = malloc(32);
    len = 0;
    if (n == 0) {
        putchar(48);
        free(buf);
        return 0;
    }
    while (n > 0) {
        d = n - (n / 10) * 10;
        poke(buf + len, d + 48);
        len++;
        n /= 10;
    }
    while (len > 0) {
        len--;
        putchar(peek(buf + len));
    }
    free(buf);
    return 0;
}

main() {
    auto fd, buf, n, msg, msg_len;

    msg = "Hello, file!\n";
    msg_len = 13;

    // Write to a temp file. O_WRONLY|O_CREAT|O_TRUNC = 1|64|512 = 577.
    fd = sys_open("/tmp/bpp_test.txt", 577);
    if (fd < 0) {
        putstr("open for write failed");
        putchar(10);
        return 1;
    }
    n = sys_write(fd, msg, msg_len);
    sys_close(fd);

    putstr("wrote ");
    putnum(n);
    putchar(10);

    // Read it back. O_RDONLY = 0.
    fd = sys_open("/tmp/bpp_test.txt", 0);
    if (fd < 0) {
        putstr("open for read failed");
        putchar(10);
        return 1;
    }
    buf = malloc(64);
    n = sys_read(fd, buf, 63);
    sys_close(fd);

    // Print what we read (minus the trailing newline).
    putstr("read: ");
    auto i;
    for (i = 0; i < n; i++) {
        putchar(peek(buf + i));
    }

    // Verify content matches.
    if (peek(buf) == 72) {
        if (peek(buf + 7) == 102) {
            putstr("OK");
        }
    }
    putchar(10);

    free(buf);
    return 0;
}
