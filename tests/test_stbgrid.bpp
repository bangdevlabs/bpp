import "stbgrid.bsm";

// test_stbgrid.bpp — Correctness pins for the stbgrid storage primitive.
//
// Covers both variants (word + byte):
//   1. Allocation starts zero-filled.
//   2. set / get round-trip preserves values.
//   3. Out-of-bounds writes are no-ops; reads return 0.
//   4. clear resets every cell.
//   5. Dimensions accessors return the constructor arguments.

static _expect_int(label: ptr, got, want) {
    if (got == want) {
        return 0;
    }
    putstr("FAIL: ");
    putstr(label);
    putstr(" got=");
    putnum(got);
    putstr(" want=");
    putnum(want);
    putstr("\n");
    return 1;
}

main() {
    auto g, fails;
    fails = 0;

    // ── Word-grid: 5 × 4 = 20 cells.
    g = grid_new_word(5, 4);

    fails += _expect_int("word w", grid_w(g), 5);
    fails += _expect_int("word h", grid_h(g), 4);
    fails += _expect_int("word zero-init (0,0)", grid_get(g, 0, 0), 0);
    fails += _expect_int("word zero-init (4,3)", grid_get(g, 4, 3), 0);
    fails += _expect_int("word zero-init mid",   grid_get(g, 2, 2), 0);

    // Round-trip a large value (won't fit in a byte) to prove the
    // word variant truly carries words, not byte-truncated values.
    grid_set(g, 2, 1, 100000);
    fails += _expect_int("word round-trip",      grid_get(g, 2, 1), 100000);

    // Neighbouring cells stay 0 — writes don't bleed.
    fails += _expect_int("word neighbour clean (1,1)", grid_get(g, 1, 1), 0);
    fails += _expect_int("word neighbour clean (3,1)", grid_get(g, 3, 1), 0);
    fails += _expect_int("word neighbour clean (2,0)", grid_get(g, 2, 0), 0);
    fails += _expect_int("word neighbour clean (2,2)", grid_get(g, 2, 2), 0);

    // In-bounds sentinel — half-open intervals.
    fails += _expect_int("word in-bounds (0,0)",  grid_in_bounds(g, 0, 0),  1);
    fails += _expect_int("word in-bounds (4,3)",  grid_in_bounds(g, 4, 3),  1);
    fails += _expect_int("word oob (5,0)",        grid_in_bounds(g, 5, 0),  0);
    fails += _expect_int("word oob (0,4)",        grid_in_bounds(g, 0, 4),  0);
    fails += _expect_int("word oob (-1,0)",       grid_in_bounds(g, -1, 0), 0);
    fails += _expect_int("word oob (0,-1)",       grid_in_bounds(g, 0, -1), 0);

    // OOB writes are no-ops; the previously-written cell stays.
    grid_set(g, -1, 2, 999);
    grid_set(g, 5,  2, 999);
    grid_set(g, 2, -1, 999);
    grid_set(g, 2,  4, 999);
    fails += _expect_int("word oob no-op preserved", grid_get(g, 2, 1), 100000);

    // OOB reads return 0.
    fails += _expect_int("word oob read (-1,0)", grid_get(g, -1, 0), 0);
    fails += _expect_int("word oob read (5,0)",  grid_get(g, 5, 0),  0);

    // Clear resets every cell.
    grid_clear(g);
    fails += _expect_int("word clear (2,1)", grid_get(g, 2, 1), 0);

    grid_free(g);

    // ── Byte-grid: 3 × 3 = 9 cells. Values 0..255.
    g = grid_new_byte(3, 3);

    fails += _expect_int("byte w", grid_w(g), 3);
    fails += _expect_int("byte h", grid_h(g), 3);
    fails += _expect_int("byte zero-init", grid_get(g, 1, 1), 0);

    // Round-trip a byte-sized value.
    grid_set(g, 0, 0, 42);
    grid_set(g, 2, 2, 200);
    fails += _expect_int("byte round-trip (0,0)", grid_get(g, 0, 0), 42);
    fails += _expect_int("byte round-trip (2,2)", grid_get(g, 2, 2), 200);
    fails += _expect_int("byte neighbour clean (1,1)", grid_get(g, 1, 1), 0);

    // OOB writes are no-ops here too.
    grid_set(g, 3, 0, 99);
    grid_set(g, 0, 3, 99);
    fails += _expect_int("byte oob no-op (0,0)", grid_get(g, 0, 0), 42);

    // Clear resets the byte grid.
    grid_clear(g);
    fails += _expect_int("byte clear (0,0)", grid_get(g, 0, 0), 0);
    fails += _expect_int("byte clear (2,2)", grid_get(g, 2, 2), 0);

    grid_free(g);

    if (fails == 0) {
        putstr("OK\n");
        return 0;
    }
    putstr("FAILED: ");
    putnum(fails);
    putstr(" assertion(s)\n");
    return 1;
}
