// test_array_elem.bpp — Verify TY_ARR element type inference (Fase 3).
// Tests that arrays declared with arr_new() compile and run correctly
// with word and float element writes. E245 (conflict) is a negative test
// that requires expected-failure infrastructure — tracked in warning_error_log.md.

import "bpp_array.bsm";

main() {
    auto a: array, i;

    // Test 1: word array — push and read back integers.
    a = arr_new();
    a = arr_push(a, 10);
    a = arr_push(a, 20);
    a = arr_push(a, 30);
    if (arr_len(a) != 3) { return 1; }
    if (arr_get(a, 0) != 10) { return 2; }
    if (arr_get(a, 2) != 30) { return 3; }
    a = arr_free(a);

    // Test 2: arr_word allocation and word element access.
    a = arr_word(4);
    a[0] = 100;
    a[1] = 200;
    a[2] = 300;
    a[3] = 400;
    if (a[0] != 100) { return 4; }
    if (a[3] != 400) { return 5; }
    free(a);

    // Test 3: arr_byte allocation and byte element access.
    a = arr_byte(16);
    poke(a + 0, 42);
    poke(a + 1, 99);
    if (peek(a + 0) != 42) { return 6; }
    if (peek(a + 1) != 99) { return 7; }
    free(a);

    return 0;
}
