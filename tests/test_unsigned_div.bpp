// `: u_word` annotation routes division through the unsigned chip
// primitive (UDIV / xor+DIV). Without the annotation, dividing -1
// by 4 produces 0 (signed). With the annotation, the same bit
// pattern is treated as 0xFFFFFFFFFFFFFFFF and the result is
// 0x3FFFFFFFFFFFFFFF.

main() {
    auto signed_x, signed_q;
    signed_x = 0xFFFFFFFFFFFFFFFF;
    signed_q = signed_x / 4;
    if (signed_q != 0) { return 1; }

    auto unsigned_x: u_word, unsigned_q;
    unsigned_x = 0xFFFFFFFFFFFFFFFF;
    unsigned_q = unsigned_x / 4;
    if (unsigned_q != 0x3FFFFFFFFFFFFFFF) { return 2; }

    return 0;
}
