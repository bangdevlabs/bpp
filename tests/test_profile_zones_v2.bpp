// skip-c: Phase 6.3 v2 epilogue drain is native-backend only — the C emitter still ships v1 leak-on-early-return semantics.
// Test Phase 6.3 v2 — scoped-cleanup epilogues for `@profile`.
//
// v1 left zones open whenever a function returned from inside a
// @profile body (early `return` skipped the trailing `_prof_zone_exit`
// call). v2 closes the leak by saving the live zone-stack depth
// at function entry and draining everything above it at the
// epilogue. The fallthrough path, the early-return path and the
// nested-recursion path must all reach depth 0 at the end.
//
// Each check verifies a known property of the runtime state after
// running through the various return shapes:
//   1. zone stack depth == 0 (no orphan opens)
//   2. all three zone names recorded a positive count
//   3. nested zone (outer wraps inner, inner returns early)
//      attributes time to BOTH zones, not just the outer

import "stbprofile.bsm";

// SCREEN_W / SCREEN_H are normally written by stbgame's `game_init`
// during normal program startup. This test bypasses the game loop
// to exercise the runtime in isolation, but stbrender still
// references them for `_stb_gpu_init`. Defining them locally
// satisfies the link without pulling in the entire game runtime.
global SCREEN_W;
global SCREEN_H;

extrn _profile_zone_stack_depth;
extrn _profile_zone_table;
extrn _profile_zone_count;

check(name, ok) {
    auto i;
    if (ok) {
        putchar('O'); putchar('K'); putchar(' ');
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(' ');
    }
    i = 0;
    while (str_peek(name, i) != 0) {
        putchar(str_peek(name, i));
        i++;
    }
    putchar(10);
    return ok;
}

// Fallthrough baseline: reaches `_prof_zone_exit` normally; v1
// already handled this. v2 must not regress it.
static fallthrough_zone() {
    @profile("fallthrough") {
        auto i, k;
        k = 0;
        for (i = 0; i < 100; i++) { k = k + i; }
    }
    return 0;
}

// Early-return shape: the body branches to `return` before reaching
// the trailing exit. v2's epilogue drain must still close the zone.
static early_return_zone(flag) {
    @profile("early_return") {
        auto i, k;
        k = 0;
        for (i = 0; i < 100; i++) { k = k + i; }
        if (flag) { return k; }
        k = k + 1;
    }
    return 0;
}

// Nested zones with early-return from the inner zone. Both outer
// AND inner must accumulate time — the drain unwinds the open
// stack down to the saved depth, accounting each popped frame.
static nested_zone() {
    @profile("outer") {
        auto i, k;
        k = 0;
        for (i = 0; i < 50; i++) { k = k + i; }
        @profile("inner") {
            auto j, m;
            m = 0;
            for (j = 0; j < 50; j++) { m = m + j; }
            return m;   // early-return from BOTH zones
        }
    }
    return 0;
}

// Sum every recorded zone count. String literals in B++ don't
// dedupe across `@profile("name")` and direct comparisons in the
// test, so name-keyed lookups would race against the linker's
// deduplication policy. The total instead is a robust witness:
// every drain that crediting a slot increments exactly one count,
// so the sum scales with the number of completed zones.
zone_count_total() {
    auto i, off, total;
    total = 0;
    for (i = 0; i < _profile_zone_count; i++) {
        off = i * 24;
        total = total + read_u64(_profile_zone_table, off + 16);
    }
    return total;
}

main() {
    auto pass;
    pass = 1;

    init_profile();

    // Run each shape; v2's invariant is that depth returns to 0
    // after every call regardless of return path.
    fallthrough_zone();
    pass = check("depth 0 after fallthrough", _profile_zone_stack_depth == 0) * pass;

    early_return_zone(1);
    pass = check("depth 0 after early-return", _profile_zone_stack_depth == 0) * pass;

    early_return_zone(0);
    pass = check("depth 0 after fallthrough on early_return shape", _profile_zone_stack_depth == 0) * pass;

    nested_zone();
    pass = check("depth 0 after nested early-return", _profile_zone_stack_depth == 0) * pass;

    // Every completed zone increments exactly one count slot.
    // Expected ≥ 5: 1 fallthrough + 2 early_return + 1 outer + 1 inner.
    pass = check(">= 5 completed zones recorded", zone_count_total() >= 5) * pass;

    // At least 4 distinct zones (one per @profile name).
    pass = check(">= 4 zone slots created", _profile_zone_count >= 4) * pass;

    if (pass) { putchar('A'); putchar('L'); putchar('L'); putchar(' '); putchar('O'); putchar('K'); putchar(10); }
    else      { putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(10); sys_exit(1); }
    return 0;
}
