// xfail: E245
// test_array_elem_conflict.bpp — E245 fires when the same array receives
// conflicting element types (byte/char from str_len, then float from a write).

main() {
    auto a: array, dummy;
    a = arr_new();
    dummy = str_len(a);  // marks element TY_WORD_B via str_* inference
    a[0] = 3.14;         // tries to mark TY_FLOAT — conflicts → E245
    return 0;
}
