// test_ternary.bpp — Validates T_TERNARY conditional expressions added
// as side quest before Mini Cooper Phase B1. The contract is enforced
// by the AST node type: ONLY the selected branch evaluates at runtime.
// `&&` and `||` lower to this same node, so this test indirectly guards
// short-circuit semantics for those operators too.

// Helper used to prove that the unselected branch's side effects do
// NOT happen — increments a global only when called.
auto _ternary_calls;

bumped() {
    _ternary_calls = _ternary_calls + 1;
    return 1;
}

main() {
    auto a, b, x;

    // Basic value selection.
    a = 5; b = 10;
    x = a > b ? a : b;
    if (x != 10) { return 10; }
    x = a < b ? a : b;
    if (x != 5)  { return 11; }

    // Literal conditions evaluate the matching branch only.
    x = 1 ? 42 : 99;
    if (x != 42) { return 20; }
    x = 0 ? 42 : 99;
    if (x != 99) { return 21; }

    // Right-associative nesting: `a ? b : c ? d : e` parses as
    // `a ? b : (c ? d : e)`.
    x = 0 ? 1 : 1 ? 2 : 3;
    if (x != 2) { return 30; }
    x = 1 ? 9 : 0 ? 8 : 7;
    if (x != 9) { return 31; }
    x = 0 ? 9 : 0 ? 8 : 7;
    if (x != 7) { return 32; }

    // Branches with side effects: only the selected one runs.
    _ternary_calls = 0;
    x = 1 ? bumped() : bumped();
    if (x != 1)               { return 40; }
    if (_ternary_calls != 1)  { return 41; }   // only true branch ran

    _ternary_calls = 0;
    x = 0 ? bumped() : bumped();
    if (x != 1)               { return 42; }
    if (_ternary_calls != 1)  { return 43; }   // only false branch ran

    return 0;
}
