// test_switch.bpp — Validates the switch statement in both forms:
// value dispatch and condition dispatch. Added in commit 8252b24
// alongside the tonify pass; codegen polished in 7b2b578 with jump
// tables and the C-emitter equivalent.

const STATE_IDLE   = 0;
const STATE_PATROL = 1;
const STATE_ATTACK = 2;
const STATE_FLEE   = 3;

// Value dispatch: tests an expression against constants. Multiple
// constants on the same arm select the same body.
classify(state) {
    switch (state) {
        STATE_IDLE, STATE_PATROL { return 1; }
        STATE_ATTACK             { return 2; }
        STATE_FLEE               { return 3; }
        else                     { return 0; }
    }
    return -1;
}

// Condition dispatch: first truthy arm wins.
priority(hp, ammo, near_enemy) {
    switch {
        hp < 20                 { return 99; }   // critical
        ammo == 0               { return 50; }   // resupply
        near_enemy              { return 30; }   // engage
        else                    { return 0; }    // calm
    }
    return -1;
}

main() {
    // Value form: each constant maps to expected case.
    if (classify(STATE_IDLE)   != 1) { return 10; }
    if (classify(STATE_PATROL) != 1) { return 11; }
    if (classify(STATE_ATTACK) != 2) { return 12; }
    if (classify(STATE_FLEE)   != 3) { return 13; }
    if (classify(99)           != 0) { return 14; }   // else

    // Condition form: first truthy arm wins.
    if (priority(10, 5, 1)  != 99) { return 20; }   // hp critical first
    if (priority(50, 0, 1)  != 50) { return 21; }   // ammo wins over near
    if (priority(50, 5, 1)  != 30) { return 22; }   // near enemy
    if (priority(50, 5, 0)  != 0)  { return 23; }   // else

    return 0;
}
