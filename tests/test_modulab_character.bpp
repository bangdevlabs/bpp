// test_modulab_character.bpp — character format round-trip.
//
// Build a character with a known-unique combination of every
// field, save, free in-memory, reload, verify every value
// survived.

import "stbgame.bsm";
import "stbforge.bsm";
// stbforge's testbed_draw references modulab's layer API; we
// link the whole of core.bsm so those symbols resolve even
// though this test only touches Character load/save.
load "../tools/modulab/core.bsm";

main() {
    auto cp, c: Character, a: Animation, ap;
    auto frames;

    init_str();

    cp = character_new();
    c  = cp;
    c.pivot_x       = 7;
    c.pivot_y       = 13;
    c.hit_x         = 3;
    c.hit_y         = 5;
    c.hit_w         = 9;
    c.hit_h         = 11;
    c.gravity       = 1200;
    c.max_speed     = 180;
    c.jump_velocity = 450;
    c.ctrl_left     = 42;
    c.ctrl_right    = 43;
    c.ctrl_jump     = 44;
    character_set_sprite(cp, "hero.json");

    ap = character_add_animation(cp, "idle", 6, 1);
    frames = malloc(2 * 8);
    *(frames + 0 * 8) = 0;
    *(frames + 1 * 8) = 1;
    character_set_frames(ap, frames, 2);
    free(frames);

    ap = character_add_animation(cp, "walk", 10, 1);
    frames = malloc(4 * 8);
    *(frames + 0 * 8) = 2;
    *(frames + 1 * 8) = 3;
    *(frames + 2 * 8) = 4;
    *(frames + 3 * 8) = 5;
    character_set_frames(ap, frames, 4);
    free(frames);

    if (character_save(cp, "/tmp/test_character.character.json") != 0) {
        print_msg("FAIL: save non-zero"); return 1;
    }
    character_free(cp);

    cp = character_load("/tmp/test_character.character.json");
    if (cp == 0) { print_msg("FAIL: load returned 0"); return 1; }
    c = cp;

    if (c.pivot_x != 7 || c.pivot_y != 13) {
        print_msg("FAIL: pivot not restored"); return 1;
    }
    if (c.hit_x != 3 || c.hit_y != 5 || c.hit_w != 9 || c.hit_h != 11) {
        print_msg("FAIL: hitbox not restored"); return 1;
    }
    if (c.gravity != 1200 || c.max_speed != 180 || c.jump_velocity != 450) {
        print_msg("FAIL: physics not restored"); return 1;
    }
    if (c.ctrl_left != 42 || c.ctrl_right != 43 || c.ctrl_jump != 44) {
        print_msg("FAIL: controls not restored"); return 1;
    }
    if (c.anim_count != 2) {
        print_msg("FAIL: animation count != 2: ");
        print_int(c.anim_count); print_ln();
        return 1;
    }
    if (c.sprite_path == 0 || str_eq(c.sprite_path, "hero.json") == 0) {
        print_msg("FAIL: sprite path not restored"); return 1;
    }

    // Inspect first animation.
    ap = c.animations;
    a  = ap;
    if (str_eq(a.name_ptr, "idle") == 0) {
        print_msg("FAIL: anim[0].name != idle"); return 1;
    }
    if (a.fps != 6 || a.loop != 1 || a.frame_count != 2) {
        print_msg("FAIL: anim[0] metadata wrong"); return 1;
    }
    if (*(a.frames + 0) != 0 || *(a.frames + 8) != 1) {
        print_msg("FAIL: anim[0] frames wrong"); return 1;
    }

    // Second animation.
    ap = c.animations + sizeof(Animation);
    a  = ap;
    if (str_eq(a.name_ptr, "walk") == 0) {
        print_msg("FAIL: anim[1].name != walk"); return 1;
    }
    if (a.frame_count != 4 || a.fps != 10) {
        print_msg("FAIL: anim[1] metadata wrong"); return 1;
    }

    character_free(cp);
    print_msg("OK");
    return 0;
}
