// test_extern_strlen.bpp — FFI extern call through the dynamic linker.
//
// Declares libc's strlen and verifies it returns the right length. On macOS
// this links libSystem (a64 GOT); on Linux (--linux64) it links libc.so.6 via
// the ELF dynamic-link path (PLT/GOT, eager BIND_NOW). Proves the whole extern
// chain end-to-end: routing -> SysV/AAPCS64 arg marshaling -> ld.so bind ->
// real libc call -> return value. Exits 0 on success (each failure has a
// distinct code for tracing).

import "System.B" {
    long strlen(ptr);
}

main() {
    if (strlen("hi") != 2)    { return 1; }
    if (strlen("hello") != 5) { return 2; }
    if (strlen("") != 0)      { return 3; }
    return 0;
}
