// test_auto_promote.bpp — Smoke test for auto smart promotion.
//
// Verifies that the compiler promotes `auto` globals to the correct
// storage class based on their usage pattern:
//   1. auto x; written once in main() before maestro_run → extrn
//   2. auto y; never written → stays auto (no promotion)
//   3. explicit extrn z; → stays extrn (not re-promoted)
//   4. explicit global w; → stays global (not re-promoted)
//
// The test only checks runtime correctness — promotion decisions are
// visible via `bpp --show-promotions`. Returns 0 on success.

auto assets;          // should be auto-promoted to extrn
auto counter;         // written in loop → stays auto
extrn config;         // explicit extrn (user knows)
global shared_val;    // explicit global (user knows)

main() {
    // Writes before freeze point.
    assets = 42;
    config = 100;
    shared_val = 200;

    // Counter is mutated after init — stays auto.
    counter = 0;
    auto i;
    for (i = 0; i < 5; i = i + 1) {
        counter = counter + 1;
    }

    if (assets != 42) { return 1; }
    if (config != 100) { return 2; }
    if (shared_val != 200) { return 3; }
    if (counter != 5) { return 4; }
    return 0;
}
