// test_aligned_alloc.bpp — Validates malloc_aligned added in Phase A2 of
// the Mini Cooper plan. Required ahead of Phase B4 (SIMD intrinsics) so
// callers can request 16/32/64-byte aligned buffers cross-platform.
//
// Confirms that:
//   1. The returned pointer respects the requested alignment.
//   2. The user region is writable across its full extent.
//   3. free() releases aligned blocks without corruption.

main() {
    auto p16, p32, p64;

    p16 = malloc_aligned(100, 16);
    p32 = malloc_aligned(100, 32);
    p64 = malloc_aligned(200, 64);

    // Alignment check: low bits of the pointer must be zero.
    if ((p16 & 15) != 0) { return 10; }
    if ((p32 & 31) != 0) { return 20; }
    if ((p64 & 63) != 0) { return 30; }

    // Write at boundaries to confirm the user region is fully usable.
    poke(p16, 42);
    poke(p16 + 99, 99);
    poke(p32 + 50, 50);
    poke(p64 + 199, 7);

    if (peek(p16) != 42)        { return 40; }
    if (peek(p16 + 99) != 99)   { return 41; }
    if (peek(p32 + 50) != 50)   { return 50; }
    if (peek(p64 + 199) != 7)   { return 60; }

    // free must accept aligned pointers without crashing.
    free(p16);
    free(p32);
    free(p64);

    return 0;
}
