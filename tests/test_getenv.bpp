// test_getenv.bpp — Smoke test for envp_get + getenv.
//
// Verifies:
//   1. envp_get(0) returns a non-zero pointer (the first env var).
//   2. envp_get terminates at NULL (returns 0 past the end).
//   3. getenv resolves a known var (HOME, set by every shell).
//   4. getenv returns 0 for an obviously absent var.
//   5. getenv prefix matching is exact ("HOM" must NOT match "HOME").
//
// Returns 0 on success, non-zero on the first failing case.

main() {
    auto i, ep, found, prev_was_zero, total;
    auto home, partial, missing;

    // Case 1: walk envp_get until we hit the NULL terminator.
    // Sanity-cap the loop at 4096 entries — way more than any real env.
    found = 0;
    i = 0;
    while (i < 4096) {
        ep = envp_get(i);
        if (ep == 0) { return 1 + (1 - found); }
        // Wait — the +(1-found) bumps the code if NO env vars exist.
        // Reset: if i == 0 and ep != 0, found = 1.
        found = 1;
        i = i + 1;
        // Stop after we have at least one entry to keep the test fast.
        if (i >= 1) {
            // Verify the next call past the end is 0 — walk to NULL.
            while (envp_get(i) != 0) {
                i = i + 1;
                if (i > 4096) { return 2; }
            }
            // i now points at the NULL terminator slot.
            if (envp_get(i) != 0) { return 3; }
            i = 4096;  // exit outer loop
        }
    }
    if (found == 0) { return 4; }

    // Case 2: HOME should be set in any reasonable test environment.
    home = getenv("HOME");
    if (home == 0) { return 5; }

    // Case 3: prefix-only match should NOT succeed. "HOM" is a prefix of
    // "HOME=" but the '=' check requires the full name.
    partial = getenv("HOM");
    if (partial != 0) { return 6; }

    // Case 4: definitely-absent var returns 0.
    missing = getenv("THIS_VAR_SHOULD_NOT_EXIST_IN_ANY_CI_OR_DEV_BOX_2026");
    if (missing != 0) { return 7; }

    return 0;
}
