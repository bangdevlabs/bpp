// test_literal_shape.bpp — Excalibur Arc Feature 1 Session 1.A.
//
// Session 1.A enriches the parser to annotate every numeric T_LIT
// node with a shape value (SHAPE_INT for `42` / `0xFF`,
// SHAPE_DECIMAL for `3.14`). The shape lives in `n.b`, sits
// dormant in this session, and gets consumed by Session 1.B's
// slot-aware type resolver.
//
// SHAPE constants live in `src/bpp_defs.bsm` — compiler-internal,
// not visible to user programs at runtime. So this test cannot
// observe them directly. Instead it pins the behavioural promise
// of Session 1.A: "purely additive AST enrichment, codegen
// emits identical code". A regression that miscategorises a
// literal would break one of these arithmetic paths.

main() {
    auto i, j, h, f: float, g: float;

    // Decimal int literal (TK_NUM → SHAPE_INT).
    i = 42;
    if (i != 42) {
        putstr("FAIL: decimal int literal\n");
        sys_exit(1);
    }

    // Hex literal (TK_HEX → SHAPE_INT).
    h = 0xFF;
    if (h != 255) {
        putstr("FAIL: hex literal\n");
        sys_exit(1);
    }

    // Decimal float literal (TK_FLOAT → SHAPE_DECIMAL).
    f = 3.14;
    if (f < 3.13 || f > 3.15) {
        putstr("FAIL: float literal value drifted\n");
        sys_exit(1);
    }

    // Negative literal — parser wraps T_LIT in T_UNARY('-'). The
    // inner T_LIT keeps its shape annotation; the unary just
    // negates at codegen time.
    j = 0 - 7;
    if (j != 0 - 7) {
        putstr("FAIL: negative int literal\n");
        sys_exit(1);
    }
    g = 0.0 - 2.5;
    if (g > 0.0 - 2.49 || g < 0.0 - 2.51) {
        putstr("FAIL: negative float literal\n");
        sys_exit(1);
    }

    // Mixed-shape arithmetic — int literal added to a float
    // local should widen to float (existing pre-arc behavior).
    g = f + 1;            // 1 is SHAPE_INT, f is float → float result
    if (g < 4.13 || g > 4.15) {
        putstr("FAIL: mixed int+float arithmetic\n");
        sys_exit(1);
    }

    putstr("OK\n");
}
