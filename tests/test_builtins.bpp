// test_builtins.bpp — Test shr() and assert() builtins.

main() {
    auto x, y;

    // shr: logical right shift (unsigned, fills with zeros).
    // Arithmetic >> on -1 gives -1 (sign extends). shr gives 0x00000000FFFFFFFF.
    x = 0 - 1;
    y = shr(x, 32);
    if (y == 4294967295) { putchar('S'); }
    else { putchar('F'); }

    // shr: basic shift.
    x = 256;
    y = shr(x, 4);
    if (y == 16) { putchar('H'); }
    else { putchar('F'); }

    // shr: shift by 0.
    x = 42;
    y = shr(x, 0);
    if (y == 42) { putchar('R'); }
    else { putchar('F'); }

    // assert: true conditions (should NOT trap).
    assert(1);
    assert(42);
    assert(1 + 1);
    putchar('A');

    putchar(10);
    return 0;
}
