// test_scene.bpp — scene manager register + switch + tick lifecycle.
// Scene manager now lives inside stbgame.bsm (was stbscene.bsm).
//
// Exercises:
//   1. Register a scene; scene_current is still -1 (no switch yet).
//   2. scene_switch queues; scene_tick executes load.
//   3. Update + draw fire on the right scene.
//   4. Switching to a different scene unloads the previous one.
//   5. scene_shutdown drops registrations cleanly.

import "stbgame.bsm";


// Event counters — each scene increments its own slot on every
// callback. Assertions below check the exact call order.
auto menu_loads, menu_updates, menu_draws, menu_unloads;
auto game_loads, game_updates, game_draws, game_unloads;

void menu_load()     { menu_loads   = menu_loads   + 1; }
void menu_update(dt) { menu_updates = menu_updates + 1; }
void menu_draw()     { menu_draws   = menu_draws   + 1; }
void menu_unload()   { menu_unloads = menu_unloads + 1; }

void game_load()     { game_loads   = game_loads   + 1; }
void game_update(dt) { game_updates = game_updates + 1; }
void game_draw()     { game_draws   = game_draws   + 1; }
void game_unload()   { game_unloads = game_unloads + 1; }

main() {
    init_scene();

    // (1) Register both scenes.
    scene_register(0,
                   fn_ptr(menu_load),
                   fn_ptr(menu_update),
                   fn_ptr(menu_draw),
                   fn_ptr(menu_unload));
    scene_register(1,
                   fn_ptr(game_load),
                   fn_ptr(game_update),
                   fn_ptr(game_draw),
                   fn_ptr(game_unload));

    if (scene_current() != 0 - 1) {
        print_msg("FAIL: scene_current should be -1 before any switch");
        return 1;
    }

    // (2) Request menu; tick executes the switch + load.
    scene_switch(0);
    scene_tick(16);
    if (menu_loads != 1) {
        print_msg("FAIL: menu_load should run exactly once");
        return 1;
    }
    if (menu_updates != 1) {
        print_msg("FAIL: menu_update should run in the same tick as load");
        return 1;
    }
    if (scene_current() != 0) {
        print_msg("FAIL: scene_current should be 0 (menu)");
        return 1;
    }

    // (3) Additional ticks update + draw only.
    scene_tick(16);
    scene_draw();
    if (menu_updates != 2 || menu_draws != 1) {
        print_msg("FAIL: menu update/draw counts wrong");
        return 1;
    }
    if (menu_loads != 1) {
        print_msg("FAIL: menu_load should NOT re-run on subsequent ticks");
        return 1;
    }

    // (4) Switch to game: unloads menu, loads game, updates game.
    scene_switch(1);
    scene_tick(16);
    if (menu_unloads != 1) {
        print_msg("FAIL: menu_unload should fire on switch away");
        return 1;
    }
    if (game_loads != 1) {
        print_msg("FAIL: game_load should fire on switch to game");
        return 1;
    }
    if (game_updates != 1) {
        print_msg("FAIL: game_update should fire in switch tick");
        return 1;
    }

    // (5) Shutdown unloads the active scene.
    scene_shutdown();
    if (game_unloads != 1) {
        print_msg("FAIL: scene_shutdown should unload active scene");
        return 1;
    }

    print_msg("stbscene: register + switch + tick + shutdown passed");
    return 0;
}
