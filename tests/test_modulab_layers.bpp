// test_modulab_layers.bpp — per-frame layer management + schema
// v2 round-trip. Exercises layer_add / delete / move / active_set,
// asserts pix_set targets the active layer, and verifies that a
// 3-layer project saved as canonical JSON reloads byte-identical.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto i, rc, lp0, lp1, lp2, l: Layer;

    init_str();
    state_init(8);

    if (layer_count() != 1) {
        print_msg("FAIL: fresh frame should have 1 layer, got ");
        print_int(layer_count()); print_ln();
        return 1;
    }

    // Paint something on layer 0 (the default active).
    history_begin_stroke();
    pix_set(0, 0, 3);
    pix_set(1, 0, 3);
    history_commit();

    // Add a second layer. Should become active automatically.
    if (layer_add() != 1) {
        print_msg("FAIL: layer_add should return new idx 1"); return 1;
    }
    if (layer_active_idx() != 1) {
        print_msg("FAIL: new layer should be active"); return 1;
    }

    // Paint on layer 1. Layer 0's cells must NOT change.
    history_begin_stroke();
    pix_set(4, 4, 5);
    history_commit();

    layer_active_set(0);
    if (pix_get(0, 0) != 3) {
        print_msg("FAIL: layer 0 painted cell lost after layer_add");
        return 1;
    }
    layer_active_set(1);
    if (pix_get(4, 4) != 5) {
        print_msg("FAIL: layer 1 painted cell lost");
        return 1;
    }

    // Add a third layer and tweak its alpha/visibility.
    layer_add();
    lp2 = layer_at(0, 2);
    layer_set_alpha(lp2, 128);
    layer_set_visible(lp2, 0);

    // Save canonical, then wipe + reload, assert layers match.
    rc = mlab_save_canonical("/tmp/test_modulab_layers.modulab.json");
    if (rc != 0) { print_msg("FAIL: save returned non-zero"); return 1; }

    state_free();
    state_init(8);

    rc = mlab_load_canonical("/tmp/test_modulab_layers.modulab.json");
    if (rc != 0) { print_msg("FAIL: load returned non-zero"); return 1; }

    if (layer_count() != 3) {
        print_msg("FAIL: reloaded layer count != 3, got ");
        print_int(layer_count()); print_ln();
        return 1;
    }

    // Layer 0 — default alpha, layer 2 — alpha 128, invisible.
    lp0 = layer_at(0, 0);
    l = lp0;
    if (l.alpha != 255) {
        print_msg("FAIL: reloaded layer 0 alpha wrong");
        return 1;
    }
    lp2 = layer_at(0, 2);
    l = lp2;
    if (l.alpha != 128 || l.visible != 0) {
        print_msg("FAIL: reloaded layer 2 alpha/visible wrong: ");
        print_int(l.alpha); print_msg(","); print_int(l.visible); print_ln();
        return 1;
    }

    // Pixel data survived the round-trip on each layer.
    layer_active_set(0);
    if (pix_get(0, 0) != 3) {
        print_msg("FAIL: layer 0 pixel (0,0) lost across save/load");
        return 1;
    }
    layer_active_set(1);
    if (pix_get(4, 4) != 5) {
        print_msg("FAIL: layer 1 pixel (4,4) lost across save/load");
        return 1;
    }

    // layer_delete on layer 1 — layer 2 becomes layer 1.
    layer_delete(1);
    if (layer_count() != 2) {
        print_msg("FAIL: layer_delete did not shrink count");
        return 1;
    }

    state_free();
    print_msg("OK");
    return 0;
}
