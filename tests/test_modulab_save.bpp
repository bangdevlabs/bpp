// test_modulab_save.bpp — headless round-trip for ModuLab's save path.
//
// Paints a known 4x4 pattern directly into the canvas, emits both
// sidecar JSON files, reloads the sprite-compat file through
// load_sprite, and byte-compares the pixels. This is the Phase 1
// guarantee: paint → save → engine-readable with no UI involved.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto i, x, y, ok, buf, fsize, src_ptr, dst_ptr;
    auto reloaded, rc;

    init_str();

    state_init(4);

    // Paint a diagonal from (0,0) to (3,3) in color 5 and a single
    // cell at (2,0) in color 2. Pattern chosen so a 90° rotation
    // in the save path would be immediately visible.
    pix_set(0, 0, 5);
    pix_set(1, 1, 5);
    pix_set(2, 2, 5);
    pix_set(3, 3, 5);
    pix_set(2, 0, 2);

    // Write both sidecars under /tmp so the test leaves no repo
    // droppings. rc != 0 means one of the two writes failed.
    rc = mlab_save_both("/tmp/test_modulab_save");
    if (rc != 0) {
        putmsg("FAIL: mlab_save_both returned non-zero");
        return 1;
    }

    // Reload through the engine's own reader. A successful parse
    // here is the proof that stbsprite and io.bsm agree on the
    // {"data": [[...]]} layout.
    reloaded = malloc(16);
    for (i = 0; i < 16; i++) { poke(reloaded + i, 255); }
    ok = load_sprite("/tmp/test_modulab_save.json", reloaded, 4, 4);
    if (ok == 0) {
        putmsg("FAIL: load_sprite could not re-read /tmp/test_modulab_save.json");
        free(reloaded);
        return 1;
    }

    // Byte-compare against the original canvas buffer.
    for (y = 0; y < 4; y++) {
        for (x = 0; x < 4; x++) {
            if (peek(reloaded + y * 4 + x) != pix_get(x, y)) {
                putmsg("FAIL: reload mismatch at (x,y)");
                putnum(x); putmsg(","); putnum(y);
                putmsg(" got "); putnum(peek(reloaded + y * 4 + x));
                putmsg(" want "); putnum(pix_get(x, y));
                putline();
                free(reloaded);
                return 1;
            }
        }
    }

    free(reloaded);
    state_free();

    putmsg("OK");
    return 0;
}
