import "bpp_str.bsm";
import "bpp_io.bsm";

main() {
    auto s;
    init_str();

    // Test 1: static functions still work.
    if (str_len("hello") != 5) { return 1; }
    if (str_eq("abc", "abc") != 1) { return 2; }
    if (str_eq("abc", "abd") != 0) { return 3; }

    // Test 2: strbuf_new creates empty string.
    s = strbuf_new();
    if (strbuf_len(s) != 0) { return 4; }
    if (peek(s) != 0) { return 5; }

    // Test 3: strbuf_cat appends strings.
    s = strbuf_cat(s, "Hello");
    if (strbuf_len(s) != 5) { return 6; }
    s = strbuf_cat(s, " World");
    if (strbuf_len(s) != 11) { return 7; }
    if (str_eq(s, "Hello World") != 1) { return 8; }

    // Test 4: strbuf_ch appends chars.
    s = strbuf_ch(s, '!');
    if (strbuf_len(s) != 12) { return 9; }
    if (str_eq(s, "Hello World!") != 1) { return 10; }

    // Test 5: strbuf_num appends numbers.
    s = strbuf_clear(s);
    s = strbuf_cat(s, "Score: ");
    s = strbuf_num(s, 42);
    if (str_eq(s, "Score: 42") != 1) { return 11; }

    // Test 6: strbuf_num with negative number.
    s = strbuf_clear(s);
    s = strbuf_num(s, -7);
    if (str_eq(s, "-7") != 1) { return 12; }

    // Test 7: grow past initial capacity (64 bytes).
    s = strbuf_clear(s);
    auto i;
    for (i = 0; i < 20; i++) {
        s = strbuf_cat(s, "ABCD");
    }
    if (strbuf_len(s) != 80) { return 13; }

    // Test 8: sb is a valid C string (can pass to str_len).
    if (str_len(s) != 80) { return 14; }

    // Test 9: strbuf_free returns 0.
    s = strbuf_free(s);
    if (s != 0) { return 15; }

    // Test 10: NULL safety.
    if (strbuf_len(0) != 0) { return 16; }
    s = strbuf_cat(0, "auto");
    if (str_eq(s, "auto") != 1) { return 17; }

    // Test 11: print works (sb is a normal C string).
    s = strbuf_new();
    s = strbuf_cat(s, "B++ strings work");
    putmsg(s);

    s = strbuf_free(s);
    return 0;
}
