import "stbstr.bsm";
import "stbio.bsm";

main() {
    auto s;
    init_str();

    // Test 1: static functions still work.
    if (str_len("hello") != 5) { return 1; }
    if (str_eq("abc", "abc") != 1) { return 2; }
    if (str_eq("abc", "abd") != 0) { return 3; }

    // Test 2: sb_new creates empty string.
    s = sb_new();
    if (sb_len(s) != 0) { return 4; }
    if (peek(s) != 0) { return 5; }

    // Test 3: sb_cat appends strings.
    s = sb_cat(s, "Hello");
    if (sb_len(s) != 5) { return 6; }
    s = sb_cat(s, " World");
    if (sb_len(s) != 11) { return 7; }
    if (str_eq(s, "Hello World") != 1) { return 8; }

    // Test 4: sb_ch appends chars.
    s = sb_ch(s, '!');
    if (sb_len(s) != 12) { return 9; }
    if (str_eq(s, "Hello World!") != 1) { return 10; }

    // Test 5: sb_int appends numbers.
    s = sb_clear(s);
    s = sb_cat(s, "Score: ");
    s = sb_int(s, 42);
    if (str_eq(s, "Score: 42") != 1) { return 11; }

    // Test 6: sb_int with negative number.
    s = sb_clear(s);
    s = sb_int(s, -7);
    if (str_eq(s, "-7") != 1) { return 12; }

    // Test 7: grow past initial capacity (64 bytes).
    s = sb_clear(s);
    auto i;
    i = 0;
    while (i < 20) {
        s = sb_cat(s, "ABCD");
        i = i + 1;
    }
    if (sb_len(s) != 80) { return 13; }

    // Test 8: sb is a valid C string (can pass to str_len).
    if (str_len(s) != 80) { return 14; }

    // Test 9: sb_free returns 0.
    s = sb_free(s);
    if (s != 0) { return 15; }

    // Test 10: NULL safety.
    if (sb_len(0) != 0) { return 16; }
    s = sb_cat(0, "auto");
    if (str_eq(s, "auto") != 1) { return 17; }

    // Test 11: print works (sb is a normal C string).
    s = sb_new();
    s = sb_cat(s, "B++ strings work");
    print_msg(s);

    s = sb_free(s);
    return 0;
}
