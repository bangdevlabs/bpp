// test_modulab_prefs.bpp — prefs save/load round-trip.
//
// prefs.bsm writes to <exe_dir>/modulab_prefs.json. For this
// headless test we can't control the exe dir easily, so the
// helper writes via the same path_exe_dir path the production
// flow uses — and we read it back via prefs_load. Defines a
// couple of actions, saves, wipes in-memory state, reloads,
// and asserts every field round-tripped.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/prefs.bsm";

// Match the zoom-accessor contract modulab.bpp provides in
// production. We stand in for them here since this test does not
// link the modulab main binary.
auto _test_zoom;
modulab_prefs_zoom_get() : base { return _test_zoom; }
void modulab_prefs_zoom_set(v) { _test_zoom = v; }

main() {
    auto rc;

    init_str();
    state_init(16);

    // Seed: force a non-default state to verify the save captures it.
    g_universe = UNIVERSE_NKOTC;
    _test_zoom = 32;
    action_define("paint", KEY_B, 0);
    action_define("save",  KEY_S, ACTION_MOD_CTRL);

    rc = prefs_save();
    if (rc != 0) { putmsg("FAIL: prefs_save non-zero"); return 1; }

    // Reset in-memory state and reload from disk.
    g_universe = UNIVERSE_MCU;
    _test_zoom = 24;
    // Skip re-registering actions — prefs_load overlays onto
    // whatever table exists.
    rc = prefs_load();
    if (rc != 0) { putmsg("FAIL: prefs_load non-zero"); return 1; }

    if (g_universe != UNIVERSE_NKOTC) {
        putmsg("FAIL: universe not restored"); return 1;
    }
    if (_test_zoom != 32) {
        putmsg("FAIL: zoom not restored: ");
        putnum(_test_zoom); putline();
        return 1;
    }

    if (action_count() < 2) {
        putmsg("FAIL: actions table not populated after load");
        return 1;
    }

    state_free();
    putmsg("OK");
    return 0;
}
