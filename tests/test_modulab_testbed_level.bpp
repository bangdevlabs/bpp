// test_modulab_testbed_level.bpp — level_editor → testbed handoff.
//
// Writes a .level.json file in the schema level_editor produces,
// calls testbed_load_world, asserts the world picked up the new
// dimensions and that a painted cell shows up as solid.

import "stbgame.bsm";
import "stbforge.bsm";
load "../tools/modulab/core.bsm";

main() {
    auto cp, c: Character;
    auto sb, rc;

    init_str();
    state_init(8);

    cp = character_new();
    c  = cp;
    c.hit_x = 0; c.hit_y = 0; c.hit_w = 1; c.hit_h = 1;
    testbed_init(cp);

    // Write a minimal 4x3 level: top two rows air, bottom row
    // solid (palette index 1). The level_editor schema is
    // { type, version, width, height, palette, tiles:[[...]] }.
    sb = strbuf_new();
    sb = json_writer_begin(sb);
    sb = json_write_object_begin(sb);
    sb = json_write_string_field(sb, "type", "level");
    sb = json_write_int_field(sb, "version", 1);
    sb = json_write_int_field(sb, "width",  4);
    sb = json_write_int_field(sb, "height", 3);
    sb = json_write_string_field(sb, "palette", "MCU-8");
    sb = json_write_array_field_begin(sb, "tiles");
    // Row 0 — all air.
    sb = json_write_array_begin(sb);
    sb = json_write_int(sb, 0); sb = json_write_int(sb, 0);
    sb = json_write_int(sb, 0); sb = json_write_int(sb, 0);
    sb = json_write_array_end(sb);
    // Row 1 — all air.
    sb = json_write_array_begin(sb);
    sb = json_write_int(sb, 0); sb = json_write_int(sb, 0);
    sb = json_write_int(sb, 0); sb = json_write_int(sb, 0);
    sb = json_write_array_end(sb);
    // Row 2 — all ground (index 3, gray). Any non-zero value
    // must be treated as solid by the testbed.
    sb = json_write_array_begin(sb);
    sb = json_write_int(sb, 3); sb = json_write_int(sb, 3);
    sb = json_write_int(sb, 3); sb = json_write_int(sb, 3);
    sb = json_write_array_end(sb);
    sb = json_write_array_end(sb);
    sb = json_write_object_end(sb);
    rc = file_write_all("/tmp/test_testbed_level.level.json",
                        sb, strbuf_len(sb));
    sb = strbuf_free(sb);
    if (rc != 0) {
        putmsg("FAIL: file write failed\n"); return 1;
    }

    if (testbed_load_world("/tmp/test_testbed_level.level.json") != 0) {
        putmsg("FAIL: testbed_load_world returned non-zero\n");
        return 1;
    }
    if (tb_world_w() != 4 || tb_world_h() != 3) {
        putmsg("FAIL: world dimensions not updated: ");
        putnum(tb_world_w()); putmsg("x"); putnum(tb_world_h());
        putline();
        return 1;
    }
    // Row 0 and 1 must be air.
    if (tb_cell_at(0, 0) != 0 || tb_cell_at(3, 1) != 0) {
        putmsg("FAIL: expected air cell was solid\n");
        return 1;
    }
    // Row 2 must be solid.
    if (tb_cell_at(0, 2) != 1 || tb_cell_at(3, 2) != 1) {
        putmsg("FAIL: expected solid cell was air\n");
        return 1;
    }

    testbed_free();
    character_free(cp);
    state_free();
    putmsg("OK");
    return 0;
}
