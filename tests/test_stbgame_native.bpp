// Test: full stb game loop via native Cocoa (no SDL, no driver).
// A green square controlled by WASD/arrows. Smoke test that exercises
// the platform layer init, the event pump, and the software draw path.
//
// Auto-exits after 30 frames (~0.5 s at 60 fps) so the test runner can
// drive it unattended. ESC also breaks the loop early. For interactive
// play, raise MAX_FRAMES.

import "stbgame.bsm";

const MAX_FRAMES = 240;

main() {
    auto px, py, frames;
    game_init(320, 180, "stb native test", 60);

    px = 144; py = 74;
    frames = 0;

    while (game_should_quit() == 0) {
        game_frame_begin();

        if (key_pressed(KEY_ESC)) { break; }

        // Move.
        if (key_down(KEY_W) | key_down(KEY_UP))    { py = py - 2; }
        if (key_down(KEY_S) | key_down(KEY_DOWN))  { py = py + 2; }
        if (key_down(KEY_A) | key_down(KEY_LEFT))  { px = px - 2; }
        if (key_down(KEY_D) | key_down(KEY_RIGHT)) { px = px + 2; }
        if (px < 0) { px = 0; }
        if (py < 0) { py = 0; }
        if (px > 288) { px = 288; }
        if (py > 148) { py = 148; }

        // Draw.
        clear(DARKGRAY);
        draw_rect(px, py, 32, 32, GREEN);
        draw_text("WASD to move, ESC to quit", 60, 4, 1, WHITE);
        draw_end();

        frames = frames + 1;
        if (frames >= MAX_FRAMES) { break; }
    }
    return 0;
}
