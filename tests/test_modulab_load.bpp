// test_modulab_load.bpp — canonical save → load round-trip.
//
// Writes a two-frame 8x8 project, clears the canvas, reloads the
// .modulab.json file, and byte-compares every frame + palette slot.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto i, rc, x, y;
    auto original_pal, f1_bytes, f2_bytes, idx;

    init_str();
    state_init(8);

    // Frame 0: diagonal in color 3.
    pix_set(0, 0, 3); pix_set(1, 1, 3); pix_set(2, 2, 3);
    pix_set(3, 3, 3); pix_set(4, 4, 3); pix_set(5, 5, 3);
    history_commit();

    // Frame 1: a filled rectangle in color 5.
    if (frame_add() < 0) { putmsg("FAIL: frame_add refused"); return 1; }
    for (y = 2; y <= 5; y = y + 1) {
        for (x = 2; x <= 5; x = x + 1) { pix_set(x, y, 5); }
    }
    history_commit();

    // Save canonical.
    rc = mlab_save_canonical("/tmp/test_modulab_load.modulab.json");
    if (rc != 0) { putmsg("FAIL: save returned non-zero"); return 1; }

    // Stash the original palette so we can compare after the reload.
    original_pal = malloc(g_pal_n * 8);
    for (i = 0; i < g_pal_n; i = i + 1) {
        *(original_pal + i * 8) = *(g_palette + i * 8);
    }

    // Wipe state by free + re-init. The reloaded file should
    // restore every frame + palette entry.
    state_free();
    state_init(8);

    rc = mlab_load_canonical("/tmp/test_modulab_load.modulab.json");
    if (rc != 0) { putmsg("FAIL: load returned non-zero"); return 1; }

    if (frame_count() != 2) {
        putmsg("FAIL: frame_count != 2 after load: ");
        putnum(frame_count()); putline();
        return 1;
    }

    // Palette round-trip.
    for (i = 0; i < g_pal_n; i = i + 1) {
        if (*(g_palette + i * 8) != *(original_pal + i * 8)) {
            putmsg("FAIL: palette mismatch at idx ");
            putnum(i); putline();
            return 1;
        }
    }

    // Frame 0 diagonal.
    frame_switch(0);
    for (i = 0; i < 6; i = i + 1) {
        if (pix_get(i, i) != 3) {
            putmsg("FAIL: frame 0 diagonal lost at i=");
            putnum(i); putline();
            return 1;
        }
    }

    // Frame 1 rect.
    frame_switch(1);
    for (y = 2; y <= 5; y = y + 1) {
        for (x = 2; x <= 5; x = x + 1) {
            if (pix_get(x, y) != 5) {
                putmsg("FAIL: frame 1 rect cell missing at ");
                putnum(x); putmsg(","); putnum(y); putline();
                return 1;
            }
        }
    }

    free(original_pal);
    state_free();

    putmsg("OK");
    return 0;
}
