// test_grouped_auto.bpp — grouped type annotation `auto (a, b, c): T` (Rule 43).
//
// Verifies the shared type distributes to EVERY name in the group, for both a
// primitive (float) and a struct type, and that a group composes with an
// ungrouped name on the same line. If grouping failed to type a member, the
// float sums collapse to integer truncation and the asserts below fire.
// Returns 0 on success; a distinct non-zero code marks which check failed.

struct Pt { x, y }

main() {
    // Float group — all three must be float (exact f64 sum = 8.0).
    auto (ax, ay, az): float;
    ax = 1.5; ay = 2.5; az = 4.0;
    if (trunc_int(ax + ay + az) != 8) { return 1; }   // ints would give 1+2+4 = 7

    // Struct group — both pointers must be Pt for typed field access.
    auto (p, q): Pt;
    p = malloc(16); q = malloc(16);
    p.x = 10; p.y = 20; q.x = 30; q.y = 40;
    if (p.x + p.y + q.x + q.y != 100) { return 2; }

    // Mixed line — a float group plus an ungrouped integer.
    auto (fx, fy): float, count;
    fx = 0.5; fy = 2.5; count = 3;
    if (trunc_int(fx + fy) != 3) { return 3; }         // floats: 3.0; ints: 0+2 = 2
    if (count != 3)              { return 4; }

    free(p); free(q);
    return 0;
}
