// test_stbui_widgets.bpp — compile + state smoke test for the
// new stbui widgets (text_input, grid, palette).
//
// Interactive exercise (mouse clicks, character input) isn't
// automatable in a headless suite; this test verifies:
//   - The module compiles with the new function signatures.
//   - text_input_new initialises the struct fields correctly.
//   - text_input_set + text_input_clear mutate state as expected.
//   - The public gui_* symbols link (we reference them in a dead
//     if-0 branch so the linker resolves them).

import "stbgame.bsm";
import "stbui.bsm";

main() {
    auto buf, ti: TextInput, i;
    auto palette_colors, clicked;

    init_str();

    // Text input state lifecycle.
    ti = malloc(sizeof(TextInput));
    buf = malloc(64);
    text_input_new(ti, buf, 32);
    if (ti.len != 0) { putmsg("FAIL: new len != 0"); return 1; }
    if (ti.maxlen != 32) { putmsg("FAIL: new maxlen"); return 1; }
    if (ti.focused != 0) { putmsg("FAIL: new focused"); return 1; }
    if (peek(buf) != 0) { putmsg("FAIL: new buf[0] should be 0"); return 1; }

    text_input_set(ti, "hello");
    if (ti.len != 5) { putmsg("FAIL: set len"); return 1; }
    if (peek(buf + 0) != 'h') { putmsg("FAIL: set[0]"); return 1; }
    if (peek(buf + 4) != 'o') { putmsg("FAIL: set[4]"); return 1; }
    if (peek(buf + 5) != 0)   { putmsg("FAIL: set nul"); return 1; }

    text_input_clear(ti);
    if (ti.len != 0) { putmsg("FAIL: clear len"); return 1; }
    if (peek(buf) != 0) { putmsg("FAIL: clear buf"); return 1; }

    // Set longer than maxlen truncates.
    text_input_set(ti, "this-string-is-way-too-long-for-a-32-char-buffer-honestly");
    if (ti.len != 32) {
        putmsg("FAIL: set truncation expected 32, got ");
        putnum(ti.len);
        putline();
        return 1;
    }
    if (peek(buf + 32) != 0) { putmsg("FAIL: truncated buf missing nul"); return 1; }

    // Link check for drawing APIs (never called because no window).
    if (0) {
        gui_text_input(ti, 10, 10, 120, 20);
        gui_grid(0, 0, 8, 4, 16, rgba(40, 40, 60, 255));

        palette_colors = malloc(4 * 8);
        *(palette_colors + 0 * 8) = rgba(255,   0,   0, 255);
        *(palette_colors + 1 * 8) = rgba(  0, 255,   0, 255);
        *(palette_colors + 2 * 8) = rgba(  0,   0, 255, 255);
        *(palette_colors + 3 * 8) = rgba(255, 255,   0, 255);
        clicked = gui_palette(0, 0, palette_colors, 4, 2, 16, 0 - 1);
    }

    free(buf);
    free(ti);

    putmsg("stbui widgets: state + link smoke passed");
    return 0;
}
