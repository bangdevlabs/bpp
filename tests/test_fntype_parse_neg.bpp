// xfail: E247
// V3 Session 1 negative gate test. Each declaration is malformed in a
// way that should fire a specific diagnostic. The test file does NOT
// compile cleanly — runners that exercise the negative cases assert
// on E247 / E248 / E249 appearing in stderr.
//
// Case A — E247: arg overflow (>8 args).
auto bad_a: func(word, word, word, word, word, word, word, word, word) -> word;

// Case B — E248: nesting depth exceeds MAX_FN_DEPTH (16).
auto bad_b: func(func(func(func(func(func(func(func(func(func(func(func(func(func(func(func(func() -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word) -> word;

// Case C — E249: malformed (missing `->` after argument list).
auto bad_c: func(float) word;

main() { return 0; }
