// test_modulab_v1_compat.bpp — v1 canonical JSON loads cleanly.
//
// Writes a hand-crafted v1-shape file (no `version`, frames are
// bare 2D arrays) and loads it through mlab_load_canonical. v1
// files must produce a single-layer frame with default alpha /
// blend / visible, and the painted cells must round-trip.

import "stbgame.bsm";
import "bpp_file.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto path, text, rc, l: Layer, lp;

    init_str();
    state_init(4);

    // Hand-construct a v1 canonical file. One frame, 4×4, cell
    // (1,1)=2, (2,2)=5, rest=0.
    path = "/tmp/test_modulab_v1.modulab.json";
    text = "{\"type\":\"modulab\",\"size\":4,\"palette\":[0,4278190080,4287371802,4286611584,4294944000,4278222848,4286578816,4294967040],\"frames\":[[[0,0,0,0],[0,2,0,0],[0,0,5,0],[0,0,0,0]]]}";
    rc = file_write_all(path, text, str_len(text));
    if (rc != 0) {
        putmsg("FAIL: could not write v1 fixture to disk");
        return 1;
    }

    rc = mlab_load_canonical(path);
    if (rc != 0) {
        putmsg("FAIL: mlab_load_canonical returned non-zero");
        return 1;
    }

    // v1 upgrades to single-layer frame.
    if (layer_count() != 1) {
        putmsg("FAIL: v1 file did not upgrade to 1 layer, got ");
        putnum(layer_count()); putline();
        return 1;
    }

    lp = layer_at(0, 0);
    l = lp;
    if (l.alpha != 255 || l.visible != 1 || l.blend != 0) {
        putmsg("FAIL: v1 upgrade did not apply default layer props");
        return 1;
    }

    if (pix_get(1, 1) != 2 || pix_get(2, 2) != 5) {
        putmsg("FAIL: v1 cell data not restored");
        putnum(pix_get(1, 1)); putmsg(","); putnum(pix_get(2, 2));
        putline();
        return 1;
    }

    if (pix_get(0, 0) != 0 || pix_get(3, 3) != 0) {
        putmsg("FAIL: v1 transparent cells not 0");
        return 1;
    }

    state_free();
    putmsg("OK");
    return 0;
}
