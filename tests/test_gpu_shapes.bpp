// test_gpu_shapes.bpp — visual smoke test for GPU render primitives.
// Draws lines, circles, and outlined shapes on screen.
//
// Same auto-exit pattern as test_gpu_circle / test_gpu_clear: a
// fixed frame budget plus an explicit `sys_exit(0)` keeps the
// runner deterministic. The natural `game_should_quit` path flaked
// under run_all.sh when the Cocoa window did not gain focus.

import "stbgame.bsm";
import "stbrender.bsm";

const TEST_FRAMES = 30;

main() {
    auto x, t, frame;

    game_init(320, 240, "GPU Shapes Test", 60);
    render_init();
    t = 0;

    for (frame = 0; frame < TEST_FRAMES; frame++) {
        game_frame_begin();
        render_begin();
        render_clear(rgba(32, 32, 48, 255));

        // Grid of lines.
        render_line(10, 10, 100, 10, WHITE);
        render_line(10, 10, 10, 100, GREEN);
        render_line(10, 10, 100, 100, RED);
        render_line(100, 10, 10, 100, YELLOW);

        // Filled circles.
        render_circle(200, 60, 30, RED);
        render_circle(250, 80, 20, BLUE);
        render_circle(160, 80, 15, GREEN);

        // Outlined shapes.
        render_circle_outline(200, 170, 40, WHITE);
        render_rect_outline(40, 140, 80, 60, YELLOW);

        // Moving rect across the lower band.
        x = 160 + t;
        if (x > 300) { t = 0; x = 160; }
        render_rect(x, 210, 16, 16, rgba(255, 128, 0, 255));
        t++;

        render_end();
        if (game_should_quit() != 0) { frame = TEST_FRAMES; }
    }

    sys_exit(0);
    return 0;
}
