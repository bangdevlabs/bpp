// test_gpu_shapes.bpp — visual test for GPU render primitives.
// Draws lines, circles, and outlined shapes on screen.

import "stbgame.bsm";
import "stbrender.bsm";

main() {
    auto x, y, t;
    game_init(320, 240, "GPU Shapes Test", 60);
    render_init();
    t = 0;

    while (game_should_quit() == 0) {
        game_frame_begin();
        render_begin();
        render_clear(rgba(32, 32, 48, 255));

        // Grid of lines.
        render_line(10, 10, 100, 10, WHITE);
        render_line(10, 10, 10, 100, GREEN);
        render_line(10, 10, 100, 100, RED);
        render_line(100, 10, 10, 100, YELLOW);

        // Filled circles.
        render_circle(200, 60, 30, RED);
        render_circle(250, 80, 20, BLUE);
        render_circle(160, 80, 15, GREEN);

        // Outlined shapes.
        render_circle_outline(200, 170, 40, WHITE);
        render_rect_outline(40, 140, 80, 60, YELLOW);

        // Moving rect.
        x = 160 + t;
        if (x > 300) { t = 0; x = 160; }
        render_rect(x, 210, 16, 16, rgba(255, 128, 0, 255));
        t++;

        render_end();
    }
    return 0;
}
