// test_global_kw.bpp — Smoke test for the `global` keyword.
// Verifies that:
//   1. `global x;` declares a file-scope variable that reads/writes
//      identically to the legacy `auto x;` form.
//   2. Mixing `global` and `auto` declarations on the same file works.
//   3. Multiple variables on a single `global` line work.
//   4. Type hints survive: `global x: float;` registers as float.
// Returns 0 on success.

global counter;
global a, b, c;
global px: float;
auto legacy_global;        // old form, still valid

bump() {
    counter = counter + 1;
    return counter;
}

main() {
    counter = 0;
    a = 10; b = 20; c = 30;
    px = 1.5;
    legacy_global = 99;

    if (bump() != 1) { return 1; }
    if (bump() != 2) { return 2; }
    if (bump() != 3) { return 3; }
    if (counter != 3) { return 4; }

    if (a + b + c != 60) { return 5; }
    if (legacy_global != 99) { return 6; }

    // Float global round-trip.
    if (px < 1.0) { return 7; }
    if (px > 2.0) { return 8; }

    return 0;
}
