// Test float: all arithmetic operations and int-float mixing.

putnum(n) {
    auto buf, i, d;
    buf = malloc(32);
    if (n == 0) { putchar('0'); return 0; }
    if (n < 0) { putchar('-'); n = 0 - n; }
    i = 0;
    while (n > 0) {
        d = n % 10;
        poke(buf + i, '0' + d);
        n = n / 10;
        i = i + 1;
    }
    while (i > 0) {
        i = i - 1;
        putchar(peek(buf + i));
    }
    return 0;
}

lerp(a: float, b: float, t: float) {
    return a + (b - a) * t;
}

main() {
    auto x: float, y: float, z: float, w: float;
    auto zi: word;
    // Basic float operations.
    x = 10.5;
    y = 3.2;
    z = x + y;      // 13.7
    zi = z; putnum(zi);
    putchar(' ');

    z = x - y;      // 7.3
    zi = z; putnum(zi);
    putchar(' ');

    z = x * y;      // 33.6
    zi = z; putnum(zi);
    putchar(' ');

    z = x / y;      // 3.28125
    zi = z; putnum(zi);
    putchar(' ');

    // Lerp: 0 + (100 - 0) * 0.75 = 75.0
    w = lerp(0.0, 100.0, 0.75);
    zi = w; putnum(zi);
    putchar('\n');

    return 0;
}
