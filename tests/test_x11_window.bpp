// test_x11_window.bpp — Phase 1 test for the X11 platform layer.
//
// Opens a 320x180 window (or falls back to ANSI terminal if DISPLAY is
// not set), fills the screen with a dark blue color, and auto-exits
// after 10 seconds. Pressing Q or closing the window exits sooner.
//
// Build: ./bpp --linux64 tests/test_x11_window.bpp -o /tmp/test_x11_window
// Run:   docker run --rm -e DISPLAY=host.docker.internal:0 \
//            -v /tmp:/tmp ubuntu:22.04 /tmp/test_x11_window
// Fallback test: docker run --rm -v /tmp:/tmp ubuntu:22.04 /tmp/test_x11_window

import "stbgame.bsm";

main() {
    auto frame;
    game_init(320, 180, "X11 Test", 30);
    frame = 0;
    while (game_should_quit() == 0) {
        game_frame_begin();
        clear(rgba(40, 40, 80, 255));
        draw_end();
        frame++;
    }
    game_end();
    return 0;
}
