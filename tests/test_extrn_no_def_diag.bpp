// xfail: E264
// skip-c: relocation diagnostic is binary-link only
// test_extrn_no_def_diag.bpp — confirm the upgraded E264 fires
// when an `extrn` reference has no backing slot in the link
// graph. Storage-class sidequest 2026-05-14 replaced the
// cryptic "internal error: global 'X' not found in data
// section" with an actionable diagnostic.
//
// stbimage transitively imports stbrender, which declares
// `extrn SCREEN_W;` and uses it inside `render_init()`. This
// test deliberately omits stbgame / stbwindow (the canonical
// definers) AND uses `const SCREEN_W` (parser-level inline,
// emits no slot) instead of `global const SCREEN_W = N;`
// (which WOULD satisfy the extrn). The compiler should refuse
// the link with E264.

import "stbimage.bsm";

const SCREEN_W = 1;
const SCREEN_H = 1;

main() {
    init_image();
    return 0;
}
