// rect_overlap with int coordinates (the canonical signature). Earlier
// this file passed float literals to verify silent float→int conversion
// at call sites; that conversion is now E233 by design. Test now uses
// int literals, exercising the same overlap geometry.

import "stbcol.bsm";
import "bpp_io.bsm";

main() {
    auto r;
    r = rect_overlap(10, 10, 16, 16, 20, 20, 16, 16);
    if (r) { print_msg("HIT"); }
    else { print_msg("MISS"); return 1; }
    return 0;
}
