// Phase B4: SIMD ops run identically against aligned and unaligned
// heap buffers. The native backends always emit the unaligned form
// (LDR Q / MOVUPS) so both `malloc_aligned(N, 16)` and plain `malloc`
// are safe. If someone later swaps in MOVAPS by mistake, the second
// section will fault — that regresses the test with a crash, not a
// silent wrong answer.

import "bpp_io.bsm";
import "bpp_mem.bsm";

// Write four float32 values as raw bytes, load with vec_load4, and
// print the sum of lanes via vec_dot4 with a splat-1 multiplier. The
// dot product equals the sum because multiplying by [1,1,1,1] is a
// no-op on each lane and FADDV sums them.
main() {
    auto buf_a, buf_u, sum;
    auto va: double;
    auto vu: double;
    auto ones: double;

    buf_a = malloc_aligned(16, 16);
    buf_u = malloc(16);

    // Both buffers get the same four int-valued floats by splat+store.
    // Keeping the pattern identical isolates the alignment variable
    // from everything else.
    va = vec_splat4(5.0);
    vec_store4(buf_a, va);
    vec_store4(buf_u, va);

    ones = vec_splat4(1.0);

    // Aligned path.
    va = vec_load4(buf_a);
    sum = vec_dot4(va, ones);
    putchar('0' + sum / 10);
    putchar('0' + sum % 10);
    putchar('\n');

    // Unaligned path — must produce the same 20.
    vu = vec_load4(buf_u);
    sum = vec_dot4(vu, ones);
    putchar('0' + sum / 10);
    putchar('0' + sum % 10);
    putchar('\n');

    free(buf_a);
    free(buf_u);
    return 0;
}
