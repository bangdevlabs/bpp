// Float test for Linux x86_64.
// Compile: ./bpp --linux64 tests/test_linux_float.bpp -o build/test_float_linux
// Test:    docker exec bpp-linux /bpp/build/test_float_linux
// Expected output:
//   3.14
//   6.28
//   OK
putnum(n) {
    auto buf, len, d;
    buf = malloc(32);
    len = 0;
    if (n == 0) {
        putchar(48);
        free(buf);
        return 0;
    }
    while (n > 0) {
        d = n - (n / 10) * 10;
        poke(buf + len, d + 48);
        len++;
        n /= 10;
    }
    while (len > 0) {
        len--;
        putchar(peek(buf + len));
    }
    free(buf);
    return 0;
}

putstr(s) {
    auto i, c;
    i = 0;
    c = peek(s + i);
    while (c != 0) {
        putchar(c);
        i++;
        c = peek(s + i);
    }
    return 0;
}

print_float2(f) {
    auto whole, frac;
    if (f < 0.0) {
        putchar(45);
        f = 0.0 - f;
    }
    whole = f;
    frac = (f - whole) * 100.0;
    frac += 0.5;
    if (frac >= 100) {
        whole++;
        frac = 0;
    }
    putnum(whole);
    putchar(46);
    if (frac < 10) { putchar(48); }
    putnum(frac);
    return 0;
}

main() {
    auto pi, doubled, hf;
    pi = 3.14;
    print_float2(pi);
    putchar(10);
    doubled = pi + pi;
    print_float2(doubled);
    putchar(10);
    hf = pi / 2.0;
    if (hf > 1.0) {
        if (hf < 2.0) {
            putstr("OK");
        }
    }
    putchar(10);
    return 0;
}
