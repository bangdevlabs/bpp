import "stbarray.bsm";

main() {
    auto a, i;
    init_array();

    // Test 1: new + push + len
    a = arr_new();
    a = arr_push(a, 10);
    a = arr_push(a, 20);
    a = arr_push(a, 30);
    if (arr_len(a) != 3) { return 1; }

    // Test 2: get
    if (arr_get(a, 0) != 10) { return 2; }
    if (arr_get(a, 1) != 20) { return 3; }
    if (arr_get(a, 2) != 30) { return 4; }

    // Test 3: set
    arr_set(a, 1, 99);
    if (arr_get(a, 1) != 99) { return 5; }

    // Test 4: pop
    if (arr_pop(a) != 30) { return 6; }
    if (arr_len(a) != 2) { return 7; }

    // Test 5: last
    if (arr_last(a) != 99) { return 8; }

    // Test 6: grow past initial capacity
    for (i = 0; i < 100; i = i + 1) {
        a = arr_push(a, i);
    }
    if (arr_len(a) != 102) { return 9; }
    if (arr_get(a, 101) != 99) { return 10; }

    // Test 7: clear
    arr_clear(a);
    if (arr_len(a) != 0) { return 11; }

    // Test 8: free returns 0
    a = arr_free(a);
    if (a != 0) { return 12; }

    // Test 9: NULL safety
    if (arr_len(0) != 0) { return 13; }

    // Test 10: push on NULL auto-creates
    a = 0;
    a = arr_push(a, 42);
    if (arr_get(a, 0) != 42) { return 14; }
    if (arr_len(a) != 1) { return 15; }

    return 0;
}
