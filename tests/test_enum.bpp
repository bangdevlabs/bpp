import "stbio.bsm";

enum Dir { UP, DOWN, LEFT, RIGHT }
enum Layer { GROUND = 1, PLAYER = 2, ENEMY = 4, BULLET = 8 }
enum State { MENU, PLAY, PAUSE, OVER }

main() {
    auto d, state;

    // Test sequential enum values.
    if (UP != 0)    { print_msg("FAIL UP"); return 1; }
    if (DOWN != 1)  { print_msg("FAIL DOWN"); return 2; }
    if (LEFT != 2)  { print_msg("FAIL LEFT"); return 3; }
    if (RIGHT != 3) { print_msg("FAIL RIGHT"); return 4; }

    // Test explicit enum values.
    if (GROUND != 1)  { print_msg("FAIL GROUND"); return 5; }
    if (PLAYER != 2)  { print_msg("FAIL PLAYER"); return 6; }
    if (ENEMY != 4)   { print_msg("FAIL ENEMY"); return 7; }
    if (BULLET != 8)  { print_msg("FAIL BULLET"); return 8; }

    // Test enum in expressions.
    d = RIGHT;
    print_int(d);
    print_ln();

    // Test bitwise with enum.
    auto mask;
    mask = PLAYER | ENEMY;
    if (mask & GROUND) { print_msg("FAIL mask ground"); return 9; }
    if ((mask & PLAYER) == 0) { print_msg("FAIL mask player"); return 10; }
    if ((mask & ENEMY) == 0)  { print_msg("FAIL mask enemy"); return 11; }

    // Test state machine pattern.
    state = MENU;
    if (state == MENU) { state = PLAY; }
    if (state != PLAY) { print_msg("FAIL state"); return 12; }

    print_msg("enum: all tests passed");
    return 0;
}
