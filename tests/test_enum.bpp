import "bpp_io.bsm";

enum Dir { UP, DOWN, LEFT, RIGHT }
enum Layer { GROUND = 1, PLAYER = 2, ENEMY = 4, BULLET = 8 }
enum State { MENU, PLAY, PAUSE, OVER }

main() {
    auto d, state;

    // Test sequential enum values.
    if (UP != 0)    { putmsg("FAIL UP"); return 1; }
    if (DOWN != 1)  { putmsg("FAIL DOWN"); return 2; }
    if (LEFT != 2)  { putmsg("FAIL LEFT"); return 3; }
    if (RIGHT != 3) { putmsg("FAIL RIGHT"); return 4; }

    // Test explicit enum values.
    if (GROUND != 1)  { putmsg("FAIL GROUND"); return 5; }
    if (PLAYER != 2)  { putmsg("FAIL PLAYER"); return 6; }
    if (ENEMY != 4)   { putmsg("FAIL ENEMY"); return 7; }
    if (BULLET != 8)  { putmsg("FAIL BULLET"); return 8; }

    // Test enum in expressions.
    d = RIGHT;
    putnum(d);
    putline();

    // Test bitwise with enum.
    auto mask;
    mask = PLAYER | ENEMY;
    if (mask & GROUND) { putmsg("FAIL mask ground"); return 9; }
    if ((mask & PLAYER) == 0) { putmsg("FAIL mask player"); return 10; }
    if ((mask & ENEMY) == 0)  { putmsg("FAIL mask enemy"); return 11; }

    // Test state machine pattern.
    state = MENU;
    if (state == MENU) { state = PLAY; }
    if (state != PLAY) { putmsg("FAIL state"); return 12; }

    putmsg("enum: all tests passed");
    return 0;
}
