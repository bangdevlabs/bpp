// Test float return type inference and cross-function float propagation.

print_int(n) {
    auto buf, i, d;
    buf = malloc(32);
    if (n == 0) { putchar('0'); return 0; }
    if (n < 0) { putchar('-'); n = 0 - n; }
    i = 0;
    while (n > 0) {
        d = n % 10;
        poke(buf + i, '0' + d);
        n = n / 10;
        i = i + 1;
    }
    while (i > 0) {
        i = i - 1;
        putchar(peek(buf + i));
    }
    return 0;
}

circle_area(r) {
    auto pi;
    pi = 3.14159;
    return pi * r * r;
}

main() {
    auto area;
    area = circle_area(10.0);
    // area = 3.14159 * 100 = 314.159, should print 314 when truncated.
    print_int(area);
    putchar('\n');
    return 0;
}
