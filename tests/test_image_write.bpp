// test_stbimagewrite.bpp — PNG writer round-trip.
//
// Builds an 8x8 RGBA buffer with a known gradient, writes it out
// as PNG via img_save_png, reads it back via stbimage's img_load,
// and byte-compares. Passes only when the writer produces bytes
// stbimage accepts AND the colours survive intact.

import "stbgame.bsm";
import "stbimage.bsm";

main() {
    auto i, w, h, total, src, loaded, rc;

    init_str();
    init_image();

    w = 8;
    h = 8;
    total = w * h * 4;
    src = malloc(total);

    // Fill with a per-pixel gradient — row encodes R, column
    // encodes G, constant B=128, constant A=255.
    auto y, x, off;
    for (y = 0; y < h; y = y + 1) {
        for (x = 0; x < w; x = x + 1) {
            off = (y * w + x) * 4;
            poke(src + off,     y * 32);
            poke(src + off + 1, x * 32);
            poke(src + off + 2, 128);
            poke(src + off + 3, 255);
        }
    }

    rc = img_save_png("/tmp/test_stbimagewrite.png", src, w, h);
    if (rc != 0) {
        putmsg("FAIL: img_save_png returned non-zero");
        return 1;
    }

    loaded = img_load("/tmp/test_stbimagewrite.png");
    if (loaded == 0) {
        putmsg("FAIL: img_load could not re-read the output PNG");
        return 1;
    }

    if (img_w() != w || img_h() != h) {
        putmsg("FAIL: reload dimensions wrong");
        putnum(img_w()); putmsg("x"); putnum(img_h()); putline();
        return 1;
    }

    // Byte-compare the source and reloaded buffers.
    for (i = 0; i < total; i = i + 1) {
        if (peek(src + i) != peek(loaded + i)) {
            putmsg("FAIL: pixel mismatch at byte ");
            putnum(i); putmsg(" src="); putnum(peek(src + i));
            putmsg(" loaded="); putnum(peek(loaded + i)); putline();
            return 1;
        }
    }

    img_free(loaded);
    free(src);

    putmsg("OK");
    return 0;
}
