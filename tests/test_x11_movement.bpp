// test_x11_movement.bpp — Verify arrow keys move the player.
//
// Prints player (px, py) to stderr every 30 frames so a non-interactive
// test harness can observe whether input is reaching the game loop.
// Runs until ESC is pressed or the window is closed. Useful for both
// automated input testing (via xdotool) and interactive play.

import "stbgame.bsm";

// Write a decimal integer to stderr. Matches print_int in stbio but
// targets fd 2 via putchar_err so the output does not get tangled with
// the ANSI framebuffer if we happen to fall back to terminal mode.
_eprint_int(n) {
    auto buf, len;
    if (n == 0) { putchar_err(48); return 0; }
    buf = malloc(16); len = 0;
    while (n > 0) {
        poke(buf + len, 48 + (n % 10));
        n = n / 10;
        len = len + 1;
    }
    while (len > 0) { len = len - 1; putchar_err(peek(buf + len)); }
    free(buf);
    return 0;
}

main() {
    auto px, py, frame;
    game_init(320, 180, "X11 Movement Test", 60);
    px = 160; py = 90;
    frame = 0;

    while (game_should_quit() == 0) {
        game_frame_begin();

        if (key_down(KEY_UP))    { py = py - 2; }
        if (key_down(KEY_DOWN))  { py = py + 2; }
        if (key_down(KEY_LEFT))  { px = px - 2; }
        if (key_down(KEY_RIGHT)) { px = px + 2; }
        if (key_pressed(KEY_ESC)) { break; }

        if (px < 8)   { px = 8; }
        if (py < 8)   { py = 8; }
        if (px > 312) { px = 312; }
        if (py > 172) { py = 172; }

        // Print position every 30 frames.
        if (frame % 30 == 0) {
            putchar_err('p'); putchar_err('x'); putchar_err('=');
            _eprint_int(px);
            putchar_err(' '); putchar_err('p'); putchar_err('y'); putchar_err('=');
            _eprint_int(py);
            putchar_err(10);
        }

        clear(rgba(20, 20, 40, 255));
        draw_rect(px - 8, py - 8, 16, 16, RED);
        draw_end();

        frame = frame + 1;
    }
    game_end();
    return 0;
}
