// test_put_dispatch.bpp — Verify put(x) smart dispatch by argument type.
// put(TY_PTR)   → putstr   (string output)
// put(TY_WORD)  → putnum   (integer output)
// put(TY_FLOAT) → putfloat (decimal output)

main() {
    auto s, n;
    auto f: float;

    // Test 1: put(string literal) compiles and runs without crashing.
    // If dispatch goes to putstr, this prints the string. We can't capture
    // stdout in the test runner, so we just verify it exits 0.
    s = "hello";
    put(s);
    putchar('\n');

    // Test 2: put(integer) → putnum.
    n = 42;
    put(n);
    putchar('\n');

    // Test 3: put(float) → putfloat.
    f = 3.14;
    put(f);
    putchar('\n');

    // Test 4: put string literal directly.
    put("world");
    putchar('\n');

    // Test 5: put_err goes to stderr — just verify it compiles and runs.
    put_err("err");
    putchar_err('\n');

    return 0;
}
