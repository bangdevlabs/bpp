// `global x: u_word` propagates the unsigned type through codegen
// the same way local annotations do. Without the global-side
// propagation, `x >> 32` on a global-scoped u_word would still
// emit ASR (arithmetic shift right, sign-extending), and the high
// 32 bits of an all-ones value would stay 0xFFFFFFFFFFFFFFFF.
// With propagation, LSR fills with zeros so the result is
// 0x00000000FFFFFFFF.

global signed_x;
global unsigned_x: u_word;

main() {
    signed_x = 0xFFFFFFFFFFFFFFFF;
    unsigned_x = 0xFFFFFFFFFFFFFFFF;

    if ((signed_x >> 32) != 0xFFFFFFFFFFFFFFFF) { return 1; }
    if ((unsigned_x >> 32) != 0x00000000FFFFFFFF) { return 2; }

    if ((unsigned_x / 4) != 0x3FFFFFFFFFFFFFFF) { return 3; }
    if ((unsigned_x % 100) != 15) { return 4; }

    return 0;
}
