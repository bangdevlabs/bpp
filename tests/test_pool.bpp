// Test stbpool.bsm — object pool correctness.

import "stbpool.bsm";

// Print a pass/fail line for a single check.
check(name, ok) {
    auto i;
    if (ok) {
        putchar('O'); putchar('K'); putchar(' ');
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(' ');
    }
    i = 0;
    while (str_peek(name, i) != 0) {
        putchar(str_peek(name, i));
        i++;
    }
    putchar(10);
    return ok;
}

main() {
    auto pool, b1, b2, b3, b4, pass;
    pass = 1;

    pool = pool_new(32, 4);

    // Get first object.
    b1 = pool_get(pool);
    pass = check("get returns non-null", b1 != 0) * pass;
    pass = check("count is 1", pool_count(pool) == 1) * pass;

    // Get second object, different address.
    b2 = pool_get(pool);
    pass = check("second get different addr", b2 != b1) * pass;
    pass = check("count is 2", pool_count(pool) == 2) * pass;

    // Put first back, then get again — should recycle.
    pool_put(pool, b1);
    pass = check("count after put is 1", pool_count(pool) == 1) * pass;

    b3 = pool_get(pool);
    pass = check("recycled address", b3 == b1) * pass;
    pass = check("count is 2 again", pool_count(pool) == 2) * pass;

    // Exhaust the pool (capacity 4, 2 live, 2 remaining).
    pool_get(pool);
    pool_get(pool);
    pass = check("count is 4", pool_count(pool) == 4) * pass;

    // Pool is now full — get should return 0.
    b4 = pool_get(pool);
    pass = check("exhausted returns 0", b4 == 0) * pass;

    pool_free(pool);

    // Final verdict.
    putchar(10);
    if (pass) {
        putchar('A'); putchar('L'); putchar('L'); putchar(' ');
        putchar('O'); putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar('E'); putchar('D'); putchar(10);
    }

    return 0;
}
