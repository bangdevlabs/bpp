// test_stbpal_builtin.bpp — exercise the built-in palette catalog.
//
// Pulls every built-in out of palette_builtin, verifies the color
// count is what the catalog promises, and that index 0 is always
// transparent (alpha 0) so callers relying on the transparency
// convention stay correct.

import "stbgame.bsm";
import "stbpal.bsm";

main() {
    auto p, argb, expected_count, i, id;

    init_str();
    init_palette();

    // Expected counts for each built-in in the order of the enum.
    expected_count = malloc(7 * 8);
    *(expected_count + 0 * 8) = 8;   // MCU-8
    *(expected_count + 1 * 8) = 4;   // NKOTC-4
    *(expected_count + 2 * 8) = 32;  // CB-32
    *(expected_count + 3 * 8) = 32;  // DB-32
    *(expected_count + 4 * 8) = 16;  // PICO-8
    *(expected_count + 5 * 8) = 5;   // GB-4 (includes transparent)
    *(expected_count + 6 * 8) = 54;  // NES-54

    for (i = 0; i < 7; i = i + 1) {
        id = i;
        p = palette_builtin(id);
        if (p == 0) {
            print_msg("FAIL: palette_builtin("); print_int(id);
            print_msg(") returned 0\n"); return 1;
        }
        if (palette_count(p) != *(expected_count + i * 8)) {
            print_msg("FAIL: palette "); print_int(id);
            print_msg(" wrong count: got ");
            print_int(palette_count(p));
            print_msg(" want ");
            print_int(*(expected_count + i * 8));
            print_ln();
            return 1;
        }
        argb = palette_get(p, 0);
        if ((argb >> 24) & 0xFF) {
            print_msg("FAIL: palette "); print_int(id);
            print_msg(" index 0 is not transparent (alpha=");
            print_int((argb >> 24) & 0xFF); print_msg(")\n");
            return 1;
        }
    }
    free(expected_count);

    // Known sanity: MCU-8 index 4 is orange (0xFFFFA500).
    p = palette_builtin(PAL_MCU_8);
    if (palette_get(p, 4) != 0xFFFFA500) {
        print_msg("FAIL: MCU-8[4] != orange\n");
        return 1;
    }
    // DB-32 index 22 is white (0xFFFFFFFF).
    p = palette_builtin(PAL_DB_32);
    if (palette_get(p, 22) != 0xFFFFFFFF) {
        print_msg("FAIL: DB-32[22] != white\n");
        return 1;
    }

    // Built-in fetch is borrowed — calling twice returns the same
    // pointer.
    if (palette_builtin(PAL_MCU_8) != palette_builtin(PAL_MCU_8)) {
        print_msg("FAIL: palette_builtin not idempotent\n");
        return 1;
    }

    print_msg("OK");
    return 0;
}
