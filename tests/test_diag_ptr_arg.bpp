// xfail: W038
// test_diag_ptr_arg.bpp — Smoke test for W038.
//
// W038 fires when a callsite passes a NON-ZERO INTEGER LITERAL to a
// parameter declared `: ptr`. The narrow gate (literal-only, no
// TY_WORD-var matching) targets the specific param-order-swap bug
// class without flooding existing code where handles flow through
// unannotated locals — Rule 13 nudge belongs in a future audit pass.
//
// Run via `tests/run_all.sh`: the `xfail: W038` tag above asks the
// runner to ASSERT the front-end emits a W038 diagnostic; any other
// result (compiles clean, fails with a different code) counts as a
// regression.

takes_ptr_param(p: ptr) {
    return p;
}

main() {
    // The bug-shaped call: integer literal in `: ptr` slot. Emits
    // W038 "argument 1 of 'takes_ptr_param' expects a pointer ...
    // got integer literal 42".
    takes_ptr_param(42);
    return 0;
}
