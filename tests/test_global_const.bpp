// test_global_const.bpp — positive smoke for the storage-class
// sidequest (2026-05-14). Declares both new slot-bearing const
// classes and confirms the parser stored each value into a real
// data slot whose contents the runtime can read back.
//
// `global const X` lives in `.data` with a global symbol and is
// addressable cross-module (covered separately in the cross-module
// test). `static const Y` lives in the same section but with a
// module-private symbol — invisible to other modules.

global const ANSWER       = 42;
global const NEG_BIRTH    = -1947;
static const _HIDDEN_PRIV = 99;

main() {
    if (ANSWER       != 42)    { return 1; }
    if (NEG_BIRTH    != -1947) { return 2; }
    if (_HIDDEN_PRIV != 99)    { return 3; }
    return 0;
}
