// test_continue.bpp — Smoke test for the `continue` keyword.
//
// Verifies that:
//   1. `continue` inside a `for` loop runs the step before re-testing.
//      In `for (i = 0; i < N; i++) { if (skip) continue; ... }`
//      the loop must terminate; otherwise we never reach the step and
//      hang forever.
//   2. `continue` inside a plain `while` jumps back to the top.
//   3. The body statements after `continue` are skipped.
//   4. Nested loops use the innermost loop's continue label.
//
// Returns 0 on success, non-zero on failure.

main() {
    auto i, sum, even_count, k, inner_hits;

    // Case 1: for loop with continue must still increment its induction var.
    sum = 0;
    even_count = 0;
    for (i = 0; i < 10; i++) {
        if (i % 2 == 1) { continue; }
        even_count++;
        sum += i;
    }
    // Even numbers 0..9 are 0,2,4,6,8 → 5 values, sum = 20.
    if (even_count != 5) { return 1; }
    if (sum != 20) { return 2; }

    // Case 2: plain while loop with continue.
    i = 0;
    sum = 0;
    while (i < 10) {
        i++;
        if (i % 3 == 0) { continue; }
        sum += i;
    }
    // 1+2+4+5+7+8+10 = 37.
    if (sum != 37) { return 3; }

    // Case 3: nested loops — inner continue must not skip the outer step.
    inner_hits = 0;
    for (i = 0; i < 3; i++) {
        for (k = 0; k < 5; k++) {
            if (k == 2) { continue; }
            inner_hits++;
        }
    }
    // Each outer iter visits 4 inner values (0,1,3,4) → 3*4 = 12.
    if (inner_hits != 12) { return 4; }

    return 0;
}
