import "bpp_buf.bsm";
import "bpp_io.bsm";

main() {
    auto buf, v;
    buf = malloc(64);

    // Test 1: write_u8 / read_u8
    write_u8(buf, 0, 42);
    if (read_u8(buf, 0) != 42) { putmsg("FAIL u8 basic"); return 1; }
    write_u8(buf, 1, 255);
    if (read_u8(buf, 1) != 255) { putmsg("FAIL u8 max"); return 2; }

    // Test 2: write_u16 / read_u16
    write_u16(buf, 0, 0);
    write_u16(buf, 0, 1234);
    if (read_u16(buf, 0) != 1234) { putmsg("FAIL u16 basic"); return 3; }
    write_u16(buf, 2, 65535);
    if (read_u16(buf, 2) != 65535) { putmsg("FAIL u16 max"); return 4; }
    // Verify little-endian byte order: 0x04D2 = 1234
    if (read_u8(buf, 0) != 210) { putmsg("FAIL u16 le lo"); return 5; }
    if (read_u8(buf, 1) != 4)   { putmsg("FAIL u16 le hi"); return 6; }

    // Test 3: write_u32 / read_u32
    write_u32(buf, 0, 0);
    write_u32(buf, 0, 305419896);
    // 305419896 = 0x12345678
    if (read_u32(buf, 0) != 305419896) { putmsg("FAIL u32 basic"); return 7; }
    // Verify byte order: 78 56 34 12
    if (read_u8(buf, 0) != 120) { putmsg("FAIL u32 le b0"); return 8; }
    if (read_u8(buf, 1) != 86)  { putmsg("FAIL u32 le b1"); return 9; }
    if (read_u8(buf, 2) != 52)  { putmsg("FAIL u32 le b2"); return 10; }
    if (read_u8(buf, 3) != 18)  { putmsg("FAIL u32 le b3"); return 11; }

    // Test 4: write_u32 max value
    write_u32(buf, 4, 4294967295);
    if (read_u32(buf, 4) != 4294967295) { putmsg("FAIL u32 max"); return 12; }

    // Test 5: non-zero offset
    write_u32(buf, 10, 99999);
    if (read_u32(buf, 10) != 99999) { putmsg("FAIL u32 offset"); return 13; }

    // Test 6: write_u64 / read_u64
    write_u64(buf, 0, 0);
    write_u64(buf, 0, 1234567890123);
    if (read_u64(buf, 0) != 1234567890123) { putmsg("FAIL u64 basic"); return 14; }

    // Test 7: adjacent writes don't clobber each other
    write_u32(buf, 0, 111);
    write_u32(buf, 4, 222);
    if (read_u32(buf, 0) != 111) { putmsg("FAIL adjacent lo"); return 15; }
    if (read_u32(buf, 4) != 222) { putmsg("FAIL adjacent hi"); return 16; }

    free(buf);
    putmsg("stbbuf: all tests passed");
    return 0;
}
