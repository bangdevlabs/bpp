// Phase B4: exercise every SIMD builtin with known inputs and print
// per-lane results via vec_get4. Expected stdout hard-coded below.
// Inline style (no helpers taking SIMD params) because passing
// `: double` through function parameters is not yet wired to the
// SysV / AAPCS64 SIMD argument registers.

import "bpp_io.bsm";

main() {
    auto a: double;
    auto b: double;
    auto c: double;
    auto lane, d;

    a = vec_splat4(2.0);
    b = vec_splat4(3.0);

    // vec_add4: 2 + 3 = 5 in every lane.
    c = vec_add4(a, b);
    lane = vec_get4(c, 0); putchar('0' + lane);
    lane = vec_get4(c, 1); putchar('0' + lane);
    lane = vec_get4(c, 2); putchar('0' + lane);
    lane = vec_get4(c, 3); putchar('0' + lane);
    putchar('\n');

    // vec_sub4: 3 - 2 = 1.
    c = vec_sub4(b, a);
    lane = vec_get4(c, 0); putchar('0' + lane);
    lane = vec_get4(c, 1); putchar('0' + lane);
    lane = vec_get4(c, 2); putchar('0' + lane);
    lane = vec_get4(c, 3); putchar('0' + lane);
    putchar('\n');

    // vec_mul4: 2 * 3 = 6.
    c = vec_mul4(a, b);
    lane = vec_get4(c, 0); putchar('0' + lane);
    lane = vec_get4(c, 1); putchar('0' + lane);
    lane = vec_get4(c, 2); putchar('0' + lane);
    lane = vec_get4(c, 3); putchar('0' + lane);
    putchar('\n');

    // vec_min4([2,2,2,2], [3,3,3,3]) = [2,2,2,2].
    c = vec_min4(a, b);
    lane = vec_get4(c, 0); putchar('0' + lane);
    lane = vec_get4(c, 3); putchar('0' + lane);
    putchar('\n');

    // vec_max4 = [3,3,3,3].
    c = vec_max4(a, b);
    lane = vec_get4(c, 0); putchar('0' + lane);
    lane = vec_get4(c, 3); putchar('0' + lane);
    putchar('\n');

    // vec_dot4 = 4 × 2 × 3 = 24.
    d = vec_dot4(a, b);
    putchar('0' + d / 10);
    putchar('0' + d % 10);
    putchar('\n');
    return 0;
}
