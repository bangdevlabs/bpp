// skip-c: SIGPROF supplement is macOS-only and depends on the
// minisym section the C path does not emit.
// test_profile_signal.bpp — Phase 6.4.2 SIGPROF smoke test.
//
// Arms a 1 kHz ITIMER_PROF, spins in `hot_loop` for roughly
// 200 ms, then dumps the top samples. Unlike the cooperative
// build, sampling fires INSIDE the loop body — so the captured
// stacks should attribute to `hot_loop` (or its caller) rather
// than to a `_job_worker_main` boundary.
//
// Verification stays loose because sampling is stochastic: the
// test asserts "we got at least one sample" and "the top entry
// resolves to a non-zero name". A specific percentage threshold
// on `hot_loop` would flake on a loaded CI host; the relative
// dominance check is left to manual inspection.
//
// SPIN_ITERS sized so the loop runs ~50-100 ms on a current
// arm64 Mac. ITIMER_PROF at 1 kHz fires roughly once per ms of
// CPU time, so the budget yields tens of samples even on a
// loaded host. Smaller workloads (5 M iterations) ran in ~10
// ms and produced zero entries about half the time — the
// stochastic threshold needs real CPU runway to hold.

import "bpp_runtime.bsm";

const SPIN_ITERS = 50000000;

hot_loop() {
    auto i, x;
    x = 0;
    for (i = 0; i < SPIN_ITERS; i++) {
        x = x * 31 + i;
    }
    return x;
}

main() {
    auto buf, n, top_count, top_name;

    profile_start(1000, 8);
    hot_loop();
    profile_stop();

    buf = buf_word(16 * 2);
    n = profile_dump(buf, 16);
    if (n == 0) { return 1; }

    top_name  = *(buf);
    top_count = *(buf + 8);
    if (top_count <= 0) { return 2; }
    if (top_name == 0)  { return 3; }

    return 0;
}
