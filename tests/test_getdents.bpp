// Test sys_getdents + sys_unlink.
main() {
    auto fd, buf, nread, pos, reclen, name_off, ch, i;
    buf = malloc(4096);

    // Open the cache directory.
    // O_RDONLY(0) | O_DIRECTORY(0x100000) on macOS
    fd = sys_open("/Users/obino/.bpp/cache", 0x100000);
    if (fd < 0) {
        putchar('E'); putchar(10);
        return 1;
    }

    // Read directory entries.
    nread = sys_getdents(fd, buf, 4096);
    putchar('R'); putchar(':');
    // Print nread as a simple number
    if (nread < 0) { putchar('-'); }
    if (nread == 0) { putchar('0'); }
    if (nread > 0) { putchar('+'); }
    putchar(10);

    // Walk entries.
    if (nread > 0) {
        pos = 0;
        while (pos < nread) {
            reclen = read_u16(buf, pos + 16);
            if (reclen == 0) { break; }
            name_off = pos + 21;
            // Print name.
            i = 0;
            ch = peek(buf + name_off + i);
            while (ch != 0) {
                putchar(ch);
                i = i + 1;
                ch = peek(buf + name_off + i);
            }
            putchar(10);
            pos = pos + reclen;
        }
    }

    sys_close(fd);
    return 0;
}
