// test_vec2_arithmetic.bpp — round-trip every Vec2 helper.
//
// Promotion test for `bpp_math.Vec2` (May 2026 — fields gained
// `: float` typing, 9 new helpers shipped). Catches regressions
// where a future refactor breaks add / sub / scale / dot /
// length / normalize / distance / distance_sq / length_sq.
//
// Each block computes against literal expected values and exits
// non-zero if any answer drifts. Tolerance is 0.0001 (well above
// double precision rounding for the small inputs used here).

void check_eq(label, got: float, want: float) {
    auto diff: float;
    diff = got - want;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff > 0.0001) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putfloat(got);
        putstr(" want="); putfloat(want);
        putline();
        sys_exit(1);
    }
}

main() {
    auto a, b, out;

    // a = (1.5, 2.5)
    a = vec2_new(1.5, 2.5);
    // b = (3.0, 0.5)
    b = vec2_new(3.0, 0.5);
    out = vec2_new(0.0, 0.0);

    auto va: Vec2, vb: Vec2, vo: Vec2;
    va = a; vb = b; vo = out;

    // add: (1.5 + 3.0, 2.5 + 0.5) = (4.5, 3.0)
    vec2_add(out, a, b);
    check_eq("add.x", vo.x, 4.5);
    check_eq("add.y", vo.y, 3.0);

    // sub: (1.5 - 3.0, 2.5 - 0.5) = (-1.5, 2.0)
    vec2_sub(out, a, b);
    check_eq("sub.x", vo.x, 0.0 - 1.5);
    check_eq("sub.y", vo.y, 2.0);

    // scale a by 2: (3.0, 5.0)
    vec2_scale(out, a, 2.0);
    check_eq("scale.x", vo.x, 3.0);
    check_eq("scale.y", vo.y, 5.0);

    // dot: 1.5*3.0 + 2.5*0.5 = 4.5 + 1.25 = 5.75
    check_eq("dot", vec2_dot(a, b), 5.75);

    // length_sq of (3, 4) = 25
    auto c;
    c = vec2_new(3.0, 4.0);
    check_eq("length_sq", vec2_length_sq(c), 25.0);
    check_eq("length",    vec2_length(c),    5.0);

    // normalize (3, 4) → (0.6, 0.8)
    vec2_normalize(out, c);
    check_eq("norm.x", vo.x, 0.6);
    check_eq("norm.y", vo.y, 0.8);

    // normalize (0, 0) → (0, 0) — epsilon guard
    auto z;
    z = vec2_new(0.0, 0.0);
    vec2_normalize(out, z);
    check_eq("norm.zero.x", vo.x, 0.0);
    check_eq("norm.zero.y", vo.y, 0.0);

    // distance_sq between (0,0) and (3,4) = 25
    auto origin;
    origin = vec2_new(0.0, 0.0);
    check_eq("dist_sq", vec2_distance_sq(origin, c), 25.0);
    check_eq("dist",    vec2_distance(origin, c),    5.0);

    // eq: same vec equals itself, different ones don't
    if (vec2_eq(a, a) != 1) { putstr("FAIL eq.same\n"); sys_exit(1); }
    if (vec2_eq(a, b) != 0) { putstr("FAIL eq.diff\n"); sys_exit(1); }

    putstr("OK\n");
}
