// test_inc_struct_field.bpp — Pin the parser's `++` / `--` desugar
// against the T_MEMLD case (struct fields, array slots).
//
// Background: `_make_inc_assign` in src/bpp_parser.bsm originally
// desugared `x++` to `T_ASSIGN(x, x + 1)` unconditionally. When the
// lhs was a T_MEMLD (struct.field, arr[i]), the resulting T_ASSIGN
// silently no-op'd on the load operation instead of writing back to
// the underlying storage. `_make_compound_assign` (for `+=` / `-=`)
// already carried the T_MEMLD → T_MEMST branch; this test pins the
// `++` path to identical behaviour so the two cannot drift again.

struct Counter { value }

main() {
    auto c: Counter, fails;
    fails = 0;
    c = malloc(sizeof(Counter));
    c.value = 10;

    // Postfix ++ on a struct field.
    c.value++;
    if (c.value != 11) {
        put("FAIL: c.value++ produced ");
        put(c.value);
        put(" (expected 11)\n");
        fails++;
    }

    // Postfix -- on a struct field.
    c.value--;
    if (c.value != 10) {
        put("FAIL: c.value-- produced ");
        put(c.value);
        put(" (expected 10)\n");
        fails++;
    }

    // Prefix ++ on a struct field (separate parse path).
    ++c.value;
    if (c.value != 11) {
        put("FAIL: ++c.value produced ");
        put(c.value);
        put(" (expected 11)\n");
        fails++;
    }

    // Prefix -- on a struct field.
    --c.value;
    if (c.value != 10) {
        put("FAIL: --c.value produced ");
        put(c.value);
        put(" (expected 10)\n");
        fails++;
    }

    // Array slot (also a T_MEMLD). buf_word indexes share the same
    // codegen path as struct fields, so the fix must cover both.
    auto arr;
    arr = buf_word(4);
    arr[2] = 100;
    arr[2]++;
    if (arr[2] != 101) {
        put("FAIL: arr[2]++ produced ");
        put(arr[2]);
        put(" (expected 101)\n");
        fails++;
    }
    arr[2]--;
    if (arr[2] != 100) {
        put("FAIL: arr[2]-- produced ");
        put(arr[2]);
        put(" (expected 100)\n");
        fails++;
    }
    free(arr);

    free(c);

    if (fails == 0) { put("OK\n"); return 0; }
    put("FAILED: "); put(fails); put(" assertion(s)\n");
    return 1;
}
