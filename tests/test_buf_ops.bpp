// Tests for bpp_buf.bsm: slice-based LE reads/writes, float access,
// buf_move (overlap-safe copy), buf_cmp, buf_free.
main() {
    auto buf;
    buf = buf_byte(64);

    // ── LE write + read roundtrip ────────────────────────────────────────

    write_u8(buf, 0, 0xAB);
    assert(read_u8(buf, 0) == 0xAB);

    write_u16(buf, 0, 0x1234);
    assert(read_u16(buf, 0) == 0x1234);

    write_u32(buf, 0, 0xDEADBEEF);
    assert(read_u32(buf, 0) == 0xDEADBEEF);

    write_u64(buf, 0, 0x0102030405060708);
    assert(read_u64(buf, 0) == 0x0102030405060708);

    // ── BE write + read roundtrip ─────────────────────────────────────────

    write_u16be(buf, 0, 0xCAFE);
    assert(read_u16be(buf, 0) == 0xCAFE);

    write_u32be(buf, 0, 0xDEADC0DE);
    assert(read_u32be(buf, 0) == 0xDEADC0DE);

    // ── BE byte order: verify the physical layout differs from LE ─────────
    // write_u16 (LE) stores low byte first; write_u16be stores high byte first.
    write_u16(buf, 0, 0x1234);
    assert(read_u8(buf, 0) == 0x34);   // low byte at lower address (LE)
    assert(read_u8(buf, 1) == 0x12);

    write_u16be(buf, 0, 0x1234);
    assert(read_u8(buf, 0) == 0x12);   // high byte at lower address (BE)
    assert(read_u8(buf, 1) == 0x34);

    // ── buf_cmp ───────────────────────────────────────────────────────────

    auto a, b;
    a = buf_byte(8);
    b = buf_byte(8);
    write_u32(a, 0, 0x12345678);
    write_u32(b, 0, 0x12345678);
    assert(buf_cmp(a, b, 4) == 0);

    write_u8(b, 2, 0xFF);
    assert(buf_cmp(a, b, 4) != 0);

    buf_free(a);
    buf_free(b);

    // ── buf_move (overlap: dst > src, backward copy required) ────────────
    auto m;
    m = buf_byte(16);
    write_u8(m, 0, 10);
    write_u8(m, 1, 20);
    write_u8(m, 2, 30);
    write_u8(m, 3, 40);
    // Shift 4 bytes forward by 2 (overlapping: dst=2, src=0, n=4).
    buf_move(m + 2, m, 4);
    assert(read_u8(m, 2) == 10);
    assert(read_u8(m, 3) == 20);
    assert(read_u8(m, 4) == 30);
    assert(read_u8(m, 5) == 40);
    buf_free(m);

    // ── buf_fill ──────────────────────────────────────────────────────────
    auto f;
    f = buf_byte(8);
    buf_fill(f, 0xBB, 8);
    assert(read_u8(f, 0) == 0xBB);
    assert(read_u8(f, 7) == 0xBB);
    buf_free(f);

    buf_free(buf);
    return 0;
}
