// test_const_fold.bpp — Validates the constant folding pass added in
// Phase B0 of the Mini Cooper plan. Each binary op with two integer
// literal operands must evaluate to the right value at runtime; the
// fold is invisible at the source level but cuts 4-6 instructions
// down to a single mov.
//
// Division and modulo by zero must NOT fold — the fold path skips them
// so the runtime trap still fires (kept here as a non-zero-divisor case
// since exercising the trap would crash the test binary).

main() {
    // Arithmetic.
    if (3 + 5 != 8)        { return 10; }
    if (100 - 7 != 93)     { return 11; }
    if (12 * 11 != 132)    { return 12; }
    if (1024 / 16 != 64)   { return 13; }
    if (17 % 5 != 2)       { return 14; }

    // Bitwise.
    if ((0xFF & 0x0F) != 15)  { return 20; }
    if ((0x10 | 0x01) != 17)  { return 21; }
    if ((0xFF ^ 0x0F) != 240) { return 22; }

    // Shifts.
    if (1 << 8 != 256)     { return 30; }
    if (256 >> 4 != 16)    { return 31; }

    // Negative results survive the fold.
    if (5 - 10 != 0 - 5)   { return 40; }

    // Larger immediates round-trip through movz/movk on ARM64.
    if (1000 * 1000 != 1000000) { return 50; }

    return 0;
}
