import "stbecs.bsm";

// bench_ecs_sparse_query.bpp — RTS Stress Arc Session 2's real
// killer use case: sparse selectivity scaling.
//
// The original Session 2 spec claimed "3-5x cache locality speedup"
// for archetype storage. That number was imported from Bevy / Unity
// DOTS pitches, where the baseline is AoS. B++'s legacy ECS is
// already SoA via parallel buf_word arrays, so the AoS→SoA win
// does not apply. tests/bench_ecs_iter.bpp confirmed this
// empirically: dense single-field iteration runs at ~0.54x of
// legacy speed under archetype storage.
//
// This bench measures the workload where AoSoA chunked DOES win,
// even without SIMD: sparse selectivity. The world has many entity
// kinds; a query targets one kind that is a minority of the
// population. Archetype storage walks only matching archetypes —
// cost is O(matching_entities), not O(total_entities).
//
// Setup:
//   - 45000 "tile" entities — only carry Pos (Pos-only archetype)
//   - 5000  "combatant" entities — carry Pos + Vel + Hp + Faction
//                                   (4-component archetype)
//   - Total: 50000 entities. Selectivity = 5000 / 50000 = 10%.
// Plus a 2%-selectivity follow-up to show the ratio scales as the
// matching fraction shrinks.

const ITERATIONS    = 2000;
const N_TILES       = 45000;
const N_COMBATANTS  = 5000;
const N_TOTAL       = 50000;

struct Pos      { x: float, y: float }
struct Vel      { dx: float, dy: float }
struct Hp       { value, max }
struct Faction  { id, color }

global _bench_sum: float;       // accumulator so callbacks don't DCE

// Archetype callback for the Vel chunk walk. Receives a direct
// pointer to the chunk's Vel array — no per-entity dispatch, no
// per-entity component scan.
void _arch_touch_vel(w, vel_base, n, stride) {
    auto i;
    auto v: Vel;
    for (i = 0; i < n; i++) {
        v = vel_base + i * stride;
        _bench_sum = _bench_sum + v.dx;
    }
}

main() {
    auto w_legacy, w_arch;
    auto i, k, iter, cap;
    auto is_combatant;          // parallel bitmap for legacy "has Vel" check
    auto pos_comp, vel_comp, hp_comp, fac_comp;
    auto tile_comp_ids, combatant_comp_ids;
    auto tile_arch, combatant_arch;
    auto q_arch;
    auto t_legacy_start, t_legacy_end, t_arch_start, t_arch_end;
    auto us_legacy, us_arch, ratio_x100;
    auto wdl: World;
    auto p: Pos, v: Vel;

    // ── Legacy world setup ──────────────────────────────────────
    // All 50000 entities exist in one world. is_combatant[k] = 1 for
    // the first 5000, 0 for the rest. This approximates the "does
    // this entity have a Vel component?" check the legacy ECS would
    // have to make in a heterogeneous world.
    w_legacy = ecs_new(N_TOTAL);
    is_combatant = buf_byte(N_TOTAL);
    for (i = 0; i < N_TOTAL; i++) {
        ecs_spawn(w_legacy);
        ecs_set_pos(w_legacy, i, i * 100, i * 200);
        if (i < N_COMBATANTS) {
            poke(is_combatant + i, 1);
            ecs_set_vel(w_legacy, i, i * 10, i * 20);
        } else {
            poke(is_combatant + i, 0);
        }
    }
    wdl = w_legacy;
    cap = ecs_capacity(w_legacy);

    // ── Archetype world setup ───────────────────────────────────
    // Two archetypes: Pos-only (tiles, 45K) and Pos+Vel+Hp+Faction
    // (combatants, 5K). The query "entities with Vel" walks only the
    // combatant archetype — selectivity is structural, not a runtime
    // check.
    w_arch = ecs_new(N_TOTAL);
    pos_comp = ecs_component_register(w_arch, 0, sizeof(Pos));
    vel_comp = ecs_component_register(w_arch, 0, sizeof(Vel));
    hp_comp  = ecs_component_register(w_arch, 0, sizeof(Hp));
    fac_comp = ecs_component_register(w_arch, 0, sizeof(Faction));

    tile_comp_ids = buf_word(1);
    tile_comp_ids[0] = pos_comp;
    tile_arch = ecs_archetype(w_arch, tile_comp_ids, 1);

    combatant_comp_ids = buf_word(4);
    combatant_comp_ids[0] = pos_comp;
    combatant_comp_ids[1] = vel_comp;
    combatant_comp_ids[2] = hp_comp;
    combatant_comp_ids[3] = fac_comp;
    combatant_arch = ecs_archetype(w_arch, combatant_comp_ids, 4);

    for (i = 0; i < N_TILES; i++) {
        auto t_id;
        t_id = ecs_spawn_at(w_arch, tile_arch);
        p = ecs_get(w_arch, pos_comp, t_id);
        p.x = i;
        p.y = i * 2.0;
    }
    for (i = 0; i < N_COMBATANTS; i++) {
        auto c_id;
        c_id = ecs_spawn_at(w_arch, combatant_arch);
        p = ecs_get(w_arch, pos_comp, c_id);
        v = ecs_get(w_arch, vel_comp, c_id);
        p.x = i;
        p.y = i * 2.0;
        v.dx = i * 0.1;
        v.dy = i * 0.2;
    }
    q_arch = ecs_query(w_arch, 1);

    // ── Warm-up so cache state is comparable ────────────────────
    _bench_sum = 0.0;
    for (k = 0; k < cap; k++) {
        if (peek(wdl.alive + k)) {
            if (peek(is_combatant + k)) {
                _bench_sum = _bench_sum + wdl.vel_x[k];
            }
        }
    }
    ecs_chunk_each(q_arch, vel_comp, fn_ptr(_arch_touch_vel));

    // ── Bench: legacy sparse scan ───────────────────────────────
    // The pattern any heterogeneous ECS without archetype awareness
    // has to use: scan every entity, conditional on whether the
    // wanted component exists. Cost O(N_TOTAL), independent of
    // selectivity. 90% of the work is on entities the query does
    // not care about.
    _bench_sum = 0.0;
    t_legacy_start = _stb_get_time_us();
    for (iter = 0; iter < ITERATIONS; iter++) {
        for (k = 0; k < cap; k++) {
            if (peek(wdl.alive + k)) {
                if (peek(is_combatant + k)) {
                    _bench_sum = _bench_sum + wdl.vel_x[k];
                }
            }
        }
    }
    t_legacy_end = _stb_get_time_us();
    us_legacy = t_legacy_end - t_legacy_start;

    // ── Bench: archetype targeted walk ──────────────────────────
    // ecs_chunk_each visits only archetypes that carry vel_comp.
    // The Pos-only tile archetype is skipped entirely — no per-tile
    // alive check, no per-tile component test. Cost
    // O(N_MATCHING_ENTITIES), proportional to selectivity.
    _bench_sum = 0.0;
    t_arch_start = _stb_get_time_us();
    for (iter = 0; iter < ITERATIONS; iter++) {
        ecs_chunk_each(q_arch, vel_comp, fn_ptr(_arch_touch_vel));
    }
    t_arch_end = _stb_get_time_us();
    us_arch = t_arch_end - t_arch_start;

    // ── Report ──────────────────────────────────────────────────
    put("--- 10% selectivity (5K of 50K) ---\n");
    put("legacy sparse scan   : "); put(us_legacy); put(" us\n");
    put("archetype direct walk: "); put(us_arch);   put(" us\n");

    if (us_arch <= 0) {
        put("FAIL: archetype timing dropped to 0us (timer too coarse)\n");
        return 1;
    }

    ratio_x100 = us_legacy * 100 / us_arch;
    put("ratio x100: "); put(ratio_x100); put("\n");

    // Gate: at 10% selectivity (5K of 50K matching), archetype's
    // O(matching) walk should outperform legacy's O(total) scan by
    // at least 2.5x. Empirical calibration (2026-05-12) at this
    // scale lands ~2.85x; the legacy bitmap walk is unexpectedly
    // fast thanks to branch-predictor + L1 residency of the alive
    // and is_combatant bytes. Selectivity SCALING (ratio grows as
    // matching fraction shrinks) is the real claim — see the
    // 2%-selectivity follow-up below.
    if (ratio_x100 < 250) {
        put("FAIL: archetype selectivity win < 2.5x at 10% sparsity\n");
        return 1;
    }

    // ── Follow-up at deeper sparsity (2%) ───────────────────────
    // 1000 combatants of 50000 total — selectivity 2%. Legacy still
    // walks all 50K alive bits + is_combatant bits. Archetype walks
    // only 1000 rows. Ratio should widen vs the 10% case.
    auto w_sparser, sparser_q, tile_arch_2, combatant_arch_2;
    auto w_sparser_arch;
    auto sparser_is_combatant, j;
    auto pos_2, vel_2, hp_2, fac_2;
    auto tile_ids_2, combat_ids_2;
    auto n_sparse_combat, n_sparse_tile;
    n_sparse_combat = 1000;
    n_sparse_tile   = 49000;

    w_sparser = ecs_new(N_TOTAL);
    sparser_is_combatant = buf_byte(N_TOTAL);
    for (i = 0; i < N_TOTAL; i++) {
        ecs_spawn(w_sparser);
        if (i < n_sparse_combat) {
            poke(sparser_is_combatant + i, 1);
            ecs_set_vel(w_sparser, i, i, i);
        } else {
            poke(sparser_is_combatant + i, 0);
        }
    }

    w_sparser_arch = ecs_new(N_TOTAL);
    pos_2 = ecs_component_register(w_sparser_arch, 0, sizeof(Pos));
    vel_2 = ecs_component_register(w_sparser_arch, 0, sizeof(Vel));
    hp_2  = ecs_component_register(w_sparser_arch, 0, sizeof(Hp));
    fac_2 = ecs_component_register(w_sparser_arch, 0, sizeof(Faction));
    tile_ids_2 = buf_word(1);
    tile_ids_2[0] = pos_2;
    tile_arch_2 = ecs_archetype(w_sparser_arch, tile_ids_2, 1);
    combat_ids_2 = buf_word(4);
    combat_ids_2[0] = pos_2;
    combat_ids_2[1] = vel_2;
    combat_ids_2[2] = hp_2;
    combat_ids_2[3] = fac_2;
    combatant_arch_2 = ecs_archetype(w_sparser_arch, combat_ids_2, 4);
    for (j = 0; j < n_sparse_tile; j++) {
        ecs_spawn_at(w_sparser_arch, tile_arch_2);
    }
    for (j = 0; j < n_sparse_combat; j++) {
        auto cid_2;
        cid_2 = ecs_spawn_at(w_sparser_arch, combatant_arch_2);
        v = ecs_get(w_sparser_arch, vel_2, cid_2);
        v.dx = j;
        v.dy = j * 2.0;
    }
    sparser_q = ecs_query(w_sparser_arch, 1);

    auto wdl2: World, cap2;
    wdl2 = w_sparser;
    cap2 = ecs_capacity(w_sparser);

    auto us_leg_2, us_arch_2, ratio_2_x100;

    _bench_sum = 0.0;
    t_legacy_start = _stb_get_time_us();
    for (iter = 0; iter < ITERATIONS; iter++) {
        for (k = 0; k < cap2; k++) {
            if (peek(wdl2.alive + k)) {
                if (peek(sparser_is_combatant + k)) {
                    _bench_sum = _bench_sum + wdl2.vel_x[k];
                }
            }
        }
    }
    t_legacy_end = _stb_get_time_us();
    us_leg_2 = t_legacy_end - t_legacy_start;

    _bench_sum = 0.0;
    t_arch_start = _stb_get_time_us();
    for (iter = 0; iter < ITERATIONS; iter++) {
        ecs_chunk_each(sparser_q, vel_2, fn_ptr(_arch_touch_vel));
    }
    t_arch_end = _stb_get_time_us();
    us_arch_2 = t_arch_end - t_arch_start;

    put("\n--- 2% selectivity (1K of 50K) ---\n");
    put("legacy sparse scan   : "); put(us_leg_2);  put(" us\n");
    put("archetype direct walk: "); put(us_arch_2); put(" us\n");
    if (us_arch_2 > 0) {
        ratio_2_x100 = us_leg_2 * 100 / us_arch_2;
        put("ratio x100: "); put(ratio_2_x100); put("\n");
    }

    put("\nOK\n");
    return 0;
}
