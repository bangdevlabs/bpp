// test_realloc.bpp — Validates realloc as a B++ built-in (commit 9eca4de
// gave B++ its own bmem allocator). Confirms that data is preserved
// across grow and shrink, and that the returned pointer can be safely
// freed regardless of whether realloc moved it.

main() {
    auto p, p2, i, ok;

    // Initial allocation, fill with a recognisable pattern.
    p = malloc(64);
    for (i = 0; i < 64; i = i + 1) {
        poke(p + i, i);
    }

    // Grow: must preserve all 64 original bytes; new bytes are uninitialised.
    p2 = realloc(p, 256);
    if (p2 == 0) { return 10; }
    ok = 1;
    for (i = 0; i < 64; i = i + 1) {
        if (peek(p2 + i) != i) { ok = 0; }
    }
    if (ok == 0) { return 20; }

    // Write into the freshly grown region.
    for (i = 64; i < 256; i = i + 1) {
        poke(p2 + i, i & 0xFF);
    }

    // Shrink: must preserve the surviving prefix exactly.
    p = realloc(p2, 32);
    if (p == 0) { return 30; }
    ok = 1;
    for (i = 0; i < 32; i = i + 1) {
        if (peek(p + i) != i) { ok = 0; }
    }
    if (ok == 0) { return 40; }

    // realloc(0, n) behaves like malloc(n).
    p2 = realloc(0, 16);
    if (p2 == 0) { return 50; }
    poke(p2, 42);
    if (peek(p2) != 42) { return 51; }

    free(p);
    free(p2);

    return 0;
}
