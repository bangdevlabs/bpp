// test_io.bpp — Test stbio print/eprint functions.
import "stb/stbio.bsm";

main() {
    // Test print_str (no trailing newline).
    print_str("hello");
    putchar(' ');

    // Test print_int (already existed, sanity check).
    print_int(42);
    putchar(' ');

    // Test print_float.
    print_float(3.14);
    putchar(' ');

    // Test negative float.
    print_float(0.0 - 2.5);
    putchar(10);

    // Test eprint_msg (goes to stderr).
    eprint_msg("stderr_ok");

    // Test eprint_int.
    eprint_int(99);
    eprint_ln();

    return 0;
}
