// test_io.bpp — Smoke test for stbio.bsm.
// Exercises the current console I/O API: putmsg, putnum,
// putchar, putline. Output is consumed by the test runner — the
// exit code is what determines pass/fail, not the printed text.

import "bpp_io.bsm";

main() {
    // putmsg writes a null-terminated string with no trailing newline.
    putmsg("hello");
    putchar(' ');
    putmsg("world");
    putline();

    // putnum writes a signed decimal integer.
    putnum(42);
    putline();
    putnum(0);
    putline();
    putnum(0 - 1);
    putline();

    // putchar writes a single byte. Combined with putnum and
    // putmsg this covers the full stbio surface.
    putchar('A');
    putchar('B');
    putchar('C');
    putline();

    return 0;
}
