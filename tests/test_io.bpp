// test_io.bpp — Smoke test for stbio.bsm.
// Exercises the current console I/O API: print_msg, print_int,
// print_char, print_ln. Output is consumed by the test runner — the
// exit code is what determines pass/fail, not the printed text.

import "stbio.bsm";

main() {
    // print_msg writes a null-terminated string with no trailing newline.
    print_msg("hello");
    print_char(' ');
    print_msg("world");
    print_ln();

    // print_int writes a signed decimal integer.
    print_int(42);
    print_ln();
    print_int(0);
    print_ln();
    print_int(0 - 1);
    print_ln();

    // print_char writes a single byte. Combined with print_int and
    // print_msg this covers the full stbio surface.
    print_char('A');
    print_char('B');
    print_char('C');
    print_ln();

    return 0;
}
