// test_path.bpp — Smoke test for stbpath.bsm.
// Verifies the A* core: open grid, simple obstacle, U-shaped wall that
// forces detour, unreachable goal, and start == goal trivial case.
// Returns 0 on success or a unique non-zero code identifying the
// first failed assertion.

import "stbpath.bsm";
import "bpp_io.bsm";

main() {
    auto pf, out, count;

    // ── Test 1: empty grid, straight-line path ──────────────
    // 10x6 open grid, expect Manhattan distance + 1 waypoints
    // (3, 2) -> (7, 4) is dx=4, dy=2, so 6 steps + start = 7 waypoints.
    pf = path_new(10, 6);
    out = malloc(64 * 16);

    count = path_find(pf, 3, 2, 7, 4, out, 64);
    if (count != 7) {
        putmsg("FAIL t1: expected 7 waypoints, got ");
        putnum(count); putline();
        return 1;
    }
    if (out[0] != 3)         { putmsg("FAIL t1: start gx"); return 2; }
    if (out[1] != 2)         { putmsg("FAIL t1: start gy"); return 3; }
    if (out[(count - 1) * 2]     != 7) { putmsg("FAIL t1: goal gx"); return 4; }
    if (out[(count - 1) * 2 + 1] != 4) { putmsg("FAIL t1: goal gy"); return 5; }

    // ── Test 2: trivial case, start == goal ─────────────────
    count = path_find(pf, 5, 3, 5, 3, out, 64);
    if (count != 1) { putmsg("FAIL t2: trivial count"); return 6; }
    if (out[0] != 5) { putmsg("FAIL t2: trivial gx"); return 7; }
    if (out[1] != 3) { putmsg("FAIL t2: trivial gy"); return 8; }

    // ── Test 3: wall column with one gap forces detour ──────
    // Wall at x=4 from y=0..5 except y=2 is open. Path from (1,1) to
    // (8,4) must squeeze through the gap. Manhattan = 7+3 = 10 cells,
    // detour adds at least 2 extra y-steps (down to gap, up after).
    path_set_blocked(pf, 4, 0, 1);
    path_set_blocked(pf, 4, 1, 1);
    path_set_blocked(pf, 4, 3, 1);
    path_set_blocked(pf, 4, 4, 1);
    path_set_blocked(pf, 4, 5, 1);

    count = path_find(pf, 1, 1, 8, 4, out, 64);
    if (count < 11) {
        // optimal length = 7 dx + 3 dy + 2 detour overhead + 1 start = 13
        // but A* gives the exact optimal so >=11 is the safe lower bound.
        putmsg("FAIL t3: detour too short, got ");
        putnum(count); putline();
        return 9;
    }
    // Path must pass through the gap row at some point.
    auto i, found_gap;
    found_gap = 0;
    for (i = 0; i < count; i++) {
        if (out[i * 2] == 4) {
            if (out[i * 2 + 1] == 2) { found_gap = 1; }
        }
    }
    if (found_gap != 1) { putmsg("FAIL t3: did not pass through gap"); return 10; }

    // ── Test 4: unreachable goal returns 0 ──────────────────
    // Seal the gap. Now (1,1) to (8,4) is impossible.
    path_set_blocked(pf, 4, 2, 1);

    count = path_find(pf, 1, 1, 8, 4, out, 64);
    if (count != 0) { putmsg("FAIL t4: unreachable should return 0"); return 11; }

    // ── Test 5: blocked start or goal returns 0 ─────────────
    // (4,2) is now blocked. Asking for it as start or goal must fail.
    count = path_find(pf, 4, 2, 8, 4, out, 64);
    if (count != 0) { putmsg("FAIL t5: blocked start"); return 12; }

    count = path_find(pf, 1, 1, 4, 2, out, 64);
    if (count != 0) { putmsg("FAIL t5: blocked goal"); return 13; }

    // ── Test 6: out of bounds endpoints return 0 ────────────
    count = path_find(pf, 0 - 1, 1, 5, 3, out, 64);
    if (count != 0) { putmsg("FAIL t6: negative start"); return 14; }
    count = path_find(pf, 1, 1, 99, 3, out, 64);
    if (count != 0) { putmsg("FAIL t6: oob goal"); return 15; }

    // ── Test 7: re-query reuses scratch state cleanly ───────
    // Open up the gap again, run a fresh search, expect a valid path.
    path_set_blocked(pf, 4, 2, 0);
    count = path_find(pf, 0, 0, 9, 5, out, 64);
    if (count < 11) {
        putmsg("FAIL t7: reuse query, got ");
        putnum(count); putline();
        return 16;
    }
    if (out[0] != 0)               { putmsg("FAIL t7: start"); return 17; }
    if (out[1] != 0)               { putmsg("FAIL t7: start"); return 18; }
    if (out[(count - 1) * 2] != 9) { putmsg("FAIL t7: goal"); return 19; }
    if (out[(count - 1) * 2 + 1] != 5) { putmsg("FAIL t7: goal"); return 20; }

    // ── Test 8: path_find_near range=0, gw=gh=1 == path_find ──
    // A fresh open grid; near-search with range 0 must match path_find's
    // straight line (3,2)->(7,4) = 7 waypoints ending exactly on the goal.
    auto pf2, ex, ey, md, md2, rdx, rdy;
    pf2 = path_new(10, 6);
    count = path_find_near(pf2, 3, 2, 7, 4, 1, 1, 0, out, 64);
    if (count != 7)                         { putmsg("FAIL t8: near range0 count"); return 21; }
    if (out[(count - 1) * 2]     != 7)      { putmsg("FAIL t8: near range0 goal gx"); return 22; }
    if (out[(count - 1) * 2 + 1] != 4)      { putmsg("FAIL t8: near range0 goal gy"); return 23; }

    // ── Test 9: range=1 stops ADJACENT to the goal (one step early) ──
    count = path_find_near(pf2, 3, 2, 7, 4, 1, 1, 1, out, 64);
    if (count != 6)                         { putmsg("FAIL t9: near range1 count"); return 24; }
    ex = out[(count - 1) * 2]; ey = out[(count - 1) * 2 + 1];
    md  = ex - 7; if (md  < 0) { md  = 0 - md;  }
    md2 = ey - 4; if (md2 < 0) { md2 = 0 - md2; }
    if (md + md2 != 1)                      { putmsg("FAIL t9: end not adjacent"); return 25; }

    // ── Test 10: a BLOCKED goal is still reachable via range=1 ──
    // path_find rejects a blocked goal (returns 0); path_find_near routes to a
    // walkable cell adjacent to it. This is the building/resource case.
    path_set_blocked(pf2, 7, 4, 1);
    count = path_find(pf2, 3, 2, 7, 4, out, 64);
    if (count != 0)                         { putmsg("FAIL t10: path_find blocked goal"); return 26; }
    count = path_find_near(pf2, 3, 2, 7, 4, 1, 1, 1, out, 64);
    if (count < 1)                          { putmsg("FAIL t10: near blocked goal"); return 27; }
    ex = out[(count - 1) * 2]; ey = out[(count - 1) * 2 + 1];
    md  = ex - 7; if (md  < 0) { md  = 0 - md;  }
    md2 = ey - 4; if (md2 < 0) { md2 = 0 - md2; }
    if (md + md2 != 1)                      { putmsg("FAIL t10: end not adjacent to blocked goal"); return 28; }

    // ── Test 11: rect goal (2x2 footprint, all blocked), range=1 ──
    // Footprint (6,3)-(7,4) entirely blocked; the search must stop within 1
    // Manhattan tile of the rect from a far start.
    path_set_blocked(pf2, 6, 3, 1);
    path_set_blocked(pf2, 7, 3, 1);
    path_set_blocked(pf2, 6, 4, 1);   // (7,4) already blocked in t10
    count = path_find_near(pf2, 1, 1, 6, 3, 2, 2, 1, out, 64);
    if (count < 1)                          { putmsg("FAIL t11: rect near empty"); return 29; }
    ex = out[(count - 1) * 2]; ey = out[(count - 1) * 2 + 1];
    rdx = 0; if (ex < 6) { rdx = 6 - ex; } else if (ex > 7) { rdx = ex - 7; }
    rdy = 0; if (ey < 3) { rdy = 3 - ey; } else if (ey > 4) { rdy = ey - 4; }
    if (rdx + rdy > 1)                      { putmsg("FAIL t11: end not within range 1 of rect"); return 30; }
    path_free(pf2);

    free(out);
    path_free(pf);

    putmsg("test_path: all PASS");
    putline();
    return 0;
}
