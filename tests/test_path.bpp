// test_path.bpp — Smoke test for stbpath.bsm.
// Verifies the A* core: open grid, simple obstacle, U-shaped wall that
// forces detour, unreachable goal, and start == goal trivial case.
// Returns 0 on success or a unique non-zero code identifying the
// first failed assertion.

import "stbpath.bsm";
import "stbio.bsm";

main() {
    auto pf, out, count;

    // ── Test 1: empty grid, straight-line path ──────────────
    // 10x6 open grid, expect Manhattan distance + 1 waypoints
    // (3, 2) -> (7, 4) is dx=4, dy=2, so 6 steps + start = 7 waypoints.
    pf = path_new(10, 6);
    out = malloc(64 * 16);

    count = path_find(pf, 3, 2, 7, 4, out, 64);
    if (count != 7) {
        print_msg("FAIL t1: expected 7 waypoints, got ");
        print_int(count); print_ln();
        return 1;
    }
    if (out[0] != 3)         { print_msg("FAIL t1: start gx"); return 2; }
    if (out[1] != 2)         { print_msg("FAIL t1: start gy"); return 3; }
    if (out[(count - 1) * 2]     != 7) { print_msg("FAIL t1: goal gx"); return 4; }
    if (out[(count - 1) * 2 + 1] != 4) { print_msg("FAIL t1: goal gy"); return 5; }

    // ── Test 2: trivial case, start == goal ─────────────────
    count = path_find(pf, 5, 3, 5, 3, out, 64);
    if (count != 1) { print_msg("FAIL t2: trivial count"); return 6; }
    if (out[0] != 5) { print_msg("FAIL t2: trivial gx"); return 7; }
    if (out[1] != 3) { print_msg("FAIL t2: trivial gy"); return 8; }

    // ── Test 3: wall column with one gap forces detour ──────
    // Wall at x=4 from y=0..5 except y=2 is open. Path from (1,1) to
    // (8,4) must squeeze through the gap. Manhattan = 7+3 = 10 cells,
    // detour adds at least 2 extra y-steps (down to gap, up after).
    path_set_blocked(pf, 4, 0, 1);
    path_set_blocked(pf, 4, 1, 1);
    path_set_blocked(pf, 4, 3, 1);
    path_set_blocked(pf, 4, 4, 1);
    path_set_blocked(pf, 4, 5, 1);

    count = path_find(pf, 1, 1, 8, 4, out, 64);
    if (count < 11) {
        // optimal length = 7 dx + 3 dy + 2 detour overhead + 1 start = 13
        // but A* gives the exact optimal so >=11 is the safe lower bound.
        print_msg("FAIL t3: detour too short, got ");
        print_int(count); print_ln();
        return 9;
    }
    // Path must pass through the gap row at some point.
    auto i, found_gap;
    found_gap = 0;
    for (i = 0; i < count; i = i + 1) {
        if (out[i * 2] == 4) {
            if (out[i * 2 + 1] == 2) { found_gap = 1; }
        }
    }
    if (found_gap != 1) { print_msg("FAIL t3: did not pass through gap"); return 10; }

    // ── Test 4: unreachable goal returns 0 ──────────────────
    // Seal the gap. Now (1,1) to (8,4) is impossible.
    path_set_blocked(pf, 4, 2, 1);

    count = path_find(pf, 1, 1, 8, 4, out, 64);
    if (count != 0) { print_msg("FAIL t4: unreachable should return 0"); return 11; }

    // ── Test 5: blocked start or goal returns 0 ─────────────
    // (4,2) is now blocked. Asking for it as start or goal must fail.
    count = path_find(pf, 4, 2, 8, 4, out, 64);
    if (count != 0) { print_msg("FAIL t5: blocked start"); return 12; }

    count = path_find(pf, 1, 1, 4, 2, out, 64);
    if (count != 0) { print_msg("FAIL t5: blocked goal"); return 13; }

    // ── Test 6: out of bounds endpoints return 0 ────────────
    count = path_find(pf, 0 - 1, 1, 5, 3, out, 64);
    if (count != 0) { print_msg("FAIL t6: negative start"); return 14; }
    count = path_find(pf, 1, 1, 99, 3, out, 64);
    if (count != 0) { print_msg("FAIL t6: oob goal"); return 15; }

    // ── Test 7: re-query reuses scratch state cleanly ───────
    // Open up the gap again, run a fresh search, expect a valid path.
    path_set_blocked(pf, 4, 2, 0);
    count = path_find(pf, 0, 0, 9, 5, out, 64);
    if (count < 11) {
        print_msg("FAIL t7: reuse query, got ");
        print_int(count); print_ln();
        return 16;
    }
    if (out[0] != 0)               { print_msg("FAIL t7: start"); return 17; }
    if (out[1] != 0)               { print_msg("FAIL t7: start"); return 18; }
    if (out[(count - 1) * 2] != 9) { print_msg("FAIL t7: goal"); return 19; }
    if (out[(count - 1) * 2 + 1] != 5) { print_msg("FAIL t7: goal"); return 20; }

    free(out);
    path_free(pf);

    print_msg("test_path: all PASS");
    print_ln();
    return 0;
}
