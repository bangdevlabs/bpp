// test_bpp_bench.bpp — smoke test for bench helpers.
//
// Exercises bench_begin / bench_end / bench_section. Doesn't
// assert timing precision (test environment varies wildly) —
// just that elapsed > 0 after a known-bounded compute, that
// bench_section returns the elapsed value, and that the print
// sites don't crash.

main() {
    auto t0, elapsed, sum, i;

    t0 = bench_begin();

    // Known-bounded compute: sum 1..100000. Fast enough the
    // test stays green on slow CI, slow enough that elapsed
    // is definitively positive.
    sum = 0;
    for (i = 1; i <= 100000; i = i + 1) {
        sum = sum + i;
    }

    elapsed = bench_section("sum_1_to_100k", t0);

    if (elapsed < 0) {
        putstr_err("FAIL: negative elapsed\n");
        return 1;
    }
    if (elapsed == 0) {
        // Conceivable on a very fast machine with low-resolution
        // clock, but still worth flagging — a 100k-iter loop
        // should measure above the noise floor on every real
        // target.
        putstr_err("FAIL: elapsed == 0 (timer resolution?)\n");
        return 1;
    }
    if (sum != 5000050000) {
        putstr_err("FAIL: math wrong\n");
        return 1;
    }

    // bench_end variant — no return value to check; just ensure
    // it doesn't crash.
    t0 = bench_begin();
    for (i = 0; i < 1000; i = i + 1) { }
    bench_end("empty_1k", t0);

    putmsg("bpp_bench: begin/end/section passed\n");
    return 0;
}
