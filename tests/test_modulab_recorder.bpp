// test_modulab_recorder.bpp — record → replay determinism check.
//
// Record a fixed input sequence for 10 frames, replay it, assert
// the replayed position matches the recorded snapshot at the
// checkpoint boundary. Verifies two contracts:
//   (1) Recorder captures inputs + snapshots cleanly.
//   (2) During playback the testbed reads inputs from the
//       recorder, not from the OS keyboard.

import "stbgame.bsm";
import "stbforge.bsm";
load "../tools/modulab/core.bsm";

main() {
    auto cp, c: Character, i;
    auto recorded_pos_x;

    init_str();
    init_input();
    state_init(16);
    recorder_init();

    cp = character_new();
    c  = cp;
    c.hit_x = 0; c.hit_y = 0; c.hit_w = 1; c.hit_h = 1;
    c.pivot_x = 0; c.pivot_y = 0;
    c.ctrl_left = KEY_LEFT; c.ctrl_right = KEY_RIGHT; c.ctrl_jump = KEY_SPACE;

    testbed_init(cp);

    // Let the character settle to the ground first.
    for (i = 0; i < 20; i = i + 1) { testbed_update(16); }

    // Start recording, press RIGHT for 10 frames.
    recorder_start();
    poke(_stb_keys + KEY_RIGHT, 1);
    for (i = 0; i < 10; i = i + 1) {
        testbed_update(16);
    }
    recorded_pos_x = tb_pos_mx();
    recorder_stop();

    if (recorder_len() != 10) {
        putmsg("FAIL: expected 10 recorded frames, got ");
        putnum(recorder_len()); putline();
        return 1;
    }

    // Reset physics + clear the keyboard, then replay — no live
    // keys should influence the outcome.
    testbed_reset();
    poke(_stb_keys + KEY_RIGHT, 0);

    recorder_play();
    for (i = 0; i < 10; i = i + 1) { testbed_update(16); }

    if (tb_pos_mx() != recorded_pos_x) {
        putmsg("FAIL: replay did not reproduce recorded position: ");
        putnum(tb_pos_mx()); putmsg(" vs ");
        putnum(recorded_pos_x); putline();
        return 1;
    }

    recorder_free();
    testbed_free();
    character_free(cp);
    state_free();
    putmsg("OK");
    return 0;
}
