// Test all three game infrastructure modules together.

import "stbarena.bsm";
import "stbpool.bsm";
import "stbecs.bsm";

check(name, ok) {
    auto i;
    if (ok) {
        putchar('O'); putchar('K'); putchar(' ');
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar(' ');
    }
    i = 0;
    while (str_peek(name, i) != 0) {
        putchar(str_peek(name, i));
        i = i + 1;
    }
    putchar(10);
    return ok;
}

main() {
    auto pass;
    pass = 1;

    // --- Arena ---
    auto arena, ap1, ap2;
    arena = arena_new(4096);
    ap1 = arena_alloc(arena, 64);
    ap2 = arena_alloc(arena, 64);
    pass = check("arena: two allocs", ap1 != 0) * pass;
    pass = check("arena: overflow", arena_alloc(arena, 8000) == 0) * pass;
    arena_reset(arena);
    pass = check("arena: recycle", arena_alloc(arena, 64) == ap1) * pass;
    arena_free(arena);

    // --- Pool ---
    auto pool, pb1, pb2;
    pool = pool_new(32, 8);
    pb1 = pool_get(pool);
    pb2 = pool_get(pool);
    pool_put(pool, pb1);
    pass = check("pool: recycle", pool_get(pool) == pb1) * pass;
    pass = check("pool: count", pool_count(pool) == 2) * pass;
    pool_free(pool);

    // --- ECS ---
    auto w, ea, eb;
    w = ecs_new(50);
    ea = ecs_spawn(w);
    eb = ecs_spawn(w);
    ecs_set_pos(w, ea, 10000, 20000);
    ecs_set_vel(w, ea, 4000, 2000);
    ecs_physics(w, 500);
    pass = check("ecs: physics x", ecs_get_x(w, ea) == 12000) * pass;
    pass = check("ecs: physics y", ecs_get_y(w, ea) == 21000) * pass;
    ecs_kill(w, eb);
    pass = check("ecs: kill+recycle", ecs_spawn(w) == eb) * pass;

    // Final.
    putchar(10);
    if (pass) {
        putchar('A'); putchar('L'); putchar('L'); putchar(' ');
        putchar('O'); putchar('K'); putchar(10);
    } else {
        putchar('F'); putchar('A'); putchar('I'); putchar('L'); putchar('E'); putchar('D'); putchar(10);
    }
    return 0;
}
