import "defs.bsm";
import "bpp_internal.bsm";
import "bpp_import.bsm";
import "bpp_parser.bsm";
import "bpp_lexer.bsm";

main() {
    auto p;
    init_defs();
    init_internal();
    init_import();

    // Check if pathbuf is set
    if (pathbuf == 0) {
        putchar('Z');
    } else {
        putchar('O');
    }

    // Check raw malloc
    p = malloc(64);
    if (p == 0) {
        putchar('Z');
    } else {
        putchar('O');
        poke(p, 65);
        putchar(peek(p));
    }
    putchar('\n');
    return 0;
}
