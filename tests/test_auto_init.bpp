// test_auto_init.bpp — Verify stdlib auto-initializes on first use.
//
// Before this test existed, every program that used sb_* or arr_*
// had to explicitly call init_str() / init_array() first. Skipping
// the call produced silent heap corruption (malloc(0), aliased
// addresses). Fixed by lazy init inside sb_new / arr_new.
//
// This test deliberately does NOT call init_str() or init_array().
// If the fix regresses, sb_new or arr_new will malloc a zero-sized
// region and the test either returns garbage or crashes.

main() {
    // Exercise the sb_* path without manual init.
    auto msg;
    msg = sb_new();
    msg = sb_cat(msg, "hello");
    msg = sb_ch(msg, ' ');
    msg = sb_int(msg, 42);
    if (sb_len(msg) != 8) {
        print_msg("FAIL: sb builder produced wrong length");
        return 1;
    }
    if (str_eq(msg, "hello 42") != 1) {
        print_msg("FAIL: sb builder produced wrong content");
        return 1;
    }
    msg = sb_free(msg);

    // Exercise the arr_* path without manual init.
    auto nums;
    nums = arr_new();
    nums = arr_push(nums, 10);
    nums = arr_push(nums, 20);
    nums = arr_push(nums, 30);
    if (arr_len(nums) != 3) {
        print_msg("FAIL: arr produced wrong length");
        return 1;
    }
    if (arr_get(nums, 0) != 10) {
        print_msg("FAIL: arr_get[0] wrong");
        return 1;
    }
    if (arr_get(nums, 2) != 30) {
        print_msg("FAIL: arr_get[2] wrong");
        return 1;
    }
    nums = arr_free(nums);

    print_msg("test_auto_init: OK");
    return 0;
}
