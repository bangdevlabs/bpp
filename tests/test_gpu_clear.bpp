// Test: GPU clear with interactive color switching.
// Press 1-6 to change the clear color. ESC to quit.

import "stbgame.bsm";
import "stbrender.bsm";

main() {
    auto color;
    game_init(320, 180, "GPU Clear Test (1-6 colors, ESC quit)", 60);
    render_init();

    color = BLUE;

    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }

        if (key_pressed(KEY_1)) { color = RED; }
        if (key_pressed(KEY_2)) { color = GREEN; }
        if (key_pressed(KEY_3)) { color = BLUE; }
        if (key_pressed(KEY_4)) { color = YELLOW; }
        if (key_pressed(KEY_5)) { color = PURPLE; }
        if (key_pressed(KEY_6)) { color = WHITE; }

        render_begin();
        render_clear(color);
        render_end();
    }
    game_end();
    return 0;
}
