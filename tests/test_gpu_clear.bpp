// test_gpu_clear.bpp — GPU clear with interactive color switching.
// Manual mode: press 1-6 to change the clear color, ESC to quit.
//
// Batch mode (run_all.sh): exits after `TEST_FRAMES` frames via an
// explicit `sys_exit(0)`. Relying on `game_should_quit` + the
// runner's SIGKILL flaked because Cocoa's window-visibility check
// races with focus acquisition; an explicit exit dodges the race.

import "stbgame.bsm";
import "stbrender.bsm";

const TEST_FRAMES = 30;

main() {
    auto color, frame;

    game_init(320, 180, "GPU Clear Test (1-6 colors, ESC quit)", 60);
    render_init();

    color = BLUE;

    for (frame = 0; frame < TEST_FRAMES; frame++) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { frame = TEST_FRAMES; }

        if (key_pressed(KEY_1)) { color = RED; }
        if (key_pressed(KEY_2)) { color = GREEN; }
        if (key_pressed(KEY_3)) { color = BLUE; }
        if (key_pressed(KEY_4)) { color = YELLOW; }
        if (key_pressed(KEY_5)) { color = PURPLE; }
        if (key_pressed(KEY_6)) { color = WHITE; }

        render_begin();
        render_clear(color);
        render_end();
        if (game_should_quit() != 0) { frame = TEST_FRAMES; }
    }

    sys_exit(0);
    return 0;
}
