// test_beat_map.bpp — parse games/rhythm/assets/beat_map.txt and
// assert the expected first few notes + metadata.

import "stbgame.bsm";
load "../games/rhythm/beat_map.bsm";

main() {
    auto map, n: BeatNote;

    map = beat_map_load("games/rhythm/assets/beat_map.txt");
    if (map == 0) {
        putmsg("FAIL: beat_map_load returned 0");
        return 1;
    }

    // BPM 120 from the file header.
    if (beat_map_bpm(map) != 120) {
        putmsg("FAIL: bpm should be 120");
        return 1;
    }

    // The current rock-groove map declares 49 notes across 4 bars.
    // If the chart is rewritten, update this number to match.
    if (beat_map_count(map) != 49) {
        putmsg("FAIL: expected 49 notes");
        putnum(beat_map_count(map));
        putline();
        return 1;
    }

    // First note: 1.0 seconds + 0.5 offset = 1500 ms, lane 1 (kick), tap.
    n = beat_map_note(map, 0);
    if (n.beat_ms != 1500) {
        putmsg("FAIL: note[0].beat_ms should be 1500");
        putnum(n.beat_ms);
        putline();
        return 1;
    }
    if (n.lane != 1) {
        putmsg("FAIL: note[0].lane should be 1 (kick)");
        return 1;
    }
    if (n.type != 0) {
        putmsg("FAIL: note[0].type should be 0 (tap)");
        return 1;
    }

    // Second note: same beat_ms 1500 (hihat layered on kick), lane 0.
    n = beat_map_note(map, 1);
    if (n.beat_ms != 1500) {
        putmsg("FAIL: note[1].beat_ms should be 1500 (layered)");
        return 1;
    }
    if (n.lane != 0) {
        putmsg("FAIL: note[1].lane should be 0 (hihat layered)");
        return 1;
    }

    beat_map_free(map);
    putmsg("beat_map: parse + 49 notes + layered first-beat kick+hihat decoded correctly");
    return 0;
}
