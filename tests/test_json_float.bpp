// test_json_float.bpp — regression test for JSON float parsing.
//
// `_json_parse_number` originally consumed fractional and exponent
// digits without computing them, so `0.6` parsed with payload 0
// (only the integer part survived). This test pins the fix: every
// float shape — simple decimals, negatives, integer-style `.0`,
// many fractional digits, tiny fractions, positive and negative
// scientific notation — must round-trip through `json_parse` and
// come back through `json_float` with the same value.
//
// Integer parsing must keep working unchanged — the last few cases
// guard against a regression where the float fix breaks pure-int
// values.

import "bpp_json.bsm";
import "bpp_str.bsm";
import "bpp_io.bsm";

// Compare two float values within a 1e-9 relative tolerance, with a
// 1e-9 absolute floor for values near zero. 1e-9 sits comfortably
// below the precision the JSON parser must deliver for game-tuning
// values (sliders rarely express more than 4 significant digits) but
// well above the float-arithmetic noise floor — anything that drifts
// more than this signals a real algorithmic bug, not rounding. The
// tolerance literal lives inline rather than as a `const` because B++
// `const` declarations do not preserve float bit patterns (the value
// would be demoted to int zero at constant definition time).
static check_close(label, got: float, expected: float) {
    auto diff: float, tol: float, abs_exp: float;
    auto tol_floor: float;
    tol_floor = 0.000000001;
    diff = got - expected;
    if (diff < 0.0) { diff = 0.0 - diff; }
    abs_exp = expected;
    if (abs_exp < 0.0) { abs_exp = 0.0 - abs_exp; }
    tol = abs_exp * tol_floor;
    if (tol < tol_floor) { tol = tol_floor; }
    if (diff > tol) {
        putmsg("FAIL: ");
        putmsg(label);
        putline();
        return 1;
    }
    return 0;
}

static check_int(label, got, expected) {
    if (got != expected) {
        putmsg("FAIL: ");
        putmsg(label);
        putmsg(" got=");
        putnum(got);
        putmsg(" expected=");
        putnum(expected);
        putline();
        return 1;
    }
    return 0;
}

// Parse a single-value JSON document and recover its float through
// json_float. Returns the parsed value; on parse failure prints
// the source and returns 0.0 (test then fails on value mismatch).
static parse_float_doc(src) {
    auto doc, root, val: float;
    doc = json_parse(src, str_len(src));
    if (doc == 0) {
        putmsg("FAIL: json_parse returned 0 for ");
        putmsg(src);
        putline();
        return 0.0;
    }
    root = json_root(doc);
    val = json_float(doc, root);
    json_free(doc);
    return val;
}

static parse_int_doc(src) {
    auto doc, root, val;
    doc = json_parse(src, str_len(src));
    if (doc == 0) {
        putmsg("FAIL: json_parse returned 0 for ");
        putmsg(src);
        putline();
        return 0;
    }
    root = json_root(doc);
    val = json_int(doc, root);
    json_free(doc);
    return val;
}

// Run one float check, isolating the parse return through an
// annotated `: float` local. Without the intermediate annotation
// the float bit pattern would be silently demoted to int across
// the function-call argument boundary (Tonify Rule 12).
static run_float_case(label, src, expected: float) {
    auto got: float;
    got = parse_float_doc(src);
    return check_close(label, got, expected);
}

main() {
    auto fails;
    init_str();
    fails = 0;

    // Simple positive decimal. The original case that surfaced the bug.
    fails = fails + run_float_case("0.6",       "0.6",       0.6);

    // Negative decimal. Sign handling on the float path.
    fails = fails + run_float_case("-0.5",      "-0.5",      -0.5);

    // Integer-style with explicit `.0`. Tags as JSON_FLOAT but value
    // equals its integer counterpart — useful sanity.
    fails = fails + run_float_case("1.0",       "1.0",       1.0);

    // Multi-digit integer + multi-digit fraction.
    fails = fails + run_float_case("12.345",    "12.345",    12.345);

    // Tiny fraction. Stresses the per-digit scale accumulation.
    fails = fails + run_float_case("0.001",     "0.001",     0.001);

    // Scientific notation, positive exponent.
    fails = fails + run_float_case("1.5e3",     "1.5e3",     1500.0);

    // Scientific notation, negative exponent.
    fails = fails + run_float_case("2.0e-5",    "2.0e-5",    0.00002);

    // Scientific notation without fractional part.
    fails = fails + run_float_case("1e10",      "1e10",      10000000000.0);

    // Integer regression — pure ints must keep parsing as before
    // (json_int path, no float math).
    fails = fails + check_int("0",           parse_int_doc("0"),           0);
    fails = fails + check_int("42",          parse_int_doc("42"),          42);
    fails = fails + check_int("-42",         parse_int_doc("-42"),         -42);

    if (fails == 0) {
        putmsg("OK test_json_float");
        return 0;
    }
    putmsg("FAIL test_json_float");
    return 1;
}
