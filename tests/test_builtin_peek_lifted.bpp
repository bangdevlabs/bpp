// test_builtin_peek_lifted.bpp — regression guard for Wave 18 peek lift.
//
// peek dispatch moved from 3 chip-local ladders into
// cg_builtin_dispatch in bpp_codegen.bsm. This test exercises the
// hot path (sequential byte access) plus high-bit patterns plus the
// float-coerce primitive path to catch regressions in any of the
// three primitives (emit_node, emit_mem_read, emit_coerce_float_to_int).

main() {
    auto buf, i;
    buf = malloc(16);

    // 8-byte sweep — real hot path: sequential write then sequential read.
    for (i = 0; i < 8; i = i + 1) { poke(buf + i, i); }
    for (i = 0; i < 8; i = i + 1) {
        if (peek(buf + i) != i) {
            putmsg("FAIL: sweep readback mismatch");
            return 1;
        }
    }

    // High-bit byte patterns (forces the compiler to preserve unsigned
    // semantics; a sign-extending load would return negative).
    poke(buf + 8, 0x5A);
    poke(buf + 9, 0xA5);
    if (peek(buf + 8) != 0x5A) {
        putmsg("FAIL: 0x5A pattern");
        return 1;
    }
    if (peek(buf + 9) != 0xA5) {
        putmsg("FAIL: 0xA5 pattern (would be negative if sign-extended)");
        return 1;
    }

    // Float-coerced address test — emit_coerce_float_to_int primitive
    // path. B++ type inference auto-promotes on mixed arithmetic;
    // passing a float expression to peek exercises the coerce
    // primitive before the mem_read.
    auto fbuf: float;
    fbuf = buf + 0.0;
    if (peek(fbuf) != 0) {
        putmsg("FAIL: float-coerced peek returned wrong value");
        return 1;
    }

    free(buf);
    putmsg("test_builtin_peek_lifted: OK");
    return 0;
}
