// test_anim_frame.bpp — anim_frame arithmetic.
// GPU-side frame sampling is exercised by games; the math helper
// can be tested headless.

import "stbgame.bsm";

main() {
    // 8 fps, 4-frame loop
    if (anim_frame(0,    8, 4, 1) != 0) { putmsg("FAIL: t=0 idle=0"); return 1; }
    if (anim_frame(125,  8, 4, 1) != 1) { putmsg("FAIL: t=125 idle=1"); return 1; }
    if (anim_frame(250,  8, 4, 1) != 2) { putmsg("FAIL: t=250 idle=2"); return 1; }
    if (anim_frame(375,  8, 4, 1) != 3) { putmsg("FAIL: t=375 idle=3"); return 1; }
    // Loop wraps at frame_count.
    if (anim_frame(500,  8, 4, 1) != 0) { putmsg("FAIL: t=500 loop wrap=0"); return 1; }

    // Non-looping: holds last frame.
    if (anim_frame(500,  8, 4, 0) != 3) { putmsg("FAIL: t=500 hold=3"); return 1; }
    if (anim_frame(9999, 8, 4, 0) != 3) { putmsg("FAIL: t=inf hold=3"); return 1; }

    // Single-frame animation is always 0.
    if (anim_frame(1234, 8, 1, 1) != 0) { putmsg("FAIL: 1-frame loop=0"); return 1; }

    putmsg("stbsprite: anim_frame passed");
    return 0;
}
