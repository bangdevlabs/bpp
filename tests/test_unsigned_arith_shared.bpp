// `: u_word` annotation does NOT change the bit pattern emitted
// for +, -, *, &, |, ^, <<, ==, != — these are bit-identical
// in two's-complement regardless of signedness. Verify that
// annotated and unannotated paths produce the same bytes for
// every "shared" operator.

main() {
    auto signed_a, signed_b;
    signed_a = 0xDEADBEEFCAFEBABE;
    signed_b = 7;

    auto u_a: u_word, u_b: u_word;
    u_a = 0xDEADBEEFCAFEBABE;
    u_b = 7;

    if ((signed_a + signed_b) != (u_a + u_b)) { return 1; }
    if ((signed_a - signed_b) != (u_a - u_b)) { return 2; }
    if ((signed_a * signed_b) != (u_a * u_b)) { return 3; }
    if ((signed_a & signed_b) != (u_a & u_b)) { return 4; }
    if ((signed_a | signed_b) != (u_a | u_b)) { return 5; }
    if ((signed_a ^ signed_b) != (u_a ^ u_b)) { return 6; }
    if ((signed_a << signed_b) != (u_a << u_b)) { return 7; }
    return 0;
}
