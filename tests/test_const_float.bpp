// test_const_float.bpp — Excalibur Arc Feature 1 gap B closure.
//
// Pins that `const NAME = 0.6;` preserves the float bits all the way
// to the use site. Pre-fix, the const machinery silently truncated
// the fractional part to integer 0, leading to the bug class
// described in `feedback_const_float_demotes.md` (e.g. `const TOL =
// 1e-9; if (diff > TOL)` always-true because TOL was 0).
//
// What this test pins:
//   - Float consts emit through the SHAPE_DECIMAL path, not through
//     `make_int_lit(0)`.
//   - Round-trip arithmetic confirms IEEE bits survive: `tol * 10000`
//     equals `1.0` if and only if tol is genuinely `0.0001` (not 0).
//   - Float consts compose with float locals at comparison sites
//     (the killer use case from the feedback memory).
//   - Plain integer consts are unchanged: `const N = 42` still
//     resolves to integer 42.

const TOL    = 0.0001;     // typical numerical-tolerance const
const PI     = 3.14159;    // typical math const
const SPEED  = 0.5;        // typical game tunable
const COUNT  = 42;         // integer const — must NOT be broken
// Note: const expressions like `0.0 - 0.5` still go through the
// integer-only `const_eval_node` path. The gap B fast path covers
// the killer use case (single literal RHS); float-const arithmetic
// would need a separate float interpreter.

void check(label, got: float, want: float) {
    auto diff: float;
    diff = got - want;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff > 0.0001) {
        putstr("FAIL "); putstr(label);
        putstr(" got=");  putfloat(got);
        putstr(" want="); putfloat(want);
        putline();
        sys_exit(1);
    }
}

main() {
    auto x: float;

    // Bit-preservation via round-trip arithmetic. tol * 10000 == 1.0
    // only if tol carries the actual fractional bits.
    x = TOL * 10000.0;
    check("tol_roundtrip", x, 1.0);

    // PI math sanity.
    x = PI * 2.0;
    check("pi_doubled", x, 6.28318);

    // Speed comparison — the canonical "game character freezes
    // because const SPEED = 0.5 was actually 0" bug. After the fix
    // SPEED > 0.0 evaluates to true.
    x = SPEED;
    if (x <= 0.0) {
        putstr("FAIL: SPEED is not positive\n");
        sys_exit(1);
    }
    check("speed", SPEED, 0.5);

    // Integer const path still works.
    if (COUNT != 42) {
        putstr("FAIL: COUNT broke\n");
        sys_exit(1);
    }

    putstr("OK\n");
    return 0;
}
