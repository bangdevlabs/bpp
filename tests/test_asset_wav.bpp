// test_asset_wav.bpp — stbasset sound loader + dedup + unload cycle.
//
// Uses a real WAV on disk (snake_shot.wav recorded by mini_synth)
// to verify the full load → get → unload pipeline.

import "stbgame.bsm";
import "stbasset.bsm";

main() {
    auto h1, h2, buf, path;
    init_asset();

    path = "tools/audio/mini_synth/records/snake_shot.wav";

    // (1) Load succeeds; handle is non-zero.
    h1 = asset_load_sound(path);
    if (h1 == 0) {
        print_msg("FAIL: asset_load_sound returned 0");
        return 1;
    }

    // (2) asset_get returns a real pointer.
    buf = asset_get(h1);
    if (buf == 0) {
        print_msg("FAIL: asset_get returned 0 on fresh handle");
        return 1;
    }

    // (3) asset_width returns frame count > 0.
    if (asset_width(h1) == 0) {
        print_msg("FAIL: asset_width should be > 0 for a loaded WAV");
        return 1;
    }

    // (4) asset_kind identifies it as a sound.
    if (asset_kind(h1) != ASSET_SOUND) {
        print_msg("FAIL: asset_kind should be ASSET_SOUND");
        return 1;
    }

    // (5) Dedup: loading the same path again returns the same handle.
    h2 = asset_load_sound(path);
    if (h2 != h1) {
        print_msg("FAIL: dedup broken — same path gave different handles");
        return 1;
    }

    // (6) asset_count is 1 (dedup kept it at one).
    if (asset_count() != 1) {
        print_msg("FAIL: asset_count should be 1 after dedup");
        return 1;
    }

    // (7) Unload invalidates the handle.
    asset_unload(h1);
    if (asset_get(h1) != 0) {
        print_msg("FAIL: asset_get after unload should be 0 (stale)");
        return 1;
    }

    // (8) asset_count drops to 0.
    if (asset_count() != 0) {
        print_msg("FAIL: asset_count should be 0 after unload");
        return 1;
    }

    // (9) Reloading after unload yields a fresh handle (new generation,
    // different from h1 because generation bumped).
    h2 = asset_load_sound(path);
    if (h2 == 0) {
        print_msg("FAIL: reload after unload returned 0");
        return 1;
    }
    if (h2 == h1) {
        print_msg("FAIL: reloaded handle should differ (generation bumped)");
        return 1;
    }

    print_msg("stbasset: WAV load + dedup + unload + reload passed");
    return 0;
}
