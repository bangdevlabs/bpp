// test_stbinput_actions.bpp — action table lookup, bindings, and
// modifier gating. Uses direct _stb_keys pokes to simulate key
// state without the platform event pump.

import "stbgame.bsm";

main() {
    init_str();
    init_input();

    // Two bindings with different modifier masks.
    action_define("paint", KEY_B, 0);
    action_define("save",  KEY_S, ACTION_MOD_CTRL);

    if (action_count() != 2) {
        print_msg("FAIL: action_count != 2");
        print_int(action_count()); print_ln();
        return 1;
    }

    // Simulate: press B (no modifier). paint should fire.
    poke(_stb_keys + KEY_B, 1);
    // No prev key state — this counts as press-edge.
    if (action_pressed("paint") == 0) {
        print_msg("FAIL: paint not detected after press");
        return 1;
    }
    if (action_down("paint") == 0) {
        print_msg("FAIL: paint not held");
        return 1;
    }
    if (action_pressed("save") != 0) {
        print_msg("FAIL: save fired without Ctrl + S");
        return 1;
    }

    // Move to next frame — copy current state to prev so the
    // press edge doesn't fire again.
    _input_save_prev();
    if (action_pressed("paint") != 0) {
        print_msg("FAIL: paint edge-fired on second frame");
        return 1;
    }

    // Press Ctrl + S. save should fire; paint should not.
    poke(_stb_keys + KEY_B, 0);
    poke(_stb_keys + KEY_S, 1);
    poke(_stb_keys + KEY_CTRL, 1);
    if (action_pressed("save") == 0) {
        print_msg("FAIL: save not detected after Ctrl+S press");
        return 1;
    }

    // Release CTRL — save no longer matches.
    poke(_stb_keys + KEY_CTRL, 0);
    _input_save_prev();
    poke(_stb_keys + KEY_S, 1);
    if (action_pressed("save") != 0) {
        print_msg("FAIL: save fired without Ctrl held");
        return 1;
    }

    // Unknown name — lookup miss returns 0.
    if (action_pressed("nonesuch") != 0) {
        print_msg("FAIL: unknown action returned non-zero");
        return 1;
    }

    // Rebind paint to a different key and assert the new key
    // triggers while the old one does not.
    action_rebind("paint", KEY_F, 0);
    poke(_stb_keys + KEY_B, 1);
    poke(_stb_keys + KEY_F, 0);
    _input_save_prev();
    poke(_stb_keys + KEY_B, 1);
    poke(_stb_keys + KEY_F, 1);
    if (action_pressed("paint") == 0) {
        print_msg("FAIL: rebind did not switch trigger key");
        return 1;
    }

    print_msg("OK");
    return 0;
}
