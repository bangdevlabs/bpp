// V3 Session 4 positive gate. Registration helper, single caller,
// matched signature — no diagnostic.
import "bpp_io.bsm";
extrn _cb_global;

void cb_float(x: float) { putmsg("ok"); putline(); }

void register_handler(name, cb) {
    _cb_global = cb;
}

main() {
    register_handler("frame", fn_ptr(cb_float));
    auto v: float; v = 1.0;
    call(_cb_global, v);
    return 0;
}
