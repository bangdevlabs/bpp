// test_typed_local_float.bpp — Regression test for Excalibur Arc
// Phase 1 gap A closure (E261 introduction).
//
// Pins that the LEGITIMATE typed-local float patterns still compile
// after E261 starts catching `auto x: word; x = 0.5;`. The error
// case lives in the eventual compile-must-fail harness; this test
// guards that we did NOT over-fire on valid float-typed locals or
// on float-to-float assignments through variables.

main() {
    auto x: float;
    x = 0.5;
    putfloat(x); putline();

    auto y: float;
    y = 42;
    putfloat(y); putline();

    auto src;
    src = 100;
    auto z: float;
    z = src;
    putfloat(z); putline();

    return 0;
}
