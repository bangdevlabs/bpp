// test_packed.bpp — Test packed struct field layout.

// Fat struct: each field = 8 bytes, total = 32 bytes.
struct Fat { r, g, b, a }

// Packed struct: each field = 1 byte, total = 4 bytes.
struct Packed { r: byte, g: byte, b: byte, a: byte }

// Mixed: some fields packed, some full-size.
struct Mixed { x, y, flags: byte }

main() {
    auto fp: Fat, pp: Packed, mp: Mixed;

    // Test 1: Fat struct (backward compat).
    fp = malloc(32);
    fp.r = 10;
    fp.g = 20;
    fp.b = 30;
    fp.a = 40;
    if (fp.r == 10) { putchar('F'); } else { putchar('f'); }
    if (fp.a == 40) { putchar('A'); } else { putchar('a'); }
    if (fp.g == 20) { putchar('T'); } else { putchar('t'); }

    // Test 2: Packed struct (4 bytes total, allocate 8 for safety).
    pp = malloc(8);
    pp.r = 255;
    pp.g = 128;
    pp.b = 64;
    pp.a = 32;
    if (pp.r == 255) { putchar('P'); } else { putchar('p'); }
    if (pp.g == 128) { putchar('A'); } else { putchar('a'); }
    if (pp.b == 64)  { putchar('C'); } else { putchar('c'); }
    if (pp.a == 32)  { putchar('K'); } else { putchar('k'); }

    // Test 3: Verify packed fields don't overlap using a fresh struct.
    auto pp2: Packed;
    pp2 = malloc(8);
    poke(pp2 + 0, 0);
    poke(pp2 + 1, 0);
    poke(pp2 + 2, 0);
    poke(pp2 + 3, 0);
    pp2.r = 170;
    // g is at offset 1. STRB to r should not contaminate g.
    if (pp2.g == 0) { putchar('!'); } else { putchar('?'); }
    free(pp2);

    // Test 4: sizeof should reflect packed size.
    if (sizeof(Fat) == 32)   { putchar('S'); } else { putchar('s'); }
    if (sizeof(Packed) == 4) { putchar('Z'); } else { putchar('z'); }

    putchar(10);
    free(fp);
    free(pp);
    return 0;
}
