// test_stbdraw_layer_ops.bpp — get/set/clear/flood on Layer.
//
// Layer gained byte-grid helpers (layer_get / layer_set /
// layer_clear / layer_fill) so tools that want just the
// palette-indexed canvas primitive — level_editor being the
// motivating second client — don't need to reach into l.fb by
// hand. Asserts each op does what it says.

import "stbgame.bsm";
import "stbdraw.bsm";

main() {
    auto l, v;

    init_str();
    init_draw();

    l = layer_new(8, 6, 0);

    // Freshly allocated layer starts zero-filled.
    if (layer_get(l, 0, 0) != 0 || layer_get(l, 7, 5) != 0) {
        print_msg("FAIL: new layer not zero-filled\n"); return 1;
    }

    // OOB reads return 0 silently.
    if (layer_get(l, -1, 0) != 0 || layer_get(l, 8, 0) != 0 ||
        layer_get(l, 0, -1) != 0 || layer_get(l, 0, 6) != 0) {
        print_msg("FAIL: OOB read did not return 0\n"); return 1;
    }

    // Set + get round-trip.
    layer_set(l, 3, 2, 5);
    if (layer_get(l, 3, 2) != 5) {
        print_msg("FAIL: set/get did not round-trip\n"); return 1;
    }

    // OOB set is a silent no-op (shouldn't crash, no state change).
    layer_set(l, 99, 99, 7);
    layer_set(l, -1, -1, 7);
    if (layer_get(l, 3, 2) != 5) {
        print_msg("FAIL: OOB set corrupted neighbour\n"); return 1;
    }

    // Clear fills every cell with the given index.
    layer_clear(l, 2);
    if (layer_get(l, 0, 0) != 2 || layer_get(l, 7, 5) != 2 ||
        layer_get(l, 3, 3) != 2) {
        print_msg("FAIL: clear did not fill layer\n"); return 1;
    }

    // Flood fill: clear to 0, paint a vertical wall at x=4,
    // flood from (0,0) with 3. Expect left column group = 3,
    // right side untouched since the wall blocks.
    layer_clear(l, 0);
    layer_set(l, 4, 0, 1);
    layer_set(l, 4, 1, 1);
    layer_set(l, 4, 2, 1);
    layer_set(l, 4, 3, 1);
    layer_set(l, 4, 4, 1);
    layer_set(l, 4, 5, 1);
    layer_fill(l, 0, 0, 3);
    if (layer_get(l, 3, 3) != 3) {
        print_msg("FAIL: flood did not reach left side\n"); return 1;
    }
    if (layer_get(l, 5, 3) != 0) {
        print_msg("FAIL: flood leaked past the wall\n"); return 1;
    }
    if (layer_get(l, 4, 3) != 1) {
        print_msg("FAIL: flood overwrote wall\n"); return 1;
    }

    // Flood on a cell already equal to target is a no-op
    // (must not crash, must not loop).
    layer_fill(l, 0, 0, 3);
    if (layer_get(l, 0, 0) != 3) {
        print_msg("FAIL: idempotent flood corrupted state\n"); return 1;
    }

    layer_free(l);
    print_msg("OK");
    return 0;
}
