// test_stbpal_cycle.bpp — palette cycling rotation + accumulator.
//
// Cycling rotates a slice of palette indices one step every
// period_ms. The first color in the range moves to the last
// position; everything else slides up by one. Asserts:
//   (1) Sub-period ticks don't rotate.
//   (2) One period advances the ring by exactly one slot.
//   (3) Large dt (several periods at once) still lands on the
//       correct phase — the implementation must step in a loop.

import "stbgame.bsm";
import "stbpal.bsm";

main() {
    auto p, c0, c1, c2, c3;

    init_str();
    init_palette();

    // Use a clone of DB-32 so we mutate without touching the
    // shared built-in catalog.
    p = palette_clone(palette_builtin(PAL_DB_32));

    // Record the original colors of the cycling window: indices
    // 2 to 5 inclusive (4 slots).
    c0 = palette_get(p, 2);
    c1 = palette_get(p, 3);
    c2 = palette_get(p, 4);
    c3 = palette_get(p, 5);

    if (palette_cycle_begin(p, 2, 4, 100) != 0) {
        putmsg("FAIL: cycle_begin returned non-zero\n");
        return 1;
    }

    // Sub-period tick — nothing moves.
    palette_cycle_tick(p, 50);
    if (palette_get(p, 2) != c0 || palette_get(p, 5) != c3) {
        putmsg("FAIL: sub-period tick rotated early\n");
        return 1;
    }

    // Complete the period — one rotation expected.
    palette_cycle_tick(p, 50);
    if (palette_get(p, 2) != c1) {
        putmsg("FAIL: after one period idx 2 should hold c1\n");
        return 1;
    }
    if (palette_get(p, 3) != c2) {
        putmsg("FAIL: after one period idx 3 should hold c2\n");
        return 1;
    }
    if (palette_get(p, 4) != c3) {
        putmsg("FAIL: after one period idx 4 should hold c3\n");
        return 1;
    }
    if (palette_get(p, 5) != c0) {
        putmsg("FAIL: after one period idx 5 should hold c0\n");
        return 1;
    }

    // Big-dt test — 350 ms = 3 more periods (plus 50 ms accum
    // carried forward). Total position advanced: 3 more slots
    // (we already advanced by 1 above, so 4 total ≡ identity).
    palette_cycle_tick(p, 350);
    if (palette_get(p, 2) != c0 || palette_get(p, 5) != c3) {
        putmsg("FAIL: 4-step cycle did not return to identity\n");
        return 1;
    }

    // Stop the cycle — further ticks should be no-ops.
    palette_cycle_stop(p, 2);
    palette_cycle_tick(p, 10000);
    if (palette_get(p, 2) != c0 || palette_get(p, 5) != c3) {
        putmsg("FAIL: cycle kept running after stop\n");
        return 1;
    }

    palette_free(p);
    putmsg("OK");
    return 0;
}
