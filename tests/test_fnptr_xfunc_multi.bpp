// xfail-warn: W028
// V3 Session 4 multi-origin gate. Two callers register different
// signatures into the same global. Estrita conflict resolution: any
// origin mismatch with the call site args fires W028. Here cb_word's
// signature disagrees with the float arg passed at the call.
extrn _cb_global;

void cb_word(x) { }
void cb_float(x: float) { }

void register_handler(name, cb) {
    _cb_global = cb;
}

main() {
    register_handler("a", fn_ptr(cb_word));
    register_handler("b", fn_ptr(cb_float));
    auto v: float; v = 1.0;
    call(_cb_global, v);   // Estrita: cb_word origin mismatches → W028
    return 0;
}
