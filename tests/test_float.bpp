// Test float inference: basic arithmetic and output.

print_int(n) {
    auto buf, i, d;
    buf = malloc(32);
    if (n == 0) { putchar('0'); return 0; }
    if (n < 0) { putchar('-'); n = 0 - n; }
    i = 0;
    while (n > 0) {
        d = n % 10;
        poke(buf + i, '0' + d);
        n = n / 10;
        i = i + 1;
    }
    while (i > 0) {
        i = i - 1;
        putchar(peek(buf + i));
    }
    return 0;
}

main() {
    auto x, y, z;
    x = 3.14;
    y = 2.0;
    z = x * y;
    // z should be 6.28 — cast to int for printing.
    print_int(z);
    putchar('\n');
    return 0;
}
