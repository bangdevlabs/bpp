// Test float inference: basic arithmetic and output.

putnum(n) {
    auto buf, i, d;
    buf = malloc(32);
    if (n == 0) { putchar('0'); return 0; }
    if (n < 0) { putchar('-'); n = 0 - n; }
    i = 0;
    while (n > 0) {
        d = n % 10;
        poke(buf + i, '0' + d);
        n = n / 10;
        i = i + 1;
    }
    while (i > 0) {
        i = i - 1;
        putchar(peek(buf + i));
    }
    return 0;
}

main() {
    auto x: float, y: float, z: float;
    auto zi: word;
    x = 3.14;
    y = 2.0;
    z = x * y;
    // z is 6.28 — copy into a word slot to truncate for the int printer.
    zi = z;
    putnum(zi);
    putchar('\n');
    return 0;
}
