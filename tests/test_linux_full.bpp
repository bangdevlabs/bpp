// Comprehensive test for Linux x86_64 backend.
// Tests: variables, arithmetic, if/else, while, functions, strings,
//        malloc/peek/poke, and recursion.
// Compile: ./bpp --linux64 tests/test_linux_full.bpp -o build/test_full_linux
// Test:    docker exec bpp-linux /bpp/build/test_full_linux
// Expected output:
//   Hello from B++!
//   1+2=3
//   10!=3628800
//   ABCDE
//   sum=55
//   OK

// Prints a string by walking its bytes until null terminator.
putstr(s) {
    auto i, c;
    i = 0;
    c = peek(s + i);
    while (c != 0) {
        putchar(c);
        i++;
        c = peek(s + i);
    }
}

// Prints an integer (positive only, for simplicity).
putnum(n) {
    auto buf, len, d;
    buf = malloc(32);
    len = 0;
    if (n == 0) {
        putchar(48);
        free(buf);
        return 0;
    }
    while (n > 0) {
        d = n - (n / 10) * 10;
        poke(buf + len, d + 48);
        len++;
        n /= 10;
    }
    while (len > 0) {
        len--;
        putchar(peek(buf + len));
    }
    free(buf);
    return 0;
}

// Simple addition function.
add(a, b) {
    return a + b;
}

// Factorial via recursion.
fact(n) {
    if (n <= 1) { return 1; }
    return n * fact(n - 1);
}

// Sum 1..n via a while loop.
sum_to(n) {
    auto s, i;
    s = 0;
    for (i = 1; i <= n; i++) {
        s += i;
    }
    return s;
}

main() {
    auto buf, i;

    // Test 1: string literal + putstr.
    putstr("Hello from B++!");
    putchar(10);

    // Test 2: function call + arithmetic.
    putstr("1+2=");
    putnum(add(1, 2));
    putchar(10);

    // Test 3: recursion (factorial).
    putstr("10!=");
    putnum(fact(10));
    putchar(10);

    // Test 4: malloc + poke + peek.
    buf = malloc(16);
    for (i = 0; i < 5; i++) {
        poke(buf + i, 65 + i);
    }
    for (i = 0; i < 5; i++) {
        putchar(peek(buf + i));
    }
    putchar(10);
    free(buf);

    // Test 5: while loop (sum 1..10).
    putstr("sum=");
    putnum(sum_to(10));
    putchar(10);

    // Test 6: if/else.
    if (add(2, 3) == 5) {
        putstr("OK");
    }
    putchar(10);

    return 0;
}
