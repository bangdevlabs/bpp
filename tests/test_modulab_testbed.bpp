// test_modulab_testbed.bpp — gravity + jump + collision physics.
//
// Asserts:
//   (1) Without input, the character falls until it hits ground,
//       then rests with grounded=1 and vel_y=0.
//   (2) Simulating KEY_SPACE press-edge while grounded sends
//       the character upward (vel_y becomes negative).
//   (3) Lateral input moves the character, but a wall stops it.
//
// Does not open a window — we call testbed_update directly with
// synthetic dt and pre-seeded _stb_keys state.

import "stbgame.bsm";
import "stbforge.bsm";
load "../tools/modulab/core.bsm";

main() {
    auto cp, c: Character, i, before_y, after_y;

    init_str();
    init_input();
    state_init(16);

    cp = character_new();
    c  = cp;
    // Use a tiny hitbox so the default spawn clears the world's
    // floor and ledges — this test wants to exercise gravity +
    // collision on a single tile, not on the hand-authored
    // layout's corner cases.
    c.hit_x = 0; c.hit_y = 0; c.hit_w = 1; c.hit_h = 1;
    c.pivot_x = 0; c.pivot_y = 0;
    c.gravity = 800;
    c.jump_velocity = 300;
    c.ctrl_left  = KEY_LEFT;
    c.ctrl_right = KEY_RIGHT;
    c.ctrl_jump  = KEY_SPACE;

    testbed_init(cp);

    // Hold 20 update frames at 16 ms each. With gravity=800 px/s²
    // the fall will cover ~200 px of travel — well past the
    // spawn's clearance to the floor.
    before_y = tb_pos_my();
    for (i = 0; i < 20; i = i + 1) { testbed_update(16); }
    after_y = tb_pos_my();

    if (after_y <= before_y) {
        print_msg("FAIL: character did not fall with gravity");
        return 1;
    }
    if (tb_grounded() == 0) {
        print_msg("FAIL: character never hit the ground");
        return 1;
    }
    if (tb_vel_y() != 0) {
        print_msg("FAIL: vel_y not zeroed after landing: ");
        print_int(tb_vel_y()); print_ln();
        return 1;
    }

    // Simulate jump: SPACE pressed this frame (edge). Use a
    // sub-ms dt so the character moves only a fraction of a
    // pixel up — won't reach any ledge the default world may
    // have placed overhead, which would clip the upward velocity
    // and confuse this assertion.
    poke(_stb_keys + KEY_SPACE, 1);
    testbed_update(1);
    if (tb_vel_y() >= 0) {
        print_msg("FAIL: jump did not produce upward velocity: ");
        print_int(tb_vel_y()); print_ln();
        return 1;
    }
    if (tb_grounded() != 0) {
        print_msg("FAIL: grounded flag stuck after jump");
        return 1;
    }
    // Next frame the key is still down but no longer press-edge.
    _input_save_prev();
    testbed_update(16);
    // vel_y should now be rising toward 0 due to gravity (less
    // negative than just after the jump). Just confirm it's still
    // airborne.
    if (tb_grounded() != 0) {
        print_msg("FAIL: grounded re-set mid-air");
        return 1;
    }

    // Lateral movement — hold LEFT, character should move left.
    // (Skipping precise delta check since world edges may clamp;
    // we just confirm velocity went negative.)
    poke(_stb_keys + KEY_SPACE, 0);
    poke(_stb_keys + KEY_LEFT,  1);
    testbed_update(16);
    if (tb_vel_x() >= 0) {
        print_msg("FAIL: left key did not produce negative vel_x");
        return 1;
    }

    testbed_free();
    character_free(cp);
    state_free();
    print_msg("OK");
    return 0;
}
