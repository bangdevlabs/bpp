// test_stbpal_lerp_lut.bpp — palette blending + LUT remap.
//
// palette_lerp blends two palettes per-channel at 0..255. Check
// that t=0 gives `a`, t=255 gives `b`, and t=128 sits near the
// midpoint.
//
// palette_lut_apply remaps indices via a LUT. Flash-to-white is
// the canonical usage — every slot maps to index N, so the output
// palette becomes uniform (except index 0 which stays transparent).

import "stbgame.bsm";
import "stbpal.bsm";

main() {
    auto a, b, out, t, lut, src, mapped, mid;
    auto c_mid, a_mid, b_mid;

    init_str();
    init_palette();

    a = palette_clone(palette_builtin(PAL_GB_4));  // 5 slots
    b = palette_new(5);
    palette_set(b, 0, 0x00000000);
    palette_set(b, 1, 0xFF000000);
    palette_set(b, 2, 0xFF800000);
    palette_set(b, 3, 0xFFFF0000);
    palette_set(b, 4, 0xFFFFFFFF);
    out = palette_new(5);

    // t=0 → copy of a.
    palette_lerp(a, b, 0, out);
    if (palette_get(out, 2) != palette_get(a, 2)) {
        print_msg("FAIL: lerp t=0 did not reproduce a\n");
        return 1;
    }

    // t=255 → copy of b.
    palette_lerp(a, b, 255, out);
    if (palette_get(out, 3) != palette_get(b, 3)) {
        print_msg("FAIL: lerp t=255 did not reproduce b\n");
        return 1;
    }

    // t=128 → between a and b. Check the red channel of slot 3
    // (a[3] = 0xFF8BAC0F red=0x8B=139, b[3] = 0xFFFF0000 red=255).
    // Midpoint is (139*127 + 255*128) / 255 = 197 (off-by-one OK).
    palette_lerp(a, b, 128, out);
    c_mid = palette_get(out, 3);
    mid = (c_mid >> 16) & 0xFF;
    if (mid < 180 || mid > 210) {
        print_msg("FAIL: lerp t=128 midpoint not near expected\n");
        return 1;
    }

    // LUT flash test — map every index to 2 (darkest green) and
    // verify every non-transparent slot becomes that color.
    src = palette_clone(palette_builtin(PAL_GB_4));
    lut = palette_lut_flash(5, 2);
    palette_lut_apply(src, lut, out);
    mapped = palette_get(src, 2);
    if (palette_get(out, 1) != mapped ||
        palette_get(out, 3) != mapped ||
        palette_get(out, 4) != mapped) {
        print_msg("FAIL: flash LUT did not collapse to target\n");
        return 1;
    }
    if (palette_get(out, 0) != 0) {
        print_msg("FAIL: LUT overwrote transparent slot 0\n");
        return 1;
    }

    palette_lut_free(lut);
    palette_free(a);
    palette_free(b);
    palette_free(out);
    palette_free(src);
    print_msg("OK");
    return 0;
}
