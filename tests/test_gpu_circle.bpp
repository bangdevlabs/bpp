// test_gpu_circle.bpp — minimal test: one circle.

import "stbgame.bsm";
import "stbrender.bsm";

main() {
    game_init(320, 240, "Circle Test", 60);
    render_init();

    while (game_should_quit() == 0) {
        game_frame_begin();
        render_begin();
        render_clear(rgba(0, 0, 32, 255));
        render_circle(160, 120, 50, RED);
        render_end();
    }
    return 0;
}
