// test_gpu_circle.bpp — minimal smoke test: one circle for a fixed
// number of frames, then exit.
//
// Why an explicit sys_exit(0) instead of the natural return-from-main
// path: under run_all.sh's batch mode, relying on the platform's
// auto-exit (the window losing focus or the runner's 10 s SIGKILL)
// flaked depending on whether the Cocoa window gained focus this run.
// The race is inside Cocoa's quit handshake, not in user code, so the
// fix lives here: count a deterministic number of frames and exit
// directly. No window-close, no signal kill.

import "stbgame.bsm";
import "stbrender.bsm";

const TEST_FRAMES = 30;

main() {
    auto frame;

    game_init(320, 240, "Circle Test", 60);
    render_init();

    for (frame = 0; frame < TEST_FRAMES; frame++) {
        game_frame_begin();
        render_begin();
        render_clear(rgba(0, 0, 32, 255));
        render_circle(160, 120, 50, RED);
        render_end();
        if (game_should_quit() != 0) { frame = TEST_FRAMES; }
    }

    sys_exit(0);
    return 0;
}
