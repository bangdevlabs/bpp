// V3 Session 2 positive gate. Three patterns must compile clean and
// run with no W028 — the flow analyser resolves each call() target
// and every arg's compile-time type matches the callee's params.
import "bpp_io.bsm";

void cb_word(x) { putmsg("w"); putline(); }
void cb_float(x: float) { putmsg("f"); putline(); }

main() {
    // Pattern A — direct fn_ptr at the call site.
    auto a; a = 1;
    call(fn_ptr(cb_word), a);

    // Pattern B — local origin captured then reused.
    auto fp;
    fp = fn_ptr(cb_word);
    call(fp, a);

    // Pattern C — same local reassigned to a different target with
    // a different signature; new origin overrides the old one.
    fp = fn_ptr(cb_float);
    auto v: float; v = 1.0;
    call(fp, v);
    return 0;
}
