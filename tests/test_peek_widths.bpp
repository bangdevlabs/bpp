// Test all peek/poke width builtins: integer (q/h/w) and float variants.
// Covers: round-trip correctness, LE byte layout, and values with high bits set.
main() {
    auto buf;
    buf = buf_byte(64);

    // ── peek_q / poke_q (16-bit) ──────────────────────────────────────────────
    poke_q(buf, 0x1234);
    assert(peek_q(buf) == 0x1234);
    // high-bit value: 0xBEEF — verifies zero-extension (no sign extension)
    poke_q(buf, 0xBEEF);
    assert(peek_q(buf) == 0xBEEF);
    // LE byte layout: low byte first
    assert(peek(buf + 0) == 0xEF);
    assert(peek(buf + 1) == 0xBE);

    // ── peek_h / poke_h (32-bit) ──────────────────────────────────────────────
    poke_h(buf, 0x12345678);
    assert(peek_h(buf) == 0x12345678);
    // high-bit value: 0xDEADBEEF — LDR W zero-extends (unlike LDRSW which sign-extends)
    poke_h(buf, 0xDEADBEEF);
    assert(peek_h(buf) == 0xDEADBEEF);
    // LE byte layout
    assert(peek(buf + 0) == 0xEF);
    assert(peek(buf + 1) == 0xBE);
    assert(peek(buf + 2) == 0xAD);
    assert(peek(buf + 3) == 0xDE);

    // ── peek_w / poke_w (64-bit) ──────────────────────────────────────────────
    poke_w(buf, 0x0102030405060708);
    assert(peek_w(buf) == 0x0102030405060708);
    assert(peek(buf + 0) == 8);
    assert(peek(buf + 7) == 1);

    // ── peekfloat / pokefloat (64-bit float) ─────────────────────────────────
    auto fval: float;
    pokefloat(buf, 3.14159);
    fval = peekfloat(buf);
    assert(fval == 3.14159);
    // byte layout: IEEE 754 double 1.5 = 0x3FF8000000000000 LE = 00 00 00 00 00 00 F8 3F
    pokefloat(buf, 1.5);
    assert(peek(buf + 6) == 0xF8);
    assert(peek(buf + 7) == 0x3F);

    // ── peekfloat_h / pokefloat_h (32-bit float) — ARM64 only ────────────────
    // IEEE 754 f32: 1.5 = 0x3FC00000 LE = 00 00 C0 3F
    auto fh: half float;
    fh = 1.5;
    pokefloat_h(buf, fh);
    assert(peek(buf + 0) == 0);
    assert(peek(buf + 1) == 0);
    assert(peek(buf + 2) == 0xC0);
    assert(peek(buf + 3) == 0x3F);
    // read back
    auto fh2: half float;
    fh2 = peekfloat_h(buf);
    assert(fh2 == 1.5);

    // ── non-zero offset: verify buf + off addressing works ────────────────────
    poke_q(buf + 10, 0xCAFE);
    assert(peek_q(buf + 10) == 0xCAFE);

    poke_h(buf + 20, 0xDEADC0DE);
    assert(peek_h(buf + 20) == 0xDEADC0DE);

    buf_free(buf);
    return 0;
}
