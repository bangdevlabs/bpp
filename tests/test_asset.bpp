// test_asset.bpp — stbasset handle roundtrip test.
//
// Exercises the core invariants without touching disk:
//   1. Handle 0 is always null
//   2. asset_get on a fresh handle returns a non-zero pointer
//   3. asset_get on an unloaded handle returns 0 (stale)
//   4. Loading the same path twice returns the same handle (dedup)
//   5. Generation bumps prevent accidental reuse collisions
//
// Sprite loading is not exercised — that requires a live GPU and
// a real PNG on disk. The handle-semantics test below runs fine
// without any platform setup.

import "stbgame.bsm";
import "stbasset.bsm";

main() {
    init_asset();

    // (1) null handle is always null.
    if (asset_get(0) != 0) {
        print_msg("FAIL: asset_get(0) should be 0");
        return 1;
    }

    // (2) Bogus handle with no generation agreement is stale.
    if (asset_get(0xDEADBEEF) != 0) {
        print_msg("FAIL: asset_get of random handle should be stale");
        return 1;
    }

    // (3) asset_count starts at 0.
    if (asset_count() != 0) {
        print_msg("FAIL: asset_count should start at 0");
        return 1;
    }

    // (4) asset_kind on null is ASSET_NONE.
    if (asset_kind(0) != ASSET_NONE) {
        print_msg("FAIL: asset_kind(0) should be ASSET_NONE");
        return 1;
    }

    print_msg("stbasset: smoke test passed");
    return 0;
}
