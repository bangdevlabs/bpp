// test_stbwindow.bpp — compile-only smoke test for the stbwindow
// public surface. We verify the module links (all externs
// resolved, objc FFI in place, dialog/alert symbols present) but
// don't actually run a dialog — that would block the regression
// suite forever waiting for a button click.
//
// Running this test: it exits 0 without opening any window. A
// genuine dialog-open test lives outside run_all.sh (manual).

import "stbgame.bsm";
import "stbwindow.bsm";

main() {
    // Reference every public function so the linker has to resolve
    // them. We never actually call them — wrapping in `if (0)`
    // makes the calls dead at runtime but alive at link.
    if (0) {
        auto path;
        path = window_save_dialog("Save As", "untitled.json");
        free(path);
        path = window_open_dialog("Open");
        free(path);
        window_alert("Info", "Something happened.");
        window_confirm("Confirm", "Are you sure?");
        window_error("Error", "Something failed.");
    }

    putmsg("stbwindow: compile + link smoke passed");
    return 0;
}
