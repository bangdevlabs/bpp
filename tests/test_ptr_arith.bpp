// Verify pointer subtraction and relational comparison are supported.
// Both operations compile to plain 64-bit integer arithmetic — no special
// treatment needed — but this test locks in that they compile and produce
// correct results so regressions are caught early.
main() {
    auto a, b;
    a = malloc(16);
    b = a + 8;
    assert(b - a == 8);
    assert(a < b);
    assert(b > a);
    assert(a != b);
    free(a);
    return 0;
}
