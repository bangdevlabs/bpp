// test_bitfield.bpp — Validates the `: bit*` struct field family added in
// Phase A1 of the Mini Cooper plan. Covers single-bit flags, multi-bit
// packed fields, byte overflow into a fresh byte, and mixing with byte+
// fields that terminate the bit-packed run.

struct E {
    alive: bit,        // byte 0, bit 0  (1 bit)
    frozen: bit,       // byte 0, bit 1  (1 bit)
    kind: bit3,        // byte 0, bit 2-4 (3 bits)
    level: bit4,       // would overflow byte 0; rolls to byte 1, bit 0-3
    hp,                // byte 2 (flushes any in-flight bit packing)
    x, y               // bytes 10, 18
}

main() {
    var e: E;

    // Round-trip every field and check they survive.
    e.alive = 1;
    e.frozen = 0;
    e.kind = 5;
    e.level = 11;
    e.hp = 100;
    e.x = 42;
    e.y = 7;

    if (e.alive != 1) { return 10; }
    if (e.frozen != 0) { return 20; }
    if (e.kind != 5)   { return 30; }
    if (e.level != 11) { return 40; }
    if (e.hp != 100)   { return 50; }
    if (e.x != 42)     { return 60; }
    if (e.y != 7)      { return 70; }

    // Overflow check: bit3 holds 0..7. Writing 7 must read back as 7,
    // not collide with neighbouring fields.
    e.kind = 7;
    if (e.kind != 7) { return 80; }
    if (e.alive != 1) { return 81; }
    if (e.frozen != 0) { return 82; }
    if (e.level != 11) { return 83; }

    // Bit field writes must not corrupt adjacent byte+ fields either.
    e.kind = 0;
    if (e.hp != 100) { return 90; }
    if (e.x != 42)   { return 91; }
    if (e.y != 7)    { return 92; }

    return 0;
}
