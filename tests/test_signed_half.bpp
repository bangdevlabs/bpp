// test_signed_half.bpp — Validates that `: half` (32-bit signed) struct
// fields and locals correctly sign-extend on load. The LDRSW emission
// fix shipped in commit 8252b24; before that, negative half values
// were loaded as zero-extended unsigned ints — a silent codegen bug
// flagged in test_slice_struct's original known-bug comment.

struct Phys {
    gravity: half,
    accel_x: half,
    accel_y: half,
    flags: byte
}

main() {
    auto p: Phys;
    p = malloc(sizeof(Phys));

    // Positive 32-bit values round-trip.
    p.gravity = 980;
    p.accel_x = 50;
    if (p.gravity != 980) { return 10; }
    if (p.accel_x != 50)  { return 11; }

    // Negative values must sign-extend on load. Pre-fix this returned
    // a large positive number because LDR W (zero-extend) was emitted
    // instead of LDRSW.
    p.gravity = 0 - 1000;
    p.accel_x = 0 - 1;
    p.accel_y = 0 - 2147483648;   // INT32_MIN
    if (p.gravity != 0 - 1000) { return 20; }
    if (p.accel_x != 0 - 1)    { return 21; }
    if (p.accel_y != 0 - 2147483648) { return 22; }

    // Mixed positive and negative arithmetic on sign-extended values.
    p.gravity = 0 - 100;
    p.accel_y = 50;
    if (p.gravity + p.accel_y != 0 - 50) { return 30; }

    free(p);
    return 0;
}
