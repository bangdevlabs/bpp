// test_modulab_view.bpp — zoom/pan hit-test math.
//
// Doesn't touch the real mouse/window — just verifies that
// canvas_hit returns the correct cell for a given (mx, my) +
// (origin_x, origin_y, zoom) combination. If that math is right,
// modulab's pan + zoom-around-cursor paths follow automatically.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/canvas.bsm";

main() {
    auto cell, x, y;

    init_str();
    state_init(16);

    // Origin (100, 100), zoom = 8. Cell (3, 5) lives at pixel
    // (100 + 3*8, 100 + 5*8) = (124, 140). Pick midpoint.
    cell = canvas_hit(128, 144, 100, 100, 8);
    if (cell < 0) {
        print_msg("FAIL: canvas_hit missed a point clearly inside");
        return 1;
    }
    x = cell % 16;
    y = cell / 16;
    if (x != 3 || y != 5) {
        print_msg("FAIL: expected cell (3,5), got ");
        print_int(x); print_msg(","); print_int(y); print_ln();
        return 1;
    }

    // Off-canvas left should return -1.
    cell = canvas_hit(0, 0, 100, 100, 8);
    if (cell != 0 - 1) {
        print_msg("FAIL: off-canvas point returned non-negative");
        return 1;
    }

    // Off-canvas right (just past the 16*8=128 px bound).
    cell = canvas_hit(100 + 128 + 1, 144, 100, 100, 8);
    if (cell != 0 - 1) {
        print_msg("FAIL: right-edge overshoot not rejected");
        return 1;
    }

    // Zoom change preserves cell identity for the same mouse pos
    // (zoom-around-cursor invariant). Pick cursor at (200, 200)
    // with origin (100, 100), zoom 8 → cell (12, 12). Then zoom
    // to 16 with origin recomputed as (200 - 12*16, 200 - 12*16)
    // = (8, 8). Cursor still at (200, 200) should still hit (12, 12).
    cell = canvas_hit(200, 200, 100, 100, 8);
    if (cell != 12 * 16 + 12) {
        print_msg("FAIL: precondition cell wrong");
        return 1;
    }
    cell = canvas_hit(200, 200, 8, 8, 16);
    if (cell != 12 * 16 + 12) {
        print_msg("FAIL: zoom-around-cursor math broken, got ");
        print_int(cell); print_ln();
        return 1;
    }

    state_free();
    print_msg("OK");
    return 0;
}
