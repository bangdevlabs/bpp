// Phase B4: verify that `: double` locals always land on a 16-byte
// boundary regardless of neighbouring slots. Without the per-slot
// rounding in a64_pre_reg_vars / x64_pre_reg_vars, a preceding 8-byte
// local would leave the SIMD slot at an odd 8-byte offset. ARMv8's
// STR Q tolerates that (unaligned writes are legal), so the correctness
// impact is nil — but MOVAPS on x86_64 would fault, and any future
// change that swaps MOVUPS for MOVAPS must still see the slot landed
// on 16. This test pins that invariant.

import "bpp_io.bsm";

main() {
    // Mixed frame: scalar int, SIMD, scalar int. The SIMD slot must
    // round up past the first scalar so (&v & 15) == 0.
    auto a, c;
    auto v: double;
    auto b;
    a = 1;
    b = 2;
    c = 3;
    v = vec_splat4(9.0);

    auto addr;
    addr = &v;
    if ((addr & 15) == 0) {
        putchar('O'); putchar('K'); putchar('\n');
    } else {
        putchar('X'); putchar('\n');
    }

    // Also exercise the op to make sure the slot actually holds a usable
    // value — if the alignment fix broke the offset arithmetic, we'd
    // write at one address and read from another.
    v = vec_add4(v, v);
    auto lane;
    lane = vec_get4(v, 2);
    putchar('0' + lane / 10);
    putchar('0' + lane % 10);
    putchar('\n');

    // Touch a and c so the compiler can't dead-strip them and shift the
    // frame layout away from the mixed-scalar setup the test asserts.
    putchar('0' + a);
    putchar('0' + b);
    putchar('0' + c);
    putchar('\n');
    return 0;
}
