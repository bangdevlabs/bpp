// test_modulab_handdiff.bpp — Phase 5 acceptance criterion.
//
// Loads games/pathfind/assets/sprites/rat_sprite.json through the
// engine's load_sprite (the same path pathfind exercises every
// frame), installs those pixels into ModuLab's canvas, re-saves
// via mlab_save_sprite_compat, and re-loads the written file.
//
// A pass means: ModuLab's save path produces bytes stbsprite
// loads back identically. If a user paints a sprite, exports it,
// and drops it into pathfind's assets/sprites/ directory, the
// rendering is bit-identical to the hand-authored reference.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/canvas.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto src, reloaded, n, total, i, x, y, idx, rc;

    init_str();

    n = 16;
    total = n * n;

    // Load the hand-authored reference straight from the game.
    src = malloc(total);
    for (i = 0; i < total; i++) { poke(src + i, 255); }
    rc = load_sprite("games/pathfind/assets/sprites/rat_sprite.json",
                     src, n, n);
    if (rc == 0) {
        putmsg("FAIL: could not load reference rat_sprite.json");
        return 1;
    }

    // Install those pixels in ModuLab's canvas.
    state_init(n);
    for (y = 0; y < n; y++) {
        for (x = 0; x < n; x++) {
            pix_set(x, y, peek(src + y * n + x));
        }
    }

    // Save through the write path a user's S-key click would
    // traverse.
    rc = mlab_save_sprite_compat("/tmp/test_modulab_handdiff.json");
    if (rc != 0) {
        putmsg("FAIL: mlab_save_sprite_compat returned non-zero");
        return 1;
    }

    // Load the freshly-written file and byte-compare against the
    // original reference pixels.
    reloaded = malloc(total);
    for (i = 0; i < total; i++) { poke(reloaded + i, 255); }
    rc = load_sprite("/tmp/test_modulab_handdiff.json", reloaded, n, n);
    if (rc == 0) {
        putmsg("FAIL: load_sprite could not re-read ModuLab's output");
        return 1;
    }

    for (i = 0; i < total; i++) {
        if (peek(src + i) != peek(reloaded + i)) {
            putmsg("FAIL: pixel mismatch at cell ");
            putnum(i); putmsg(" src="); putnum(peek(src + i));
            putmsg(" ml="); putnum(peek(reloaded + i)); putline();
            return 1;
        }
    }

    free(src);
    free(reloaded);
    state_free();

    putmsg("OK");
    return 0;
}
