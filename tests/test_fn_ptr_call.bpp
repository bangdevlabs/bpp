// Wave 18 batch 5 regression: fn_ptr was lifted to the portable
// ChipPrimitives slot emit_fn_ptr; call() stays chip-local for now.
// This test exercises both together — the "real world" indirect-
// call pattern where a function is captured by address and later
// invoked with runtime arguments.

add(a, b) { return a + b; }

main() {
    auto fp, result;
    fp = fn_ptr(add);
    result = call(fp, 2, 3);
    if (result != 5) {
        putchar_err('F'); putchar_err('A'); putchar_err('I'); putchar_err('L'); putchar_err('\n');
        sys_exit(1);
    }
    return 0;
}
