// skip-c: autovec P5 (code emission) not yet wired — the matcher in
//         P2 only flags candidates; P5 will lower them to vec_* form.
//         Today the loop runs scalar, but the AV_P1 diag at compile
//         time confirms the matcher accepts the pattern.
//
// test_autovec_p1.bpp — Canonical match for autovec pattern P1.
//
// Shape: `arr[i] = arr[i] OP literal` over a stride-1 loop with a
// global bound. This is exactly what the matcher in P2 of the
// autovec sidequest is meant to flag.
//
// Until P5 lands, the loop still runs scalar — the test just
// validates that:
//   1. The matcher accepts the candidate (visible via the
//      `AV_P1` diag at compile time, scrubbed before commit).
//   2. The scalar fallback still produces the correct result.
//
// Returns 0 on output match.

import "bpp_io.bsm";

const N = 16;

global arr;

main() {
    auto i, sum, expected;

    arr = malloc(N * 8);
    for (i = 0; i < 16; i++) {
        *(arr + i * 8) = i + 1;       // seed 1..N
    }

    // Pattern P1: arr[i] = arr[i] OP literal.
    // The matcher's AST recognition fires here.
    for (i = 0; i < 16; i++) {
        *(arr + i * 8) = *(arr + i * 8) * 7;
    }

    // Verify: each slot = (i + 1) * 7
    sum = 0;
    for (i = 0; i < 16; i++) {
        expected = (i + 1) * 7;
        if (*(arr + i * 8) != expected) {
            putmsg("MISMATCH");
            free(arr);
            return 1;
        }
        sum = sum + *(arr + i * 8);
    }

    free(arr);
    return 0;
}
