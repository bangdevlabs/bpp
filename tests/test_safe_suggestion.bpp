// test_safe_suggestion.bpp — Pins W031 silence when callbacks
// registered via maestro_register_base / job_submit ARE annotated
// `@safe`. The negative variant (W031 firing on un-annotated targets)
// lives in the compile-time warning suite, not here — this test is a
// runtime smoke that the annotated path executes correctly.
//
// Phase annotation collapse Task 4 (commit pending). The `@safe`
// suggestion engine emits W031 at compile time when a fn_ptr literal
// passed to a callback-registration sink targets a function that has
// not been annotated `@safe`. This program registers two annotated
// callbacks (one for a worker phase, one for a job submission), so
// the compiler is silent and the runtime path proves the bytes flow
// correctly through the maestro and job pipelines.

// Worker phase callback. Pure compute over the dt input — bounded
// time, no malloc, no IO. The @safe annotation is the contract the
// compiler verifies via W026.
worker_phase(dt: float)@safe {
    return dt * 2.0;
}

// Worker task callback. Same shape as worker_phase — pure compute
// returning the doubled arg. The job runner unwraps the result.
worker_task(arg)@safe {
    return arg + arg;
}

main() {
    // Both registrations would fire W031 if the targets were not
    // annotated @safe. Compiling clean is the proof the suggestion
    // engine is silent on annotated targets.
    maestro_register_base(fn_ptr(worker_phase));
    job_init(2);
    job_submit(fn_ptr(worker_task), 21);
    job_shutdown();

    putstr("OK\n");
    return 0;
}
