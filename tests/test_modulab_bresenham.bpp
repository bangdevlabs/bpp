// test_modulab_bresenham.bpp — line, rect, oval symmetry + endpoints.
//
// Asserts that tool_line is symmetric (A→B renders the same cells
// as B→A), that rect endpoints are inclusive on both axes, and that
// tool_oval never escapes its bounding box.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/canvas.bsm";

// Snapshot the canvas into a caller-allocated buffer so we can
// compare two drawings cell by cell.
static void _copy_canvas(dst) {
    auto i, total;
    total = canvas_n() * canvas_n();
    for (i = 0; i < total; i = i + 1) { poke(dst + i, pix_get(i % canvas_n(), i / canvas_n())); }
}

// Compare two buffers of `n` bytes. Returns 1 if equal, 0 otherwise.
static _eq(a, b, n) : base {
    auto i;
    for (i = 0; i < n; i = i + 1) {
        if (peek(a + i) != peek(b + i)) { return 0; }
    }
    return 1;
}

main() {
    auto n, bytes, buf_a, buf_b, x, y, inside_box, idx;

    init_str();
    state_init(16);
    n = canvas_n();
    bytes = n * n;

    buf_a = malloc(bytes);
    buf_b = malloc(bytes);

    // ── Line symmetry ────────────────────────────────────
    g_sel_color = 1;
    canvas_clear();
    tool_line(2, 3, 12, 11);
    _copy_canvas(buf_a);

    canvas_clear();
    tool_line(12, 11, 2, 3);
    _copy_canvas(buf_b);

    if (_eq(buf_a, buf_b, bytes) == 0) {
        putmsg("FAIL: tool_line not symmetric");
        return 1;
    }

    // Vertical line.
    canvas_clear();
    tool_line(5, 2, 5, 14);
    for (y = 2; y <= 14; y = y + 1) {
        if (pix_get(5, y) == 0) {
            putmsg("FAIL: vertical line has a gap at y=");
            putnum(y); putline();
            return 1;
        }
    }

    // Horizontal line.
    canvas_clear();
    tool_line(1, 8, 14, 8);
    for (x = 1; x <= 14; x = x + 1) {
        if (pix_get(x, 8) == 0) {
            putmsg("FAIL: horizontal line has a gap at x=");
            putnum(x); putline();
            return 1;
        }
    }

    // ── Rect endpoints ───────────────────────────────────
    canvas_clear();
    tool_rect(3, 3, 7, 7, 0);  // outline
    if (pix_get(3, 3) == 0 || pix_get(7, 3) == 0
     || pix_get(3, 7) == 0 || pix_get(7, 7) == 0) {
        putmsg("FAIL: rect outline missing a corner");
        return 1;
    }
    if (pix_get(5, 5) != 0) {
        putmsg("FAIL: rect outline painted the interior");
        return 1;
    }

    canvas_clear();
    tool_rect(3, 3, 7, 7, 1);  // filled
    if (pix_get(5, 5) == 0) {
        putmsg("FAIL: filled rect did not paint interior");
        return 1;
    }

    // ── Oval bounds ──────────────────────────────────────
    canvas_clear();
    tool_oval(4, 4, 10, 10, 0);  // outline
    inside_box = 1;
    for (y = 0; y < n; y = y + 1) {
        for (x = 0; x < n; x = x + 1) {
            idx = pix_get(x, y);
            if (idx == 0) { continue; }
            if (x < 4 || x > 10 || y < 4 || y > 10) {
                inside_box = 0;
            }
        }
    }
    if (inside_box == 0) {
        putmsg("FAIL: oval painted outside its bounding rectangle");
        return 1;
    }

    free(buf_a);
    free(buf_b);
    state_free();

    putmsg("OK");
    return 0;
}
