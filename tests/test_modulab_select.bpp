// test_modulab_select.bpp — rect selection + clipboard semantics.
//
// Exercises the full copy/paste + undo loop, then verifies the
// two contract lines documented on select_paste:
//   (1) paste always targets the active layer;
//   (2) paste respects the stencil — cells whose destination
//       equals g_stencil_color are refused.

import "stbgame.bsm";
load "../tools/modulab/core.bsm";
load "../tools/modulab/select.bsm";
load "../tools/modulab/io.bsm";

main() {
    auto i, x, y, n;

    init_str();
    init_beat();
    state_init(8);

    n = g_canvas_n;

    // Paint a 3x3 pattern of colour 4 at (1..3, 1..3).
    history_begin_stroke();
    for (y = 1; y <= 3; y = y + 1) {
        for (x = 1; x <= 3; x = x + 1) { pix_set(x, y, 4); }
    }
    history_commit();

    // Select + copy that rect.
    select_begin(1, 1);
    select_update(3, 3);
    select_end();
    if (select_copy() == 0) {
        print_msg("FAIL: select_copy returned 0"); return 1;
    }
    if (select_has_clip() == 0) {
        print_msg("FAIL: clipboard empty after copy"); return 1;
    }

    // Paste at (5, 5). Destination cells must match source cells.
    select_paste(5, 5);
    for (y = 0; y < 3; y = y + 1) {
        for (x = 0; x < 3; x = x + 1) {
            if (pix_get(5 + x, 5 + y) != 4) {
                print_msg("FAIL: paste destination cell wrong at ");
                print_int(x); print_msg(","); print_int(y); print_ln();
                return 1;
            }
        }
    }

    // Undo should roll back the paste cleanly — destination cells
    // go back to 0, source cells stay.
    if (history_undo() == 0) { print_msg("FAIL: undo returned 0"); return 1; }
    for (y = 0; y < 3; y = y + 1) {
        for (x = 0; x < 3; x = x + 1) {
            if (pix_get(5 + x, 5 + y) != 0) {
                print_msg("FAIL: undo did not clear paste dest");
                return 1;
            }
            if (pix_get(1 + x, 1 + y) != 4) {
                print_msg("FAIL: undo disturbed source cells");
                return 1;
            }
        }
    }

    // Cut — copy + erase in one stroke. Source cells cleared; undo
    // restores them.
    select_begin(1, 1); select_update(3, 3); select_end();
    if (select_cut() == 0) {
        print_msg("FAIL: select_cut returned 0"); return 1;
    }
    for (y = 1; y <= 3; y = y + 1) {
        for (x = 1; x <= 3; x = x + 1) {
            if (pix_get(x, y) != 0) {
                print_msg("FAIL: cut did not clear source");
                return 1;
            }
        }
    }
    if (history_undo() == 0) { print_msg("FAIL: undo(cut) returned 0"); return 1; }
    for (y = 1; y <= 3; y = y + 1) {
        for (x = 1; x <= 3; x = x + 1) {
            if (pix_get(x, y) != 4) {
                print_msg("FAIL: undo(cut) did not restore source");
                return 1;
            }
        }
    }

    // Stencil contract: protect colour 4. Paste onto cell that
    // currently holds 4 must be refused (pix_set short-circuits).
    g_stencil_on    = 1;
    g_stencil_color = 4;
    // Paint cell (7,7) = 4 so stencil guards it.
    g_stencil_on = 0;
    history_begin_stroke();
    pix_set(7, 7, 4);
    history_commit();
    g_stencil_on = 1;

    // Refresh clipboard to single cell of colour 2 so paste would
    // overwrite (7,7).
    g_stencil_on = 0;
    history_begin_stroke();
    pix_set(0, 0, 2);
    history_commit();
    g_stencil_on = 1;
    select_begin(0, 0); select_update(0, 0); select_end();
    if (select_copy() == 0) { print_msg("FAIL: stencil copy"); return 1; }

    select_paste(7, 7);
    if (pix_get(7, 7) != 4) {
        print_msg("FAIL: stencil did not protect cell during paste");
        print_int(pix_get(7, 7)); print_ln();
        return 1;
    }

    // Layer contract: paste targets active. Switch to layer 1,
    // paste, assert only layer 1 changed.
    g_stencil_on = 0;
    layer_add();       // now 2 layers, active = 1
    select_begin(0, 0); select_update(0, 0); select_end();
    if (select_copy() == 0) { print_msg("FAIL: copy on empty l1 ok"); return 1; }
    // Force clipboard to something paintable.
    layer_active_set(0);
    history_begin_stroke();
    pix_set(0, 0, 6);
    history_commit();
    select_begin(0, 0); select_update(0, 0); select_end();
    select_copy();

    layer_active_set(1);
    select_paste(4, 4);
    if (pix_get(4, 4) != 6) {
        print_msg("FAIL: paste did not land on active layer 1");
        return 1;
    }
    layer_active_set(0);
    if (pix_get(4, 4) != 0) {
        print_msg("FAIL: paste leaked onto layer 0");
        return 1;
    }

    select_free();
    state_free();
    print_msg("OK");
    return 0;
}
