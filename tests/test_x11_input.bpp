// test_x11_input.bpp — Phase 3 test: keyboard + mouse input from X11.
//
// A red square follows the arrow keys. A small green dot tracks the
// mouse cursor. Holding the left mouse button draws a yellow circle
// at the cursor. ESC or closing the window exits.
//
// After the game is running, Alt-Tab away and back to verify that
// FocusOut clears any stuck keys (the square should stop moving when
// the window loses focus even if a key is held).
//
// Build: ./bpp --linux64 tests/test_x11_input.bpp -o /tmp/test_x11_input
// Run:   docker run --rm -e DISPLAY=host.docker.internal:0 \
//            -v /tmp:/tmp ubuntu:22.04 /tmp/test_x11_input

import "stbgame.bsm";

main() {
    auto px, py;
    game_init(320, 180, "X11 Input Test", 60);
    px = 160; py = 90;

    while (game_should_quit() == 0) {
        game_frame_begin();

        // Arrow key movement — 2 pixels per frame.
        if (key_down(KEY_UP))    { py = py - 2; }
        if (key_down(KEY_DOWN))  { py = py + 2; }
        if (key_down(KEY_LEFT))  { px = px - 2; }
        if (key_down(KEY_RIGHT)) { px = px + 2; }
        if (key_pressed(KEY_ESC)) { break; }

        // Clamp to window bounds so the player cannot leave the screen.
        if (px < 8)   { px = 8; }
        if (py < 8)   { py = 8; }
        if (px > 312) { px = 312; }
        if (py > 172) { py = 172; }

        clear(rgba(20, 20, 40, 255));

        // Player: 16x16 red square centered on (px, py).
        draw_rect(px - 8, py - 8, 16, 16, RED);

        // Mouse cursor: 4x4 green dot.
        draw_rect(mouse_x() - 2, mouse_y() - 2, 4, 4, GREEN);

        // Left click: yellow circle at cursor position.
        if (mouse_down(MOUSE_LEFT)) {
            draw_circle(mouse_x(), mouse_y(), 10, YELLOW);
        }

        draw_text("Arrows to move  ESC to quit", 10, 10, 1, WHITE);
        draw_end();
    }
    game_end();
    return 0;
}

// No auto-close: the test runs until ESC is pressed or the window is
// closed via the window manager. Useful for interactive testing.
