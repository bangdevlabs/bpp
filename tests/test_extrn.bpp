// test_extrn.bpp — Smoke test for the `extrn` keyword.
//
// Verifies that extrn declarations:
//   1. Parse without errors.
//   2. Allocate runtime storage like a normal global.
//   3. Are writable (the freeze enforcement is a separate validator
//      pass — task #27 — and is NOT exercised here).
//   4. Coexist with `auto`, `global`, and `const` at the same file scope.
//
// Returns 0 on success.

extrn assets;
extrn config;
global world;
auto debug;
const TILE_SIZE = 32;

main() {
    assets = 100;
    config = 200;
    world = 300;
    debug = 400;

    if (assets != 100) { return 1; }
    if (config != 200) { return 2; }
    if (world != 300) { return 3; }
    if (debug != 400) { return 4; }
    if (TILE_SIZE != 32) { return 5; }

    // Multi-declaration form: extrn a, b, c; should work like auto/global.
    return 0;
}
