// test_json.bpp — round-trip smoke test for bpp_json reader + writer.
//
// Writes a small document, parses it back, and verifies every
// value survives the trip. Covers string escaping, int, bool,
// null, nested array, nested object.

import "bpp_json.bsm";

static check_eq(label, got, expected) {
    if (got != expected) {
        putmsg("FAIL: ");
        putmsg(label);
        putmsg(" got=");
        putnum(got);
        putmsg(" expected=");
        putnum(expected);
        putline();
        return 1;
    }
    return 0;
}

main() {
    auto sb, doc, root, name, score, active, nope, palette, frames, first_row, first_cell;

    init_str();

    // Build a document with every primitive type + one layer of
    // nesting (array of arrays) to stress the child-index wiring.
    sb = strbuf_new();
    sb = json_writer_begin(sb);
    sb = json_write_object_begin(sb);
        sb = json_write_string_field(sb, "name", "snake");
        sb = json_write_int_field(sb, "score", 42);
        sb = json_write_bool_field(sb, "active", 1);
        sb = json_write_null_field(sb, "nope");
        sb = json_write_array_field_begin(sb, "palette");
            sb = json_write_string(sb, "#ff0000");
            sb = json_write_string(sb, "#00ff00");
        sb = json_write_array_end(sb);
        sb = json_write_array_field_begin(sb, "frames");
            sb = json_write_array_begin(sb);
                sb = json_write_int(sb, 0);
                sb = json_write_int(sb, 1);
                sb = json_write_int(sb, 2);
            sb = json_write_array_end(sb);
        sb = json_write_array_end(sb);
    sb = json_write_object_end(sb);

    doc = json_parse(sb, strbuf_len(sb));
    if (doc == 0) { putmsg("FAIL: parse returned 0"); return 1; }
    root = json_root(doc);

    if (check_eq("type(root)", json_type(doc, root), JSON_OBJECT)) { return 1; }

    name = json_object_get(doc, root, "name");
    if (name < 0) { putmsg("FAIL: name missing"); return 1; }
    if (json_type(doc, name) != JSON_STRING) { putmsg("FAIL: name not string"); return 1; }
    if (str_eq(json_string(doc, name), "snake") == 0) { putmsg("FAIL: name round-trip"); return 1; }

    score = json_object_get(doc, root, "score");
    if (check_eq("score", json_int(doc, score), 42)) { return 1; }

    active = json_object_get(doc, root, "active");
    if (check_eq("active", json_bool(doc, active), 1)) { return 1; }

    nope = json_object_get(doc, root, "nope");
    if (check_eq("nope type", json_type(doc, nope), JSON_NULL)) { return 1; }

    palette = json_object_get(doc, root, "palette");
    if (check_eq("palette len", json_length(doc, palette), 2)) { return 1; }
    if (str_eq(json_string(doc, json_child(doc, palette, 0)), "#ff0000") == 0) {
        putmsg("FAIL: palette[0]"); return 1;
    }
    if (str_eq(json_string(doc, json_child(doc, palette, 1)), "#00ff00") == 0) {
        putmsg("FAIL: palette[1]"); return 1;
    }

    frames = json_object_get(doc, root, "frames");
    if (check_eq("frames len", json_length(doc, frames), 1)) { return 1; }
    first_row = json_child(doc, frames, 0);
    if (check_eq("first_row len", json_length(doc, first_row), 3)) { return 1; }
    first_cell = json_child(doc, first_row, 0);
    if (check_eq("first_cell val", json_int(doc, first_cell), 0)) { return 1; }
    if (check_eq("mid_cell val", json_int(doc, json_child(doc, first_row, 1)), 1)) { return 1; }
    if (check_eq("last_cell val", json_int(doc, json_child(doc, first_row, 2)), 2)) { return 1; }

    // Typed convenience getters with defaults.
    if (check_eq("get_int(score)", json_object_get_int(doc, root, "score", 0), 42)) { return 1; }
    if (check_eq("get_int(missing)", json_object_get_int(doc, root, "xxx", 99), 99)) { return 1; }
    if (str_eq(json_object_get_string(doc, root, "name"), "snake") == 0) {
        putmsg("FAIL: get_string(name)"); return 1;
    }

    json_free(doc);
    strbuf_free(sb);

    putmsg("bpp_json: write + parse + all accessors round-tripped");
    return 0;
}
