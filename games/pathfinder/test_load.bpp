// test_load.bpp — Verify that load_sprite reads the JSON correctly.
// Prints the first row of palette indices from rat_sprite.json.
// Expected output: 0 0 0 0 0 0 0 0 5 5 0 0 0 0 0 0

import "stbfile.bsm";
import "stbio.bsm";

// Minimal JSON sprite loader — no GPU, no stbsprite.
// Reads "data" array from a sprite JSON and prints the first two rows.
main() {
    auto buf, fsize_buf, fsize, pos, ch, val, i, y, x;

    fsize_buf = malloc(8);
    buf = file_read_all("assets/sprites/rat_sprite.json", fsize_buf);
    if (buf == 0) {
        print_msg("ERROR: file_read_all failed\n");
        free(fsize_buf);
        return 1;
    }
    fsize = *(fsize_buf);
    free(fsize_buf);
    print_msg("File loaded, bytes: ");
    print_int(fsize);
    print_msg("\n");

    // Find the "data" key.
    pos = 0;
    while (pos + 5 < fsize) {
        if (peek(buf+pos)=='"') { if (peek(buf+pos+1)=='d') { if (peek(buf+pos+2)=='a') {
            if (peek(buf+pos+3)=='t') { if (peek(buf+pos+4)=='a') { if (peek(buf+pos+5)=='"') {
                pos = pos + 6; break;
            } } }
        } } }
        pos = pos + 1;
    }
    print_msg("Found data at pos: ");
    print_int(pos);
    print_msg("\n");

    // Find outer array opening bracket.
    while (pos < fsize) {
        if (peek(buf + pos) == '[') { pos = pos + 1; break; }
        pos = pos + 1;
    }

    // Parse and print first 2 rows.
    y = 0;
    while (y < 2) {
        while (pos < fsize) {
            ch = peek(buf + pos); pos = pos + 1;
            if (ch == '[') { break; }
        }
        print_msg("Row ");
        print_int(y);
        print_msg(": ");
        x = 0;
        while (x < 16) {
            while (pos < fsize) {
                ch = peek(buf + pos);
                if (ch >= '0') { if (ch <= '9') { break; } }
                pos = pos + 1;
            }
            val = peek(buf + pos) - '0';
            pos = pos + 1;
            while (pos < fsize) {
                ch = peek(buf + pos);
                if (ch < '0') { break; }
                if (ch > '9') { break; }
                pos = pos + 1;
            }
            print_int(val);
            print_msg(" ");
            x = x + 1;
        }
        while (pos < fsize) {
            ch = peek(buf + pos); pos = pos + 1;
            if (ch == ']') { break; }
        }
        print_msg("\n");
        y = y + 1;
    }

    free(buf);
    return 0;
}
