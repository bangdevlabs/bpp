// rts2_render.bsm — ECS wiring + spawn + per-frame render walk.
//
// Session 3 ships one archetype (peasant) with three components:
// Pos (grid coords), Sprite (atlas + frame), UnitType (kind tag).
// Render is a thin walk that reads Pos + Sprite per entity and
// calls image_draw_size with the WC2 visual offset (sprites are
// 32 px tall but tiles are 16 px, so each peasant overhangs one
// tile row — center horizontally + bottom-align so the feet sit
// on the tile, matching war1gus).
//
// Animation, movement, combat, hot-reload of entities all defer
// to later sessions. The render callback isn't @safe annotated:
// it eventually calls _stb_gpu_sprite_uv (GPU side effect) and
// the call chain isn't @safe-tagged anywhere. Pathfind / fps
// renderers follow the same convention.

import "stbecs.bsm";
import "stbimage.bsm";
import "stbcamera.bsm";
import "stbcharsheet.bsm";
load   "rts2_units.bsm";
load   "rts2_anims.bsm";

// S9 — Gather component constants (mirrored from rts2_gather.bsm
// to avoid a wc2_render ↔ wc2_gather load cycle). The render
// path inlines the carry-atlas dispatch + mine-hide check
// because both are one-struct-load decisions that don't earn
// a cross-module function call. wc2_gather owns the writes;
// wc2_render only reads.
const _GATHER_TARGET_NONE_RD = 0;
const _GATHER_TARGET_MINE_RD = 1;
const _CARRY_NONE_RD         = 0;
const _CARRY_GOLD_RD         = 1;
const _CARRY_WOOD_RD         = 2;

// Per-faction carry atlases — populated by rts.bpp at startup via
// `wc2_render_set_carry_atlases`. Mirrors the symmetric setup in
// wc2_gather (both modules read these for their own dispatch); we
// keep TWO copies instead of one shared global because the cycle
// would require `import` instead of `load`, and the four extrn
// slots live on the bare-minimum heap (32 bytes).
static auto _render_carry_atlas_human_gold;
static auto _render_carry_atlas_human_wood;
static auto _render_carry_atlas_orc_gold;
static auto _render_carry_atlas_orc_wood;

void wc2_render_set_carry_atlases(human_gold, human_wood,
                                  orc_gold,   orc_wood) {
    _render_carry_atlas_human_gold = human_gold;
    _render_carry_atlas_human_wood = human_wood;
    _render_carry_atlas_orc_gold   = orc_gold;
    _render_carry_atlas_orc_wood   = orc_wood;
    return;
}

// Component layouts. Pos uses PIXEL coords (not tile coords) so
// movement can interpolate sub-tile for smooth 60 FPS render.
// Convert to grid via `/16` when path planning needs cell coords.
// Sprite carries the atlas pointer per entity so future archetypes
// can reference their own atlas without a global-table lookup.
// UnitType is the kind tag (UNIT_PEASANT etc). Target carries the
// right-clicked DESTINATION GRID CELL set by wc2_input; gx == -1
// sentinel means "no target". Path tracks the active movement
// intent: `mode` switches between A* waypoints (0) and flow-field
// sampling (1) — see rts2_movement.bsm PATH_MODE_*; `buf` is a per-
// unit buf_word(MAX_WP * 2) used by mode 0; `count` is the live
// waypoint count (0 = no path); `cursor` is the next waypoint
// index. In flow mode `count` / `cursor` are unused — the field
// itself drives the next-tile sample each frame. `tile_gx` /
// `tile_gy` is the unit's CURRENT TILE CLAIM in the occupancy
// grid (see rts2_movement.bsm `_occupied`); transferred atomically
// whenever the micro-target tile changes so two units can never
// stack on the same tile.
struct Pos      { x, y }
struct Sprite   { atlas, frame }
struct UnitType { kind }
struct Target   { gx, gy }
struct Path     { mode, buf, count, cursor, tile_gx, tile_gy }
// Faction tags every unit with its owning player id (0 = human side
// 1, 1 = orc side 1, ...) so S7 combat can decide "friend vs foe"
// in one read instead of consulting an external table. Stored as a
// component because every unit is faction-typed from spawn time —
// archetype-fan-out isn't needed unless future buildings or
// neutral entities show a different layout (Rule 30 trigger).
struct Faction  { player }
// Sheet stores the per-unit CharSheet handle allocated at spawn
// time. Stats (armor, damage, weapon range, cooldown, sight,
// size class, damage type) + resources (HP today; shields,
// energy when those tech upgrades land) all live behind one
// handle. Consumers read via cs_stat_get / cs_res_current.
struct Sheet    { handle }
// AttackTarget records the entity the unit is currently engaging
// plus the cooldown timer between swings. eid == -1 is the "no
// target" sentinel (matches Target.gx/gy's convention). Right-
// click on an enemy unit writes it; right-click on ground clears
// it. last_attack_ms accumulates dt while in range; combat fires
// when it crosses STAT_COOLDOWN_MS, then resets to 0.
struct AttackTarget { eid, last_attack_ms }
// Anim drives the per-unit animation state. `state` is one of
// UNIT_STATE_IDLE / UNIT_STATE_WALK (const enums in rts2_anims.bsm)
// — used to dispatch between idle anim and walk anim families.
// `facing` is one of FACE_N..FACE_NW (clockwise from north,
// 0..7); picks which atlas tag to play and whether to mirror
// horizontally. `elapsed_ms` accumulates since the last state OR
// facing change so wc2_movement can reset the cycle to frame 0
// when the unit turns or starts/stops.
struct Anim     { state, facing, elapsed_ms }
// S9 — gather state. Carried by every peasant in the unit
// archetype (it's small + always present even when the unit isn't
// gathering). `target_kind` is GATHER_TARGET_* (NONE / MINE /
// TREE); `target` is the mine eid (MINE) or the tree tile linear
// index gy*map_w+gx (TREE). `deposit_eid` is latched to the
// nearest town hall on the first cycle so subsequent runs route
// through the same building. `progress_ms` accumulates dt while
// peasant is at the target; reaches _WC2_GATHER_TICK_MS and the
// peasant flips to RETURNING_*. `carry` is CARRY_NONE / GOLD /
// WOOD — drives the atlas swap to peasant_with_gold /
// peasant_with_wood while the peasant walks back.
struct Gather   { target_kind, target, deposit_eid, progress_ms, carry }

// Maximum waypoints in a single peasant's path. Forest1 is 64×64;
// a worst-case Manhattan path crosses ~128 tiles. 256 covers that
// with headroom for diagonal expansion when 8-way pathing lands.
// Per-unit allocation = 256 * 16 bytes = 4 KB; at 256-unit cap
// that's 1 MB total for movement state — fine.
const MAX_WAYPOINTS = 256;

// Globals captured by the render callback. ecs_query_each's
// callback signature is fn(world, entity_id) — extra state has
// to flow through globals because B++ doesn't carry closures.
// Same pattern every other stbecs consumer follows.
global pos_comp, sprite_comp, unit_comp, target_comp, path_comp, anim_comp;
global faction_comp, sheet_comp, attack_target_comp, gather_comp;
global peasant_arch, peasant_q;

// Verbose per-event combat / AI / command logging gate. Off by default;
// set to 1 once at startup by rts.bpp main when `RTS_DEBUG` is in the
// environment. The hit / kill / target / AI-state lines flood the
// terminal AND show up in the frame profile (putstr was the #2 cost
// during a stress battle), so they only print when explicitly asked for.
global wc2_debug;

// Camera handle owned by rts.bpp. Read by _render_unit via
// cam_x / cam_y accessors to subtract the viewport offset from
// the per-entity screen coords; without this, units would render
// in world coords and stay pinned to (gx*16, gy*16) regardless
// of where the camera looks.
extrn cam;

// Register components + the peasant archetype + the render query.
// Call once at game startup AFTER ecs_new but BEFORE any spawn.
// The query gets built once and reused every frame; the mask
// (`1 << unit_comp`) filters the iteration to ONLY this archetype
// once S8 introduces a second one for buildings. Without the
// filter the unit render callback would fire on building entities
// too, reading garbage out of components that don't exist in the
// building archetype's chunk layout.
ecs_wire(world) {
    auto comps;
    pos_comp           = ecs_component_register(world, "Pos",          sizeof(Pos));
    sprite_comp        = ecs_component_register(world, "Sprite",       sizeof(Sprite));
    unit_comp          = ecs_component_register(world, "UnitType",     sizeof(UnitType));
    target_comp        = ecs_component_register(world, "Target",       sizeof(Target));
    path_comp          = ecs_component_register(world, "Path",         sizeof(Path));
    anim_comp          = ecs_component_register(world, "Anim",         sizeof(Anim));
    faction_comp       = ecs_component_register(world, "Faction",      sizeof(Faction));
    sheet_comp         = ecs_component_register(world, "Sheet",        sizeof(Sheet));
    attack_target_comp = ecs_component_register(world, "AttackTarget", sizeof(AttackTarget));
    gather_comp        = ecs_component_register(world, "Gather",       sizeof(Gather));
    comps    = buf_word(10);
    comps[0] = pos_comp;
    comps[1] = sprite_comp;
    comps[2] = unit_comp;
    comps[3] = target_comp;
    comps[4] = path_comp;
    comps[5] = anim_comp;
    comps[6] = faction_comp;
    comps[7] = sheet_comp;
    comps[8] = attack_target_comp;
    comps[9] = gather_comp;
    peasant_arch = ecs_archetype(world, comps, 10);
    peasant_q    = ecs_query(world, 1 << unit_comp);
}

// Spawn one unit of `kind` (UNIT_PEASANT, UNIT_ARCHER, etc.) at
// grid (gx, gy) owned by `player`. Returns the encoded entity id so
// callers can hold onto it for later kills / queries; the id is
// opaque (encoded with the archetype bit) and only useful to
// ecs_get / ecs_kill_at. The `player` argument tags the unit's
// Faction so combat can decide friend vs foe at hit-test and tick
// time; the `kind` argument selects which UnitDef (HP / damage /
// weapon range / etc.) seeds the per-unit CharSheet.
//
// All unit kinds share the same archetype today — same component
// set, only the UnitType.kind tag and the Sheet stats differ.
// Per-archetype fan-out (Rule 30 trigger) kicks in when a unit
// class needs a STRUCTURALLY different component set (e.g.
// buildings without Path, or stationary turrets without Sheet);
// the workers / ranged / melee infantry / casters share this one.
ecs_spawn_unit(world, atlas, gx, gy, player, kind) {
    auto eid;
    auto p: Pos, s: Sprite, u: UnitType, t: Target, pa: Path, an: Anim;
    auto fa: Faction, sh: Sheet, at: AttackTarget, gt: Gather;
    auto def: UnitDef;
    def = unit_def_for(kind);
    eid = ecs_spawn_at(world, peasant_arch);
    p = ecs_get(world, pos_comp, eid);
    // Pos lives in PIXEL coords so the movement system can walk
    // sub-tile each frame. Spawn places the unit centered on the
    // requested grid cell.
    p.x = gx * 32;
    p.y = gy * 32;
    s = ecs_get(world, sprite_comp, eid);
    s.atlas = atlas;
    s.frame = def.atlas_frame;
    u = ecs_get(world, unit_comp, eid);
    u.kind = kind;
    // Sentinel "no target" — movement consumer treats gx == -1
    // as "stay put" so a freshly spawned peasant doesn't try to
    // walk to (0, 0).
    t = ecs_get(world, target_comp, eid);
    t.gx = -1;
    t.gy = -1;
    // Per-unit path buffer. count = 0 means "no path", so the
    // movement tick is a no-op until wc2_input writes a target
    // and the path planner populates count + cursor. mode = 0
    // is PATH_MODE_ASTAR (defined in rts2_movement.bsm); a fresh
    // peasant always starts on the A* code path. tile_gx /
    // tile_gy mirror the spawn tile so the unit's occupancy
    // claim aligns with its initial Pos.
    pa = ecs_get(world, path_comp, eid);
    pa.buf    = buf_word(MAX_WAYPOINTS * 2);
    pa.count  = 0;
    pa.cursor = 0;
    pa.mode   = 0;
    pa.tile_gx = gx;
    pa.tile_gy = gy;
    // Reserve the spawn tile in the shared occupancy grid so
    // pathing for OTHER units treats this peasant as a blocker.
    wc2_collision_register(eid, gx, gy);
    // Initial anim state: idle facing south (the convention every
    // WC2 unit sprite renders by default). wc2_movement updates
    // facing per step + flips to UNIT_STATE_WALK when a path is
    // active.
    an = ecs_get(world, anim_comp, eid);
    an.state      = UNIT_STATE_IDLE;
    an.facing     = FACE_S;
    an.elapsed_ms = 0;
    // Faction tag — used by S7+ combat to decide friend vs foe.
    // Single-player today runs the human as player 0 against orc
    // factions at 1..N; the spawner sources this from the level
    // JSON's `player` field.
    fa = ecs_get(world, faction_comp, eid);
    fa.player = player;
    // Per-unit Sheet — clone the kind's template CharSheet so this entity
    // gets its own mutable HP/energy/shields + the combat stats. The handle
    // is freed in the death hook when the entity dies (today: leaks on quit,
    // bounded by the unit cap).
    sh = ecs_get(world, sheet_comp, eid);
    sh.handle = cs_clone(def.tmpl);
    // AttackTarget — sentinel -1 means "no target." Right-click
    // on an enemy unit (rts2_input.bsm) writes the target eid; the
    // combat tick reads + engages. last_attack_ms accumulates
    // toward STAT_COOLDOWN_MS while in range.
    at = ecs_get(world, attack_target_comp, eid);
    at.eid = -1;
    at.last_attack_ms = 0;
    // S9 Gather — every unit carries the slot; the gather tick
    // skips entries with target_kind == GATHER_TARGET_NONE so
    // non-peasant units (footmen etc.) pay zero cycle cost.
    gt = ecs_get(world, gather_comp, eid);
    gt.target_kind  = 0;          // GATHER_TARGET_NONE
    gt.target       = 0;
    gt.deposit_eid  = -1;
    gt.progress_ms  = 0;
    gt.carry        = 0;          // CARRY_NONE
    return eid;
}

// Per-entity render callback. Reads Pos + Sprite + Anim, resolves
// the current animation frame via wc2_anim_id_for + image_anim_frame,
// then dispatches to image_draw_size or image_draw_size_flipped
// depending on whether the facing requires horizontal mirror (WC2
// only stores 5 facings; W/NW/SW reuse E/NE/SE flipped).
//
// Per-entity render callback. Sprite size comes from the unit's
// UnitDef (32 px for infantry / workers, 48 px for cavalry +
// heroes — knight, raider, lothar, etc. — to fit the horse + rider
// pixels). Offset math centers horizontally + bottom-aligns the
// feet on the 32 px tile anchor: dx = -(px - 32) / 2, dy = -(px - 32).
// For a 48 px sprite that yields (-8, -16); for a 64 px sprite,
// (-16, -32). Matches the war1gus reference placement.
static void _render_unit(w, eid) {
    auto p: Pos, s: Sprite, an: Anim, u: UnitType;
    auto def: UnitDef;
    auto anim_id, flip, sprite_id, sx, sy, px, off_x, off_y;
    auto draw_atlas, gt: Gather, fa: Faction;
    p  = ecs_get(w, pos_comp,    eid);
    s  = ecs_get(w, sprite_comp, eid);
    an = ecs_get(w, anim_comp,   eid);
    u  = ecs_get(w, unit_comp,   eid);
    gt = ecs_get(w, gather_comp, eid);
    def = unit_def_for(u.kind);
    // Native-size draw: paint the padded sprite cell (frame_w) at 1:1 with
    // the figure's foot anchor (anc_x, anc_y) sitting on the tile's ground
    // point — tile centre x (p.x + 16) and tile bottom y (p.y + 32). No
    // downscale; the unit stands at native resolution on its tile.
    px    = def.frame_w;
    off_x = 16 - def.anc_x;
    off_y = 32 - def.anc_y;
    // S9 — peasants inside a gold mine vanish (canonical WC2
    // feedback). The gather state machine sets the Anim.state to
    // GATHER_GOLD only after the peasant arrives at the mine,
    // so this check skips the actual draw without removing the
    // unit from the simulation.
    if (gt.target_kind == _GATHER_TARGET_MINE_RD
        && gt.carry == _CARRY_NONE_RD
        && an.state == UNIT_STATE_GATHER_GOLD) {
        return;
    }
    anim_id = 0;
    flip    = 0;
    wc2_anim_id_for(an.state, an.facing, &anim_id, &flip);
    // S9 — atlas swap. Peasants carrying gold / wood render
    // through the peasant_with_* / peon_with_* atlases so the
    // WC2 carry visual shows up. Faction read tells us which
    // sprite set to use (human vs orc).
    // Carry sprite is a PEASANT-only visual. Guard on kind so a
    // military unit that happens to carry stale gather state (ECS slot
    // recycling can leave a freed peon's carry behind) never renders
    // with the peon-carry atlas — that produced the "footman/archer
    // turned into a giant/small peon" bug.
    draw_atlas = s.atlas;
    if (u.kind == UNIT_PEASANT && gt.carry != _CARRY_NONE_RD) {
        fa = ecs_get(w, faction_comp, eid);
        if (gt.carry == _CARRY_GOLD_RD) {
            if (fa.player == 0) { draw_atlas = _render_carry_atlas_human_gold; }
            else                { draw_atlas = _render_carry_atlas_orc_gold;   }
        } else {
            if (fa.player == 0) { draw_atlas = _render_carry_atlas_human_wood; }
            else                { draw_atlas = _render_carry_atlas_orc_wood;   }
        }
        if (draw_atlas == 0) { draw_atlas = s.atlas; }
    }
    sprite_id = image_anim_frame(draw_atlas, anim_id, an.elapsed_ms);
    // Defensive: if the atlas didn't carry the requested anim,
    // sprite_id falls back to -1 — keep rendering the spawn-time
    // default frame instead of crashing.
    if (sprite_id < 0) { sprite_id = s.frame; }
    sx = cam_world_to_screen_x(cam, p.x + off_x);
    sy = cam_world_to_screen_y(cam, p.y + off_y);
    if (flip != 0) {
        image_draw_size_flipped(draw_atlas, sprite_id, sx, sy, px, px);
    } else {
        image_draw_size(draw_atlas, sprite_id, sx, sy, px, px);
    }
}

// Walk every unit and emit its sprite. Call once per frame between
// the tile draw and game_render_end. Cheap — peasant_q caches the
// query so the per-frame cost is just the alive-bitmap walk +
// per-entity callback dispatch.
ecs_render_units(world) {
    ecs_query_each(peasant_q, fn_ptr(_render_unit));
}
