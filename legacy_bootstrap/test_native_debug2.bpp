import "defs.bsm";
import "bpp_internal.bsm";
import "bpp_import.bsm";
import "bpp_parser.bsm";
import "bpp_lexer.bsm";
import "bpp_types.bsm";
import "bpp_dispatch.bsm";
import "bpp_emitter.bsm";
import "bpp_enc_arm64.bsm";
import "bpp_codegen_arm64.bsm";
import "bpp_macho.bsm";

main() {
    auto arg_len, arg_ptr;

    init_defs();
    init_internal();
    init_import();
    init_parser();
    init_lexer();
    init_types();
    init_dispatch();
    init_emitter();
    init_enc_arm64();
    init_codegen_arm64();
    init_macho();

    putchar('A');
    arg_ptr = argv_get(1);
    putchar('B');
    arg_len = copy_cstr(pathbuf, arg_ptr);
    putchar('C');
    process_file(pathbuf, arg_len);
    putchar('D');

    src = outbuf;
    src_len = outbuf_len;
    putchar('E');
    lex_all();
    putchar('F');
    parse_program();
    putchar('G');
    run_types();
    putchar('H');
    run_dispatch();
    putchar('I');

    emit_all();
    putchar('J');
    putchar('\n');
    return 0;
}
