// bpp_validate.bsm — Unified validation + type checking for the B++ compiler.
// Runs after type inference, before codegen. Checks:
//   Layer 1 (always on): undefined functions, arg count, unreachable code, float→int at call.
//   Layer 2 (hint-activated): type compatibility on annotated variables.
// All errors are platform-agnostic. When validate passes, any backend can trust the IR.

import "bpp_defs.bsm";
import "bpp_array.bsm";
import "bpp_hash.bsm";
import "bpp_internal.bsm";
import "bpp_diag.bsm";
import "bpp_parser.bsm";
import "bpp_types.bsm";

// ── Hint table (per-function, tracks type annotations) ──────

static auto _val_hn, _val_ht;

// Symbol lookup acceleration. _val_func_hash maps a function name's
// byte sequence to (index + 1) in funcs[] — the +1 keeps "absent"
// distinguishable from "index 0". Same scheme for externs. The hashes
// are rebuilt at the start of each validation pass (run_validate or
// validate_module) so they always reflect the current func/extern
// tables, including modules loaded incrementally.
static auto _val_func_hash, _val_extern_hash;
static auto _val_current_fi;    // func index currently being validated
static auto _val_src_tok;       // src_tok of the current node being checked

// Print source location for a warning/error using the AST node's saved
// token position. Shows file:line + source line with caret, compatible
// with Emacs M-x compile and VS Code problem matcher.
static void _val_show_context_at(stok) {
    if (stok > 0) {
        diag_loc(stok);
        diag_show_line(stok);
    }
}

// Show context from the current node being validated.
// Falls back to function name if no source token available.
static void _val_show_context() {
    // Caller should use _val_show_context_at(n.src_tok) when possible.
    // This fallback shows the function name for cases where we don't
    // have a specific node (e.g., dispatch-level warnings).
    auto _fn_name;
    if (_val_current_fi >= 0) {
        _fn_name = *(funcs[_val_current_fi] + FN_NAME);
        diag_str("  in: ");
        diag_packed(_fn_name);
        diag_str("()");
        diag_newline();
    }
}

void init_validate() {
    _val_hn = arr_new();
    _val_ht = arr_new();
    _val_func_hash = hash_str_new(256);
    _val_extern_hash = hash_str_new(64);
}

static void _val_reset_hints() {
    arr_clear(_val_hn);
    arr_clear(_val_ht);
}

static void _val_add_hint(name_p, hint) {
    auto i;
    for (i = 0; i < arr_len(_val_hn); i++) {
        if (packed_eq(arr_get(_val_hn, i), name_p)) { return; }
    }
    _val_hn = arr_push(_val_hn, name_p);
    _val_ht = arr_push(_val_ht, hint);
}

static _val_get_hint(name_p) {
    auto i;
    for (i = 0; i < arr_len(_val_hn); i++) {
        if (packed_eq(arr_get(_val_hn, i), name_p)) { return arr_get(_val_ht, i); }
    }
    return 0;
}

// Returns 1 if name_p is the name of an un-hinted parameter of the
// function currently under validation. Used by W025 to detect the
// shape "public function, param used in float arithmetic, caller
// never told us whether the param is int or float".
static _val_is_unhinted_param(name_p) {
    auto rec, params_arr, hints, pc, j;
    if (_val_current_fi < 0) { return 0; }
    rec = funcs[_val_current_fi];
    params_arr = *(rec + FN_PARS);
    hints = *(rec + FN_HINTS);
    pc = *(rec + FN_PCNT);
    for (j = 0; j < pc; j++) {
        if (packed_eq(params_arr[j], name_p)) {
            if (hints == 0) { return 1; }
            if (hints[j] == 0) { return 1; }
            return 0;
        }
    }
    return 0;
}

// ── Builtin recognition ─────────────────────────────────────

// Compare a packed name against a C literal of known length. Pure: only
// reads from vbuf via peek. Marked `: base` so dispatch classifies the
// caller (`val_is_builtin`) as base-eligible too.
static _val_name_eq(name_p, lit, len) {
    if (unpack_l(name_p) != len) { return 0; }
    return buf_eq(vbuf + unpack_s(name_p), lit, len);
}

// W027 — RESOLVED 2026-05-04 by the AAPCS64 / System V refactor.
// `call(fp, args...)` now routes float args to d0..d7 / xmm0..xmm7
// per ABI (independent counters, separate from int regs), and the
// callee prologue reads float params from those FP registers
// directly. The trap the diagnostic flagged no longer exists; the
// helper is kept as a no-op stub so the call site in T_CALL
// doesn't need a code change beyond the `diag_warn(27)` deletion.
// See `docs/warning_error_log.md` "FFI float-param trap" entry for
// the historical context.
static void _val_check_fn_ptr(name_p, nd) {
    return;
}

// V3 Session 3 — when `call(fp, ...)` is invoked through a local that
// carries an explicit `: func(...)` annotation, the annotation is the
// contract. Validate each arg against the annotated signature; mismatch
// is E246 hard error. Skips slots where either side is TY_UNK.
static void _val_check_call_args_against_fntype(fp_ty, args_arr, arg_cnt, src_tok) {
    auto ai, arg_nd, arg: Node, arg_ty, par_ty, expected_arg_count;
    expected_arg_count = fn_type_arg_count(fp_ty);
    for (ai = 0; ai < arg_cnt; ai++) {
        if (ai >= expected_arg_count) { break; }
        arg_nd = args_arr[ai];
        if (arg_nd == 0) { continue; }
        arg = arg_nd;
        arg_ty = arg.itype;
        par_ty = fn_type_arg(fp_ty, ai);
        if (arg_ty == TY_UNK || par_ty == TY_UNK) { continue; }
        if (is_fn_type(arg_ty) || is_fn_type(par_ty)) { continue; }
        if (is_float_type(arg_ty) != is_float_type(par_ty)) {
            diag_error(246);
            diag_str("argument ");
            diag_int(ai + 1);
            diag_str(" of call() is ");
            diag_str(val_type_name(arg_ty));
            diag_str(", but the func-type annotation declares parameter ");
            diag_int(ai + 1);
            diag_str(" as ");
            diag_str(val_type_name(par_ty));
            diag_newline();
            _val_show_context_at(src_tok);
            diag_str("  = help: the annotation '");
            diag_str(val_type_name(fp_ty));
            diag_str("' is the contract — change the caller to pass the matching type, or update the annotation");
            diag_newline();
        }
    }
}

// Excalibur Arc Feature 1 (Session 1.B) — promote a SHAPE_INT
// literal to a SHAPE_DECIMAL one in place, so codegen treats it
// as float. Used at the call boundary when an integer literal is
// passed to a `: float` parameter — int → float widening is
// lossless and matches the universal numeric-literal idiom of
// every modern language we draw from (Jai / Zig / Odin / C).
//
// Implementation: append ".0" to the literal's source bytes in
// `vbuf` (the shared interned buffer; codegen's `cg_sbuf` is the
// same pointer) and update the node's packed ref to span the new
// length. `cg_is_float_lit` then recognises it on the codegen
// side without any new code path.
//
// Hex literals are NOT promoted — `0xFF.0` would not parse as a
// float. The detection in the E240 site filters them out.
//
// `@io` because it mutates the shared `vbuf` buffer.
static void _val_promote_int_lit_to_float(node_p)  {
    auto n: Node, s, l, new_start, i, ch;
    n = node_p;
    s = unpack_s(n.a);
    l = unpack_l(n.a);
    new_start = vbuf_pos;
    for (i = 0; i < l; i++) {
        ch = peek(vbuf + s + i);
        poke(vbuf + vbuf_pos, ch);
        vbuf_pos++;
    }
    poke(vbuf + vbuf_pos, '.');
    vbuf_pos++;
    poke(vbuf + vbuf_pos, '0');
    vbuf_pos++;
    n.a     = pack(new_start, l + 2);
    n.b     = SHAPE_DECIMAL;
    n.itype = TY_FLOAT;
}

// Return 1 when a literal node's source bytes look like a
// hexadecimal literal (`0x...`). Hex literals can't be promoted
// to float by appending ".0" — `0xFF.0` is not a valid float
// syntax — so the polymorphic-literal path skips them and lets
// E240 fire as before.
static _val_lit_is_hex(node_p) {
    auto n: Node, s, l;
    n = node_p;
    s = unpack_s(n.a);
    l = unpack_l(n.a);
    if (l < 2) { return 0; }
    if (peek(vbuf + s) != '0') { return 0; }
    if (peek(vbuf + s + 1) == 'x') { return 1; }
    if (peek(vbuf + s + 1) == 'X') { return 1; }
    return 0;
}

// V3 Session 2 — for a resolved target function fidx, validate each
// arg's compile-time type against the callee's declared param type.
// Mismatch on float/int polarity emits W028. Skips slots where either
// side is TY_UNK (no information → no diagnostic).
static void _val_check_call_args_against(target_fi, args_arr, arg_cnt, target_name_p, src_tok) {
    auto ai, arg_nd, arg: Node, arg_ty, par_ty;
    for (ai = 0; ai < arg_cnt; ai++) {
        arg_nd = args_arr[ai];
        if (arg_nd == 0) { continue; }
        arg = arg_nd;
        arg_ty = arg.itype;
        par_ty = get_fn_par_type(target_fi, ai);
        if (arg_ty == TY_UNK || par_ty == TY_UNK) { continue; }
        if (is_fn_type(arg_ty) || is_fn_type(par_ty)) { continue; }
        // Mismatch only when one side is float and the other is not —
        // call() routes through register banks, so the bit pattern
        // ends up in the wrong bank and silently corrupts.
        if (is_float_type(arg_ty) != is_float_type(par_ty)) {
            diag_warn(28);
            diag_str("argument ");
            diag_int(ai + 1);
            diag_str(" of call() is ");
            diag_str(val_type_name(arg_ty));
            diag_str(", but the resolved target '");
            diag_packed(target_name_p);
            diag_str("' declares parameter ");
            diag_int(ai + 1);
            diag_str(" as ");
            diag_str(val_type_name(par_ty));
            diag_str(" — call() routes args by AAPCS64/SysV register bank, so this mismatch will silently corrupt the value at runtime");
            diag_newline();
            _val_show_context_at(src_tok);
            diag_str("  = help: declare the local as ': ");
            diag_str(val_type_name(par_ty));
            diag_str("' so its bits flow unchanged, OR change the callee's parameter type to match");
            diag_newline();
        }
    }
}

// Return 1 if `name_p` refers to a compiler-emitted builtin. The set is
// closed — any call to a name not listed here and not declared by the
// user's source falls through to E201. Grouped by family so a future
// addition lands in the right block without shotgun-search.
//
// Notes on what is NOT here:
//   - malloc / free / realloc / memcpy — live in
//     `backend/os/<target>/_bmem_<target>.bsm` as auto-injected B++
//     functions. They look like builtins to the programmer but the
//     validator sees real definitions.
//   - putchar / getchar / putchar_err — same story, `bpp_io.bsm`.
val_is_builtin(name_p) {
    // Scalar ops + core accessors.
    if (_val_name_eq(name_p, "shr", 3))        { return 1; }
    if (_val_name_eq(name_p, "assert", 6))     { return 1; }
    if (_val_name_eq(name_p, "float_ret", 9))  { return 1; }
    if (_val_name_eq(name_p, "float_ret2", 10)){ return 1; }
    if (_val_name_eq(name_p, "peek", 4))          { return 1; }
    if (_val_name_eq(name_p, "poke", 4))          { return 1; }
    if (_val_name_eq(name_p, "str_peek", 8))      { return 1; }
    if (_val_name_eq(name_p, "peek_q", 6))        { return 1; }
    if (_val_name_eq(name_p, "peek_h", 6))        { return 1; }
    if (_val_name_eq(name_p, "peek_w", 6))        { return 1; }
    if (_val_name_eq(name_p, "poke_q", 6))        { return 1; }
    if (_val_name_eq(name_p, "poke_h", 6))        { return 1; }
    if (_val_name_eq(name_p, "poke_w", 6))        { return 1; }
    if (_val_name_eq(name_p, "peekfloat", 9))     { return 1; }
    if (_val_name_eq(name_p, "peekfloat_h", 11))  { return 1; }
    if (_val_name_eq(name_p, "pokefloat", 9))     { return 1; }
    if (_val_name_eq(name_p, "pokefloat_h", 11))  { return 1; }

    // Excalibur Feature 2 — explicit float→int conversion builtins.
    // Each takes a `: float` arg and returns a `: word` integer. The
    // codegen lowers them to chip-specific rounding+cast pairs.
    if (_val_name_eq(name_p, "floor_int", 9))     { return 1; }
    if (_val_name_eq(name_p, "trunc_int", 9))     { return 1; }
    if (_val_name_eq(name_p, "round_int", 9))     { return 1; }

    // Phase 6.2c — caller introspection. caller_pc(n) is the
    // FP-chain walk builtin; caller_name(pc) is a regular B++
    // function in bpp_runtime.bsm (auto-injected) so it is NOT
    // listed here.
    if (_val_name_eq(name_p, "caller_pc", 9))     { return 1; }

    // Process-level: argv/envp/arg_count and function-pointer dispatch.
    if (_val_name_eq(name_p, "argc_get", 8))   { return 1; }
    if (_val_name_eq(name_p, "argv_get", 8))   { return 1; }
    if (_val_name_eq(name_p, "envp_get", 8))   { return 1; }
    if (_val_name_eq(name_p, "fn_ptr", 6))     { return 1; }
    if (_val_name_eq(name_p, "call", 4))       { return 1; }

    // Raw syscalls. sys_* are target-specific but the names are shared
    // across macOS and Linux — codegen picks the right syscall number.
    if (_val_name_eq(name_p, "sys_write", 9))         { return 1; }
    if (_val_name_eq(name_p, "sys_read", 8))          { return 1; }
    if (_val_name_eq(name_p, "sys_open", 8))          { return 1; }
    if (_val_name_eq(name_p, "sys_close", 9))         { return 1; }
    if (_val_name_eq(name_p, "sys_fork", 8))          { return 1; }
    if (_val_name_eq(name_p, "sys_execve", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_waitpid", 11))      { return 1; }
    if (_val_name_eq(name_p, "sys_exit", 8))          { return 1; }
    if (_val_name_eq(name_p, "sys_getdents", 12))     { return 1; }
    if (_val_name_eq(name_p, "sys_unlink", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_ptrace", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_wait4", 9))         { return 1; }
    if (_val_name_eq(name_p, "sys_lseek", 9))         { return 1; }
    if (_val_name_eq(name_p, "sys_fchmod", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_ioctl", 9))         { return 1; }
    if (_val_name_eq(name_p, "sys_socket", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_connect", 11))      { return 1; }
    if (_val_name_eq(name_p, "sys_select", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_usleep", 10))       { return 1; }
    if (_val_name_eq(name_p, "sys_nanosleep", 13))    { return 1; }
    if (_val_name_eq(name_p, "sys_clock_gettime", 17)){ return 1; }
    if (_val_name_eq(name_p, "sys_mkdir", 9))         { return 1; }
    if (_val_name_eq(name_p, "mem_barrier", 11))      { return 1; }
    if (_val_name_eq(name_p, "sys_mmap", 8))          { return 1; }
    if (_val_name_eq(name_p, "sys_munmap", 10))       { return 1; }

    // Phase B4: 128-bit SIMD (4 × float32). Each vec_* lowers to NEON on
    // ARM64 and SSE2 on x86_64. vec_dot4 and vec_get4 return a scalar
    // double; every other vec_* returns a SIMD value in V0 / xmm0.
    if (_val_name_eq(name_p, "vec_load4", 9))   { return 1; }
    if (_val_name_eq(name_p, "vec_store4", 10)) { return 1; }
    if (_val_name_eq(name_p, "vec_add4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_sub4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_mul4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_div4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_min4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_max4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_splat4", 10)) { return 1; }
    if (_val_name_eq(name_p, "vec_dot4", 8))    { return 1; }
    if (_val_name_eq(name_p, "vec_get4", 8))    { return 1; }
    return 0;
}

// ── Lookup helpers ──────────────────────────────────────────

// Rebuild the function-name hash from the current funcs[] table.
// Called at the top of every validation pass so the hash always
// reflects the live symbol table (modules can be loaded incrementally
// and grow funcs[] between passes). Stores (i + 1) so a return of 0
// from hash_str_get unambiguously means "absent".
static void _val_build_func_hash() {
    auto i, rec, name_p;
    hash_str_clear(_val_func_hash);
    for (i = 0; i < func_cnt; i++) {
        rec = funcs[i];
        name_p = *(rec + FN_NAME);
        hash_str_set(_val_func_hash,
                     vbuf + unpack_s(name_p), unpack_l(name_p),
                     i + 1);
    }
}

// Rebuild the extern-name hash from the current externs[] table.
static void _val_build_extern_hash() {
    auto i, rec, name_p;
    hash_str_clear(_val_extern_hash);
    for (i = 0; i < ext_cnt; i++) {
        rec = externs[i];
        name_p = *(rec + EX_NAME);
        hash_str_set(_val_extern_hash,
                     vbuf + unpack_s(name_p), unpack_l(name_p),
                     i + 1);
    }
}

// E223: a name cannot serve as both an `extrn`-declared global and a
// defined function. The native backend tolerates the duplicate because
// it resolves call sites through the function table and ignores the
// extrn entry, but C — the language B++ targets through the C emitter
// and exposes through FFI — has a single namespace where a symbol is
// either a variable or a function, never both. Catching the conflict
// here keeps B++'s symbol surface compatible with C/Unix linker rules.
//
// The fix at the source side is almost always to delete the stale
// `extrn X;` declaration: cross-module function calls in B++ resolve
// through the function table, so the forward declaration was never
// load-bearing.
static void _val_check_extrn_func_collision() {
    auto i, name_p;
    for (i = 0; i < glob_cnt; i++) {
        if (arr_get(glob_class, i) == GLOB_EXTRN) {
            name_p = globals[i];
            if (val_find_func(name_p) >= 0) {
                diag_error(223);
                diag_str("'");
                diag_packed(name_p);
                diag_str("' is declared as `extrn` (global) but also defined as a function — a symbol cannot occupy both namespaces in C/FFI builds");
                diag_newline();
                diag_help("delete the `extrn ");
                diag_packed(name_p);
                diag_str(";` declaration; cross-module function calls resolve through the function table without a forward declaration");
                diag_newline();
            }
        }
    }
}

// Look up a function by packed name. O(1) via the hash; falls back to
// returning -1 if absent. The +1/-1 dance compensates for hash_str_get
// returning 0 for absent keys.
val_find_func(name_p) {
    auto v;
    v = hash_str_get(_val_func_hash,
                     vbuf + unpack_s(name_p), unpack_l(name_p));
    if (v == 0) { return -1; }
    return v - 1;
}

// Look up an extern by packed name. O(1) via the hash.
val_find_extern(name_p) {
    auto v;
    v = hash_str_get(_val_extern_hash,
                     vbuf + unpack_s(name_p), unpack_l(name_p));
    if (v == 0) { return -1; }
    return v - 1;
}

// ── Type name helper (for diagnostics) ──────────────────────

// Shared scratch buffer for fn-type pretty printing. Reused across
// every val_type_name call that hits a fn-type — diag_str copies the
// content out before the next val_type_name fires, so a single buffer
// suffices.
static auto _val_fntype_buf;

const VAL_FNTYPE_MAX_DEPTH = 8;

// Recursively format a fn-type into the strbuf. Caller passes the
// current buf; this returns the (possibly relocated) buf so chained
// strbuf_cat calls stay correct.
static _val_fntype_format(buf, ty, depth) {
    auto rec: FnTypeRec, i;
    if (depth >= VAL_FNTYPE_MAX_DEPTH) {
        buf = strbuf_cat(buf, "func(<too deep>)");
        return buf;
    }
    if (is_fn_type(ty) == 0) {
        buf = strbuf_cat(buf, val_type_name(ty));
        return buf;
    }
    rec = fn_type_get_record(ty);
    buf = strbuf_cat(buf, "func(");
    for (i = 0; i < rec.arg_count; i++) {
        if (i > 0) { buf = strbuf_cat(buf, ", "); }
        buf = _val_fntype_format(buf, rec.args[i], depth + 1);
    }
    buf = strbuf_cat(buf, ") -> ");
    if (rec.ret_type == TY_UNK) {
        buf = strbuf_cat(buf, "void");
    } else {
        buf = _val_fntype_format(buf, rec.ret_type, depth + 1);
    }
    return buf;
}

// V3 Session 3 — structural compat check between two func-types.
// Hash-cons interning makes equal-id imply equal-shape, so the
// short-circuit catches every legitimately-compatible pair. The
// fallback loop is defensive: if a future intern bug ever produced
// two distinct ids for the same shape, we still answer truthfully
// instead of falsely rejecting.
static _val_fn_types_compat(a_ty, b_ty) {
    auto a: FnTypeRec, b: FnTypeRec, i;
    if (a_ty == b_ty) { return 1; }
    a = fn_type_get_record(a_ty);
    b = fn_type_get_record(b_ty);
    if (a.arg_count != b.arg_count) { return 0; }
    if (a.ret_type != b.ret_type) { return 0; }
    for (i = 0; i < a.arg_count; i++) {
        if (a.args[i] != b.args[i]) { return 0; }
    }
    return 1;
}

val_type_name(ty) {
    if (is_fn_type(ty)) {
        if (_val_fntype_buf == 0) { _val_fntype_buf = strbuf_new(); }
        strbuf_clear(_val_fntype_buf);
        _val_fntype_buf = _val_fntype_format(_val_fntype_buf, ty, 0);
        return _val_fntype_buf;
    }
    if (ty == TY_WORD)    { return "word"; }
    if (ty == TY_WORD_H)  { return "half"; }
    if (ty == TY_WORD_Q)  { return "quarter"; }
    if (ty == TY_WORD_B)  { return "byte"; }
    if (ty == TY_FLOAT)   { return "float"; }
    if (ty == TY_FLOAT_H) { return "half float"; }
    if (ty == TY_FLOAT_Q) { return "quarter float"; }
    if (ty == TY_WORD_BIT)  { return "bit"; }
    if (ty == TY_WORD_BIT2) { return "bit2"; }
    if (ty == TY_WORD_BIT3) { return "bit3"; }
    if (ty == TY_WORD_BIT4) { return "bit4"; }
    if (ty == TY_WORD_BIT5) { return "bit5"; }
    if (ty == TY_WORD_BIT6) { return "bit6"; }
    if (ty == TY_WORD_BIT7) { return "bit7"; }
    if (ty == TY_PTR)     { return "ptr"; }
    if (ty == TY_STRUCT)  { return "struct"; }
    return "unknown";
}

// ── Layer 2: type compatibility check ───────────────────────

// Check assignment compatibility when the variable has a type hint.
// Returns 0=ok, 1=warning, 2=error.
val_check_assign_compat(hint_ty, val_ty, var_name_p) {
    auto hb, vb, hs, vs;
    if (val_ty == TY_UNK) { return 0; }
    // V3 Session 3: when both sides carry func-type annotations, do
    // a structural shape match. Mismatch is E246 hard error — the
    // annotation is the contract. One-sided fn-typed assignments
    // still skip (rude-first preserved); flow analysis (W028) covers
    // the runtime risk for those.
    if (is_fn_type(hint_ty) && is_fn_type(val_ty)) {
        if (_val_fn_types_compat(hint_ty, val_ty) == 0) {
            diag_error(246);
            diag_str("incompatible func-types: cannot assign ");
            diag_str(val_type_name(val_ty));
            diag_str(" to '");
            diag_packed(var_name_p);
            diag_str("' (declared as ");
            diag_str(val_type_name(hint_ty));
            diag_str(")");
            diag_newline();
            _val_show_context_at(_val_src_tok);
        }
        return 0;
    }
    if (is_fn_type(hint_ty) || is_fn_type(val_ty)) { return 0; }

    hb = ty_base(hint_ty);
    vb = ty_base(val_ty);
    hs = ty_slice(hint_ty);
    vs = ty_slice(val_ty);

    // E050: ptr to non-ptr.
    if (vb == BASE_PTR) {
        if (hb != BASE_PTR) {
            diag_error(50);
            diag_str("cannot assign ptr to '");
            diag_packed(var_name_p);
            diag_str("' (declared as ");
            diag_str(val_type_name(hint_ty));
            diag_str(")");
            diag_newline();
            _val_show_context_at(_val_src_tok);
        }
    }

    // E053: non-ptr to ptr.
    if (hb == BASE_PTR) {
        if (vb != BASE_PTR) {
            diag_error(53);
            diag_str("assigning ");
            diag_str(val_type_name(val_ty));
            diag_str(" to '");
            diag_packed(var_name_p);
            diag_str("' (declared as ptr) without cast");
            diag_newline();
            _val_show_context_at(_val_src_tok);
        }
    }

    // Float-to-word truncation is intentional and commonly used to
    // convert float results to integer storage (e.g. rounding screen
    // coordinates). The native backends emit fcvtzs implicitly and the
    // C emitter relies on C's implicit double→long long truncation, so
    // no diagnostic fires here. See _stb_platform_macos.bsm mouse code
    // for the canonical pattern.

    // W011: int to narrow float (precision loss). BASE_UWORD also
    // an int family — precision loss is signedness-agnostic, so
    // both signed (BASE_WORD) and unsigned (BASE_UWORD) sources
    // narrow into a smaller float identically.
    if (hb == BASE_FLOAT) {
        if (vb == BASE_WORD || vb == BASE_UWORD) {
            if (slice_width(hs) < slice_width(vs)) {
                diag_warn(11);
                diag_str("possible precision loss: ");
                diag_str(val_type_name(val_ty));
                diag_str(" to '");
                diag_packed(var_name_p);
                diag_str("' (");
                diag_str(val_type_name(hint_ty));
                diag_str(")");
                diag_newline();
                _val_show_context_at(_val_src_tok);
            }
        }
    }

    // W010: narrowing same base.
    if (hb == vb) {
        if (slice_width(hs) < slice_width(vs)) {
            diag_warn(10);
            diag_str("narrowing: ");
            diag_str(val_type_name(val_ty));
            diag_str(" to '");
            diag_packed(var_name_p);
            diag_str("' (");
            diag_str(val_type_name(hint_ty));
            diag_str(")");
            diag_newline();
            _val_show_context_at(_val_src_tok);
        }
    }

    return 0;
}

// ── AST walker ──────────────────────────────────────────────

// Forward declaration for mutual recursion.
val_check_node(nd) { return 0; }

// Walk a statement list. W005: warn on unreachable code after return.
val_check_list(arr, cnt) {
    auto i, saw_ret, nd;
    auto sn: Node;
    saw_ret = 0;
    for (i = 0; i < cnt; i++) {
        nd = arr[i];
        if (nd != 0) {
            if (saw_ret) {
                diag_warn(5);
                diag_str("unreachable code after return");
                diag_newline();
                _val_show_context_at(sn.src_tok);
                saw_ret = 0;
            }
            sn = nd;
            if (sn.ntype == T_RET) { saw_ret = 1; }
        }
        val_check_node(nd);
    }
    return 0;
}

// Recursively validate + type-check an AST node.
val_check_node(nd) {
    auto n: Node, t, name_p;
    if (nd == 0) { return 0; }
    n = nd;
    t = n.ntype;
    _val_src_tok = n.src_tok;

    switch (t) {
    T_DECL {
        auto vars_arr, var_cnt, hints_arr, single_hint, i, h;
        vars_arr = n.a;
        var_cnt = n.b;
        hints_arr = n.e;
        single_hint = n.c;
        if (hints_arr != 0) {
            for (i = 0; i < var_cnt; i++) {
                h = hints_arr[i];
                if (h > 0) { _val_add_hint(vars_arr[i], h); }
            }
        } else if (single_hint > 0) {
            for (i = 0; i < var_cnt; i++) {
                _val_add_hint(vars_arr[i], single_hint);
            }
        }
        return 0;
    }
    T_ASSIGN {
        auto lhs: Node, rhs: Node, hint_ty, val_ty, lhs_ty;
        lhs = n.a;
        if (lhs != 0) {
            if (lhs.ntype == T_VAR) {
                // E263 — write to a const slot. `global const` and
                // `static const` declare read-only data slots; any
                // assignment to them is a contract violation. Walk
                // globals[] to resolve the var name and inspect its
                // class. The lookup is the same shape dsp_find_global
                // uses, inlined here to avoid pulling bpp_dispatch
                // into validate's import graph.
                auto _cw_i, _cw_gp, _cw_class;
                _cw_class = -1;
                for (_cw_i = 0; _cw_i < glob_cnt; _cw_i++) {
                    _cw_gp = arr_get(globals, _cw_i);
                    if (_cw_gp == lhs.a) {
                        _cw_class = arr_get(glob_class, _cw_i);
                        break;
                    }
                    if (packed_eq(_cw_gp, lhs.a)) {
                        _cw_class = arr_get(glob_class, _cw_i);
                        break;
                    }
                }
                if (_cw_class == GLOB_GLOBAL_CONST
                    || _cw_class == GLOB_STATIC_CONST) {
                    diag_error(263);
                    diag_str("cannot assign to const slot '");
                    diag_packed(lhs.a);
                    diag_str("'");
                    diag_newline();
                    _val_show_context_at(_val_src_tok);
                    diag_help("'global const' / 'static const' slots are read-only after init — declare the slot as 'auto' or 'global' if mutability is required");
                    diag_newline();
                }
                hint_ty = _val_get_hint(lhs.a);
                val_ty  = n.itype;
                // Node.itype is byte-sliced; func-type ids (BASE_FN +
                // table_idx in upper bits) overflow to BASE_FN alone.
                // For VAR-to-VAR assignments the recorded hint is the
                // authoritative full-word id, so consult it.
                if (n.b != 0) {
                    rhs = n.b;
                    if (rhs.ntype == T_VAR) {
                        auto _rhs_hint;
                        _rhs_hint = _val_get_hint(rhs.a);
                        if (_rhs_hint > 0) { val_ty = _rhs_hint; }
                    }
                }
                lhs_ty  = lhs.itype;
                if (hint_ty > 0) {
                    val_check_assign_compat(hint_ty, val_ty, lhs.a);
                }
                // E262 — cross-struct assignment between typed locals.
                // Excalibur Feature 3 closure: if both lhs and rhs are
                // typed variables (`auto wp: WorldPos`, `auto gp:
                // GridPos`) and their struct identities differ, the
                // assignment is almost always a domain-mixing bug. The
                // error fires for the canonical case `wp = gp;` where
                // both wrap Vec2 but represent different worlds. The
                // help text suggests the explicit conversion-helper
                // pattern the spec endorses.
                if (n.b != 0) {
                    auto _xs_rhs: Node, _xs_lhs_sidx, _xs_rhs_sidx;
                    _xs_rhs = n.b;
                    if (_xs_rhs.ntype == T_VAR) {
                        _xs_lhs_sidx = get_var_type_in_fn(lhs.a, _val_current_fi);
                        _xs_rhs_sidx = get_var_type_in_fn(_xs_rhs.a, _val_current_fi);
                        if (_xs_lhs_sidx >= 0) {
                            if (_xs_rhs_sidx >= 0) {
                                if (_xs_lhs_sidx != _xs_rhs_sidx) {
                                    diag_error(262);
                                    diag_str("'");
                                    diag_packed(lhs.a);
                                    diag_str("' (declared as struct '");
                                    diag_packed(arr_get(sd_names, _xs_lhs_sidx));
                                    diag_str("') cannot be assigned from '");
                                    diag_packed(_xs_rhs.a);
                                    diag_str("' (declared as struct '");
                                    diag_packed(arr_get(sd_names, _xs_rhs_sidx));
                                    diag_str("')");
                                    diag_newline();
                                    _val_show_context_at(_val_src_tok);
                                    diag_help("structs are distinct types in B++; an assignment between two struct identities is almost always a domain-mixing bug");
                                    diag_newline();
                                    diag_help("if the conversion is intentional, write a helper function (e.g. `world_to_grid(w: WorldPos): GridPos { ... }`) to make the boundary explicit");
                                    diag_newline();
                                    diag_help("see docs/tonify_checklist.md Rule 29 for the newtype pattern");
                                    diag_newline();
                                }
                            }
                        }
                    }
                }
                // E261 — float literal stored into a typed-int destination.
                // Excalibur Arc Feature 1 closure (gap A). The variable case
                // (`x: word; x = some_float_var;`) stays silent because
                // `val_check_assign_compat` documents truncation as
                // intentional for screen-coordinate / pixel rounding work.
                // The LITERAL case is bug-shaped: writing `x: word; x = 0.5;`
                // takes a literal that exists only to carry fractional bits
                // and stores it where those bits cannot survive. Almost
                // always either a missing `: float` annotation or a stray
                // decimal point. The fix the programmer wants is one of
                // `floor_int(0.5)` / `trunc_int(0.5)` / `round_int(0.5)`
                // (Excalibur Feature 2 cast builtins) which makes the
                // truncation intent explicit at the use site.
                if (n.b != 0) {
                    auto _ga_rhs: Node;
                    _ga_rhs = n.b;
                    if (hint_ty > 0) {
                        // E261 covers signed and unsigned int hints
                        // identically — storing a float literal into
                        // either drops the fractional bits the same way.
                        if (ty_base(hint_ty) == BASE_WORD
                            || ty_base(hint_ty) == BASE_UWORD) {
                            if (is_float_lit_node(_ga_rhs)) {
                                diag_error(261);
                                diag_str("storing float literal into '");
                                diag_packed(lhs.a);
                                diag_str("' (declared as ");
                                diag_str(val_type_name(hint_ty));
                                diag_str(") would silently drop the fractional bits");
                                diag_newline();
                                _val_show_context_at(_val_src_tok);
                                diag_help("if the conversion is intentional, write `floor_int(0.5)` / `trunc_int(0.5)` / `round_int(0.5)` to make it explicit");
                                diag_newline();
                                diag_help("if the variable should hold the float value, declare it ': float' instead");
                                diag_newline();
                            }
                        }
                    }
                }
                // E232: storing a float value into a destination with NO type
                // annotation silently drops the IEEE 754 bits. The runtime
                // FCVTZS converts 44100.0 to integer 44100 — fine if you
                // wanted truncation, disastrous when you wanted to preserve
                // the bit pattern (e.g. building a CoreAudio sample-rate
                // field). The principle: a literal that ends in `.0` declares
                // float intent; storing it into a variable that never said
                // anything about its type is almost always a bug or a
                // copy-paste accident. Make the user choose explicitly.
                //
                // The error fires only when the destination is COMPLETELY
                // unannotated. An explicit `: word` (or any other int slice)
                // counts as a deliberate choice to truncate — that path stays
                // silent because the user already opted in. An explicit
                // `: float` (or float slice) means no conversion at all — also
                // silent. The error catches the middle case: untyped local or
                // untyped global being asked to swallow a float behind your
                // back.
                if (is_float_type(val_ty)) {
                    if (hint_ty == 0) {
                        if (is_float_type(lhs_ty) == 0) {
                            if (is_float_type(ty_get_global_type(lhs.a)) == 0) {
                                diag_error(232);
                                diag_str("'");
                                diag_packed(lhs.a);
                                diag_str("' has no type annotation but the value being stored is a float — the IEEE 754 bits will be silently truncated to an integer");
                                diag_newline();
                                _val_show_context_at(_val_src_tok);
                                diag_help("a number literal with a decimal point (e.g. 3.0) is a FLOAT; without the decimal point (3) it is an INT");
                                diag_newline();
                                diag_help("if you want integer math, drop the decimal point: write `3` instead of `3.0`");
                                diag_newline();
                                diag_help("if you want to keep the float value, declare '");
                                diag_packed(lhs.a);
                                diag_str(": float' so the variable holds the bit pattern");
                                diag_newline();
                            }
                        }
                    }
                }
            }
        }
        val_check_node(n.a);
        val_check_node(n.b);
        return 0;
    }
    T_CALL {
        auto fi, callee, expected, ai, arg_nd, arg_ty, par_ty;
        auto an: Node;
        name_p = n.a;
        if (val_is_builtin(name_p) == 0) {
            if (val_find_func(name_p) < 0) {
                if (val_find_extern(name_p) < 0) {
                    diag_error(201);
                    diag_str("function '");
                    diag_packed(name_p);
                    diag_str("' called but never defined -- missing import?");
                    diag_newline();
                    _val_show_context_at(n.src_tok);
                    return 0;
                }
            }
        }
        fi = val_find_func(name_p);
        if (fi >= 0) {
            callee = funcs[fi];
            expected = *(callee + FN_PCNT);
            if (arr_get(fn_static, fi) != 0) {
                auto _callee_mod, _caller_mod;
                _callee_mod = arr_get(func_mods, fi);
                _caller_mod = arr_get(func_mods, _val_current_fi);
                if (_callee_mod != _caller_mod) {
                    diag_warn(20);
                    diag_str("'");
                    diag_packed(name_p);
                    diag_str("' is static (private to its module)");
                    diag_newline();
                    _val_show_context_at(n.src_tok);
                }
            }
            if (n.c != expected) {
                diag_warn(3);
                diag_str("'");
                diag_packed(name_p);
                diag_str("' expects ");
                diag_int(expected);
                diag_str(" argument(s), got ");
                diag_int(n.c);
                diag_newline();
                _val_show_context_at(n.src_tok);
            }
            for (ai = 0; ai < n.c; ai++) {
                arg_nd = n.b[ai];
                if (arg_nd != 0) {
                    an = arg_nd;
                    arg_ty = an.itype;
                    par_ty = get_fn_par_type(fi, ai);
                    // V3 Session 1: skip int/float diagnostics when either
                    // side is a fn-type — Session 2 will check Fn-vs-Fn
                    // signature compatibility once flow analysis lands.
                    if (is_fn_type(arg_ty) || is_fn_type(par_ty)) { continue; }
                    if (is_float_type(arg_ty)) {
                        if (is_float_type(par_ty) == 0) {
                            // E233: passing a float-typed value to a parameter
                            // declared without `: float` drops the IEEE 754
                            // bits the same way E232 does at assignment sites.
                            // Hard error for consistency — the language never
                            // silently corrupts a float on its way to a callee.
                            diag_error(233);
                            diag_str("argument ");
                            diag_int(ai + 1);
                            diag_str(" of '");
                            diag_packed(name_p);
                            diag_str("' is a float, but the parameter is an int — the IEEE 754 bits will be silently truncated");
                            diag_newline();
                            _val_show_context_at(n.src_tok);
                            diag_help("a number literal with a decimal point (e.g. 3.0) is a FLOAT; without the decimal point (3) it is an INT");
                            diag_newline();
                            diag_help("if you meant to pass an integer, drop the decimal point on the literal");
                            diag_newline();
                            diag_help("if '");
                            diag_packed(name_p);
                            diag_str("' should accept a float, declare its parameter with ': float'");
                            diag_newline();
                        }
                    }
                    // E240: callee expects float, caller passed something
                    // explicitly int-typed. The codegen would either reinterpret
                    // the integer's bits as a float (junk) or silently convert
                    // (via SCVTF) — both are bug-shaped. Force the user to
                    // either annotate the local `: float` or write the value
                    // as a float literal.
                    //
                    // Excalibur Arc Feature 1 (Session 1.B) — bare integer
                    // literals (decimal `42`, NOT hex `0xFF`) get promoted
                    // to float in place when bound to a `: float` parameter.
                    // The widening is lossless and matches every modern
                    // language's polymorphic-literal idiom. Typed int locals
                    // and hex literals continue to error: the locals could
                    // have been silently demoted upstream, and hex implies a
                    // bit-pattern intent that float-cast would mangle.
                    if (is_float_type(par_ty)) {
                        if (is_float_type(arg_ty) == 0) {
                            if (arg_ty != TY_UNK) {
                                if (an.ntype == T_LIT
                                    && lit_shape(arg_nd) == SHAPE_INT
                                    && _val_lit_is_hex(arg_nd) == 0) {
                                    _val_promote_int_lit_to_float(arg_nd);
                                    continue;
                                }
                                diag_error(240);
                                diag_str("argument ");
                                diag_int(ai + 1);
                                diag_str(" of '");
                                diag_packed(name_p);
                                diag_str("' must be a float, but the value passed is an int");
                                diag_newline();
                                _val_show_context_at(n.src_tok);
                                diag_help("if the source variable holds a float, declare it ': float' so its bits flow through unchanged");
                                diag_newline();
                                diag_help("if you meant to pass a literal, write it with a decimal point (e.g. 44100.0)");
                                diag_newline();
                            }
                        }
                    }
                }
            }
        }
        if (val_find_extern(name_p) >= 0) {
            for (ai = 0; ai < n.c; ai++) {
                arg_nd = n.b[ai];
                if (arg_nd != 0) {
                    an = arg_nd;
                    if (an.ntype == T_ADDR) {
                        diag_warn(12);
                        diag_str("'&' used as argument to extern '");
                        diag_packed(name_p);
                        diag_str("' — may crash at runtime (use malloc for FFI out-params)");
                        diag_newline();
                        _val_show_context_at(n.src_tok);
                    }
                }
            }
        }
        if (val_is_builtin(name_p)) {
            // W027 — fn_ptr targeting a function with a `: float`
            // parameter. Body factored out into `_val_check_fn_ptr`
            // so the nesting here stays at one line.
            _val_check_fn_ptr(name_p, nd);
            if (buf_eq(vbuf + unpack_s(name_p), "call", unpack_l(name_p))) { if (unpack_l(name_p) == 4) {
                for (ai = 0; ai < n.c; ai++) {
                    arg_nd = n.b[ai];
                    if (arg_nd != 0) {
                        an = arg_nd;
                        if (an.ntype == T_ADDR) {
                            diag_warn(12);
                            diag_str("'&' used as argument to call() — may crash at runtime (use malloc for FFI out-params)");
                            diag_newline();
                            _val_show_context_at(n.src_tok);
                        }
                    }
                }
                // V3 Sessions 2 + 3 — call() arg validation.
                //
                // Session 3 first: if fp is a local with an explicit
                // `: func(...)` annotation, the annotation is the
                // contract. Hard-error E246 on mismatch.
                //
                // Session 2 fallback: read the dispatch walker's
                // pre-resolved target snapshot stashed in `n.e`
                // (`target_fi + 1`, 0 = unresolved). Soft-warn W028.
                //
                // Annotation wins over flow analysis to keep the
                // contract authoritative even when both could fire.
                if (n.c >= 1) {
                    auto _fp_node: Node, _fp_hint, _annotation_used;
                    _annotation_used = 0;
                    _fp_node = n.b[0];
                    if (_fp_node.ntype == T_VAR) {
                        _fp_hint = _val_get_hint(_fp_node.a);
                        if (_fp_hint > 0) {
                            if (is_fn_type(_fp_hint)) {
                                _val_check_call_args_against_fntype(
                                    _fp_hint, n.b + 8, n.c - 1, n.src_tok);
                                _annotation_used = 1;
                            }
                        }
                    }
                    if (_annotation_used == 0) {
                        if (n.e > 0) {
                            auto _fp_target_fi, _target_name_p, _target_rec;
                            _fp_target_fi = n.e - 1;
                            _target_rec = funcs[_fp_target_fi];
                            _target_name_p = *(_target_rec + FN_NAME);
                            _val_check_call_args_against(_fp_target_fi,
                                                         n.b + 8, n.c - 1,
                                                         _target_name_p, n.src_tok);
                        } else {
                            // V3 Session 4 — multi-origin via registration
                            // pattern. Walker did not resolve a single
                            // intra-function target; consult the global
                            // origin map populated by Pass B. Estrita:
                            // every origin checked independently — any
                            // mismatch fires W028 for that origin.
                            if (_fp_node.ntype == T_VAR) {
                                auto _origins, _on, _o, _t_fi, _t_name_p, _t_rec;
                                _origins = dsp_glob_origins(_fp_node.a);
                                if (_origins != 0) {
                                    _on = arr_len(_origins);
                                    for (_o = 0; _o < _on; _o++) {
                                        _t_fi = arr_get(_origins, _o);
                                        if (_t_fi < 0) { continue; }
                                        _t_rec = funcs[_t_fi];
                                        _t_name_p = *(_t_rec + FN_NAME);
                                        _val_check_call_args_against(_t_fi,
                                                                     n.b + 8, n.c - 1,
                                                                     _t_name_p, n.src_tok);
                                    }
                                }
                            }
                        }
                    }
                }
            } }
        }
        val_check_list(n.b, n.c);
        return 0;
    }
    T_BINOP {
        // E242: shift count out of range. Bit shifts wider than 63 are
        // architecturally undefined on x86_64 (the SHL/SHR instructions
        // mask the count to 6 bits) and meaningless on a 64-bit word
        // anywhere. Catch them at the AST level when the shift count is
        // a literal — runtime values still reach codegen unchanged.
        auto opp, op_s, op_l, op0, op1, rhs_n: Node, sc;
        opp = n.a;
        op_s = unpack_s(opp);
        op_l = unpack_l(opp);
        if (op_l == 2) {
            op0 = peek(vbuf + op_s);
            op1 = peek(vbuf + op_s + 1);
            if ((op0 == '<' && op1 == '<') || (op0 == '>' && op1 == '>')) {
                rhs_n = n.c;
                if (is_int_lit_node(rhs_n)) {
                    sc = parse_int_lit_value(rhs_n.a);
                    if (sc > 63) {
                        diag_error(242);
                        diag_str("shift count ");
                        diag_int(sc);
                        diag_str(" is out of range — bit shifts on a 64-bit word must be 0..63");
                        diag_newline();
                        _val_show_context_at(n.src_tok);
                        diag_help("on x86_64 the hardware masks the count to 6 bits, so `x << 64` actually emits `x << 0` — the value is silently wrong");
                        diag_newline();
                    }
                }
                // E244 (shift form): float literal as shift count is
                // nonsense — shifts are bit positions, not fractional
                // amounts. Caught here at the validator alongside the
                // array-index case in the parser.
                if (is_float_lit_node(rhs_n)) {
                    diag_error(244);
                    diag_str("shift count is a float literal — shifts take an integer bit count");
                    diag_newline();
                    _val_show_context_at(n.src_tok);
                    diag_help("drop the decimal point on the shift count");
                    diag_newline();
                }
            }
            // E243: pointer compared to non-zero literal. Comparing a
            // pointer to 0 is the canonical null check; comparing it to
            // any other integer almost always means the programmer
            // confused a value with an address. Caught here on `==` and
            // `!=` when one side is pointer-typed and the other is a
            // non-zero int literal.
            if ((op0 == '=' && op1 == '=') || (op0 == '!' && op1 == '=')) {
                auto lhs_n: Node, lit_n: Node, has_ptr, sv;
                lhs_n = n.b;
                rhs_n = n.c;
                has_ptr = 0;
                lit_n = 0;
                if (ty_base(lhs_n.itype) == BASE_PTR) {
                    has_ptr = 1;
                    if (is_int_lit_node(rhs_n)) { lit_n = rhs_n; }
                }
                if (ty_base(rhs_n.itype) == BASE_PTR) {
                    has_ptr = 1;
                    if (is_int_lit_node(lhs_n)) { lit_n = lhs_n; }
                }
                if (has_ptr) {
                    if (lit_n != 0) {
                        sv = parse_int_lit_value(lit_n.a);
                        if (sv != 0) {
                            diag_error(243);
                            diag_str("pointer compared to non-zero literal ");
                            diag_int(sv);
                            diag_str(" — this is almost always a bug");
                            diag_newline();
                            _val_show_context_at(n.src_tok);
                            diag_help("`ptr == 0` and `ptr != 0` are the canonical null checks; any other integer rarely makes sense as an address");
                            diag_newline();
                        }
                    }
                }
            }
        }
        // W025 — public function receives an un-hinted parameter that
        // the body uses in float arithmetic. Caller sees the signature
        // with no type hint and has no way to know whether the param
        // wants an int or a float; the body's internal use promotes
        // silently at the call site. Only fires for non-static
        // functions (static callers have a single intra-module
        // call surface that code review can catch).
        if (_val_current_fi >= 0 && arr_get(fn_static, _val_current_fi) == 0) {
            auto w_lhs: Node, w_rhs: Node, w_var: Node, w_other: Node, w_fire;
            w_lhs = n.b;
            w_rhs = n.c;
            w_fire = 0;
            w_var = 0;
            w_other = 0;
            if (w_lhs.ntype == T_VAR && _val_is_unhinted_param(w_lhs.a)) {
                if (ty_base(w_rhs.itype) == BASE_FLOAT) {
                    w_fire = 1;
                    w_var = w_lhs;
                    w_other = w_rhs;
                }
            }
            if (w_fire == 0 && w_rhs.ntype == T_VAR && _val_is_unhinted_param(w_rhs.a)) {
                if (ty_base(w_lhs.itype) == BASE_FLOAT) {
                    w_fire = 1;
                    w_var = w_rhs;
                    w_other = w_lhs;
                }
            }
            if (w_fire) {
                diag_warn(25);
                diag_str("parameter `");
                diag_packed(w_var.a);
                diag_str("` of public function `");
                diag_packed(*(funcs[_val_current_fi] + FN_NAME));
                diag_str("` is used in float arithmetic but has no type hint");
                diag_newline();
                _val_show_context_at(n.src_tok);
                diag_help("annotate the parameter so callers know what to pass — `name: float` preserves IEEE bits, `name: word` forces integer");
                diag_newline();
            }
        }
        val_check_node(n.b); val_check_node(n.c);
        return 0;
    }
    T_UNARY { val_check_node(n.b); return 0; }
    T_RET   { val_check_node(n.a); return 0; }
    T_IF {
        val_check_node(n.a);
        val_check_list(n.b, n.c);
        if (n.e > 0) { val_check_list(n.d, n.e); }
        return 0;
    }
    T_WHILE {
        val_check_node(n.a);
        val_check_list(n.b, n.c);
        if (n.e != 0) { val_check_node(n.e); }
        return 0;
    }
    T_BLOCK {
        val_check_list(n.b, n.c);
        return 0;
    }
    T_MEMLD { val_check_node(n.a); return 0; }
    T_ADDR  { val_check_node(n.a); return 0; }
    T_MEMST { val_check_node(n.a); val_check_node(n.b); return 0; }
    else { }
    }
    return 0;
}

// ── Entry point ─────────────────────────────────────────────

// Run validation on all functions. Per-function: reset hints, collect
// param hints, walk body. Symbol hashes are rebuilt up front so every
// val_find_func / val_find_extern call inside the body walk is O(1).
void run_validate() {
    auto i, rec, body_arr, body_cnt, hints, h, j, params_arr, param_cnt;
    _val_build_func_hash();
    _val_build_extern_hash();
    _val_check_extrn_func_collision();
    for (i = 0; i < func_cnt; i++) {
        rec = funcs[i];
        body_arr = *(rec + FN_BODY);
        body_cnt = *(rec + FN_BCNT);
        _val_current_fi = i;
        // Skip cached functions loaded from .bo (no body to check).
        if (body_cnt == 0) { i = i; }
        else {
            params_arr = *(rec + FN_PARS);
            param_cnt = *(rec + FN_PCNT);
            hints = *(rec + FN_HINTS);

            _val_reset_hints();

            // Register parameter type hints.
            if (hints != 0) {
                for (j = 0; j < param_cnt; j++) {
                    h = hints[j];
                    if (h > 0) { _val_add_hint(params_arr[j], h); }
                }
            }

            val_check_list(body_arr, body_cnt);
        }
    }
    diag_check_errors();
}

// Per-module version for the incremental pipeline.
// Validates only functions belonging to the given module index. Cached
// functions loaded from .bo have body_cnt==0 and are skipped (they were
// already validated when the cache was built in a previous compilation).
// Symbol hashes are rebuilt before each module pass so they include any
// functions or externs added since the previous pass.
validate_module(mi) {
    auto i, rec, body_arr, body_cnt, hints, h, j, params_arr, param_cnt;
    _val_build_func_hash();
    _val_build_extern_hash();
    for (i = 0; i < func_cnt; i++) {
        if (arr_get(func_mods, i) == mi) {
            rec = funcs[i];
            body_arr = *(rec + FN_BODY);
            body_cnt = *(rec + FN_BCNT);
            _val_current_fi = i;
            if (body_cnt > 0) {
                params_arr = *(rec + FN_PARS);
                param_cnt = *(rec + FN_PCNT);
                hints = *(rec + FN_HINTS);

                _val_reset_hints();

                if (hints != 0) {
                    for (j = 0; j < param_cnt; j++) {
                        h = hints[j];
                        if (h > 0) { _val_add_hint(params_arr[j], h); }
                    }
                }

                val_check_list(body_arr, body_cnt);
            }
        }
    }
    return 0;
}
