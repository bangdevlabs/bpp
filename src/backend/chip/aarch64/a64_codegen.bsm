// bpp_codegen_arm64.bsm — ARM64 code generator for the unified B++ compiler.
// Reads AST data from the parser's in-memory structures (no JSON).
// Writes ARM64 assembly (macOS Apple Silicon) to stdout.
//
// Usage: import this module into bpp.bpp, then call emit_all_arm64()
// after run_types()/run_dispatch() to emit assembly instead of C.

import "bpp_defs.bsm";
import "bpp_array.bsm";
import "bpp_internal.bsm";
import "bpp_parser.bsm";
import "bpp_types.bsm";
import "a64_enc.bsm";
// ARM64 codegen always targets macOS (the chip+OS coupling B++ has today).
// Import the macOS syscall table and runtime startup globals directly,
// not via target-suffix — this codegen cannot target any other OS.
import "_bsys_macos.bsm";
import "_brt0_macos.bsm";

// ── Emitter-owned globals ──────────────────────────────────

// String buffer alias: points to vbuf (set by bridge_data_arm64).
auto a64_sbuf;

// Function table (parallel dynamic arrays, deduplicated from parser).
// a64_fn_fidx maps emitter index → parser func_cnt index for type queries.
auto a64_fn_name, a64_fn_par, a64_fn_pcnt, a64_fn_body, a64_fn_bcnt, a64_fn_fidx;

// Global variable list (dynamic array).
auto a64_gl_name;

// FFI extern table: parallel dynamic arrays for type-aware external calls.
auto a64_ex_name, a64_ex_ret, a64_ex_args, a64_ex_acnt;

// Current function's variable scope (dynamic array, for stack frame layout).
auto a64_vars;

// Stack struct tracking: per-variable dynamic arrays for flags and computed frame offsets.
auto a64_var_stack, a64_var_struct_idx, a64_var_off, a64_var_forced_ty;

// Phase B3 — local register allocation.
auto a64_var_refs;
auto a64_var_addr_taken;
auto a64_var_promote;
auto a64_promoted_regs;
auto a64_b3_spill_base;

// Float literal data table (dynamic array): stores packed string refs for .double emission.
auto a64_flt_tbl;

// String literal table (dynamic array): each entry stores the packed string content.
auto a64_str_tbl;

// Label counter and stack depth tracking.
auto a64_lbl_cnt, a64_depth;

// Break label stack (dynamic array): tracks the exit label of the current while loop.
auto a64_break_stack;

// Continue label stack (dynamic array): tracks the loop-step label of the current while.
// For plain while, this points just before the unconditional branch back to top.
// For for-loops, this points just before the step expression so continue runs the step.
auto a64_continue_stack;

// Current function being emitted.
auto a64_cur_fn_name, a64_cur_fn_idx;

// Binary mode: 0 = text assembly (default), 1 = binary encoding via bpp_enc_arm64.bsm.
auto a64_bin_mode;

// Binary mode: function entry labels (dynamic array mapping fn index → label ID).
auto a64_fn_lbl;

// Binary mode: return label for the current function (set in a64_emit_func).
auto a64_ret_lbl;

// Sentinel packed names for hidden argc/argv/envp globals.
// These use negative values that can never collide with real packed names.
auto a64_argc_sym, a64_argv_sym, a64_envp_sym;

// ── Phase B1 register freelists ──────────────────────────────
//
// Two pools from day one. gp_freelist backs B1-B3 (integer / pointer
// temps). simd_freelist is allocated empty and activated by B4, where
// `: double` variables bind to it. Keeping both pools present now means
// B4 does not have to touch B1-B3 code.
//
// GP pool = x9..x15 (7 temps). Bit i set = reg (9+i) is free.
// SIMD pool = v0..v15 (16 regs). Bit i set = reg i is free.
static auto a64_gp_free_mask;
static auto a64_simd_free_mask;


// ── Initialization ─────────────────────────────────────────

void init_codegen_arm64() {
    a64_fn_name = arr_new(); a64_fn_par = arr_new();
    a64_fn_pcnt = arr_new(); a64_fn_body = arr_new();
    a64_fn_bcnt = arr_new(); a64_fn_fidx = arr_new();
    a64_gl_name = arr_new();
    a64_ex_name = arr_new(); a64_ex_ret = arr_new();
    a64_ex_args = arr_new(); a64_ex_acnt = arr_new();
    a64_vars = arr_new();
    a64_var_stack = arr_new();
    a64_var_struct_idx = arr_new();
    a64_var_off = arr_new();
    a64_var_forced_ty = arr_new();
    a64_var_refs = arr_new();
    a64_var_addr_taken = arr_new();
    a64_var_promote = arr_new();
    a64_promoted_regs = arr_new();
    a64_flt_tbl = arr_new();
    a64_str_tbl = arr_new();
    a64_lbl_cnt = 0; a64_depth = 0;
    a64_break_stack = arr_new();
    a64_continue_stack = arr_new();
    a64_bin_mode = 0;
    a64_fn_lbl = arr_new();
    a64_ret_lbl = 0;
    // Initialized to 0 (invalid packed name). Real values are assigned
    // by a64_bind_startup_syms() once brt0.bsm has been parsed.
    a64_argc_sym = 0;
    a64_argv_sym = 0;
    a64_envp_sym = 0;
    a64_gp_free_mask = 0;
    a64_simd_free_mask = 0;
}

// ── Phase B1 register freelist helpers ──────────────────────
//
// Reset both pools to fully-free at the start of every function. GP
// pool covers x9..x15 (bit i = reg 9+i free). SIMD pool covers v0..v15
// (bit i = reg i free). Fallbacks to push/pop are unconditional — if
// the freelist is full, the caller must emit the old stack-save path
// so no code path ever runs out of options.

static void a64_freelist_reset() {
    a64_gp_free_mask = 0x7F;     // bits 0..6 set = x9..x15 all free
    a64_simd_free_mask = 0xFFFF; // bits 0..15 set = v0..v15 all free
}

// Allocate a free GP temp. Returns register number (9..15) on success
// or -1 when the pool is exhausted. Callers must fall back to
// a64_emit_push / a64_emit_pop on -1.
static a64_gp_alloc() {
    auto i, m;
    for (i = 0; i < 7; i = i + 1) {
        m = 1 << i;
        if (a64_gp_free_mask & m) {
            a64_gp_free_mask = a64_gp_free_mask & ~m;
            return 9 + i;
        }
    }
    return 0 - 1;
}

// Return a previously-allocated GP reg to the pool. No-op if reg is
// outside the x9..x15 range — freeing a permanent reg (x0-x8) would
// corrupt the mask bookkeeping. Double-free is silent (bit stays set).
static void a64_gp_free(reg) {
    auto m;
    if (reg < 9 || reg > 15) { return; }
    m = 1 << (reg - 9);
    a64_gp_free_mask = a64_gp_free_mask | m;
}

// Allocate a free SIMD reg. Returns register number (0..15) or -1.
// The SIMD pool is reserved from day one for Phase B4 (: double slice)
// so its existence does not become a B1-B3 refactor later.
static a64_simd_alloc() {
    auto i, m;
    for (i = 0; i < 16; i = i + 1) {
        m = 1 << i;
        if (a64_simd_free_mask & m) {
            a64_simd_free_mask = a64_simd_free_mask & ~m;
            return i;
        }
    }
    return 0 - 1;
}

// Return a SIMD reg to the pool. Bounds-checked the same way as GP.
static void a64_simd_free(reg) {
    auto m;
    if (reg < 0 || reg > 15) { return; }
    m = 1 << reg;
    a64_simd_free_mask = a64_simd_free_mask | m;
}

// Return 1 if the given subtree contains any T_CALL node. Used by the
// T_BINOP freelist path to decide whether a register save via mov is
// safe across the right-side emission. ARM64 treats x9..x15 as caller-
// saved, so a BL instruction anywhere in the right-side expression
// would clobber a value we parked there — in that case we must fall
// back to the stack-save path.
//
// Pure tree scan, no side effects — eligible for `: base`.
static _a64_has_call(nd) : base {
    auto n: Node, t;
    if (nd == 0) { return 0; }
    n = nd;
    t = n.ntype;
    switch (t) {
    T_CALL { return 1; }
    T_BINOP {
        if (_a64_has_call(n.b)) { return 1; }
        return _a64_has_call(n.c);
    }
    T_TERNARY {
        if (_a64_has_call(n.a)) { return 1; }
        if (_a64_has_call(n.b)) { return 1; }
        return _a64_has_call(n.c);
    }
    T_ASSIGN, T_MEMST {
        if (_a64_has_call(n.a)) { return 1; }
        return _a64_has_call(n.b);
    }
    T_UNARY { return _a64_has_call(n.b); }
    T_MEMLD, T_ADDR, T_RET { return _a64_has_call(n.a); }
    else { return 0; }
    }
}

// Look up the packed names of brt0's hidden globals (_bpp_argc, _bpp_argv,
// _bpp_envp) from the globals array. Must be called AFTER brt0.bsm has been
// parsed (any time during module 0 emission). The packed names are then
// used as relocation targets for argc_get/argv_get/envp_get builtins and
// for the argc/argv/envp save in main()'s prologue.
void a64_bind_startup_syms() {
    auto i, name_p;
    for (i = 0; i < glob_cnt; i = i + 1) {
        name_p = *(globals + i * 8);
        switch {
            a64_str_eq(name_p, "_bpp_argc", 9) { a64_argc_sym = name_p; }
            a64_str_eq(name_p, "_bpp_argv", 9) { a64_argv_sym = name_p; }
            a64_str_eq(name_p, "_bpp_envp", 9) { a64_envp_sym = name_p; }
            else { }
        }
    }
    return;
}

// ── Bridge: copy parser data into emitter parallel arrays ──
// Same pattern as bpp_emitter.bsm:bridge_data().

static void bridge_data_arm64() {
    auto i, rec, name_p, idx, j;

    // Point string buffer at the parser's vbuf.
    a64_sbuf = vbuf;

    // Copy reachable functions from parser's 64-byte records into parallel
    // arrays. Unreachable functions (not called from main) are skipped.
    arr_clear(a64_fn_name); arr_clear(a64_fn_par); arr_clear(a64_fn_pcnt);
    arr_clear(a64_fn_body); arr_clear(a64_fn_bcnt); arr_clear(a64_fn_fidx);
    i = 0;
    while (i < func_cnt) {
        // Lazy emit: skip unreachable functions.
        if (_lazy_emit_ready) {
            if (arr_get(fn_reachable, i) == 0) { i = i + 1; continue; }
        }
        rec = *(funcs + i * 8);
        name_p = *(rec + FN_NAME);
        // Check if this function was already added (forward declaration).
        idx = -1;
        j = 0;
        while (j < arr_len(a64_fn_name)) {
            if (a64_str_eq_packed(name_p, arr_get(a64_fn_name, j))) { idx = j; }
            j = j + 1;
        }
        if (idx < 0) {
            // New function: append to all parallel arrays.
            idx = arr_len(a64_fn_name);
            a64_fn_name = arr_push(a64_fn_name, name_p);
            a64_fn_par  = arr_push(a64_fn_par,  *(rec + FN_PARS));
            a64_fn_pcnt = arr_push(a64_fn_pcnt, *(rec + FN_PCNT));
            a64_fn_body = arr_push(a64_fn_body, *(rec + FN_BODY));
            a64_fn_bcnt = arr_push(a64_fn_bcnt, *(rec + FN_BCNT));
            a64_fn_fidx = arr_push(a64_fn_fidx, i);
        } else {
            // Forward declaration override: overwrite existing entry.
            arr_set(a64_fn_name, idx, name_p);
            arr_set(a64_fn_par,  idx, *(rec + FN_PARS));
            arr_set(a64_fn_pcnt, idx, *(rec + FN_PCNT));
            arr_set(a64_fn_body, idx, *(rec + FN_BODY));
            arr_set(a64_fn_bcnt, idx, *(rec + FN_BCNT));
            arr_set(a64_fn_fidx, idx, i);
        }
        i = i + 1;
    }

    // Copy globals, deduplicating by string content.
    // The parser may add the same name multiple times (from different modules).
    // Each must map to a single __DATA slot in the binary.
    arr_clear(a64_gl_name);
    i = 0;
    while (i < glob_cnt) {
        name_p = *(globals + i * 8);
        idx = -1;
        j = 0;
        while (j < arr_len(a64_gl_name)) {
            if (a64_str_eq_packed(name_p, arr_get(a64_gl_name, j))) { idx = j; }
            j = j + 1;
        }
        if (idx < 0) {
            a64_gl_name = arr_push(a64_gl_name, name_p);
        }
        i = i + 1;
    }

    // Copy externs from parser's 64-byte records into parallel arrays.
    arr_clear(a64_ex_name); arr_clear(a64_ex_ret);
    arr_clear(a64_ex_args); arr_clear(a64_ex_acnt);
    i = 0;
    while (i < ext_cnt) {
        rec = *(externs + i * 8);
        a64_ex_name = arr_push(a64_ex_name, *(rec + EX_NAME));
        a64_ex_ret  = arr_push(a64_ex_ret,  *(rec + EX_RET));
        a64_ex_args = arr_push(a64_ex_args, *(rec + EX_ARGS));
        a64_ex_acnt = arr_push(a64_ex_acnt, *(rec + EX_ACNT));
        i = i + 1;
    }

}

// ── String utilities ───────────────────────────────────────

// Find an extern function by packed name. Returns first match index or -1.
static a64_find_ext(name_p) {
    auto i;
    i = 0;
    while (i < arr_len(a64_ex_name)) {
        if (a64_str_eq_packed(name_p, arr_get(a64_ex_name, i))) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

// Find an extern function by packed name AND argument count.
// Allows multiple declarations of the same name with different signatures.
static a64_find_ext_by_argc(name_p, argc) {
    auto i;
    i = 0;
    while (i < arr_len(a64_ex_name)) {
        if (a64_str_eq_packed(name_p, arr_get(a64_ex_name, i))) {
            if (arr_get(a64_ex_acnt, i) == argc) { return i; }
        }
        i = i + 1;
    }
    // Fallback: match by name only (for cases with single declaration).
    return a64_find_ext(name_p);
}

// Check if an extern parameter at index par_idx is "double".
static a64_ext_par_is_float(exi, par_idx) {
    auto arr, tp;
    arr = arr_get(a64_ex_args, exi);
    tp = *(arr + par_idx * 8);
    return a64_str_eq(tp, "double", 6);
}

// Check if an extern's return type is "double".
static a64_ext_ret_is_float(exi) {
    auto tp;
    tp = arr_get(a64_ex_ret, exi);
    return a64_str_eq(tp, "double", 6);
}

// Compare a packed string against a C literal. Returns 1 if equal.
a64_str_eq(p, lit, litlen) {
    if (unpack_l(p) != litlen) { return 0; }
    return buf_eq(a64_sbuf + unpack_s(p), lit, litlen);
}

// Compare two packed strings byte by byte.
a64_str_eq_packed(a, b) {
    auto as, al, bs, bl, i;
    al = unpack_l(a); bl = unpack_l(b);
    if (al != bl) { return 0; }
    as = unpack_s(a); bs = unpack_s(b);
    i = 0;
    while (i < al) {
        if (peek(a64_sbuf + as + i) != peek(a64_sbuf + bs + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

// Print a packed string to stdout.
static void a64_print_p(p) {
    print_buf(a64_sbuf + unpack_s(p), unpack_l(p));
}

// ── Helper functions ───────────────────────────────────────

// Print a decimal integer to stdout. Used for assembly immediates.
static void a64_print_dec(n) {
    auto buf, len, i;
    if (n < 0) { putchar('-'); n = 0 - n; }
    if (n == 0) { putchar('0'); return; }
    buf = malloc(20); len = 0;
    while (n > 0) {
        poke(buf + len, '0' + n % 10);
        len = len + 1;
        n = n / 10;
    }
    for (i = len - 1; i >= 0; i = i - 1) {
        putchar(peek(buf + i));
    }
}

// ── Variable tracking for current function ─────────────────

// Add a variable to the current scope. Returns its slot index.
static a64_var_add(name_p) {
    auto idx; idx = arr_len(a64_vars);
    a64_vars = arr_push(a64_vars, name_p);
    a64_var_stack = arr_push(a64_var_stack, 0);
    a64_var_struct_idx = arr_push(a64_var_struct_idx, 0 - 1);
    a64_var_off = arr_push(a64_var_off, 0);
    a64_var_forced_ty = arr_push(a64_var_forced_ty, 0);
    a64_var_refs = arr_push(a64_var_refs, 0);
    a64_var_addr_taken = arr_push(a64_var_addr_taken, 0);
    a64_var_promote = arr_push(a64_var_promote, 0 - 1);
    return idx;
}

// Find a variable index by name. Returns index or -1 if not found.
static a64_var_idx(name_p) {
    auto i; i = 0;
    while (i < arr_len(a64_vars)) {
        if (a64_str_eq_packed(name_p, arr_get(a64_vars, i))) { return i; }
        i = i + 1;
    }
    return -1;
}

// ── Phase B3 — local register allocation ──────────────────

static _a64_b3_eligible(vi) : base {
    auto fty;
    if (arr_get(a64_var_stack, vi)) { return 0; }
    if (arr_get(a64_var_addr_taken, vi)) { return 0; }
    fty = arr_get(a64_var_forced_ty, vi);
    if (is_float_type(fty)) { return 0; }
    if (ty_slice(fty) != SL_FULL) { return 0; }
    return 1;
}

static _a64_b3_walk(nd) {
    auto n: Node, t, vi, child: Node, arr, cnt, i;
    if (nd == 0) { return 0; }
    n = nd;
    t = n.ntype;
    if (t == T_VAR) {
        vi = a64_var_idx(n.a);
        if (vi >= 0) { arr_set(a64_var_refs, vi, arr_get(a64_var_refs, vi) + 1); }
        return 0;
    }
    if (t == T_ADDR) {
        child = n.a;
        if (child != 0 && child.ntype == T_VAR) {
            vi = a64_var_idx(child.a);
            if (vi >= 0) { arr_set(a64_var_addr_taken, vi, 1); }
            return 0;
        }
        _a64_b3_walk(child);
        return 0;
    }
    switch (t) {
    T_BINOP    { _a64_b3_walk(n.b); _a64_b3_walk(n.c); }
    T_ASSIGN   { _a64_b3_walk(n.a); _a64_b3_walk(n.b); }
    T_MEMST    { _a64_b3_walk(n.a); _a64_b3_walk(n.b); }
    T_UNARY    { _a64_b3_walk(n.b); }
    T_MEMLD    { _a64_b3_walk(n.a); }
    T_RET      { _a64_b3_walk(n.a); }
    T_TERNARY  { _a64_b3_walk(n.a); _a64_b3_walk(n.b); _a64_b3_walk(n.c); }
    T_CALL {
        arr = n.b; cnt = n.c;
        for (i = 0; i < cnt; i = i + 1) { _a64_b3_walk(arr[i]); }
    }
    T_IF {
        _a64_b3_walk(n.a);
        arr = n.b; cnt = n.c;
        for (i = 0; i < cnt; i = i + 1) { _a64_b3_walk(arr[i]); }
        if (n.e > 0) {
            arr = n.d; cnt = n.e;
            for (i = 0; i < cnt; i = i + 1) { _a64_b3_walk(arr[i]); }
        }
    }
    T_WHILE {
        _a64_b3_walk(n.a);
        arr = n.b; cnt = n.c;
        for (i = 0; i < cnt; i = i + 1) { _a64_b3_walk(arr[i]); }
        if (n.e != 0) { _a64_b3_walk(n.e); }
    }
    T_BLOCK {
        arr = n.b; cnt = n.c;
        for (i = 0; i < cnt; i = i + 1) { _a64_b3_walk(arr[i]); }
    }
    else { }
    }
}

// ARM64 callee-saved pool: x19..x24 (6 regs).
static void _a64_b3_select() {
    auto budget, used, vi, n, best_vi, best_refs, reg;
    budget = 6;
    n = arr_len(a64_vars);
    arr_clear(a64_promoted_regs);
    used = 0;
    while (used < budget) {
        best_vi = 0 - 1;
        best_refs = 1;
        for (vi = 0; vi < n; vi = vi + 1) {
            if (arr_get(a64_var_promote, vi) >= 0) { continue; }
            if (_a64_b3_eligible(vi) == 0) { continue; }
            if (arr_get(a64_var_refs, vi) > best_refs) {
                best_refs = arr_get(a64_var_refs, vi);
                best_vi = vi;
            }
        }
        if (best_vi < 0) { return; }
        reg = 19 + used;
        arr_set(a64_var_promote, best_vi, reg);
        a64_promoted_regs = arr_push(a64_promoted_regs, reg);
        used = used + 1;
    }
}

// Find a variable by name. Returns stack offset from x29, or -1 if not found.
static a64_var_find(name_p) {
    auto i;
    i = a64_var_idx(name_p);
    if (i >= 0) { return arr_get(a64_var_off, i); }
    return -1;
}

// Walk a function body and register all declared variables (for frame sizing).
static void a64_pre_reg_vars(arr, cnt) {
    auto i, j;
    auto n: Node;
    i = 0;
    while (i < cnt) {
        n = *(arr + i * 8);
        if (n != 0) {
            if (n.ntype == T_DECL) {
                j = 0;
                while (j < n.b) {
                    auto vi;
                    vi = a64_var_add(*(n.a + j * 8));
                    // Mark stack struct variables (var keyword: n.d == 1).
                    if (n.d == 1) {
                        arr_set(a64_var_stack, vi, 1);
                        arr_set(a64_var_struct_idx, vi, get_var_type(*(n.a + j * 8)));
                    }
                    // Record explicit primitive type hint (byte, quarter, half, float).
                    if (n.c > 0) {
                        arr_set(a64_var_forced_ty, vi, n.c);
                    }
                    j = j + 1;
                }
            }
            if (n.ntype == T_IF) {
                a64_pre_reg_vars(n.b, n.c);
                if (n.e > 0) { a64_pre_reg_vars(n.d, n.e); }
            }
            if (n.ntype == T_WHILE) { a64_pre_reg_vars(n.b, n.c); }
            if (n.ntype == T_SWITCH) {
                // Recurse into each switch arm body to find auto declarations.
                auto sw_bodies, sw_cnt2, si2, sb_arr2, sb_cnt2;
                sw_bodies = n.src_tok;
                sw_cnt2 = n.c;
                for (si2 = 0; si2 < sw_cnt2; si2 = si2 + 1) {
                    sb_arr2 = sw_bodies[si2 * 2];
                    sb_cnt2 = sw_bodies[si2 * 2 + 1];
                    a64_pre_reg_vars(sb_arr2, sb_cnt2);
                }
                if (n.d != 0) { a64_pre_reg_vars(n.d, n.e); }
            }
        }
        i = i + 1;
    }
}

// ── Literal helpers ────────────────────────────────────────

// Parse a packed integer literal (decimal or hex). Returns the numeric value.
static a64_parse_int(p) {
    auto s, l, i, ch, val;
    s = unpack_s(p); l = unpack_l(p); val = 0; i = 0;
    // Hex: 0x...
    if (l > 2) {
        if (peek(a64_sbuf + s) == '0') {
            if (peek(a64_sbuf + s + 1) == 'x' | peek(a64_sbuf + s + 1) == 'X') {
                i = 2;
                while (i < l) {
                    ch = peek(a64_sbuf + s + i); val = val * 16;
                    if (ch >= '0' && ch <= '9') { val = val + ch - '0'; }
                    if (ch >= 'A' && ch <= 'F') { val = val + ch - 55; }
                    if (ch >= 'a' && ch <= 'f') { val = val + ch - 87; }
                    i = i + 1;
                }
                return val;
            }
        }
    }
    // Decimal.
    while (i < l) { ch = peek(a64_sbuf + s + i); val = val * 10 + ch - '0'; i = i + 1; }
    return val;
}

// Check if a packed literal contains a decimal point (float literal).
static a64_is_float_lit(p) {
    auto s, l, i;
    s = unpack_s(p); l = unpack_l(p);
    i = 0;
    while (i < l) {
        if (peek(a64_sbuf + s + i) == '.') { return 1; }
        i = i + 1;
    }
}

// ── Type query helpers ─────────────────────────────────────
// Wrap bpp_types.bsm queries for cleaner code in emit_node/emit_stmt.

// Return the inferred type code of a local variable by slot index.
static a64_var_type(vi) {
    return get_fn_var_type(a64_cur_fn_idx, arr_get(a64_vars, vi));
}

// Check if a variable (by slot index) is float in the current function.
// An explicit integer type hint (: word, : byte, : half, : quarter) overrides
// float inference — the programmer's annotation wins.
static a64_var_is_float(vi) {
    auto fty;
    fty = arr_get(a64_var_forced_ty, vi);
    if (fty > 0) {
        return is_float_type(fty);
    }
    return is_float_type(a64_var_type(vi));
}

// Emit a sized load from [x29, #off] into x0/w0 based on the variable's
// explicit type annotation. Only uses sub-word ops when the programmer
// declared a type hint. Inferred types always use 64-bit load.
// Returns 1 if result is in d0 (float), 0 if in x0 (integer).
static a64_emit_load_var(vi, off) {
    auto fty, sl, _preg;
    // Phase B3: promoted local — emit register move, skip stack load.
    _preg = arr_get(a64_var_promote, vi);
    if (_preg >= 0) {
        if (a64_bin_mode) { enc_add_imm(0, _preg, 0); }
        else { out("  mov x0, x"); a64_print_dec(_preg); putchar(10); }
        return 0;
    }
    fty = arr_get(a64_var_forced_ty, vi);
    sl = ty_slice(fty);
    // `: double` — 128-bit SIMD local. Value lives on the stack as a
    // 16-byte slot; LDR Q pulls it straight into V0 for the caller.
    if (sl == SL_DOUBLE) {
        if (a64_bin_mode) { enc_ldr_q_uoff(0, 29, off); }
        else { out("  ldr q0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 2;
    }
    // Float sub-types: FLOAT_H loads s-register, FLOAT_Q loads h-register.
    // All widen to d0 (double) for computation.
    if (a64_var_is_float(vi)) {
        if (sl == SL_HALF) {
            if (a64_bin_mode) { enc_ldr_s_uoff(0, 29, off); }
            if (a64_bin_mode) { enc_fcvt_d_s(0, 0); }
            if (a64_bin_mode == 0) { out("  ldr s0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
            if (a64_bin_mode == 0) { out("  fcvt d0, s0"); putchar(10); }
            return 1;
        }
        if (sl == SL_QUARTER) {
            if (a64_bin_mode) { enc_ldr_h_uoff(0, 29, off); }
            if (a64_bin_mode) { enc_fcvt_d_h(0, 0); }
            if (a64_bin_mode == 0) { out("  ldr h0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
            if (a64_bin_mode == 0) { out("  fcvt d0, h0"); putchar(10); }
            return 1;
        }
        if (a64_bin_mode) { enc_ldr_d_uoff(0, 29, off); }
        if (a64_bin_mode == 0) { out("  ldr d0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 1;
    }
    // Sub-word loads only when explicitly annotated by the programmer.
    if (sl == SL_BYTE) {
        if (a64_bin_mode) { enc_ldrb_uoff(0, 29, off); }
        else { out("  ldrb w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    if (sl == SL_QUARTER) {
        if (a64_bin_mode) { enc_ldrh_uoff(0, 29, off); }
        else { out("  ldrh w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    if (sl == SL_HALF) {
        if (a64_bin_mode) { enc_ldr_w_uoff(0, 29, off); }
        else { out("  ldr w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    // Default: 64-bit load.
    if (a64_bin_mode) { enc_ldr_uoff(0, 29, off); }
    else { out("  ldr x0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
}

// Emit a sized store from x0/d0 into [x29, #off] based on the variable's
// explicit type annotation. Only uses sub-word ops when the programmer
// declared a type hint. rty: 0 = integer in x0, 1 = float in d0.
static void a64_emit_store_var(vi, off, rty) {
    auto fty, sl, _preg;
    _preg = arr_get(a64_var_promote, vi);
    if (_preg >= 0) {
        if (rty == 1) {
            if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar(10); }
        }
        if (a64_bin_mode) { enc_add_imm(_preg, 0, 0); }
        else { out("  mov x"); a64_print_dec(_preg); out(", x0"); putchar(10); }
        return 0;
    }
    fty = arr_get(a64_var_forced_ty, vi);
    sl = ty_slice(fty);
    // `: double` — 128-bit SIMD. Incoming value is expected in V0 (rty=2);
    // STR Q writes the whole 16-byte slot back to the stack.
    if (sl == SL_DOUBLE) {
        if (rty != 2) {
            diag_error(231);
            diag_str("cannot assign non-SIMD value to ': double' local");
            diag_newline();
        }
        if (a64_bin_mode) { enc_str_q_uoff(0, 29, off); }
        else { out("  str q0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    // Guard: SIMD value assigned to a non-SIMD local is a type error.
    // B3 may have promoted the target to a GPR — writing V0's bits to
    // X0 / a callee-saved reg produces silent garbage.
    if (rty == 2) {
        diag_error(231);
        diag_str("cannot assign SIMD value to non-':double' local (declare it ': double')");
        diag_newline();
    }
    // Float sub-types: convert int→double if needed, then narrow for sub-types.
    if (a64_var_is_float(vi)) {
        if (rty == 0) {
            if (a64_bin_mode) { enc_scvtf(0, 0); }
            if (a64_bin_mode == 0) { out("  scvtf d0, x0"); putchar(10); }
        }
        if (sl == SL_HALF) {
            if (a64_bin_mode) { enc_fcvt_s_d(0, 0); }
            if (a64_bin_mode) { enc_str_s_uoff(0, 29, off); }
            if (a64_bin_mode == 0) { out("  fcvt s0, d0"); putchar(10); }
            if (a64_bin_mode == 0) { out("  str s0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
            return 0;
        }
        if (sl == SL_QUARTER) {
            if (a64_bin_mode) { enc_fcvt_h_d(0, 0); }
            if (a64_bin_mode) { enc_str_h_uoff(0, 29, off); }
            if (a64_bin_mode == 0) { out("  fcvt h0, d0"); putchar(10); }
            if (a64_bin_mode == 0) { out("  str h0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
            return 0;
        }
        if (a64_bin_mode) { enc_str_d_uoff(0, 29, off); }
        if (a64_bin_mode == 0) { out("  str d0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    // Integer path: convert float to int if source is float.
    if (rty == 1) {
        if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar(10); }
    }
    // Sub-word stores only when explicitly annotated by the programmer.
    if (sl == SL_BYTE) {
        if (a64_bin_mode) { enc_strb_uoff(0, 29, off); }
        else { out("  strb w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    if (sl == SL_QUARTER) {
        if (a64_bin_mode) { enc_strh_uoff(0, 29, off); }
        else { out("  strh w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    if (sl == SL_HALF) {
        if (a64_bin_mode) { enc_str_w_uoff(0, 29, off); }
        else { out("  str w0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
        return 0;
    }
    // Default: 64-bit store.
    if (a64_bin_mode) { enc_str_uoff(0, 29, off); }
    else { out("  str x0, [x29, #"); a64_print_dec(off); out("]"); putchar(10); }
}

// Find a B++ function's emitter index by packed name. Returns -1 if not found.
static a64_find_fn(name_p) {
    auto i;
    i = 0;
    while (i < arr_len(a64_fn_name)) {
        if (a64_str_eq_packed(name_p, arr_get(a64_fn_name, i))) { return i; }
        i = i + 1;
    }
    return -1;
}

// ── ARM64 emission primitives ──────────────────────────────

// Generate a unique label number.
static a64_new_lbl() { auto l; l = a64_lbl_cnt; a64_lbl_cnt = a64_lbl_cnt + 1; return l; }

// Load a 64-bit immediate into x0 using movz/movk sequence.
static void a64_emit_mov(val) {
    auto lo, hi;
    if (a64_bin_mode) { enc_mov_wide(0, val); return 0; }
    if (val >= 0) {
        if (val < 65536) {
            out("  mov x0, #"); a64_print_dec(val); putchar('\n');
            return 0;
        }
    }
    // Use movz/movk for larger values.
    lo = val & 0xFFFF;
    out("  movz x0, #"); a64_print_dec(lo); putchar('\n');
    hi = (val >> 16) & 0xFFFF;
    if (hi > 0) { out("  movk x0, #"); a64_print_dec(hi); out(", lsl #16"); putchar('\n'); }
    hi = (val >> 32) & 0xFFFF;
    if (hi > 0) { out("  movk x0, #"); a64_print_dec(hi); out(", lsl #32"); putchar('\n'); }
    hi = (val >> 48) & 0xFFFF;
    if (hi > 0) { out("  movk x0, #"); a64_print_dec(hi); out(", lsl #48"); putchar('\n'); }
}

// ── Switch jump-table analysis ───────────────────────────────
//
// A switch is eligible for jump-table emission when all arm values are
// compile-time integer literals (T_LIT nodes) AND the range is dense
// enough to make the table small. Results are stored in these globals
// so callers read them without handling out-parameters.

auto a64_sw_min;     // Lowest arm value seen (signed 64-bit).
auto a64_sw_max;     // Highest arm value seen.
auto a64_sw_total;   // Total count of arm values (across all arms).

// Return 1 when the switch is eligible for a jump table, 0 otherwise.
// On success, a64_sw_min/max/total hold the observed range and count.
// Density rule: range (max - min) must be under 2 * total, and the
// range must fit in 512 table entries — keeps worst-case table size
// bounded (2 KB of code). Fewer than 3 distinct values use the plain
// comparison chain — a branch table saves nothing at that size.
static a64_switch_is_dense(sw_arms, sw_cnt) {
    auto si, sk, sv_arr, sv_cnt, val, first, range;
    auto node: Node;
    first = 1;
    a64_sw_min = 0;
    a64_sw_max = 0;
    a64_sw_total = 0;
    for (si = 0; si < sw_cnt; si = si + 1) {
        sv_arr = sw_arms[si * 2];
        sv_cnt = sw_arms[si * 2 + 1];
        for (sk = 0; sk < sv_cnt; sk = sk + 1) {
            node = sv_arr[sk];
            if (node.ntype != T_LIT) { return 0; }
            val = a64_parse_int(node.a);
            if (first) {
                a64_sw_min = val;
                a64_sw_max = val;
                first = 0;
            } else {
                if (val < a64_sw_min) { a64_sw_min = val; }
                if (val > a64_sw_max) { a64_sw_max = val; }
            }
            a64_sw_total = a64_sw_total + 1;
        }
    }
    if (a64_sw_total < 3) { return 0; }
    range = a64_sw_max - a64_sw_min;
    if (range < 0) { return 0; }
    if (range > 512) { return 0; }
    if (range >= 2 * a64_sw_total) { return 0; }
    return 1;
}

// Emit an ARM64 jump table for a dense Form-1 switch.
// Layout:
//   <cond eval + normalize + bounds check + adr + add + br>
//   table_lbl:
//     b arm_label_0
//     b arm_label_1
//     ... one slot per value in [min..max]; gaps target else.
//   arm_label_0: body_0 + b sw_end
//   arm_label_1: body_1 + b sw_end
//   ...
//   else_lbl: else_body
//   sw_end_lbl:
//
// Saves O(N) comparison instructions per switch execution at the cost
// of a single indirect branch plus (range+1) words of branch-table code.
static void a64_emit_switch_jtbl(nd, sw_end_lbl) {
    auto n: Node;
    auto node: Node;
    auto sw_arms, sw_bodies, sw_cnt, range;
    auto arm_labels, else_lbl, table_lbl;
    auto si, sk, sv_arr, sv_cnt, sb_arr, sb_cnt, i, target, val;

    n = nd;
    sw_arms = n.b;
    sw_bodies = n.src_tok;
    sw_cnt = n.c;
    range = a64_sw_max - a64_sw_min;

    // Allocate one match label per arm plus the else label.
    arm_labels = malloc(sw_cnt * 8);
    for (si = 0; si < sw_cnt; si = si + 1) {
        arm_labels[si] = enc_new_label();
    }
    else_lbl = enc_new_label();
    table_lbl = enc_new_label();

    // Evaluate condition into x0.
    a64_emit_node(n.a);

    // Normalize to 0-based index by subtracting min_val.
    // Small positive min: 12-bit sub immediate; otherwise load via mov+sub.
    if (a64_sw_min != 0) {
        if (a64_sw_min > 0) {
            if (a64_sw_min < 0x1000) {
                enc_sub_imm(0, 0, a64_sw_min);
            } else {
                a64_emit_mov(a64_sw_min);
                enc_sub_reg(0, 0, 0);
            }
        } else {
            // Negative min: add |min| via load.
            a64_emit_push();
            a64_emit_mov(a64_sw_min);
            enc_mov_reg(1, 0);
            a64_emit_pop(0);
            enc_sub_reg(0, 0, 1);
        }
    }

    // Bounds check: x0 > range ? go to else (unsigned comparison catches
    // negatives too — they wrap to huge unsigned values).
    enc_cmp_imm(0, range);
    enc_b_cond_label(8, else_lbl);  // B.HI = unsigned higher than

    // Indirect branch: x1 = table_base + (x0 << 2); br x1.
    enc_adr_label(1, table_lbl);
    enc_add_reg_shift(1, 1, 0, 2);
    enc_br(1);

    // Emit the branch table: one `b` instruction per slot in [min..max].
    enc_def_label(table_lbl);
    for (i = 0; i <= range; i = i + 1) {
        target = else_lbl;
        for (si = 0; si < sw_cnt; si = si + 1) {
            sv_arr = sw_arms[si * 2];
            sv_cnt = sw_arms[si * 2 + 1];
            for (sk = 0; sk < sv_cnt; sk = sk + 1) {
                node = sv_arr[sk];
                val = a64_parse_int(node.a);
                if (val == a64_sw_min + i) { target = arm_labels[si]; }
            }
        }
        enc_b_label(target);
    }

    // Emit arm bodies. Each body ends with a branch to sw_end.
    for (si = 0; si < sw_cnt; si = si + 1) {
        enc_def_label(arm_labels[si]);
        sb_arr = sw_bodies[si * 2];
        sb_cnt = sw_bodies[si * 2 + 1];
        for (sk = 0; sk < sb_cnt; sk = sk + 1) { a64_emit_stmt(sb_arr[sk]); }
        enc_b_label(sw_end_lbl);
    }

    // Else body.
    enc_def_label(else_lbl);
    if (n.d != 0) {
        auto ek;
        for (ek = 0; ek < n.e; ek = ek + 1) { a64_emit_stmt(n.d[ek]); }
    }

    enc_def_label(sw_end_lbl);
    free(arm_labels);
    return;
}

// Push x0 onto the stack. Maintains 16-byte alignment.
static void a64_emit_push() {
    if (a64_bin_mode) { enc_str_pre(0, 31, -16); } else { out("  str x0, [sp, #-16]!"); putchar('\n'); }
    a64_depth = a64_depth + 1; return 0;
}

// Pop from the stack into a register (0=x0, 1=x1, etc.).
static void a64_emit_pop(r) {
    if (a64_bin_mode) { enc_ldr_post(r, 31, 16); } else { out("  ldr x"); a64_print_dec(r); out(", [sp], #16"); putchar('\n'); }
    a64_depth = a64_depth - 1; return 0;
}

// Push d0 onto the stack (float value).
static void a64_emit_fpush() {
    if (a64_bin_mode) { enc_str_d_pre(0, 31, -16); } else { out("  str d0, [sp, #-16]!"); putchar('\n'); }
    a64_depth = a64_depth + 1; return 0;
}

// Pop from the stack into a float register (0=d0, 1=d1, etc.).
static void a64_emit_fpop(r) {
    if (a64_bin_mode) { enc_ldr_d_post(r, 31, 16); } else { out("  ldr d"); a64_print_dec(r); out(", [sp], #16"); putchar('\n'); }
    a64_depth = a64_depth - 1; return 0;
}

// Push v0 onto the stack as a 16-byte SIMD value (Phase B4). a64_depth
// tracks 16-byte slots one unit at a time so SIMD push matches scalar
// push for depth bookkeeping.
static void a64_emit_vpush() {
    if (a64_bin_mode) { enc_str_q_pre(0, 31, 0 - 16); }
    else { out("  str q0, [sp, #-16]!"); putchar('\n'); }
    a64_depth = a64_depth + 1;
}

// Pop a 16-byte SIMD value from the stack into the given V register.
static void a64_emit_vpop(r) {
    if (a64_bin_mode) { enc_ldr_q_post(r, 31, 16); }
    else { out("  ldr q"); a64_print_dec(r); out(", [sp], #16"); putchar('\n'); }
    a64_depth = a64_depth - 1;
}

// Phase B4: emit a two-operand SIMD builtin through a single helper.
// All six packed-float ops (add/sub/mul/div/min/max) share the same
// spill-right/reload-left choreography — only the NEON opcode and the
// asm mnemonic differ. Caller passes both so the bin and asm paths
// emit in sync.
static void _a64_vec_binop(n: Node, opcode, mnemonic) {
    auto arr;
    arr = n.b;
    a64_emit_node(*(arr + 0));   // left  → v0
    a64_emit_vpush();
    a64_emit_node(*(arr + 8));   // right → v0
    a64_emit_vpop(1);             // v1 = left
    if (a64_bin_mode) { enc_neon_vvv(opcode, 0, 1, 0); }
    else {
        out("  "); out(mnemonic); out(" v0.4s, v1.4s, v0.4s"); putchar('\n');
    }
}

// ── Expression emission ────────────────────────────────────
// Emits ARM64 code for an expression node.
// Returns 0 if result is integer (in x0), 1 if float (in d0).

static a64_emit_node(n) { return 0; }

static a64_emit_node(nd) {
    auto n: Node;
    auto t, op_s, op_l, c0, c1, arr, cnt, i, off, lbl, lbl2, vi, lty, rty;
    auto lit_s, lit_l, sid, str_p, fid, use_flt, is_io, uty, ety, fidx_c, fi, fn_name: Node;
    if (nd == 0) {
        if (a64_bin_mode) { enc_movz(0, 0, 0); } else { out("  mov x0, #0"); putchar('\n'); }
        return 0;
    }
    n = nd; t = n.ntype;

    if (t == T_LIT) {
        // Check if this literal is a string (starts with double-quote).
        lit_s = unpack_s(n.a); lit_l = unpack_l(n.a);
        if (peek(a64_sbuf + lit_s) == '"') {
            // String literal: strip quotes, store in string table, emit address load.
            sid = arr_len(a64_str_tbl);
            str_p = pack(lit_s + 1, lit_l - 2);
            a64_str_tbl = arr_push(a64_str_tbl, str_p);
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, sid, 1);
                enc_adrp(0); enc_add_imm(0, 0, 0);
            } else {
                out("  adrp x0, _str_"); a64_print_dec(sid); out("@PAGE"); putchar('\n');
                out("  add x0, x0, _str_"); a64_print_dec(sid); out("@PAGEOFF"); putchar('\n');
            }
            return 0;
        }
        // Check if float literal (contains a decimal point).
        if (a64_is_float_lit(n.a) == 1) {
            fid = arr_len(a64_flt_tbl);
            a64_flt_tbl = arr_push(a64_flt_tbl, n.a);
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, fid, 2);
                enc_adrp(8); enc_add_imm(8, 8, 0);
                enc_ldr_d_uoff(0, 8, 0);
            } else {
                out("  adrp x8, _flt_"); a64_print_dec(fid); out("@PAGE"); putchar('\n');
                out("  add x8, x8, _flt_"); a64_print_dec(fid); out("@PAGEOFF"); putchar('\n');
                out("  ldr d0, [x8]"); putchar('\n');
            }
            return 1;
        }
        a64_emit_mov(a64_parse_int(n.a)); return 0;
    }

    if (t == T_VAR) {
        vi = a64_var_idx(n.a);
        if (vi >= 0) {
            off = arr_get(a64_var_off, vi);
            // Stack struct: return the address of the struct on the stack.
            if (arr_get(a64_var_stack, vi)) {
                if (a64_bin_mode) { enc_add_imm(0, 29, off); }
                else { out("  add x0, x29, #"); a64_print_dec(off); putchar('\n'); }
                return 0;
            }
            // Type-aware load: uses the correct instruction for the variable's size.
            return a64_emit_load_var(vi, off);
        }
        // Global variable: load address then load value.
        // Check if the global was inferred as float across all functions.
        if (is_float_type(ty_get_global_type(n.a))) {
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, n.a, 0);
                enc_adrp(8); enc_add_imm(8, 8, 0);
                enc_ldr_d_uoff(0, 8, 0);
            } else {
                out("  adrp x8, _"); a64_print_p(n.a); out("@PAGE"); putchar('\n');
                out("  add x8, x8, _"); a64_print_p(n.a); out("@PAGEOFF"); putchar('\n');
                out("  ldr d0, [x8]"); putchar('\n');
            }
            return 1;
        }
        if (a64_bin_mode) {
            enc_add_reloc(enc_pos, n.a, 0);
            enc_adrp(8); enc_add_imm(8, 8, 0);
            enc_ldr_uoff(0, 8, 0);
        } else {
            out("  adrp x8, _"); a64_print_p(n.a); out("@PAGE"); putchar('\n');
            out("  add x8, x8, _"); a64_print_p(n.a); out("@PAGEOFF"); putchar('\n');
            out("  ldr x0, [x8]"); putchar('\n');
        }
        return 0;
    }

    // Conditional expression `cond ? then : else`. Short-circuit by contract:
    // ONLY the selected branch evaluates. This is also the lowering target
    // for `&&` / `||` (parser rewrites them so backends never see those
    // operators). The result type is whichever branch ran (returned in x0
    // for integers, d0 for floats); both branches are expected to agree.
    if (t == T_TERNARY) {
        auto lbl_else, lbl_done, ety_then, ety_else;
        ety = a64_emit_node(n.a);
        // Normalize float condition to an integer truth value so cbz can branch.
        if (ety == 1) {
            if (a64_bin_mode) { enc_fcmp_zero(0); enc_cset(0, 1); }
            else { out("  fcmp d0, #0.0"); putchar('\n'); out("  cset x0, ne"); putchar('\n'); }
        }
        if (a64_bin_mode) {
            lbl_else = enc_new_label();
            lbl_done = enc_new_label();
            enc_cbz_label(0, lbl_else);
            ety_then = a64_emit_node(n.b);
            enc_b_label(lbl_done);
            enc_def_label(lbl_else);
            ety_else = a64_emit_node(n.c);
            enc_def_label(lbl_done);
        } else {
            lbl_else = a64_new_lbl();
            lbl_done = a64_new_lbl();
            out("  cbz x0, .Lter"); a64_print_dec(lbl_else); putchar('\n');
            ety_then = a64_emit_node(n.b);
            out("  b .Lter"); a64_print_dec(lbl_done); putchar('\n');
            out(".Lter"); a64_print_dec(lbl_else); out(":"); putchar('\n');
            ety_else = a64_emit_node(n.c);
            out(".Lter"); a64_print_dec(lbl_done); out(":"); putchar('\n');
        }
        // Branches must agree on result type; trust the parser to enforce.
        return ety_then;
    }

    if (t == T_BINOP) {
        op_s = unpack_s(n.a); op_l = unpack_l(n.a);
        c0 = peek(a64_sbuf + op_s);
        c1 = 0; if (op_l > 1) { c1 = peek(a64_sbuf + op_s + 1); }

        // Constant folding lives in the parser — by the time a T_BINOP
        // reaches codegen, at least one operand is guaranteed non-literal.

        // Check if this is an integer-only operator (%, &, |, ^, <<, >>).
        is_io = 0;
        if (c0 == '%' || c0 == '^') { is_io = 1; }
        if ((c0 == '&' || c0 == '|') && op_l == 1) { is_io = 1; }
        if ((c0 == '<' && c1 == '<') || (c0 == '>' && c1 == '>')) { is_io = 1; }

        // Evaluate left operand, save it for the op below. Phase B1a.2:
        // try the GP freelist before falling back to push/pop — a single
        // mov beats two memory accesses through the stack. Float operands
        // always use the float stack because the freelist is integer-only.
        auto alloc_reg, left_reg_int;
        alloc_reg = 0 - 1;
        lty = a64_emit_node(n.b);
        if (lty == 1) {
            a64_emit_fpush();
        } else if (_a64_has_call(n.c)) {
            // A BL inside the right-side would clobber x9..x15 (caller-
            // saved on ARM64). Skip the freelist and push to stack.
            a64_emit_push();
        } else {
            alloc_reg = a64_gp_alloc();
            if (alloc_reg >= 0) {
                if (a64_bin_mode) { enc_mov_reg(alloc_reg, 0); }
                else { out("  mov x"); a64_print_dec(alloc_reg); out(", x0"); putchar('\n'); }
            } else {
                a64_emit_push();
            }
        }

        // Evaluate right operand.
        rty = a64_emit_node(n.c);

        // Determine if we use float arithmetic.
        use_flt = is_io == 0 && (lty == 1 || rty == 1) ? 1 : 0;

        if (use_flt == 1) {
            // Ensure right operand is in d0.
            if (rty == 0) { if (a64_bin_mode) { enc_scvtf(0, 0); } else { out("  scvtf d0, x0"); putchar('\n'); } }
            // Place left operand in d1. Three sources, depending on how
            // we saved it: the float stack, a freelist reg, or a push.
            if (lty == 1) {
                a64_emit_fpop(1);
            } else if (alloc_reg >= 0) {
                if (a64_bin_mode) { enc_scvtf(1, alloc_reg); }
                else { out("  scvtf d1, x"); a64_print_dec(alloc_reg); putchar('\n'); }
                a64_gp_free(alloc_reg);
                alloc_reg = 0 - 1;
            } else {
                a64_emit_pop(1);
                if (a64_bin_mode) { enc_scvtf(1, 1); } else { out("  scvtf d1, x1"); putchar('\n'); }
            }
            // d1 = left, d0 = right.

            // Float arithmetic operators.
            if (c0 == '+' && op_l == 1) { if (a64_bin_mode) { enc_fadd(0,1,0); } else { out("  fadd d0, d1, d0"); putchar('\n'); } return 1; }
            if (c0 == '-' && op_l == 1) { if (a64_bin_mode) { enc_fsub(0,1,0); } else { out("  fsub d0, d1, d0"); putchar('\n'); } return 1; }
            if (c0 == '*' && op_l == 1) { if (a64_bin_mode) { enc_fmul(0,1,0); } else { out("  fmul d0, d1, d0"); putchar('\n'); } return 1; }
            if (c0 == '/' && op_l == 1) { if (a64_bin_mode) { enc_fdiv(0,1,0); } else { out("  fdiv d0, d1, d0"); putchar('\n'); } return 1; }

            // Float comparison operators — result is integer in x0.
            if (c0 == '=' && c1 == '=') { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,0); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, eq"); putchar('\n'); } return 0; }
            if (c0 == '!' && c1 == '=') { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,1); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, ne"); putchar('\n'); } return 0; }
            if (c0 == '<') {
                if (c1 == '=') { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,9); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, ls"); putchar('\n'); } return 0; }
                if (op_l == 1) { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,4); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, mi"); putchar('\n'); } return 0; }
            }
            if (c0 == '>') {
                if (c1 == '=') { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,10); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, ge"); putchar('\n'); } return 0; }
                if (op_l == 1) { if (a64_bin_mode) { enc_fcmp(1,0); enc_cset(0,12); } else { out("  fcmp d1, d0"); putchar('\n'); out("  cset x0, gt"); putchar('\n'); } return 0; }
            }
            // && and || removed from T_BINOP — parser now lowers them to
            // T_TERNARY which carries the short-circuit contract directly.
            return 1;
        }

        // Integer path. Convert float operands to int if needed, then
        // place left in either the allocated freelist reg or in x1 via
        // the fallback pop. left_reg_int names that register so every
        // op below emits through a single parameter.
        if (rty == 1) { if (a64_bin_mode) { enc_fcvtzs(0,0); } else { out("  fcvtzs x0, d0"); putchar('\n'); } }
        if (lty == 1) {
            a64_emit_fpop(0);
            if (a64_bin_mode) { enc_fcvtzs(1,0); } else { out("  fcvtzs x1, d0"); putchar('\n'); }
            left_reg_int = 1;
        } else if (alloc_reg >= 0) {
            left_reg_int = alloc_reg;
            // Free the freelist bit up front — the data still lives in
            // the register until the single op instruction below reads
            // it, so bookkeeping can run ahead of the actual read.
            a64_gp_free(alloc_reg);
            alloc_reg = 0 - 1;
        } else {
            a64_emit_pop(1);
            left_reg_int = 1;
        }
        // x{left_reg_int} = left, x0 = right.
        if (c0 == '+' && op_l == 1) { if (a64_bin_mode) { enc_add_reg(0,left_reg_int,0); } else { out("  add x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '-' && op_l == 1) { if (a64_bin_mode) { enc_sub_reg(0,left_reg_int,0); } else { out("  sub x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '*' && op_l == 1) { if (a64_bin_mode) { enc_mul(0,left_reg_int,0); } else { out("  mul x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '/' && op_l == 1) { if (a64_bin_mode) { enc_sdiv(0,left_reg_int,0); } else { out("  sdiv x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '%' && op_l == 1) {
            if (a64_bin_mode) { enc_sdiv(8,left_reg_int,0); enc_msub(0,8,0,left_reg_int); }
            else {
                out("  sdiv x8, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n');
                out("  msub x0, x8, x0, x"); a64_print_dec(left_reg_int); putchar('\n');
            }
            return 0;
        }
        // Bitwise operators.
        if (c0 == '&' && op_l == 1) { if (a64_bin_mode) { enc_and_reg(0,left_reg_int,0); } else { out("  and x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '|' && op_l == 1) { if (a64_bin_mode) { enc_orr_reg(0,left_reg_int,0); } else { out("  orr x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '^' && op_l == 1) { if (a64_bin_mode) { enc_eor_reg(0,left_reg_int,0); } else { out("  eor x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        // Shift operators.
        if (c0 == '>' && c1 == '>') { if (a64_bin_mode) { enc_asrv(0,left_reg_int,0); } else { out("  asr x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        if (c0 == '<' && c1 == '<') { if (a64_bin_mode) { enc_lslv(0,left_reg_int,0); } else { out("  lsl x0, x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); } return 0; }
        // Comparison operators.
        if (c0 == '=' && c1 == '=') { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,0); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, eq"); putchar('\n'); } return 0; }
        if (c0 == '!' && c1 == '=') { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,1); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, ne"); putchar('\n'); } return 0; }
        if (c0 == '<') {
            if (c1 == '=') { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,13); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, le"); putchar('\n'); } return 0; }
            if (op_l == 1) { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,11); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, lt"); putchar('\n'); } return 0; }
        }
        if (c0 == '>') {
            if (c1 == '=') { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,10); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, ge"); putchar('\n'); } return 0; }
            if (op_l == 1) { if (a64_bin_mode) { enc_cmp_reg(left_reg_int,0); enc_cset(0,12); } else { out("  cmp x"); a64_print_dec(left_reg_int); out(", x0"); putchar('\n'); out("  cset x0, gt"); putchar('\n'); } return 0; }
        }
        // && and || removed from T_BINOP integer path — parser lowers them
        // to T_TERNARY (see parse_binops in bpp_parser.bsm).
        return 0;
    }

    if (t == T_UNARY) {
        uty = a64_emit_node(n.b);
        // Check if operator is '~' (bitwise NOT) or '-' (negate).
        op_s = unpack_s(n.a); op_l = unpack_l(n.a);
        if (op_l == 1 && peek(a64_sbuf + op_s) == '~') {
            // Bitwise NOT: MVN Xd, Xn
            if (a64_bin_mode) { enc_mvn(0, 0); } else { out("  mvn x0, x0"); putchar('\n'); }
            return 0;
        }
        if (uty == 1) {
            if (a64_bin_mode) { enc_fneg(0, 0); } else { out("  fneg d0, d0"); putchar('\n'); }
            return 1;
        }
        if (a64_bin_mode) { enc_neg(0, 0); } else { out("  neg x0, x0"); putchar('\n'); }
        return 0;
    }

    if (t == T_CALL) {
        // (putchar, putchar_err, getchar removed as builtins — they live
        // in bpp_io.bsm as B++ functions that call sys_write/sys_read.)
        // (malloc, free, realloc, memcpy removed as builtins — they live
        // in backend/os/<target>/_bmem_<target>.bsm as B++ functions
        // that call sys_mmap/sys_munmap directly. Auto-injected via
        // bpp_mem.bsm for every user program.)
        // Built-in: peek — byte read from real pointer.
        if (a64_str_eq(n.a, "peek", 4)) {
            arr = n.b; ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            if (a64_bin_mode) { enc_ldrb_uoff(0, 0, 0); } else { out("  ldrb w0, [x0]"); putchar('\n'); }
            return 0;
        }
        // Built-in: poke — byte write to real pointer.
        if (a64_str_eq(n.a, "poke", 4)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1);
            if (a64_bin_mode) { enc_strb_uoff(1, 0, 0); } else { out("  strb w1, [x0]"); putchar('\n'); }
            return 0;
        }
        // Built-in: float_ret() — read the first float return value saved after the last extern call.
        // Loads d0 from the hidden d0_save slot at [x29, #24].
        if (a64_str_eq(n.a, "float_ret", 9)) {
            if (a64_bin_mode) { enc_ldr_d_uoff(0, 29, 24); }
            else { out("  ldr d0, [x29, #24]"); putchar('\n'); }
            return 1;
        }
        // Built-in: float_ret2() — read the second float return value saved after the last extern call.
        // Loads d0 from the hidden d1_save slot at [x29, #32].
        if (a64_str_eq(n.a, "float_ret2", 10)) {
            if (a64_bin_mode) { enc_ldr_d_uoff(0, 29, 32); }
            else { out("  ldr d0, [x29, #32]"); putchar('\n'); }
            return 1;
        }
        // Built-in: shr(value, shift) — logical right shift (unsigned, fills with zeros).
        // Unlike >> which is arithmetic (sign-extending), shr uses LSRV.
        if (a64_str_eq(n.a, "shr", 3)) {
            arr = n.b;
            a64_emit_node(*(arr + 8));
            a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1);
            if (a64_bin_mode) { enc_lsrv(0, 0, 1); }
            else { out("  lsr x0, x0, x1"); putchar('\n'); }
            return 0;
        }
        // Built-in: assert(cond) — abort with trap if condition is zero.
        if (a64_str_eq(n.a, "assert", 6)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            if (a64_bin_mode) {
                auto lbl_ok;
                lbl_ok = enc_new_label();
                enc_cbnz_label(0, lbl_ok);
                enc_emit32(0xD4200000);
                enc_def_label(lbl_ok);
            } else {
                auto lbl_ok;
                lbl_ok = a64_new_lbl();
                out("  cbnz x0, .Lok"); a64_print_dec(lbl_ok); putchar('\n');
                out("  brk #0"); putchar('\n');
                out(".Lok"); a64_print_dec(lbl_ok); out(":"); putchar('\n');
            }
            return 0;
        }
        // Built-in: str_peek — byte read from real string pointer.
        if (a64_str_eq(n.a, "str_peek", 8)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1);
            if (a64_bin_mode) { enc_ldrb_reg(0, 0, 1); } else { out("  ldrb w0, [x0, x1]"); putchar('\n'); }
            return 0;
        }
        // Built-in: sys_write(fd, buf, len) — raw write syscall.
        if (a64_str_eq(n.a, "sys_write", 9)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 16));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_WRITE);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x16, #4"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_read(fd, buf, len) — raw read syscall.
        if (a64_str_eq(n.a, "sys_read", 8)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 16));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_READ);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x16, #3"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_open(path, flags) — raw open syscall.
        if (a64_str_eq(n.a, "sys_open", 8)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1);
            if (a64_bin_mode) {
                enc_mov_wide(2, 493);
                enc_mov_wide(16, BSYS_OPEN);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x2, #493"); putchar('\n');
                out("  mov x16, #5"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_close(fd) — raw close syscall.
        if (a64_str_eq(n.a, "sys_close", 9)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_CLOSE);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x16, #6"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_mkdir(path, mode) — create a directory. Returns 0 on success.
        if (a64_str_eq(n.a, "sys_mkdir", 9)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 8));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_push();
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
            a64_emit_pop(1);
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_MKDIR);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x16, #136"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_fork() — fork the process. Returns child pid to parent, 0 to child.
        if (a64_str_eq(n.a, "sys_fork", 8)) {
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_FORK);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
                lbl = enc_new_label();
                enc_cbz_label(1, lbl);
                enc_mov_wide(0, 0);
                enc_def_label(lbl);
            } else {
                out("  mov x16, #2"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
                out("  cbz x1, 8"); putchar('\n');
                out("  mov x0, #0"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_execve(path, argv, envp) — replace process image.
        if (a64_str_eq(n.a, "sys_execve", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 0)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 16));
            a64_emit_pop(1);
            a64_emit_pop(2);
            // Swap: x0=path(was x2), x1=argv(was x1), x2=envp(was x0)
            // Actually after pops: x2=path, x1=argv, x0=envp. Need x0=path, x1=argv, x2=envp.
            if (a64_bin_mode) {
                enc_mov_reg(3, 0);  // x3 = envp
                enc_mov_reg(0, 2);  // x0 = path
                enc_mov_reg(2, 3);  // x2 = envp
                enc_mov_wide(16, BSYS_EXECVE);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x3, x0"); putchar('\n');
                out("  mov x0, x2"); putchar('\n');
                out("  mov x2, x3"); putchar('\n');
                out("  mov x16, #59"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_waitpid(pid) — wait for child process to exit.
        if (a64_str_eq(n.a, "sys_waitpid", 11)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) {
                enc_mov_wide(1, 0);  // status = NULL
                enc_mov_wide(2, 0);  // options = 0
                enc_mov_wide(3, 0);  // rusage = NULL
                enc_mov_wide(16, BSYS_WAIT4);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
            } else {
                out("  mov x1, #0"); putchar('\n');
                out("  mov x2, #0"); putchar('\n');
                out("  mov x3, #0"); putchar('\n');
                out("  mov x16, #7"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
                out("  csneg x0, x0, x0, cc"); putchar('\n');
            }
            return 0;
        }
        // Built-in: sys_ptrace(request, pid, addr, data) — process trace.
        // macOS syscall 26. 4 args in x0-x3.
        if (a64_str_eq(n.a, "sys_ptrace", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 24)); a64_emit_push();
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2); a64_emit_pop(3);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_PTRACE); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            return 0;
        }
        // Built-in: sys_wait4(pid, status, options, rusage) — wait for child.
        // macOS syscall 7. 4 args in x0-x3.
        if (a64_str_eq(n.a, "sys_wait4", 9)) {
            arr = n.b;
            a64_emit_node(*(arr + 24)); a64_emit_push();
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2); a64_emit_pop(3);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_WAIT4); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            return 0;
        }
        // Built-in: sys_mmap(addr, len, prot, flags, fd, offset) — 6 args in x0-x5.
        // Returns mapped address, or -1 on failure.
        if (a64_str_eq(n.a, "sys_mmap", 8)) {
            arr = n.b;
            a64_emit_node(*(arr + 40)); a64_emit_push();
            a64_emit_node(*(arr + 32)); a64_emit_push();
            a64_emit_node(*(arr + 24)); a64_emit_push();
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2); a64_emit_pop(3);
            a64_emit_pop(4); a64_emit_pop(5);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_MMAP); enc_svc(0x80); }
            return 0;
        }
        // Built-in: sys_munmap(addr, len) — release a mapping. Returns 0 on success.
        if (a64_str_eq(n.a, "sys_munmap", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_MUNMAP); enc_svc(0x80); }
            return 0;
        }
        // Built-in: sys_usleep(us) — sleep for N microseconds.
        // Uses select(0,0,0,0,&timeval) — macOS syscall 93.
        // Assumes us < 1000000 so tv_sec=0, tv_usec=us.
        if (a64_str_eq(n.a, "sys_usleep", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) {
                // x0 = microseconds. Build timeval {0, x0} on stack.
                enc_mov_wide(1, 0);
                enc_stp_pre(1, 0, 31, 0 - 16);  // push {tv_sec=0, tv_usec=x0}
                enc_add_imm(4, 31, 0);   // x4 = sp (pointer to timeval)
                enc_mov_wide(0, 0);      // nfds = 0
                enc_mov_wide(1, 0);      // readfds = NULL
                enc_mov_wide(2, 0);      // writefds = NULL
                enc_mov_wide(3, 0);      // exceptfds = NULL
                enc_mov_wide(16, BSYS_SELECT);
                enc_svc(0x80);
                enc_csneg(0, 0, 0, 3);
                enc_add_imm(31, 31, 16); // restore stack
            }
            return 0;
        }
        // Built-in: mem_barrier() — full bidirectional memory fence.
        // Emits ARM64 DMB ISH (Data Memory Barrier, Inner Shareable),
        // encoded as 0xD5033BBF. Used by stbjob to order producer
        // writes against consumer reads on the SPSC queues. This is a
        // full fence, which is overkill compared to release/acquire,
        // but acquire/release primitives can wait until a real audio
        // hot loop proves they matter. Returns 0 by convention.
        if (a64_str_eq(n.a, "mem_barrier", 11)) {
            if (a64_bin_mode) {
                enc_emit32(0xD5033BBF);
                enc_mov_wide(0, 0);
            } else {
                out("  dmb ish\n  mov x0, #0\n");
            }
            return 0;
        }
        // Built-in: sys_socket(domain, type, protocol) — create a socket.
        // macOS syscall 97. 3 args in x0-x2.
        if (a64_str_eq(n.a, "sys_socket", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_SOCKET); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            return 0;
        }
        // Built-in: sys_connect(fd, addr, addrlen) — connect a socket.
        // macOS syscall 98. 3 args in x0-x2.
        if (a64_str_eq(n.a, "sys_connect", 11)) {
            arr = n.b;
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_CONNECT); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            return 0;
        }
        // Built-in: sys_unlink(path) — delete a file. macOS syscall 10.
        if (a64_str_eq(n.a, "sys_unlink", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_UNLINK); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            else { out("  mov x16, #10\n  svc #0x80\n  csneg x0, x0, x0, cc\n"); }
            return 0;
        }
        // Built-in: sys_getdents(fd, buf, bufsize) — read directory entries.
        // macOS: getdirentries64 (syscall 344). Returns bytes read, 0 at end.
        if (a64_str_eq(n.a, "sys_getdents", 12)) {
            arr = n.b;
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) {
                // getdirentries64 needs a 4th arg (basep) = NULL.
                enc_mov_wide(3, 0);
                enc_mov_wide(16, BSYS_GETDENTS); enc_svc(0x80); enc_csneg(0, 0, 0, 3);
            } else { out("  mov x3, #0\n  mov x16, #344\n  svc #0x80\n  csneg x0, x0, x0, cc\n"); }
            return 0;
        }
        // Built-in: sys_lseek(fd, offset, whence) — reposition file offset.
        // macOS syscall 199. Returns new offset or -1 on error.
        if (a64_str_eq(n.a, "sys_lseek", 9)) {
            arr = n.b;
            a64_emit_node(*(arr + 16)); a64_emit_push();
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1); a64_emit_pop(2);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_LSEEK); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            else { out("  mov x16, #199\n  svc #0x80\n  csneg x0, x0, x0, cc\n"); }
            return 0;
        }
        // Built-in: sys_fchmod(fd, mode) — change file permissions by fd.
        // macOS syscall 124. Returns 0 on success.
        if (a64_str_eq(n.a, "sys_fchmod", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 8)); a64_emit_push();
            a64_emit_node(*(arr + 0));
            a64_emit_pop(1);
            if (a64_bin_mode) { enc_mov_wide(16, BSYS_FCHMOD); enc_svc(0x80); enc_csneg(0, 0, 0, 3); }
            else { out("  mov x16, #124\n  svc #0x80\n  csneg x0, x0, x0, cc\n"); }
            return 0;
        }
        // Built-in: sys_exit(code) — terminate the process immediately.
        if (a64_str_eq(n.a, "sys_exit", 8)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) {
                enc_mov_wide(16, BSYS_EXIT);
                enc_svc(0x80);
            } else {
                out("  mov x16, #1"); putchar('\n');
                out("  svc #0x80"); putchar('\n');
            }
            return 0;
        }
        // Built-in: argc_get() — return the argument count.
        if (a64_str_eq(n.a, "argc_get", 8)) {
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, a64_argc_sym, 0);
                enc_adrp(8); enc_add_imm(8, 8, 0);
                enc_ldr_uoff(0, 8, 0);
            } else {
                out("  adrp x8, _bpp_argc@PAGE"); putchar('\n');
                out("  add x8, x8, _bpp_argc@PAGEOFF"); putchar('\n');
                out("  ldr x0, [x8]"); putchar('\n');
            }
            return 0;
        }
        // Built-in: argv_get(i) — return a pointer to the i-th argument string.
        if (a64_str_eq(n.a, "argv_get", 8)) {
            // Evaluate the index argument.
            a64_emit_node(*(n.b));
            a64_emit_push();
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, a64_argv_sym, 0);
                enc_adrp(8); enc_add_imm(8, 8, 0);
                enc_ldr_uoff(0, 8, 0);
                a64_emit_pop(1);
                enc_ldr_reg_shift3(0, 0, 1);
            } else {
                out("  adrp x8, _bpp_argv@PAGE"); putchar('\n');
                out("  add x8, x8, _bpp_argv@PAGEOFF"); putchar('\n');
                out("  ldr x0, [x8]"); putchar('\n');
                a64_emit_pop(1);
                out("  ldr x0, [x0, x1, lsl #3]"); putchar('\n');
            }
            return 0;
        }
        // Built-in: envp_get(i) — return a pointer to the i-th environment
        // string ("NAME=value\0"). Returns 0 once i passes the NULL terminator.
        // Use this to walk the env vars; the higher-level getenv() in
        // bpp_io.bsm searches by name and returns just the value.
        if (a64_str_eq(n.a, "envp_get", 8)) {
            a64_emit_node(*(n.b));
            a64_emit_push();
            if (a64_bin_mode) {
                enc_add_reloc(enc_pos, a64_envp_sym, 0);
                enc_adrp(8); enc_add_imm(8, 8, 0);
                enc_ldr_uoff(0, 8, 0);
                a64_emit_pop(1);
                enc_ldr_reg_shift3(0, 0, 1);
            } else {
                out("  adrp x8, _bpp_envp@PAGE"); putchar('\n');
                out("  add x8, x8, _bpp_envp@PAGEOFF"); putchar('\n');
                out("  ldr x0, [x8]"); putchar('\n');
                a64_emit_pop(1);
                out("  ldr x0, [x0, x1, lsl #3]"); putchar('\n');
            }
            return 0;
        }

        // Built-in: fn_ptr(name) — return the code address of a B++ function.
        if (a64_str_eq(n.a, "fn_ptr", 6)) {
            arr = n.b;
            fn_name = *(arr + 0);
            fi = a64_find_fn(fn_name.a);
            // Guard: emit error if the function name was not found.
            if (fi < 0) {
                diag_str("internal error: fn_ptr target not found after validate\n");
                sys_exit(2);
            }
            if (a64_bin_mode) {
                enc_adr_label(0, arr_get(a64_fn_lbl, fi));
            } else {
                out("  adrp x0, _"); a64_print_p(fn_name.a); out("@PAGE"); putchar('\n');
                out("  add x0, x0, _"); a64_print_p(fn_name.a); out("@PAGEOFF"); putchar('\n');
            }
            return 0;
        }

        // Built-in: call(fn_ptr, arg0, arg1, ...) — indirect function call.
        // First argument is the function address, remaining are passed to it.
        if (a64_str_eq(n.a, "call", 4)) {
            arr = n.b; cnt = n.c;
            // Evaluate all arguments (fn_ptr + real args) and push.
            i = 0;
            while (i < cnt) {
                a64_emit_node(*(arr + i * 8));
                a64_emit_push();
                i = i + 1;
            }
            // Pop real args into x0..x(cnt-2).
            i = cnt - 2;
            while (i >= 0) { a64_emit_pop(i); i = i - 1; }
            // Pop function pointer into x9 (it was pushed first, so it's last to pop).
            a64_emit_pop(9);
            // Indirect call. Save d0/d1 for float_ret() / float_ret2().
            if (a64_bin_mode) {
                enc_blr(9);
                enc_str_d_uoff(0, 29, 24);
                enc_str_d_uoff(1, 29, 32);
            } else {
                out("  blr x9"); putchar('\n');
                out("  str d0, [x29, #24]"); putchar('\n');
                out("  str d1, [x29, #32]"); putchar('\n');
            }
            return 0;
        }

        // ── Phase B4: SIMD builtins (4-wide float32) ──
        // Each builtin lowers to NEON V-register ops. Binary ops route
        // through _a64_vec_binop with the encoder opcode + asm mnemonic;
        // the spill/reload dance for the left operand is shared. Result
        // lands in V0 for return; return type 2 signals SIMD, 1 signals
        // scalar float (used by vec_dot4 / vec_get4).
        if (a64_str_eq(n.a, "vec_load4", 9)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) { enc_ldr_q_uoff(0, 0, 0); }
            else { out("  ldr q0, [x0]"); putchar('\n'); }
            return 2;
        }
        if (a64_str_eq(n.a, "vec_store4", 10)) {
            arr = n.b;
            a64_emit_node(*(arr + 8));   // value → v0
            a64_emit_vpush();
            a64_emit_node(*(arr + 0));   // ptr → x0
            a64_emit_vpop(1);             // v1 = value
            if (a64_bin_mode) { enc_str_q_uoff(1, 0, 0); }
            else { out("  str q1, [x0]"); putchar('\n'); }
            return 0;
        }
        if (a64_str_eq(n.a, "vec_add4", 8)) { _a64_vec_binop(n, 0x4E20D400, "fadd"); return 2; }
        if (a64_str_eq(n.a, "vec_sub4", 8)) { _a64_vec_binop(n, 0x4EA0D400, "fsub"); return 2; }
        if (a64_str_eq(n.a, "vec_mul4", 8)) { _a64_vec_binop(n, 0x6E20DC00, "fmul"); return 2; }
        if (a64_str_eq(n.a, "vec_div4", 8)) { _a64_vec_binop(n, 0x6E20FC00, "fdiv"); return 2; }
        if (a64_str_eq(n.a, "vec_min4", 8)) { _a64_vec_binop(n, 0x4EA0F400, "fmin"); return 2; }
        if (a64_str_eq(n.a, "vec_max4", 8)) { _a64_vec_binop(n, 0x4E20F400, "fmax"); return 2; }
        if (a64_str_eq(n.a, "vec_splat4", 10)) {
            arr = n.b;
            ety = a64_emit_node(*(arr + 0));
            if (ety == 1) {
                // Float scalar in d0: convert double→single, broadcast from S0.
                if (a64_bin_mode) { enc_fcvt_s_d(0, 0); enc_dup_v_4s_from_s(0, 0); }
                else { out("  fcvt s0, d0"); putchar('\n'); out("  dup v0.4s, v0.s[0]"); putchar('\n'); }
            } else {
                // Integer in x0: broadcast W0 to all 4 lanes.
                if (a64_bin_mode) { enc_dup_v_4s(0, 0); }
                else { out("  dup v0.4s, w0"); putchar('\n'); }
            }
            return 2;
        }
        if (a64_str_eq(n.a, "vec_dot4", 8)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            if (a64_bin_mode) { enc_str_q_pre(0, 31, 0 - 16); }
            else { out("  str q0, [sp, #-16]!"); putchar('\n'); }
            a64_emit_node(*(arr + 8));
            // Horizontal sum via two FADDPs — matches LLVM's lowering of
            // `vaddvq_f32` and avoids the single-instruction FADDV path
            // whose encoding is easy to mis-assemble by hand.
            if (a64_bin_mode) {
                enc_ldr_q_post(1, 31, 16);
                enc_fmul_v_4s(0, 1, 0);
                enc_faddp_v_4s(0, 0, 0);
                enc_faddp_s(0, 0);
            } else {
                out("  ldr q1, [sp], #16"); putchar('\n');
                out("  fmul v0.4s, v1.4s, v0.4s"); putchar('\n');
                out("  faddp v0.4s, v0.4s, v0.4s"); putchar('\n');
                out("  faddp s0, v0.2s"); putchar('\n');
            }
            // Result is scalar float in s0; widen to d0 for the float convention.
            if (a64_bin_mode) { enc_fcvt_d_s(0, 0); }
            else { out("  fcvt d0, s0"); putchar('\n'); }
            return 1;
        }
        // vec_get4(v, lane) — extract one float32 lane as a scalar double.
        // Lane index must be a compile-time literal (0..3). Spills the
        // vector to the stack and loads the lane as a 32-bit float,
        // avoiding the need for a specialized scalar-DUP encoder.
        if (a64_str_eq(n.a, "vec_get4", 8)) {
            arr = n.b;
            a64_emit_node(*(arr + 0));
            auto lane_nd: Node, lane_v;
            lane_nd = *(arr + 8);
            lane_v = a64_parse_int(lane_nd.a);
            if (a64_bin_mode) {
                enc_sub_imm(31, 31, 16);
                enc_str_q_uoff(0, 31, 0);
                enc_ldr_s_uoff(0, 31, lane_v * 4);
                enc_add_imm(31, 31, 16);
                enc_fcvt_d_s(0, 0);
            } else {
                out("  sub sp, sp, #16"); putchar('\n');
                out("  str q0, [sp]"); putchar('\n');
                out("  ldr s0, [sp, #"); a64_print_dec(lane_v * 4); out("]"); putchar('\n');
                out("  add sp, sp, #16"); putchar('\n');
                out("  fcvt d0, s0"); putchar('\n');
            }
            return 1;
        }

        // Regular B++ function call.
        // Query bpp_types.bsm for callee's parameter and return types.
        fidx_c = find_func_idx(n.a);
        // Phase B2: splice tiny pure `: base` helpers inline.
        if (fidx_c >= 0 && arr_get(fn_inlineable, fidx_c)) {
            auto inl_callee, inl_body, inl_ret: Node, inl_expr;
            auto inl_params, inl_pcnt, inl_cloned;
            inl_callee = funcs[fidx_c];
            inl_body = *(inl_callee + FN_BODY);
            inl_ret = inl_body[0];
            inl_expr = inl_ret.a;
            inl_params = *(inl_callee + FN_PARS);
            inl_pcnt = *(inl_callee + FN_PCNT);
            inl_cloned = ast_clone_subst(inl_expr, inl_params, inl_pcnt, n.b);
            return a64_emit_node(inl_cloned);
        }
        arr = n.b; cnt = n.c;
        i = 0;
        while (i < cnt) {
            ety = a64_emit_node(*(arr + i * 8));
            if (fidx_c >= 0) {
                vi = is_float_type(get_fn_par_type(fidx_c, i));
                if (ety == 1) {
                    if (vi == 1) {
                        if (a64_bin_mode) { enc_fmov_to_gpr(0, 0); } else { out("  fmov x0, d0"); putchar('\n'); }
                    } else {
                        if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
                    }
                } else {
                    if (vi == 1) {
                        if (a64_bin_mode) {
                            enc_scvtf(0, 0);
                            enc_fmov_to_gpr(0, 0);
                        } else {
                            out("  scvtf d0, x0"); putchar('\n');
                            out("  fmov x0, d0"); putchar('\n');
                        }
                    }
                }
            } else {
                if (ety == 1) {
                    if (a64_bin_mode) { enc_fmov_to_gpr(0, 0); } else { out("  fmov x0, d0"); putchar('\n'); }
                }
            }
            a64_emit_push();
            i = i + 1;
        }
        // Pop args into x0..x(cnt-1) in reverse order.
        i = cnt - 1;
        while (i >= 0) { a64_emit_pop(i); i = i - 1; }

        // For FFI calls: rearrange args per ARM64 ABI.
        // Int and float args use SEPARATE register counters:
        //   int args  → x0, x1, x2, ...  (int_idx)
        //   float args → d0, d1, d2, ... (flt_idx)
        // After pop, all args sit in x0..x(N-1). Rearrange in one pass.
        // Invariant: int_idx <= i, so compacting ints never clobbers unread values.
        auto exi;
        exi = a64_find_ext_by_argc(n.a, cnt);
        if (exi >= 0) {
            auto int_idx, flt_idx;
            int_idx = 0; flt_idx = 0;
            i = 0;
            while (i < cnt) {
                if (a64_ext_par_is_float(exi, i)) {
                    // Move bit pattern from x[i] → d[flt_idx].
                    if (a64_bin_mode) { enc_fmov_from_gpr(flt_idx, i); }
                    else { out("  fmov d"); a64_print_dec(flt_idx); out(", x"); a64_print_dec(i); putchar('\n'); }
                    flt_idx = flt_idx + 1;
                } else {
                    // Compact int args: x[i] → x[int_idx].
                    if (int_idx != i) {
                        if (a64_bin_mode) { enc_add_imm(int_idx, i, 0); }
                        else { out("  mov x"); a64_print_dec(int_idx); out(", x"); a64_print_dec(i); putchar('\n'); }
                    }
                    int_idx = int_idx + 1;
                }
                i = i + 1;
            }
        }

        if (a64_bin_mode) {
            fi = a64_find_fn(n.a);
            if (fi >= 0) {
                enc_bl_label(arr_get(a64_fn_lbl, fi));
            } else if (a64_find_ext(n.a) >= 0) {
                // External function: load address from GOT and call indirectly.
                // Save d0/d1 after the call for float_ret() / float_ret2().
                enc_add_reloc(enc_pos, n.a, 3);
                enc_adrp(16);
                enc_ldr_uoff(16, 16, 0);
                enc_blr(16);
                enc_str_d_uoff(0, 29, 24);
                enc_str_d_uoff(1, 29, 32);
            } else {
                // Cross-module B++ function: BL placeholder with type 4 relocation.
                enc_add_reloc(enc_pos, n.a, 4);
                enc_emit32(0x94000000);
            }
        } else {
            out("  bl _"); a64_print_p(n.a); putchar('\n');
            // Save float return registers after extern calls for float_ret() / float_ret2().
            if (exi >= 0) {
                out("  str d0, [x29, #24]"); putchar('\n');
                out("  str d1, [x29, #32]"); putchar('\n');
            }
        }
        // Check if callee returns float (B++ functions or FFI).
        if (fidx_c >= 0) {
            if (is_float_type(get_fn_ret_type(fidx_c))) { return 1; }
        }
        if (exi >= 0) {
            if (a64_ext_ret_is_float(exi)) { return 1; }
        }
        return 0;
    }

    // mem_load: *(ptr) — load 8 bytes from real pointer.
    // mem_load: *(ptr) — load from real pointer.
    // n.b holds the field type hint for packed structs (0 = default 8-byte load).
    if (t == T_MEMLD) {
        auto fh;
        fh = n.b;
        ety = a64_emit_node(n.a);
        if (ety == 1) {
            if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
        }
        // Float field types: load to float register and widen to double.
        // SIMD (`: double`, 128 bits) stays in V0 as a SIMD value; the
        // narrower forms load + widen to D0 per the scalar convention.
        if (is_float_type(fh)) {
            if (ty_slice(fh) == SL_DOUBLE) {
                if (a64_bin_mode) { enc_ldr_q_uoff(0, 0, 0); }
                else { out("  ldr q0, [x0]"); putchar('\n'); }
                return 2;
            }
            if (ty_slice(fh) == SL_HALF) {
                if (a64_bin_mode) { enc_ldr_s_uoff(0, 0, 0); enc_fcvt_d_s(0, 0); }
                else {
                    out("  ldr s0, [x0]"); putchar('\n');
                    out("  fcvt d0, s0"); putchar('\n');
                }
                return 1;
            }
            if (ty_slice(fh) == SL_QUARTER) {
                if (a64_bin_mode) { enc_ldr_h_uoff(0, 0, 0); enc_fcvt_d_h(0, 0); }
                else {
                    out("  ldr h0, [x0]"); putchar('\n');
                    out("  fcvt d0, h0"); putchar('\n');
                }
                return 1;
            }
            if (a64_bin_mode) { enc_ldr_d_uoff(0, 0, 0); }
            else { out("  ldr d0, [x0]"); putchar('\n'); }
            return 1;
        }
        // Bit-packed field types: load the containing byte, extract the
        // requested bit slice with UBFX. The bit offset within the byte
        // travels in bits 8-10 of the hint word (encoded by resolve_dot).
        auto sl, bo, bw;
        sl = ty_slice(fh);
        if (sl >= SL_BIT && sl <= SL_BIT7) {
            bo = (fh / 256) & 7;
            bw = sl - 3;
            if (a64_bin_mode) {
                enc_ldrb_uoff(0, 0, 0);
                enc_ubfx_w(0, 0, bo, bw);
            } else {
                out("  ldrb w0, [x0]"); putchar('\n');
                out("  ubfx w0, w0, #"); a64_print_dec(bo);
                out(", #"); a64_print_dec(bw); putchar('\n');
            }
            return 0;
        }
        // Integer field types: load to integer register.
        if (sl == SL_BYTE) {
            if (a64_bin_mode) { enc_ldrb_uoff(0, 0, 0); } else { out("  ldrb w0, [x0]"); putchar('\n'); }
        } else if (sl == SL_QUARTER) {
            if (a64_bin_mode) { enc_ldrh_uoff(0, 0, 0); } else { out("  ldrh w0, [x0]"); putchar('\n'); }
        } else if (sl == SL_HALF) {
            if (a64_bin_mode) { enc_ldrsw_uoff(0, 0, 0); } else { out("  ldrsw x0, [x0]"); putchar('\n'); }
        } else {
            if (a64_bin_mode) { enc_ldr_uoff(0, 0, 0); } else { out("  ldr x0, [x0]"); putchar('\n'); }
        }
        return 0;
    }

    // ── Address-of: &x ──
    // Computes the memory address of a variable without loading its value.
    if (t == T_ADDR) {
        auto child: Node;
        child = n.a;
        if (child != 0) {
            if (child.ntype == T_VAR) {
                vi = a64_var_idx(child.a);
                if (vi >= 0) {
                    off = arr_get(a64_var_off, vi);
                    if (a64_bin_mode) { enc_add_imm(0, 29, off); }
                    else { out("  add x0, x29, #"); a64_print_dec(off); putchar('\n'); }
                    return 0;
                }
                // Global variable: compute address without loading.
                if (a64_bin_mode) {
                    enc_add_reloc(enc_pos, child.a, 0);
                    enc_adrp(0); enc_add_imm(0, 0, 0);
                } else {
                    out("  adrp x0, _"); a64_print_p(child.a); out("@PAGE"); putchar('\n');
                    out("  add x0, x0, _"); a64_print_p(child.a); out("@PAGEOFF"); putchar('\n');
                }
                return 0;
            }
        }
        return 0;
    }

}

// ── Statement emission ─────────────────────────────────────

static void a64_emit_body(arr, cnt) {
    auto i;
    auto n: Node;
    i = 0;
    while (i < cnt) {
        n = *(arr + i * 8);
        if (n != 0) { a64_emit_stmt(n); }
        i = i + 1;
    }
}

static void a64_emit_stmt(nd) {
    auto n: Node;
    auto lhs: Node;
    auto t, off, lbl, lbl2, arr, cnt, i, rty, vi, ety;
    if (nd == 0) { return 0; }
    n = nd; t = n.ntype;

    if (t == T_DECL) {
        // Variables already pre-registered in emit_func. No-op.
        return 0;
    }

    if (t == T_ASSIGN) {
        lhs = n.a;
        if (lhs.ntype == T_VAR) {
            vi = a64_var_idx(lhs.a);
            if (vi >= 0) {
                // Stack struct copy: copy all fields from source address.
                if (arr_get(a64_var_stack, vi)) {
                    a64_emit_node(n.b);
                    // x0 = source struct address. Copy fields to dest on stack.
                    off = arr_get(a64_var_off, vi);
                    auto fc, j, sidx;
                    sidx = arr_get(a64_var_struct_idx, vi);
                    fc = (get_struct_size(sidx) + 7) / 8;
                    j = 0;
                    while (j < fc) {
                        if (a64_bin_mode) {
                            enc_ldr_uoff(8, 0, j * 8);
                            enc_str_uoff(8, 29, off + j * 8);
                        } else {
                            out("  ldr x8, [x0, #"); a64_print_dec(j * 8); out("]"); putchar('\n');
                            out("  str x8, [x29, #"); a64_print_dec(off + j * 8); out("]"); putchar('\n');
                        }
                        j = j + 1;
                    }
                    return 0;
                }
        }
        }
        rty = a64_emit_node(n.b);
        if (lhs.ntype == T_VAR) {
            vi = a64_var_idx(lhs.a);
            if (vi >= 0) {
                off = arr_get(a64_var_off, vi);
                // Type-aware store: uses the correct instruction for the variable's size.
                a64_emit_store_var(vi, off, rty);
            } else {
                // Global variable store.
                if (is_float_type(ty_get_global_type(lhs.a))) {
                    // Float global: keep value in d0, convert int if needed.
                    if (rty == 0) {
                        if (a64_bin_mode) { enc_scvtf(0, 0); } else { out("  scvtf d0, x0"); putchar('\n'); }
                    }
                    if (a64_bin_mode) {
                        enc_add_reloc(enc_pos, lhs.a, 0);
                        enc_adrp(8); enc_add_imm(8, 8, 0);
                        enc_str_d_uoff(0, 8, 0);
                    } else {
                        out("  adrp x8, _"); a64_print_p(lhs.a); out("@PAGE"); putchar('\n');
                        out("  add x8, x8, _"); a64_print_p(lhs.a); out("@PAGEOFF"); putchar('\n');
                        out("  str d0, [x8]"); putchar('\n');
                    }
                } else {
                    // Integer global.
                    if (rty == 1) {
                        if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
                    }
                    if (a64_bin_mode) {
                        enc_add_reloc(enc_pos, lhs.a, 0);
                        enc_adrp(8); enc_add_imm(8, 8, 0);
                        enc_str_uoff(0, 8, 0);
                    } else {
                        out("  adrp x8, _"); a64_print_p(lhs.a); out("@PAGE"); putchar('\n');
                        out("  add x8, x8, _"); a64_print_p(lhs.a); out("@PAGEOFF"); putchar('\n');
                        out("  str x0, [x8]"); putchar('\n');
                    }
                }
            }
        }
        return 0;
    }

    // mem_store: *(ptr) = val — store to real pointer.
    // n.c holds the field type hint for packed structs (0 = default 8-byte store).
    if (t == T_MEMST) {
        auto fh;
        fh = n.c;
        // Float field types: keep the value in a float register, narrow
        // if the slice calls for it. SIMD (`: double`, 128 bits) takes a
        // distinct path since the value must stay in a V register — not
        // the scalar D-register pipeline the narrower slices use.
        if (is_float_type(fh)) {
            auto fh_sl;
            fh_sl = ty_slice(fh);
            if (fh_sl == SL_DOUBLE) {
                // Value side is SIMD (rty=2) already in V0. Spill to the
                // SIMD push slot, evaluate the pointer, reload into V1,
                // and store at [x0].
                ety = a64_emit_node(n.b);
                if (ety != 2) {
                    diag_error(231);
                    diag_str("cannot store non-SIMD value through a ': double' field");
                    diag_newline();
                }
                a64_emit_vpush();
                a64_emit_node(n.a);
                a64_emit_vpop(1);
                if (a64_bin_mode) { enc_str_q_uoff(1, 0, 0); }
                else { out("  str q1, [x0]"); putchar('\n'); }
                return 0;
            }
            // Scalar float slice: coerce int→double, push as scalar, then
            // narrow on the store side per slice width.
            ety = a64_emit_node(n.b);
            if (ety == 0) {
                if (a64_bin_mode) { enc_scvtf(0, 0); }
                else { out("  scvtf d0, x0"); putchar('\n'); }
            }
            a64_emit_fpush();
            a64_emit_node(n.a);
            a64_emit_fpop(1);
            if (fh_sl == SL_HALF) {
                if (a64_bin_mode) { enc_fcvt_s_d(1, 1); enc_str_s_uoff(1, 0, 0); }
                else {
                    out("  fcvt s1, d1"); putchar('\n');
                    out("  str s1, [x0]"); putchar('\n');
                }
            }
            if (fh_sl == SL_QUARTER) {
                if (a64_bin_mode) { enc_fcvt_h_d(1, 1); enc_str_h_uoff(1, 0, 0); }
                else {
                    out("  fcvt h1, d1"); putchar('\n');
                    out("  str h1, [x0]"); putchar('\n');
                }
            }
            if (fh_sl == SL_FULL) {
                if (a64_bin_mode) { enc_str_d_uoff(1, 0, 0); }
                else { out("  str d1, [x0]"); putchar('\n'); }
            }
            return 0;
        }
        // Integer field types: emit value, save it, emit pointer, store.
        // Phase B1c: freelist the value save when safe. The pointer
        // expression in n.a might trigger a BL (caller-saved clobber),
        // in which case we keep the push/pop fallback.
        auto alloc_reg_st, val_reg;
        alloc_reg_st = 0 - 1;
        val_reg = 1;
        ety = a64_emit_node(n.b);
        if (ety == 1) {
            if (a64_bin_mode) { enc_fmov_to_gpr(0, 0); } else { out("  fmov x0, d0"); putchar('\n'); }
        }
        if (_a64_has_call(n.a)) {
            a64_emit_push();
        } else {
            alloc_reg_st = a64_gp_alloc();
            if (alloc_reg_st >= 0) {
                if (a64_bin_mode) { enc_mov_reg(alloc_reg_st, 0); }
                else { out("  mov x"); a64_print_dec(alloc_reg_st); out(", x0"); putchar('\n'); }
            } else {
                a64_emit_push();
            }
        }
        a64_emit_node(n.a);
        if (alloc_reg_st >= 0) {
            val_reg = alloc_reg_st;
            a64_gp_free(alloc_reg_st);
        } else {
            a64_emit_pop(1);
        }
        // x0 = pointer, x{val_reg} = source value.
        auto sl, bo, bw;
        sl = ty_slice(fh);
        if (sl >= SL_BIT && sl <= SL_BIT7) {
            bo = (fh / 256) & 7;
            bw = sl - 3;
            if (a64_bin_mode) {
                enc_ldrb_uoff(2, 0, 0);
                enc_bfi_w(2, val_reg, bo, bw);
                enc_strb_uoff(2, 0, 0);
            } else {
                out("  ldrb w2, [x0]"); putchar('\n');
                out("  bfi w2, w"); a64_print_dec(val_reg); out(", #"); a64_print_dec(bo);
                out(", #"); a64_print_dec(bw); putchar('\n');
                out("  strb w2, [x0]"); putchar('\n');
            }
            return 0;
        }
        if (sl == SL_BYTE) {
            if (a64_bin_mode) { enc_strb_uoff(val_reg, 0, 0); }
            else { out("  strb w"); a64_print_dec(val_reg); out(", [x0]"); putchar('\n'); }
        } else if (sl == SL_QUARTER) {
            if (a64_bin_mode) { enc_strh_uoff(val_reg, 0, 0); }
            else { out("  strh w"); a64_print_dec(val_reg); out(", [x0]"); putchar('\n'); }
        } else if (sl == SL_HALF) {
            if (a64_bin_mode) { enc_str_w_uoff(val_reg, 0, 0); }
            else { out("  str w"); a64_print_dec(val_reg); out(", [x0]"); putchar('\n'); }
        } else {
            if (a64_bin_mode) { enc_str_uoff(val_reg, 0, 0); }
            else { out("  str x"); a64_print_dec(val_reg); out(", [x0]"); putchar('\n'); }
        }
        return 0;
    }

    if (t == T_IF) {
        // Literal-condition DCE lives in the parser (parse_if rewrites
        // `if (literal)` to T_BLOCK of the taken branch) — by the time a
        // T_IF reaches here, the condition is a runtime value.
        if (a64_bin_mode) {
            lbl = enc_new_label();
            lbl2 = enc_new_label();
            ety = a64_emit_node(n.a);
            if (ety == 1) {
                enc_fcmp_zero(0);
                enc_cset(0, 1);
            }
            enc_cbz_label(0, lbl);
            a64_emit_body(n.b, n.c);
            enc_b_label(lbl2);
            enc_def_label(lbl);
            if (n.e > 0) { a64_emit_body(n.d, n.e); }
            enc_def_label(lbl2);
        } else {
            lbl = a64_new_lbl();
            ety = a64_emit_node(n.a);
            if (ety == 1) {
                out("  fcmp d0, #0.0"); putchar('\n');
                out("  cset x0, ne"); putchar('\n');
            }
            out("  cbz x0, .Lelse"); a64_print_dec(lbl); putchar('\n');
            a64_emit_body(n.b, n.c);
            out("  b .Lendif"); a64_print_dec(lbl); putchar('\n');
            out(".Lelse"); a64_print_dec(lbl); out(":"); putchar('\n');
            if (n.e > 0) { a64_emit_body(n.d, n.e); }
            out(".Lendif"); a64_print_dec(lbl); out(":"); putchar('\n');
        }
        return 0;
    }

    if (t == T_BREAK) {
        // Jump to the exit label of the innermost while loop.
        if (arr_len(a64_break_stack) > 0) {
            auto brk_lbl;
            brk_lbl = arr_last(a64_break_stack);
            if (a64_bin_mode) {
                enc_b_label(brk_lbl);
            } else {
                out("  b .Lend"); a64_print_dec(brk_lbl); putchar('\n');
            }
        }
        return 0;
    }

    if (t == T_CONTINUE) {
        // Jump to the continue label of the innermost while loop. For
        // plain while this lands just before the back-branch to top; for
        // for-loops it lands just before the step expression so the step
        // still runs before the next condition test.
        if (arr_len(a64_continue_stack) > 0) {
            auto cnt_lbl;
            cnt_lbl = arr_last(a64_continue_stack);
            if (a64_bin_mode) {
                enc_b_label(cnt_lbl);
            } else {
                out("  b .Lcont"); a64_print_dec(cnt_lbl); putchar('\n');
            }
        }
        return 0;
    }

    if (t == T_WHILE) {
        // n.e (offset 40) holds the for-loop step expression, or 0 for plain while.
        // The continue label is emitted between the body and the step so that
        // `continue` runs the step before re-testing the condition.
        // The step is a statement (T_ASSIGN typically), so it must be emitted
        // via a64_emit_stmt — a64_emit_node doesn't handle T_ASSIGN.
        auto step_node, lbl3;
        step_node = n.e;
        if (a64_bin_mode) {
            lbl = enc_new_label();
            lbl2 = enc_new_label();
            lbl3 = enc_new_label();
            a64_break_stack = arr_push(a64_break_stack, lbl2);
            a64_continue_stack = arr_push(a64_continue_stack, lbl3);
            enc_def_label(lbl);
            ety = a64_emit_node(n.a);
            if (ety == 1) {
                enc_fcmp_zero(0);
                enc_cset(0, 1);
            }
            enc_cbz_label(0, lbl2);
            a64_emit_body(n.b, n.c);
            enc_def_label(lbl3);
            if (step_node != 0) { a64_emit_stmt(step_node); }
            enc_b_label(lbl);
            enc_def_label(lbl2);
            arr_pop(a64_break_stack);
            arr_pop(a64_continue_stack);
        } else {
            lbl = a64_new_lbl();
            lbl3 = a64_new_lbl();
            a64_break_stack = arr_push(a64_break_stack, lbl);
            a64_continue_stack = arr_push(a64_continue_stack, lbl3);
            out(".Lloop"); a64_print_dec(lbl); out(":"); putchar('\n');
            ety = a64_emit_node(n.a);
            if (ety == 1) {
                out("  fcmp d0, #0.0"); putchar('\n');
                out("  cset x0, ne"); putchar('\n');
            }
            out("  cbz x0, .Lend"); a64_print_dec(lbl); putchar('\n');
            a64_emit_body(n.b, n.c);
            out(".Lcont"); a64_print_dec(lbl3); out(":"); putchar('\n');
            if (step_node != 0) { a64_emit_stmt(step_node); }
            out("  b .Lloop"); a64_print_dec(lbl); putchar('\n');
            out(".Lend"); a64_print_dec(lbl); out(":"); putchar('\n');
            arr_pop(a64_break_stack);
            arr_pop(a64_continue_stack);
        }
        return 0;
    }

    if (t == T_RET) {
        rty = a64_emit_node(n.a);
        // Ensure return value matches function's declared return type.
        if (is_float_type(get_fn_ret_type(a64_cur_fn_idx))) {
            if (rty == 0) {
                if (a64_bin_mode) { enc_scvtf(0, 0); } else { out("  scvtf d0, x0"); putchar('\n'); }
            }
        } else {
            if (rty == 1) {
                if (a64_bin_mode) { enc_fcvtzs(0, 0); } else { out("  fcvtzs x0, d0"); putchar('\n'); }
            }
        }
        if (a64_bin_mode) {
            enc_b_label(a64_ret_lbl);
        } else {
            out("  b .Lret_"); a64_print_p(a64_cur_fn_name); putchar('\n');
        }
        return 0;
    }

    if (t == T_SWITCH) {
        // Two forms:
        // Form 1 (n.a != 0): value dispatch — compare condition against each arm value
        // Form 2 (n.a == 0): condition dispatch — evaluate each arm as boolean
        //
        // Form 1 evaluates the condition expression ONCE and peeks it from
        // the stack for each comparison. Previous implementation re-evaluated
        // the condition per arm-value, turning N-arm switches into N function
        // calls when the condition was e.g. get_token_type(node). Stack grows
        // by 16 bytes (alignment); bodies use FP-relative addressing so the
        // imbalance is invisible to them. Each match and the else fall-through
        // pop the saved cond before running the body.
        auto sw_arms, sw_bodies, sw_cnt, sw_end_lbl;
        auto si, sv_arr, sv_cnt, sb_arr, sb_cnt, snext_lbl;
        sw_arms = n.b;
        sw_bodies = n.src_tok;
        sw_cnt = n.c;
        if (a64_bin_mode) { sw_end_lbl = enc_new_label(); }
        else { sw_end_lbl = a64_new_lbl(); }

        // Form 1 dense switches go through the jump-table path.
        if (a64_bin_mode) {
            if (n.a != 0) {
                if (a64_switch_is_dense(sw_arms, sw_cnt)) {
                    a64_emit_switch_jtbl(n, sw_end_lbl);
                    return 0;
                }
            }
        }

        // Form 1: evaluate condition once, push.
        if (n.a != 0) {
            a64_emit_node(n.a);
            a64_emit_push();
        }

        for (si = 0; si < sw_cnt; si = si + 1) {
            sv_arr = sw_arms[si * 2];
            sv_cnt = sw_arms[si * 2 + 1];
            sb_arr = sw_bodies[si * 2];
            sb_cnt = sw_bodies[si * 2 + 1];
            if (a64_bin_mode) { snext_lbl = enc_new_label(); }
            else { snext_lbl = a64_new_lbl(); }

            auto smatch_lbl, sk;
            if (a64_bin_mode) { smatch_lbl = enc_new_label(); }
            else { smatch_lbl = a64_new_lbl(); }

            if (n.a == 0) {
                // Form 2: condition dispatch. Evaluate the condition expression.
                // If truthy (nonzero), enter the body.
                a64_emit_node(sv_arr[0]);
                if (a64_bin_mode) { enc_cbnz_label(0, smatch_lbl); }
                else { out("  cbnz x0, .L"); a64_print_dec(smatch_lbl); putchar('\n'); }
            } else {
                // Form 1: compare condition (peeked from [sp]) against each value.
                for (sk = 0; sk < sv_cnt; sk = sk + 1) {
                    a64_emit_node(sv_arr[sk]);
                    if (a64_bin_mode) {
                        enc_ldr_uoff(1, 31, 0);
                        enc_cmp_reg(1, 0); enc_b_cond_label(0, smatch_lbl);
                    } else {
                        out("  ldr x1, [sp]"); putchar('\n');
                        out("  cmp x1, x0"); putchar('\n');
                        out("  b.eq .L"); a64_print_dec(smatch_lbl); putchar('\n');
                    }
                }
            }
            if (a64_bin_mode) { enc_b_label(snext_lbl); }
            else { out("  b .L"); a64_print_dec(snext_lbl); putchar('\n'); }

            if (a64_bin_mode) { enc_def_label(smatch_lbl); }
            else { out(".L"); a64_print_dec(smatch_lbl); out(":"); putchar('\n'); }
            // Pop saved cond before running the body (stack rebalance).
            if (n.a != 0) { a64_emit_pop(9); }
            for (sk = 0; sk < sb_cnt; sk = sk + 1) { a64_emit_stmt(sb_arr[sk]); }
            if (a64_bin_mode) { enc_b_label(sw_end_lbl); }
            else { out("  b .L"); a64_print_dec(sw_end_lbl); putchar('\n'); }

            if (a64_bin_mode) { enc_def_label(snext_lbl); }
            else { out(".L"); a64_print_dec(snext_lbl); out(":"); putchar('\n'); }
        }

        // Fell through all arms — pop cond before else body or end.
        if (n.a != 0) { a64_emit_pop(9); }

        if (n.d != 0) {
            auto ek;
            for (ek = 0; ek < n.e; ek = ek + 1) { a64_emit_stmt(n.d[ek]); }
        }

        if (a64_bin_mode) { enc_def_label(sw_end_lbl); }
        else { out(".L"); a64_print_dec(sw_end_lbl); out(":"); putchar('\n'); }
        return 0;
    }

    if (t == T_NOP) { return 0; }

    // T_BLOCK holds a statement array produced by parser-level DCE when a
    // literal `if` condition collapses to its taken branch. Emit each
    // child as a normal statement — there is no header or terminator.
    if (t == T_BLOCK) { a64_emit_body(n.b, n.c); return 0; }

    // Expression statement (e.g., function call as statement).
    a64_emit_node(nd);
}

// ── Function emission ──────────────────────────────────────

static void a64_emit_func(fi) {
    auto name_p, par_arr, par_cnt, body_arr, body_cnt;
    auto frame, i;
    name_p = arr_get(a64_fn_name, fi);
    par_arr = arr_get(a64_fn_par, fi); par_cnt = arr_get(a64_fn_pcnt, fi);
    body_arr = arr_get(a64_fn_body, fi); body_cnt = arr_get(a64_fn_bcnt, fi);

    // Reset variable tracking for this function.
    arr_clear(a64_vars);
    arr_clear(a64_var_stack);
    arr_clear(a64_var_struct_idx);
    arr_clear(a64_var_off);
    arr_clear(a64_var_forced_ty);
    arr_clear(a64_var_refs);
    arr_clear(a64_var_addr_taken);
    arr_clear(a64_var_promote);
    arr_clear(a64_promoted_regs);
    a64_freelist_reset();
    a64_cur_fn_name = name_p;
    a64_cur_fn_idx = arr_get(a64_fn_fidx, fi);

    // Register params as variables (slots 0..par_cnt-1).
    // If the function has explicit type hints for params, record them.
    auto hints, ph, fn_rec;
    fn_rec = arr_get(funcs, a64_cur_fn_idx);
    hints = *(fn_rec + 48);
    i = 0;
    while (i < par_cnt) {
        auto pvi;
        pvi = a64_var_add(*(par_arr + i * 8));
        if (hints != 0) {
            ph = *(hints + i * 8);
            if (ph > 0) { arr_set(a64_var_forced_ty, pvi, ph); }
        }
        i = i + 1;
    }

    // Pre-register all declared variables from body (including nested blocks).
    a64_pre_reg_vars(body_arr, body_cnt);

    // Compute per-variable frame offsets. Slots start after the 40-byte
    // hidden area (fp/lr + scratch). `: double` (SIMD) locals need 16
    // bytes AND a 16-byte aligned absolute address so STR Q / LDR Q get
    // natural alignment — rounding `total` alone is not enough, since
    // 40 itself is only 8-aligned; we round `abs_off = 40 + total`.
    // Stack structs round their size up to 8 so the 8-byte chunked
    // struct-copy path never spills into the next slot.
    auto total, sz, _fty, abs_off;
    total = 0;
    for (i = 0; i < arr_len(a64_vars); i = i + 1) {
        _fty = arr_get(a64_var_forced_ty, i);
        abs_off = 40 + total;
        if (slice_width(ty_slice(_fty)) == 128) {
            abs_off = (abs_off + 15) / 16 * 16;
            arr_set(a64_var_off, i, abs_off);
            total = abs_off - 40 + 16;
        } else if (arr_get(a64_var_stack, i)) {
            arr_set(a64_var_off, i, abs_off);
            sz = (get_struct_size(arr_get(a64_var_struct_idx, i)) + 7) / 8 * 8;
            total = total + sz;
        } else {
            arr_set(a64_var_off, i, abs_off);
            total = total + 8;
        }
    }

    // Phase B3: walk body, count refs, select promotions.
    auto stmt_i: Node;
    for (i = 0; i < body_cnt; i = i + 1) {
        stmt_i = body_arr[i];
        if (stmt_i != 0) { _a64_b3_walk(stmt_i); }
    }
    _a64_b3_select();
    a64_b3_spill_base = 40 + total;
    total = total + arr_len(a64_promoted_regs) * 8;

    frame = 40 + total;
    frame = (frame + 15) / 16 * 16;

    if (a64_bin_mode) {
        // Define the label for this function's entry point.
        enc_def_label(arr_get(a64_fn_lbl, fi));

        // Allocate a return label for this function.
        a64_ret_lbl = enc_new_label();

        // Prologue: save frame pointer and return address, allocate frame.
        // stp pre-index caps at ±504 in its 7-bit immediate — split for larger frames.
        if (frame <= 504) {
            enc_stp_pre(29, 30, 31, 0 - frame);
        } else {
            enc_sub_imm(31, 31, frame);
            enc_str_uoff(29, 31, 0);
            enc_str_uoff(30, 31, 8);
        }
        enc_add_imm(29, 31, 0);

        // Phase B3: spill chosen callee-saved registers.
        auto _b3_i, _b3_n, _b3_reg, _b3_off;
        _b3_n = arr_len(a64_promoted_regs);
        for (_b3_i = 0; _b3_i < _b3_n; _b3_i = _b3_i + 1) {
            _b3_reg = arr_get(a64_promoted_regs, _b3_i);
            _b3_off = a64_b3_spill_base + _b3_i * 8;
            enc_str_uoff(_b3_reg, 29, _b3_off);
        }

        // In main(), save x0 (argc), x1 (argv), and x2 (envp) to hidden globals.
        if (a64_str_eq(name_p, "main", 4)) {
            enc_add_reloc(enc_pos, a64_argc_sym, 0);
            enc_adrp(8); enc_add_imm(8, 8, 0);
            enc_str_uoff(0, 8, 0);
            enc_add_reloc(enc_pos, a64_argv_sym, 0);
            enc_adrp(8); enc_add_imm(8, 8, 0);
            enc_str_uoff(1, 8, 0);
            enc_add_reloc(enc_pos, a64_envp_sym, 0);
            enc_adrp(8); enc_add_imm(8, 8, 0);
            enc_str_uoff(2, 8, 0);
        }

        // Store incoming register arguments. Promoted params go straight into
        // their callee-saved register.
        auto _p_preg;
        i = 0;
        while (i < par_cnt) {
            _p_preg = arr_get(a64_var_promote, i);
            if (_p_preg >= 0) {
                enc_add_imm(_p_preg, i, 0);
            } else {
                enc_str_uoff(i, 29, arr_get(a64_var_off, i));
            }
            i = i + 1;
        }

        // Phase B3: zero non-parameter promoted locals.
        auto _z_vi, _z_n, _z_preg;
        _z_n = arr_len(a64_vars);
        for (_z_vi = par_cnt; _z_vi < _z_n; _z_vi = _z_vi + 1) {
            _z_preg = arr_get(a64_var_promote, _z_vi);
            if (_z_preg >= 0) { enc_mov_wide(_z_preg, 0); }
        }

        // Narrow float sub-type params from double to their declared precision.
        i = 0;
        while (i < par_cnt) {
            auto fty_p;
            fty_p = arr_get(a64_var_forced_ty, i);
            if (is_float_type(fty_p)) {
                if (ty_slice(fty_p) == SL_HALF) { enc_ldr_d_uoff(0, 29, arr_get(a64_var_off, i)); }
                if (ty_slice(fty_p) == SL_HALF) { enc_fcvt_s_d(0, 0); }
                if (ty_slice(fty_p) == SL_HALF) { enc_str_s_uoff(0, 29, arr_get(a64_var_off, i)); }
                if (ty_slice(fty_p) == SL_QUARTER) { enc_ldr_d_uoff(0, 29, arr_get(a64_var_off, i)); }
                if (ty_slice(fty_p) == SL_QUARTER) { enc_fcvt_h_d(0, 0); }
                if (ty_slice(fty_p) == SL_QUARTER) { enc_str_h_uoff(0, 29, arr_get(a64_var_off, i)); }
            }
            i = i + 1;
        }

        // Emit function body.
        a64_depth = 0;
        a64_emit_body(body_arr, body_cnt);

        // Implicit return 0: if the body falls through without an explicit
        // return statement, x0 is set to 0. Explicit returns branch directly
        // to the epilogue label with x0 already set, so this mov is dead
        // code in that case — the branch jumps over it.
        enc_mov_wide(0, 0);

        // Epilogue. Centralized restore of spilled callee-saved regs.
        enc_def_label(a64_ret_lbl);
        auto _e_i, _e_n, _e_reg, _e_off;
        _e_n = arr_len(a64_promoted_regs);
        for (_e_i = 0; _e_i < _e_n; _e_i = _e_i + 1) {
            _e_reg = arr_get(a64_promoted_regs, _e_i);
            _e_off = a64_b3_spill_base + _e_i * 8;
            enc_ldr_uoff(_e_reg, 29, _e_off);
        }
        if (frame <= 504) {
            enc_ldp_post(29, 30, 31, frame);
        } else {
            enc_ldr_uoff(29, 31, 0);
            enc_ldr_uoff(30, 31, 8);
            enc_add_imm(31, 31, frame);
        }
        enc_ret();
    } else {
        // Emit function header.
        out(".p2align 2"); putchar('\n');
        if (a64_str_eq(name_p, "main", 4)) {
            out(".globl _main"); putchar('\n');
            out("_main:"); putchar('\n');
        } else {
            out("_"); a64_print_p(name_p); out(":"); putchar('\n');
        }

        // Prologue: save frame pointer and return address, allocate frame.
        if (frame <= 504) {
            out("  stp x29, x30, [sp, #-"); a64_print_dec(frame); out("]!"); putchar('\n');
        } else {
            out("  sub sp, sp, #"); a64_print_dec(frame); putchar('\n');
            out("  str x29, [sp]"); putchar('\n');
            out("  str x30, [sp, #8]"); putchar('\n');
        }
        out("  mov x29, sp"); putchar('\n');

        // Phase B3: spill chosen callee-saved registers.
        auto _b3_i, _b3_n, _b3_reg, _b3_off;
        _b3_n = arr_len(a64_promoted_regs);
        for (_b3_i = 0; _b3_i < _b3_n; _b3_i = _b3_i + 1) {
            _b3_reg = arr_get(a64_promoted_regs, _b3_i);
            _b3_off = a64_b3_spill_base + _b3_i * 8;
            out("  str x"); a64_print_dec(_b3_reg); out(", [x29, #"); a64_print_dec(_b3_off); out("]"); putchar('\n');
        }

        // In main(), save x0 (argc), x1 (argv), and x2 (envp) to globals.
        if (a64_str_eq(name_p, "main", 4)) {
            out("  adrp x8, _bpp_argc@PAGE"); putchar('\n');
            out("  add x8, x8, _bpp_argc@PAGEOFF"); putchar('\n');
            out("  str x0, [x8]"); putchar('\n');
            out("  adrp x8, _bpp_argv@PAGE"); putchar('\n');
            out("  add x8, x8, _bpp_argv@PAGEOFF"); putchar('\n');
            out("  str x1, [x8]"); putchar('\n');
            out("  adrp x8, _bpp_envp@PAGE"); putchar('\n');
            out("  add x8, x8, _bpp_envp@PAGEOFF"); putchar('\n');
            out("  str x2, [x8]"); putchar('\n');
        }

        // Store incoming register arguments. Promoted params go to their reg.
        auto _p_preg;
        i = 0;
        while (i < par_cnt) {
            _p_preg = arr_get(a64_var_promote, i);
            if (_p_preg >= 0) {
                out("  mov x"); a64_print_dec(_p_preg); out(", x"); a64_print_dec(i); putchar('\n');
            } else {
                out("  str x"); a64_print_dec(i); out(", [x29, #"); a64_print_dec(arr_get(a64_var_off, i)); out("]"); putchar('\n');
            }
            i = i + 1;
        }

        // Phase B3: zero non-parameter promoted locals.
        auto _z_vi, _z_n, _z_preg;
        _z_n = arr_len(a64_vars);
        for (_z_vi = par_cnt; _z_vi < _z_n; _z_vi = _z_vi + 1) {
            _z_preg = arr_get(a64_var_promote, _z_vi);
            if (_z_preg >= 0) {
                out("  mov x"); a64_print_dec(_z_preg); out(", #0"); putchar('\n');
            }
        }

        // Narrow float sub-type params from double to their declared precision.
        i = 0;
        while (i < par_cnt) {
            auto fty_p;
            fty_p = arr_get(a64_var_forced_ty, i);
            if (is_float_type(fty_p)) {
                if (ty_slice(fty_p) == SL_HALF) { out("  ldr d0, [x29, #"); a64_print_dec(arr_get(a64_var_off, i)); out("]"); putchar('\n'); }
                if (ty_slice(fty_p) == SL_HALF) { out("  fcvt s0, d0"); putchar('\n'); }
                if (ty_slice(fty_p) == SL_HALF) { out("  str s0, [x29, #"); a64_print_dec(arr_get(a64_var_off, i)); out("]"); putchar('\n'); }
                if (ty_slice(fty_p) == SL_QUARTER) { out("  ldr d0, [x29, #"); a64_print_dec(arr_get(a64_var_off, i)); out("]"); putchar('\n'); }
                if (ty_slice(fty_p) == SL_QUARTER) { out("  fcvt h0, d0"); putchar('\n'); }
                if (ty_slice(fty_p) == SL_QUARTER) { out("  str h0, [x29, #"); a64_print_dec(arr_get(a64_var_off, i)); out("]"); putchar('\n'); }
            }
            i = i + 1;
        }

        // Emit function body.
        a64_depth = 0;
        a64_emit_body(body_arr, body_cnt);

        // Implicit return 0 for functions without explicit return.
        out("  mov x0, #0"); putchar('\n');

        // Epilogue. Centralized restore of spilled callee-saved regs.
        out(".Lret_"); a64_print_p(name_p); out(":"); putchar('\n');
        auto _e_i, _e_n, _e_reg, _e_off;
        _e_n = arr_len(a64_promoted_regs);
        for (_e_i = 0; _e_i < _e_n; _e_i = _e_i + 1) {
            _e_reg = arr_get(a64_promoted_regs, _e_i);
            _e_off = a64_b3_spill_base + _e_i * 8;
            out("  ldr x"); a64_print_dec(_e_reg); out(", [x29, #"); a64_print_dec(_e_off); out("]"); putchar('\n');
        }
        if (frame <= 504) {
            out("  ldp x29, x30, [sp], #"); a64_print_dec(frame); putchar('\n');
        } else {
            out("  ldr x29, [sp]"); putchar('\n');
            out("  ldr x30, [sp, #8]"); putchar('\n');
            out("  add sp, sp, #"); a64_print_dec(frame); putchar('\n');
        }
        out("  ret"); putchar('\n');
        putchar('\n');
    }
}

// ── Per-module emission (for incremental compilation) ──────

// Initialize the encoder and global tables for per-module codegen.
// Call once before the per-module loop. Populates globals and externs
// from the parser so that all modules share the same data tables.
void a64_mod_init() {
    auto i, rec, name_p, idx, j;
    a64_sbuf = vbuf;

    // Reset encoder state for a fresh build.
    enc_pos = 0;
    enc_lbl_max = 0;
    arr_clear(enc_lbl_off);
    enc_fix_cnt = 0;
    arr_clear(enc_fix_pos); arr_clear(enc_fix_lbl); arr_clear(enc_fix_ty);
    arr_clear(enc_rel_pos); arr_clear(enc_rel_sym); arr_clear(enc_rel_ty);

    // Clear function tables (will be populated per-module).
    arr_clear(a64_fn_name); arr_clear(a64_fn_par); arr_clear(a64_fn_pcnt);
    arr_clear(a64_fn_body); arr_clear(a64_fn_bcnt); arr_clear(a64_fn_fidx);
    arr_clear(a64_fn_lbl);

    // Copy ALL globals with deduplication (shared across all modules).
    arr_clear(a64_gl_name);
    i = 0;
    while (i < glob_cnt) {
        name_p = *(globals + i * 8);
        idx = -1;
        j = 0;
        while (j < arr_len(a64_gl_name)) {
            if (a64_str_eq_packed(name_p, arr_get(a64_gl_name, j))) { idx = j; }
            j = j + 1;
        }
        if (idx < 0) { a64_gl_name = arr_push(a64_gl_name, name_p); }
        i = i + 1;
    }
    // Hidden runtime globals (_bpp_argc/argv/envp) come in via brt0.bsm
    // as regular entries in globals[], so the loop above already includes them.

    // Externs are refreshed per-module in emit_module_arm64() instead of here,
    // because in the incremental pipeline modules are parsed one at a time.
    arr_clear(a64_ex_name); arr_clear(a64_ex_ret);
    arr_clear(a64_ex_args); arr_clear(a64_ex_acnt);

}

// Emit code for a single module. Functions accumulate in a64_fn_name
// across calls. Cross-module calls emit type 4 relocations.
// Returns the byte offset where this module's code starts in enc_buf.
void emit_module_arm64(mi) {
    auto fn_start, code_start, i, rec, name_p, idx, j;

    // Record where new functions will start in the accumulated table.
    fn_start = arr_len(a64_fn_name);

    // Add functions from this module only, with forward-declaration override.
    // Lazy emit: skip unreachable functions when the pass has run.
    i = 0;
    while (i < func_cnt) {
        if (_lazy_emit_ready) {
            if (arr_get(fn_reachable, i) == 0) { i = i + 1; continue; }
        }
        if (arr_get(func_mods, i) == mi) {
            rec = *(funcs + i * 8);
            name_p = *(rec + FN_NAME);
            idx = -1;
            j = 0;
            while (j < arr_len(a64_fn_name)) {
                if (a64_str_eq_packed(name_p, arr_get(a64_fn_name, j))) { idx = j; }
                j = j + 1;
            }
            if (idx < 0) {
                idx = arr_len(a64_fn_name);
                a64_fn_name = arr_push(a64_fn_name, name_p);
                a64_fn_par  = arr_push(a64_fn_par,  *(rec + FN_PARS));
                a64_fn_pcnt = arr_push(a64_fn_pcnt, *(rec + FN_PCNT));
                a64_fn_body = arr_push(a64_fn_body, *(rec + FN_BODY));
                a64_fn_bcnt = arr_push(a64_fn_bcnt, *(rec + FN_BCNT));
                a64_fn_fidx = arr_push(a64_fn_fidx, i);
            } else {
                arr_set(a64_fn_name, idx, name_p);
                arr_set(a64_fn_par,  idx, *(rec + FN_PARS));
                arr_set(a64_fn_pcnt, idx, *(rec + FN_PCNT));
                arr_set(a64_fn_body, idx, *(rec + FN_BODY));
                arr_set(a64_fn_bcnt, idx, *(rec + FN_BCNT));
                arr_set(a64_fn_fidx, idx, i);
            }
        }
        i = i + 1;
    }

    // Assign labels for new functions only.
    i = fn_start;
    while (i < arr_len(a64_fn_name)) {
        a64_fn_lbl = arr_push(a64_fn_lbl, enc_new_label());
        i = i + 1;
    }

    // Refresh externs from parser state (may have grown from previous modules).
    arr_clear(a64_ex_name); arr_clear(a64_ex_ret);
    arr_clear(a64_ex_args); arr_clear(a64_ex_acnt);
    i = 0;
    while (i < ext_cnt) {
        rec = *(externs + i * 8);
        a64_ex_name = arr_push(a64_ex_name, *(rec + EX_NAME));
        a64_ex_ret  = arr_push(a64_ex_ret,  *(rec + EX_RET));
        a64_ex_args = arr_push(a64_ex_args, *(rec + EX_ARGS));
        a64_ex_acnt = arr_push(a64_ex_acnt, *(rec + EX_ACNT));
        i = i + 1;
    }

    // Clear per-module fixups. Labels and relocations accumulate.
    enc_fix_cnt = 0;
    arr_clear(enc_fix_pos); arr_clear(enc_fix_lbl); arr_clear(enc_fix_ty);

    // Record code start and emit new functions only.
    code_start = enc_pos;
    i = fn_start;
    while (i < arr_len(a64_fn_name)) {
        a64_emit_func(i);
        i = i + 1;
    }

    // Resolve internal branch fixups for this module.
    enc_resolve_fixups();

    return code_start;
}

// ── Top-level emission ─────────────────────────────────────

// Run all ARM64 emission stages in order.
void emit_all_arm64() {
    auto i, sp, ss, sl, j, ch, fp, fs, fl;

    bridge_data_arm64();

    if (a64_bin_mode) {
        // Hidden runtime globals come in via brt0.bsm (auto-injected).

        // Binary mode: allocate a label for each function, emit code, resolve fixups.
        enc_pos = 0;
        enc_lbl_max = 0;
        arr_clear(enc_lbl_off);
        enc_fix_cnt = 0;
        arr_clear(enc_fix_pos); arr_clear(enc_fix_lbl); arr_clear(enc_fix_ty);
        enc_rel_cnt = 0;
        arr_clear(enc_rel_pos); arr_clear(enc_rel_sym); arr_clear(enc_rel_ty);

        // Allocate a label for each function.
        arr_clear(a64_fn_lbl);
        i = 0;
        while (i < arr_len(a64_fn_name)) {
            a64_fn_lbl = arr_push(a64_fn_lbl, enc_new_label());
            i = i + 1;
        }

        // Emit all functions into the code buffer.
        i = 0;
        while (i < arr_len(a64_fn_name)) { a64_emit_func(i); i = i + 1; }

        // Resolve all forward branch fixups.
        enc_resolve_fixups();

        // Code is now in enc_buf[0..enc_pos). The caller decides whether
        // to write it to stdout or pass it to the Mach-O writer.
    } else {
        // Text assembly mode.
        out(".section __TEXT,__text,regular,pure_instructions"); putchar('\n');
        putchar('\n');

        // Emit all functions.
        i = 0;
        while (i < arr_len(a64_fn_name)) { a64_emit_func(i); i = i + 1; }

        // Emit global variables in data section.
        out(".section __DATA,__data"); putchar('\n');
        // Hidden globals for argc/argv/envp access.
        out(".p2align 3"); putchar('\n');
        out("_bpp_argc: .quad 0"); putchar('\n');
        out("_bpp_argv: .quad 0"); putchar('\n');
        out("_bpp_envp: .quad 0"); putchar('\n');
        i = 0;
        while (i < arr_len(a64_gl_name)) {
            out(".globl _"); a64_print_p(arr_get(a64_gl_name, i)); putchar('\n');
            out(".p2align 3"); putchar('\n');
            out("_"); a64_print_p(arr_get(a64_gl_name, i)); out(":"); putchar('\n');
            out("  .quad 0"); putchar('\n');
            i = i + 1;
        }
        putchar('\n');

        // Emit string literals in a read-only data section.
        if (arr_len(a64_str_tbl) > 0) {
            out(".section __TEXT,__cstring,cstring_literals"); putchar('\n');
            i = 0;
            while (i < arr_len(a64_str_tbl)) {
                sp = arr_get(a64_str_tbl, i);
                ss = unpack_s(sp); sl = unpack_l(sp);
                out("_str_"); a64_print_dec(i); out(":"); putchar('\n');
                out("  .asciz "); putchar('"');
                j = 0;
                while (j < sl) {
                    ch = peek(a64_sbuf + ss + j);
                    if (ch == '\n') { putchar('\\'); putchar('n'); }
                    else { if (ch == '"') { putchar('\\'); putchar('"'); }
                    else { if (ch == '\\') { putchar('\\'); putchar('\\'); }
                    else { putchar(ch); } } }
                    j = j + 1;
                }
                putchar('"'); putchar('\n');
                i = i + 1;
            }
            putchar('\n');
        }

        // Emit float literal constants in a read-only data section.
        if (arr_len(a64_flt_tbl) > 0) {
            out(".section __DATA,__const"); putchar('\n');
            i = 0;
            while (i < arr_len(a64_flt_tbl)) {
                fp = arr_get(a64_flt_tbl, i);
                fs = unpack_s(fp); fl = unpack_l(fp);
                out(".p2align 3"); putchar('\n');
                out("_flt_"); a64_print_dec(i); out(":"); putchar('\n');
                out("  .double ");
                j = 0;
                while (j < fl) { putchar(peek(a64_sbuf + fs + j)); j = j + 1; }
                putchar('\n');
                i = i + 1;
            }
            putchar('\n');
        }
    }

}
