        if (x64_str_eq(n.a, "vec_store4", 10)) {
            arr = n.b;
            x64_emit_node(*(arr + 8));  // value → xmm0
            x64_emit_vpush();
            x64_emit_node(*(arr + 0));  // ptr → rax
            x64_emit_vpop(1);            // xmm1 = value
            x64_enc_movups_store(1, 0, 0);
            return 0;
        }
        // Binary ops dispatch through _x64_vec_binop.
        if (x64_str_eq(n.a, "vec_add4", 8)) { _x64_vec_binop(n, 0x58, 1); return 2; }
        if (x64_str_eq(n.a, "vec_mul4", 8)) { _x64_vec_binop(n, 0x59, 1); return 2; }
        if (x64_str_eq(n.a, "vec_min4", 8)) { _x64_vec_binop(n, 0x5D, 1); return 2; }
        if (x64_str_eq(n.a, "vec_max4", 8)) { _x64_vec_binop(n, 0x5F, 1); return 2; }
        if (x64_str_eq(n.a, "vec_sub4", 8)) { _x64_vec_binop(n, 0x5C, 0); return 2; }
        if (x64_str_eq(n.a, "vec_div4", 8)) { _x64_vec_binop(n, 0x5E, 0); return 2; }
        if (x64_str_eq(n.a, "vec_splat4", 10)) {
            arr = n.b;
            ety = x64_emit_node(*(arr + 0));
            if (ety == 1) {
                // Float scalar in xmm0 (double). Convert to single, then
                // shuffle to broadcast lane 0 across all four lanes.
                x64_enc_cvtsd2ss(0, 0);
            } else {
                // Integer in rax. MOVD transfers low 32 bits into xmm0's
                // low lane with upper 96 zeroed.
                x64_enc_movd_to_xmm(0, 0);
            }
            x64_enc_shufps(0, 0, 0x00);
            return 2;
        }
        if (x64_str_eq(n.a, "vec_dot4", 8)) {
            arr = n.b;
            x64_emit_node(*(arr + 0));
            x64_emit_vpush();
            x64_emit_node(*(arr + 8));
            x64_emit_vpop(1);
            // SSE2-only horizontal sum (no DPPS — SSE4.1 is out of scope):
            //   MULPS   xmm0, xmm1          ; xmm0 = a * b
            //   MOVHLPS xmm1, xmm0          ; xmm1 low = xmm0 high
            //   ADDPS   xmm0, xmm1          ; pairs summed in low 64
            //   PSHUFD  xmm1, xmm0, 0x01    ; xmm1[0] = xmm0[1]
            //   ADDSS   xmm0, xmm1          ; xmm0[0] = full dot product
            x64_enc_mulps(0, 1);
            x64_enc_movhlps(1, 0);
            x64_enc_addps(0, 1);
            x64_enc_pshufd(1, 0, 0x01);
            x64_enc_addss(0, 1);
            // Widen single-precision result to double for the float convention.
            x64_enc_cvtss2sd(0, 0);
            return 1;
        }
        if (x64_str_eq(n.a, "vec_get4", 8)) {
            // Lane index must be a compile-time literal (0..3). PSHUFD
            // moves the chosen lane to position 0; a stack-round-trip
            // reloads those bits as a scalar single; CVTSS2SD widens.
            arr = n.b;
            x64_emit_node(*(arr + 0));
            auto lane_nd: Node, lane_v, lane_mask;
            lane_nd = *(arr + 8);
            lane_v = x64_parse_int(lane_nd.a);
            lane_mask = lane_v | (lane_v << 2) | (lane_v << 4) | (lane_v << 6);
            x64_enc_pshufd(0, 0, lane_mask);
            x64_enc_sub_imm(4, 16);
            x64_enc_movups_store(0, 4, 0);
            x64_enc_load_ss(0, 4, 0);
            x64_enc_add_imm(4, 16);
            x64_enc_cvtss2sd(0, 0);
            return 1;
        }

        // Regular B++ function call.
        // Query bpp_types for callee's parameter types (mirrors ARM64 logic).
        fidx_c = find_func_idx(n.a);
        // B2 inline is deliberately skipped on x86_64. The recursive
        // ast_clone_subst + x64_emit_node tail call path exposes a
        // latent emission bug in the 6a3f71a-based x64_codegen that only
        // manifests when bpp self-hosts on Linux with many inlineable
        // call sites. ARM64 applies inline fully; Linux takes the
        // regular call path until the bug is found and fixed. See
        // docs/todo.md for the bisect trail.
        arr = n.b; cnt = n.c;
        // Evaluate all arguments and push as GPR values (uniform convention).
        i = 0;
        while (i < cnt) {
            ety = x64_emit_node(*(arr + i * 8));
            if (fidx_c >= 0) {
                // Cross-function type awareness: convert value to match callee's expected type.
                par_flt = is_float_type(get_fn_par_type(fidx_c, i));
                if (ety == 1) {
                    if (par_flt) {
                        // Float expr → float param: bit-transfer XMM0 to RAX.
                        x64_enc_movq_from_xmm(0, 0);
                    } else {
                        // Float expr → int param: value-convert (truncate).
                        x64_enc_cvttsd2si(0, 0);
                    }
                } else {
                    if (par_flt) {
                        // Int expr → float param: value-convert to double, then bit-transfer.
                        x64_enc_cvtsi2sd(0, 0);
                        x64_enc_movq_from_xmm(0, 0);
                    }
                    // Int expr → int param: nothing needed, already in RAX.
                }
            } else {
                // Unknown callee: fallback bit-transfer for float values.
                if (ety == 1) {
                    x64_enc_movq_from_xmm(0, 0);
                }
            }
            x64_emit_push();
            i = i + 1;
        }
        // Pop into System V argument registers.
        i = cnt - 1;
        while (i >= 0) { x64_emit_pop(x64_arg_reg(i)); i = i - 1; }

        // Call the function.
        fi = x64_find_fn(n.a);
        padded = x64_align_call();
        if (fi >= 0) {
            x64_enc_call_label(arr_get(x64_fn_lbl, fi));
        } else {
            // Cross-module or extern function: CALL rel32 placeholder with type 4 relocation.
            x64_enc_add_reloc(x64_enc_pos + 1, n.a, 4);
            x64_enc_emit8(0xE8);
            x64_enc_emit32(0);
        }
        // Save float return registers after extern calls for float_ret() / float_ret2().
        if (x64_find_ext(n.a) >= 0) {
            x64_enc_store_sd(0, 5, 0 - 16);
            x64_enc_store_sd(1, 5, 0 - 24);
        }
        x64_unalign_call(padded);

        // Check if callee returns float.
        if (fidx_c >= 0) {
            if (is_float_type(get_fn_ret_type(fidx_c))) { return 1; }
        }
        return 0;
    }

    // ── Memory load: *(ptr) ──
    // mem_load: *(ptr) — n.b holds field type hint for packed structs.
    if (t == T_MEMLD) {
        auto fh, sl, bo, bw, mask;
        fh = n.b;
        ety = x64_emit_node(n.a);
        if (ety == 1) { x64_enc_cvttsd2si(0, 0); }
        sl = ty_slice(fh);
        // `: double` field (128-bit SIMD) — MOVUPS into xmm0 and return
        // type 2 (SIMD) so chained vec_* ops receive the right-width reg.
        if (sl == SL_DOUBLE) {
            x64_enc_movups_load(0, 0, 0);
            return 2;
        }
        // Bit-packed fields: load the containing byte, shift the field down to
        // bit 0, mask off the high bits. The bit offset within the byte is
        // encoded in bits 8-10 of the hint by resolve_dot.
        if (sl >= SL_BIT && sl <= SL_BIT7) {
            bo = (fh / 256) & 7;
            bw = sl - 3;
            mask = (1 << bw) - 1;
            x64_enc_loadb(0, 0, 0);
            if (bo > 0) { x64_enc_shr_imm(0, bo); }
            x64_enc_and_imm(0, mask);
            return 0;
        }
        if (sl == SL_BYTE) { x64_enc_loadb(0, 0, 0); }
        else if (sl == SL_QUARTER) { x64_enc_loadh(0, 0, 0); }
        else if (sl == SL_HALF) { x64_enc_load_sw(0, 0, 0); }
        else { x64_enc_load(0, 0, 0); }
        return 0;
    }

    // ── Address-of: &x ──
    // Computes the memory address of a variable without loading its value.
    if (t == T_ADDR) {
        auto child: Node;
        child = n.a;
        if (child != 0) {
            if (child.ntype == T_VAR) {
                vi = x64_var_idx(child.a);
                if (vi >= 0) {
                    off = arr_get(x64_var_off, vi);
                    x64_enc_lea(0, 5, off);
                    return 0;
                }
                // Global variable: compute address without loading.
                auto dpos;
                dpos = x64_enc_lea_rip(0);
                x64_enc_add_reloc(dpos, child.a, 0);
                return 0;
            }
        }
        return 0;
    }

}

// ── Statement emission ─────────────────────────────────────

static void x64_emit_body(arr, cnt) {
    auto i;
    auto n: Node;
    i = 0;
    while (i < cnt) {
        n = *(arr + i * 8);
        if (n != 0) { x64_emit_stmt(n); }
        i = i + 1;
    }
}

static void x64_emit_stmt(nd) {
    auto n: Node;
    auto lhs: Node;
    auto t, off, lbl, lbl2, arr, cnt, i, rty, vi, ety;
    if (nd == 0) { return 0; }
    n = nd; t = n.ntype;

    if (t == T_DECL) { return 0; }

    if (t == T_ASSIGN) {
        lhs = n.a;
        if (lhs.ntype == T_VAR) {
            vi = x64_var_idx(lhs.a);
            if (vi >= 0) {
                // Stack struct copy.
                if (arr_get(x64_var_stack, vi)) {
                    x64_emit_node(n.b);
                    off = arr_get(x64_var_off, vi);
                    auto fc, j, sidx;
                    sidx = arr_get(x64_var_struct_idx, vi);
                    fc = (get_struct_size(sidx) + 7) / 8;
                    j = 0;
                    while (j < fc) {
                        x64_enc_load(10, 0, j * 8);
                        x64_enc_store(10, 5, off + j * 8);
                        j = j + 1;
                    }
                    return 0;
                }
            }
        }
        rty = x64_emit_node(n.b);
        if (lhs.ntype == T_VAR) {
            vi = x64_var_idx(lhs.a);
            if (vi >= 0) {
                off = arr_get(x64_var_off, vi);
                // Type-aware store: uses the correct instruction for the variable's size.
                x64_emit_store_var(vi, off, rty);
            } else {
                // Global variable store.
                auto dpos;
                if (is_float_type(ty_get_global_type(lhs.a))) {
                    if (rty == 0) { x64_enc_cvtsi2sd(0, 0); }
                    dpos = x64_enc_lea_rip(10);
                    x64_enc_add_reloc(dpos, lhs.a, 0);
                    x64_enc_store_sd(0, 10, 0);
                } else {
                    if (rty == 1) { x64_enc_cvttsd2si(0, 0); }
                    dpos = x64_enc_lea_rip(10);
                    x64_enc_add_reloc(dpos, lhs.a, 0);
                    x64_enc_store(0, 10, 0);
                }
            }
        }
        return 0;
    }

    // Memory store: *(ptr) = val. n.c holds field type hint for packed structs.
    if (t == T_MEMST) {
        auto fh, sl, bo, bw, mask, clear_mask;
        fh = n.c;
        sl = ty_slice(fh);
        // `: double` field (128-bit SIMD). Value must already be in xmm0
        // (rty=2); spill through the SIMD stack slot, evaluate pointer,
        // reload into xmm1, then MOVUPS to [rax].
        if (sl == SL_DOUBLE) {
            ety = x64_emit_node(n.b);
            if (ety != 2) {
                diag_error(231);
                diag_str("cannot store non-SIMD value through a ': double' field");
                diag_newline();
            }
            x64_emit_vpush();
            x64_emit_node(n.a);
            x64_emit_vpop(1);
            x64_enc_movups_store(1, 0, 0);
            return 0;
        }
        ety = x64_emit_node(n.b);
        if (ety == 1) { x64_enc_movq_from_xmm(0, 0); }
        x64_emit_push();
        x64_emit_node(n.a);
        x64_emit_pop(1);
        // Bit-packed field stores: load the containing byte into rdx, clear
        // the destination field bits, shift the source value into position,
        // OR them together, store the byte back. rax holds the pointer and
        // rcx holds the source value after the pop.
        if (sl >= SL_BIT && sl <= SL_BIT7) {
            bo = (fh / 256) & 7;
            bw = sl - 3;
            mask = (1 << bw) - 1;
            clear_mask = 255 ^ (mask << bo);
            x64_enc_loadb(2, 0, 0);
            x64_enc_and_imm(2, clear_mask);
            x64_enc_and_imm(1, mask);
            if (bo > 0) { x64_enc_shl_imm(1, bo); }
            x64_enc_or_reg(2, 1);
            x64_enc_storeb(2, 0, 0);
            return 0;
        }
        if (sl == SL_BYTE) { x64_enc_storeb(1, 0, 0); }
        else if (sl == SL_QUARTER) { x64_enc_storeh(1, 0, 0); }
        else if (sl == SL_HALF) { x64_enc_store_w(1, 0, 0); }
        else { x64_enc_store(1, 0, 0); }
        return 0;
    }

    if (t == T_IF) {
        // Literal-condition DCE lives in the parser (parse_if rewrites
        // `if (literal)` to T_BLOCK of the taken branch) — by the time a
        // T_IF reaches here, the condition is a runtime value.
        lbl = x64_enc_new_label();
        lbl2 = x64_enc_new_label();
        ety = x64_emit_node(n.a);
        if (ety == 1) {
            x64_enc_xorpd(1, 1);
            x64_enc_ucomisd(0, 1);
            x64_enc_setcc(CC_NE, 0);
            x64_enc_movzx8(0, 0);
        }
        x64_enc_test_reg(0, 0);
        x64_enc_jcc_label(CC_E, lbl);
        x64_emit_body(n.b, n.c);
        x64_enc_jmp_label(lbl2);
        x64_enc_def_label(lbl);
        if (n.e > 0) { x64_emit_body(n.d, n.e); }
        x64_enc_def_label(lbl2);
        return 0;
    }

    if (t == T_BREAK) {
        if (arr_len(x64_break_stack) > 0) {
            auto brk_lbl;
            brk_lbl = arr_last(x64_break_stack);
            x64_enc_jmp_label(brk_lbl);
        }
        return 0;
    }

    if (t == T_CONTINUE) {
        if (arr_len(x64_continue_stack) > 0) {
            auto cnt_lbl;
            cnt_lbl = arr_last(x64_continue_stack);
            x64_enc_jmp_label(cnt_lbl);
        }
        return 0;
    }

    if (t == T_WHILE) {
        // n.e (offset 40) holds the for-loop step expression, or 0 for plain while.
        // The continue label is emitted between body and step so continue runs the
        // step before re-testing the condition.
        auto step_node, lbl3;
        step_node = n.e;
        lbl = x64_enc_new_label();
        lbl2 = x64_enc_new_label();
        lbl3 = x64_enc_new_label();
        x64_break_stack = arr_push(x64_break_stack, lbl2);
        x64_continue_stack = arr_push(x64_continue_stack, lbl3);
        x64_enc_def_label(lbl);
        ety = x64_emit_node(n.a);
        if (ety == 1) {
            x64_enc_xorpd(1, 1);
            x64_enc_ucomisd(0, 1);
            x64_enc_setcc(CC_NE, 0);
            x64_enc_movzx8(0, 0);
        }
        x64_enc_test_reg(0, 0);
        x64_enc_jcc_label(CC_E, lbl2);
        x64_emit_body(n.b, n.c);
        x64_enc_def_label(lbl3);
        if (step_node != 0) { x64_emit_stmt(step_node); }
        x64_enc_jmp_label(lbl);
        x64_enc_def_label(lbl2);
        arr_pop(x64_break_stack);
        arr_pop(x64_continue_stack);
        return 0;
    }

    if (t == T_RET) {
        rty = x64_emit_node(n.a);
        if (is_float_type(get_fn_ret_type(x64_cur_fn_idx))) {
            if (rty == 0) { x64_enc_cvtsi2sd(0, 0); }
        } else {
            if (rty == 1) { x64_enc_cvttsd2si(0, 0); }
        }
        x64_enc_jmp_label(x64_ret_lbl);
        return 0;
    }

    if (t == T_SWITCH) {
        // Form 1 evaluates the condition ONCE, pushes it, then peeks from
        // [rsp] for each comparison. Bodies use RBP-relative addressing so
        // the stack imbalance is invisible to them. Each match and the
        // else fall-through pops the saved cond before running the body.
        auto sw_arms, sw_bodies, sw_cnt, sw_end_lbl;
        auto si, sv_arr, sv_cnt, sb_arr, sb_cnt, snext_lbl;
        sw_arms = n.b;
        sw_bodies = n.src_tok;
        sw_cnt = n.c;
        sw_end_lbl = x64_enc_new_label();

        // Form 1 dense switches go through the jump-table path.
        if (n.a != 0) {
            if (x64_switch_is_dense(sw_arms, sw_cnt)) {
                x64_emit_switch_jtbl(n, sw_end_lbl);
                return 0;
            }
        }

        // Form 1: evaluate condition once, push.
        if (n.a != 0) {
            x64_emit_node(n.a);
            x64_emit_push();
        }

        for (si = 0; si < sw_cnt; si = si + 1) {
            sv_arr = sw_arms[si * 2];
            sv_cnt = sw_arms[si * 2 + 1];
            sb_arr = sw_bodies[si * 2];
            sb_cnt = sw_bodies[si * 2 + 1];
            snext_lbl = x64_enc_new_label();

            auto smatch_lbl, sk;
            smatch_lbl = x64_enc_new_label();
            if (n.a == 0) {
                // Form 2: condition dispatch. Evaluate, test nonzero.
                x64_emit_node(sv_arr[0]);
                x64_enc_test_reg(0, 0);
                x64_enc_jcc_label(5, smatch_lbl);   // JNE = 5 (nonzero)
            } else {
                // Form 1: compare each value against cond peeked from [rsp].
                for (sk = 0; sk < sv_cnt; sk = sk + 1) {
                    x64_emit_node(sv_arr[sk]);
                    x64_enc_load(1, 4, 0);           // rcx = [rsp]
                    x64_enc_cmp_reg(1, 0);
                    x64_enc_jcc_label(4, smatch_lbl);
                }
            }
            x64_enc_jmp_label(snext_lbl);

            x64_enc_def_label(smatch_lbl);
            // Pop saved cond before running the body (stack rebalance).
            if (n.a != 0) { x64_emit_pop(1); }
            for (sk = 0; sk < sb_cnt; sk = sk + 1) { x64_emit_stmt(sb_arr[sk]); }
            x64_enc_jmp_label(sw_end_lbl);

            x64_enc_def_label(snext_lbl);
        }

        // Fell through all arms — pop cond before else body or end.
        if (n.a != 0) { x64_emit_pop(1); }

        if (n.d != 0) {
            auto ek;
            for (ek = 0; ek < n.e; ek = ek + 1) { x64_emit_stmt(n.d[ek]); }
        }

        x64_enc_def_label(sw_end_lbl);
        return 0;
    }

    if (t == T_NOP) { return 0; }

    // T_BLOCK holds a statement array produced by parser-level DCE when a
    // literal `if` condition collapses to its taken branch. Emit each
    // child as a normal statement — there is no header or terminator.
    if (t == T_BLOCK) { x64_emit_body(n.b, n.c); return 0; }

    // Expression statement.
    x64_emit_node(nd);
}

// ── Function emission ──────────────────────────────────────

static void x64_emit_func(fi) {
    auto name_p, par_arr, par_cnt, body_arr, body_cnt;
    auto frame, i, total, sz;
    name_p = arr_get(x64_fn_name, fi);
    par_arr = arr_get(x64_fn_par, fi); par_cnt = arr_get(x64_fn_pcnt, fi);
    body_arr = arr_get(x64_fn_body, fi); body_cnt = arr_get(x64_fn_bcnt, fi);

    arr_clear(x64_vars); arr_clear(x64_var_stack);
    arr_clear(x64_var_struct_idx); arr_clear(x64_var_off); arr_clear(x64_var_forced_ty);
    arr_clear(x64_var_refs); arr_clear(x64_var_addr_taken);
    arr_clear(x64_var_promote); arr_clear(x64_promoted_regs);
    x64_cur_fn_name = name_p;
    x64_cur_fn_idx = arr_get(x64_fn_fidx, fi);

    // Register params as variables with optional type hints.
    auto fn_rec, hints, ph;
    fn_rec = arr_get(funcs, x64_cur_fn_idx);
    hints = *(fn_rec + 48);
    i = 0;
    while (i < par_cnt) {
        auto pvi;
        pvi = x64_var_add(*(par_arr + i * 8));
        if (hints != 0) {
            ph = *(hints + i * 8);
            if (ph > 0) { arr_set(x64_var_forced_ty, pvi, ph); }
        }
        i = i + 1;
    }

    // Pre-register all declared variables.
    x64_pre_reg_vars(body_arr, body_cnt);

    // Compute per-variable frame offsets (negative from rbp).
    // [rbp - 8]  = scratch, [rbp - 16] = xmm0 save, [rbp - 24] = xmm1
    // save. First variable at rbp - 32 and so on. `: double` locals
    // need the absolute offset from rbp to be a multiple of 16 so
    // MOVUPS / MOVAPS see natural alignment. The scratch area is 24
    // bytes so `total` starts 8 mod 16 — rounding needs to happen on
    // `24 + total` (the absolute magnitude), not `total` alone.
    auto _fty, abs_mag;
    total = 0;
    for (i = 0; i < arr_len(x64_vars); i = i + 1) {
        _fty = arr_get(x64_var_forced_ty, i);
        abs_mag = 24 + total;
        if (slice_width(ty_slice(_fty)) == 128) {
            abs_mag = (abs_mag + 15) / 16 * 16;
            total = abs_mag - 24 + 16;
            arr_set(x64_var_off, i, 0 - abs_mag - 16);
        } else if (arr_get(x64_var_stack, i)) {
            sz = (get_struct_size(arr_get(x64_var_struct_idx, i)) + 7) / 8 * 8;
            total = total + sz;
            arr_set(x64_var_off, i, 0 - (24 + total));
        } else {
            total = total + 8;
            arr_set(x64_var_off, i, 0 - (24 + total));
        }
    }
    // Phase B3: walk body, count refs, select promotions. Done before
    // frame size is finalized so the spill area shares the allocation.
    auto stmt_i: Node;
    for (i = 0; i < body_cnt; i = i + 1) {
        stmt_i = body_arr[i];
        if (stmt_i != 0) { _x64_b3_walk(stmt_i); }
    }
    _x64_b3_select();
    x64_b3_spill_off = 0 - (24 + total);
    total = total + arr_len(x64_promoted_regs) * 8;

    // Frame size: 8 (scratch) + 16 (xmm0/xmm1 save slots) + total variables, rounded up to 16.
    frame = 24 + total;
    frame = (frame + 15) / 16 * 16;

    // Define the label for this function.
    x64_enc_def_label(arr_get(x64_fn_lbl, fi));

    // Allocate return label.
    x64_ret_lbl = x64_enc_new_label();

    // Prologue: save frame pointer, allocate stack frame.
    x64_enc_push(5);                 // push rbp
    x64_enc_mov_reg(5, 4);           // mov rbp, rsp
    if (frame > 0) { x64_enc_sub_imm(4, frame); }  // sub rsp, frame

    // Phase B3: spill the chosen callee-saved registers.
    auto _b3_i, _b3_n, _b3_reg, _b3_off;
    _b3_n = arr_len(x64_promoted_regs);
    for (_b3_i = 0; _b3_i < _b3_n; _b3_i = _b3_i + 1) {
        _b3_reg = arr_get(x64_promoted_regs, _b3_i);
        _b3_off = x64_b3_spill_off - (_b3_i + 1) * 8;
        x64_enc_store(_b3_reg, 5, _b3_off);
    }

    // In main(), save argc (RDI), argv (RSI), and envp (RDX) to hidden
    // globals. The _start stub below sets up RDI/RSI/RDX from the kernel
    // stack so that main sees the standard `(int argc, char**argv, char**envp)`
    // signature even though Linux passes these via the stack at process entry.
    if (x64_str_eq(name_p, "main", 4)) {
        auto dpos;
        dpos = x64_enc_lea_rip(10);
        x64_enc_add_reloc(dpos, x64_argc_sym, 0);
        x64_enc_store(7, 10, 0);
        dpos = x64_enc_lea_rip(10);
        x64_enc_add_reloc(dpos, x64_argv_sym, 0);
        x64_enc_store(6, 10, 0);
        dpos = x64_enc_lea_rip(10);
        x64_enc_add_reloc(dpos, x64_envp_sym, 0);
        x64_enc_store(2, 10, 0);
    }

    // Store incoming register arguments. Promoted parameters land
    // straight in their assigned callee-saved register.
    auto _p_preg;
    i = 0;
    while (i < par_cnt) {
        _p_preg = arr_get(x64_var_promote, i);
        if (_p_preg >= 0) {
            x64_enc_mov_reg(_p_preg, x64_arg_reg(i));
        } else {
            x64_enc_store(x64_arg_reg(i), 5, arr_get(x64_var_off, i));
        }
        i = i + 1;
    }

    // Phase B3: zero any promoted local that is NOT a parameter.
    auto _z_vi, _z_n, _z_preg;
    _z_n = arr_len(x64_vars);
    for (_z_vi = par_cnt; _z_vi < _z_n; _z_vi = _z_vi + 1) {
        _z_preg = arr_get(x64_var_promote, _z_vi);
        if (_z_preg >= 0) { x64_enc_xor_zero(_z_preg); }
    }

    // Emit function body.
    x64_depth = 0;
    x64_emit_body(body_arr, body_cnt);

    // Implicit return 0: set rax = 0 for functions without explicit return.
    x64_enc_xor_zero(0);

    // Epilogue. Centralized so every explicit return restores the
    // spilled callee-saved registers exactly once.
    x64_enc_def_label(x64_ret_lbl);
    auto _e_i, _e_n, _e_reg, _e_off;
    _e_n = arr_len(x64_promoted_regs);
    for (_e_i = 0; _e_i < _e_n; _e_i = _e_i + 1) {
        _e_reg = arr_get(x64_promoted_regs, _e_i);
        _e_off = x64_b3_spill_off - (_e_i + 1) * 8;
        x64_enc_load(_e_reg, 5, _e_off);
    }
    x64_enc_mov_reg(4, 5);           // mov rsp, rbp
    x64_enc_pop(5);                  // pop rbp
    x64_enc_ret();

}

// ── Per-module emission (for incremental compilation) ──────

// Initialize encoder and global tables for per-module x86_64 codegen.
// Call once before the per-module loop.
void x64_mod_init() {
    auto i, rec, name_p, idx, j;
    x64_sbuf = vbuf;

    // Reset encoder state.
    x64_enc_pos = 0;
    arr_clear(x64_enc_lbl_off);
    arr_clear(x64_enc_fix_pos); arr_clear(x64_enc_fix_lbl);
    arr_clear(x64_enc_rel_pos); arr_clear(x64_enc_rel_sym); arr_clear(x64_enc_rel_ty);

    // Clear function tables.
    arr_clear(x64_fn_name); arr_clear(x64_fn_par); arr_clear(x64_fn_pcnt);
    arr_clear(x64_fn_body); arr_clear(x64_fn_bcnt); arr_clear(x64_fn_fidx);
    arr_clear(x64_fn_lbl);

    // Copy ALL globals with deduplication.
    arr_clear(x64_gl_name);
    i = 0;
    while (i < glob_cnt) {
        name_p = *(globals + i * 8);
        idx = -1;
        j = 0;
        while (j < arr_len(x64_gl_name)) {
            if (x64_str_eq_packed(name_p, arr_get(x64_gl_name, j))) { idx = j; }
            j = j + 1;
        }
        if (idx < 0) { x64_gl_name = arr_push(x64_gl_name, name_p); }
        i = i + 1;
    }
    // Hidden runtime globals come in via brt0.bsm (auto-injected).

    // Copy ALL externs.
    arr_clear(x64_ex_name); arr_clear(x64_ex_ret);
    arr_clear(x64_ex_args); arr_clear(x64_ex_acnt);
    for (i = 0; i < ext_cnt; i = i + 1) {
        rec = *(externs + i * 8);
        x64_ex_name = arr_push(x64_ex_name, *(rec + EX_NAME));
        x64_ex_ret  = arr_push(x64_ex_ret,  *(rec + EX_RET));
        x64_ex_args = arr_push(x64_ex_args, *(rec + EX_ARGS));
        x64_ex_acnt = arr_push(x64_ex_acnt, *(rec + EX_ACNT));
    }

}

// Emit code for one module. Returns code_start offset in x64_enc_buf.
void emit_module_x86_64(mi) {
    auto fn_start, code_start, i, rec, name_p, idx, j;

    fn_start = arr_len(x64_fn_name);

    // Add functions from this module only.
    i = 0;
    while (i < func_cnt) {
        if (arr_get(func_mods, i) == mi) {
            rec = *(funcs + i * 8);
            name_p = *(rec + FN_NAME);
            idx = -1;
            j = 0;
            while (j < arr_len(x64_fn_name)) {
                if (x64_str_eq_packed(name_p, arr_get(x64_fn_name, j))) { idx = j; }
                j = j + 1;
            }
            if (idx < 0) {
                idx = arr_len(x64_fn_name);
                x64_fn_name = arr_push(x64_fn_name, name_p);
                x64_fn_par  = arr_push(x64_fn_par,  *(rec + FN_PARS));
                x64_fn_pcnt = arr_push(x64_fn_pcnt, *(rec + FN_PCNT));
                x64_fn_body = arr_push(x64_fn_body, *(rec + FN_BODY));
                x64_fn_bcnt = arr_push(x64_fn_bcnt, *(rec + FN_BCNT));
                x64_fn_fidx = arr_push(x64_fn_fidx, i);
            } else {
                arr_set(x64_fn_name, idx, name_p);
                arr_set(x64_fn_par,  idx, *(rec + FN_PARS));
                arr_set(x64_fn_pcnt, idx, *(rec + FN_PCNT));
                arr_set(x64_fn_body, idx, *(rec + FN_BODY));
                arr_set(x64_fn_bcnt, idx, *(rec + FN_BCNT));
                arr_set(x64_fn_fidx, idx, i);
            }
        }
        i = i + 1;
    }

    // Assign labels for new functions only.
    i = fn_start;
    while (i < arr_len(x64_fn_name)) {
        x64_fn_lbl = arr_push(x64_fn_lbl, x64_enc_new_label());
        i = i + 1;
    }

    // Clear per-module fixups.
    arr_clear(x64_enc_fix_pos); arr_clear(x64_enc_fix_lbl);

    // Emit new functions only.
    code_start = x64_enc_pos;
    i = fn_start;
    while (i < arr_len(x64_fn_name)) {
        x64_emit_func(i);
        i = i + 1;
    }

    x64_enc_resolve_fixups();
    return code_start;
}

// Emit the _start entry point stub after all modules have been emitted.
// Finds main in x64_fn_name, emits argc/argv/envp setup, calls main, exits.
// Returns the _start label ID.
x64_emit_start_stub() {
    auto start_lbl, main_fi, i;
    arr_clear(x64_enc_fix_pos); arr_clear(x64_enc_fix_lbl);
    start_lbl = x64_enc_new_label();
    x64_enc_def_label(start_lbl);
    x64_enc_pop(7);                  // RDI = argc
    x64_enc_mov_reg(6, 4);           // RSI = &argv[0]
    // Compute envp = &argv[argc+1] before alignment.
    x64_enc_mov_reg(2, 7);           // RDX = argc
    x64_enc_shl_imm(2, 3);           // RDX = argc * 8
    x64_enc_add_reg(2, 6);           // RDX = &argv[argc]
    x64_enc_add_imm(2, 8);           // RDX = &argv[argc+1] = envp[0]
    x64_enc_and_imm(4, 0 - 16);      // align stack
    main_fi = 0 - 1;
    i = 0;
    while (i < arr_len(x64_fn_name)) {
        if (x64_str_eq(arr_get(x64_fn_name, i), "main", 4)) { main_fi = i; }
        i = i + 1;
    }
    if (main_fi >= 0) {
        x64_enc_call_label(arr_get(x64_fn_lbl, main_fi));
    }
    x64_enc_mov_reg(7, 0);
    x64_enc_mov_wide(0, BSYS_EXIT);
    x64_enc_syscall();
    x64_enc_resolve_fixups();
    return start_lbl;
}

// ── Top-level emission ─────────────────────────────────────

void emit_all_x86_64() {
    auto i, sp, ss, sl, j, fp, fs, fl, main_fi, main_lbl, start_lbl;

    bridge_data_x86_64();

    // Hidden runtime globals come in via brt0.bsm (auto-injected).

    // Reset encoder state.
    x64_enc_pos = 0;
    arr_clear(x64_enc_lbl_off);
    arr_clear(x64_enc_fix_pos);
    arr_clear(x64_enc_fix_lbl);
    arr_clear(x64_enc_rel_pos);
    arr_clear(x64_enc_rel_sym);
    arr_clear(x64_enc_rel_ty);

    // Allocate a label for each function.
    arr_clear(x64_fn_lbl);
    i = 0;
    while (i < arr_len(x64_fn_name)) {
        x64_fn_lbl = arr_push(x64_fn_lbl, x64_enc_new_label());
        i = i + 1;
    }

    // Emit _start stub: extracts argc/argv/envp from stack, calls main, then exits.
    start_lbl = x64_enc_new_label();
    x64_enc_def_label(start_lbl);
    // On Linux, at _start: [RSP] = argc, [RSP+8] = argv[0], ...,
    // [RSP+(argc+1)*8] = envp[0]. Layout per the SysV ABI process startup.
    x64_enc_pop(7);                   // RDI = argc (pop from stack)
    x64_enc_mov_reg(6, 4);            // RSI = RSP = &argv[0]
    // Compute envp = &argv[argc+1] BEFORE aligning the stack, because
    // the alignment loses RSP's relationship to the original kernel layout.
    // Equivalent to lea rdx, [rsi + rdi*8 + 8].
    x64_enc_mov_reg(2, 7);            // RDX = RDI = argc
    x64_enc_shl_imm(2, 3);            // RDX = argc * 8
    x64_enc_add_reg(2, 6);            // RDX = RSI + argc*8 = &argv[argc] (NULL terminator)
    x64_enc_add_imm(2, 8);            // RDX = &argv[argc+1] = envp[0]
    // Align stack to 16 bytes before calling main.
    x64_enc_and_imm(4, 0 - 16);
    // Call main(argc, argv, envp). RDI=argc, RSI=argv, RDX=envp now set.
    main_fi = x64_find_fn(pack(0, 0));  // Will be found by name below.
    i = 0;
    while (i < arr_len(x64_fn_name)) {
        if (x64_str_eq(arr_get(x64_fn_name, i), "main", 4)) { main_fi = i; }
        i = i + 1;
    }
    if (main_fi >= 0) {
        x64_enc_call_label(arr_get(x64_fn_lbl, main_fi));
    }
    // Exit with main's return value: sys_exit(RAX).
    x64_enc_mov_reg(7, 0);            // RDI = return value
    x64_enc_mov_wide(0, BSYS_EXIT);
    x64_enc_syscall();

    // Emit all functions into the code buffer.
    i = 0;
    while (i < arr_len(x64_fn_name)) { x64_emit_func(i); i = i + 1; }

    // Resolve all forward branch fixups.
    x64_enc_resolve_fixups();

    // String and float data preparation is done by the caller (bpp.bpp)
    // after this function returns, using mo_atof for float parsing.

    return start_lbl;
}
