// bpp_parser.bsm — B++ parser module for the unified compiler.
// Converts token stream into AST.

import "bpp_defs.bsm";
import "bpp_array.bsm";
import "bpp_hash.bsm";
import "bpp_internal.bsm";
import "bpp_diag.bsm";

// ── Parser-owned globals ────────────────────────────────────

// Token storage (filled by the lexer before parsing begins).
extrn toks;
global tok_cnt, tok_pos;
extrn vbuf;
global vbuf_pos;

// Program structure collected during parsing.
extrn globals, glob_cnt;
// 1 if the global was declared with the `global` keyword (shared with
// worker threads, dispatchable from auto-parallelized loops); 0 if it
// was declared with `auto` at file scope (legacy / main-thread-only,
// conservative default that the auto-dispatch pass refuses to touch).
// Both forms produce the same runtime layout — the difference is purely
// a static intent flag that smart dispatch consults to decide whether
// a loop touching the global is safe to fan out across workers.
// Per-global storage class (parallel to globals[]). One of GLOB_AUTO,
// GLOB_GLOBAL, GLOB_EXTRN, GLOB_GLOBAL_CONST, or GLOB_STATIC_CONST.
// Codegen and the smart-dispatch pass read this to decide whether a
// loop touching the variable is safe to fan out, and whether the slot
// needs initialised data emitted.
global glob_class;

// Parallel arrays carrying the initial value for `global const` and
// `static const` declarations. For all other storage classes the slot
// at index i is left at 0 and ignored. `glob_init_is_float` tags
// whether the value should be emitted as float bits (1) or integer
// (0) — the parser detects this via SHAPE_DECIMAL on the literal,
// matching the float-const fast path in `parse_const`.
global glob_init_val;
global glob_init_is_float;

// Set to 1 by the orchestrator (bpp.bpp) when parsing the entry file's
// content (module 0). Used by Fix 2 to enforce "main() only in entry file"
// without relying on tok_mod() which returns incorrect module attribution
// for module 0 (its content sits at mod0_real_start, past all auto-injected
// modules, but diag_file_starts[0] points to position 0 in outbuf).
global _parser_is_entry;
extrn externs, ext_cnt;
extrn funcs, func_cnt;
global fn_static;   // parallel to funcs[]: 1 if static (private to module)
global fn_void;     // parallel to funcs[]: 1 if void (no useful return)

// Struct registry: 7 parallel dynamic arrays (name, fields ptr, field count, size, hints, byte offs, bit offs).
// sd_byte_offs[i][j] = byte offset of field j in struct i (precomputed by add_struct_field).
// sd_bit_offs[i][j]  = bit offset within that byte for bit-packed fields; 0 for byte+ fields.
extrn sd_names, sd_fields, sd_fcounts, sd_sizes, sd_fhints;

// Excalibur Feature 3 — struct newtype registry. `sd_newtype_base[i]`
// stores the base struct index (>= 0) when struct i was declared as
// `struct WorldPos as Vec2;`, or -1 when struct i is a normal struct
// with its own field list. The byte layout (sd_fields, sd_fhints,
// sd_byte_offs, sd_bit_offs, sd_sizes, sd_fcounts) is COPIED from the
// base at declaration time so every existing layout-walker stays
// agnostic — a newtype is byte-identical to its base, which is the
// "zero cost" property the type checker leans on. Identity lives in
// `sd_names[i]` (distinct packed name) plus this slot (non-negative
// flags newtype-ness for the type-system's cross-newtype check).
extrn sd_newtype_base;
extrn sd_byte_offs, sd_bit_offs;

// Struct lookup acceleration. _parser_struct_hash maps a struct
// name's byte sequence to (struct_idx + 1). Updated incrementally by
// add_struct_def — find_struct then runs in O(1) without ever needing
// to rebuild. Inserts and lookups happen interleaved during parsing,
// so eager/lazy strategies would cost O(n) per insertion; incremental
// is the only correct fit here.
static auto _parser_struct_hash;

// Variable type map: 2 parallel dynamic arrays (var_name packed, struct_index).
static auto vt_names, vt_sidx;
// Parallel to funcs[]: snapshot of arr_len(vt_names) at the start
// of each parse_function call. Lets the bug debugger ask "did THIS
// function annotate `name` with a struct?" without picking up an
// `auto name: T` from a different function. The codegen continues
// to use the global vt_names walk (which deliberately bleeds, so
// `arena_alloc(a, b)` inherits the `Arena` annotation from
// `arena_new`'s `auto a: Arena;`); only the bug emit path narrows
// to a single function's window.
static auto fn_vt_starts;

// Stack struct flag: tracks which variables are stack-allocated (via var keyword).
// Two parallel arrays — name + function index — so a `var v: T` in
// function A doesn't make a same-named `auto v` in function B look
// stack-allocated. Function index is taken from `arr_len(funcs)` at
// the moment the var is registered.
static auto var_stack_names;
static auto var_stack_fns;

// Enum constant registry: 3 parallel dynamic arrays.
//   ev_names[eid]    packed (offset, length) ref to the constant name
//   ev_values[eid]   integer value (or 0 placeholder for float consts)
//   ev_lit_src[eid]  packed source ref for float consts, or 0 if int
//
// `ev_lit_src` is the Excalibur Arc Feature 1 closure (gap B): when a
// const RHS is a SHAPE_DECIMAL literal, the original source bytes
// ("0.6", "1e-9", etc.) are captured here so the inline-at-use-site
// path can rebuild a real float T_LIT instead of casting to int 0.
extrn ev_names, ev_values, ev_lit_src;

// Const function registry: name, params array, param count, body array, body count.
static auto cf_names, cf_params, cf_pcnts, cf_bodies, cf_bcnts, cf_count;

// TK_FLOAT is not declared in defs.bpp, so the parser owns it.
extrn TK_FLOAT;

// Primitive type hint set by try_type_annotation(). 0 = no hint,
// TY_FLOAT or TY_WORD when the annotation is a primitive name.
static auto _prim_hint;

// Block nesting depth. 0 = function top level. Incremented by parse_body
// when called from if/while/for. Used to warn about auto inside blocks.
static auto _block_depth;

// Loop nesting depth. 0 = outside any loop. Incremented by parse_while
// and parse_for around their `parse_body()` call; decremented on exit.
// Stamped onto every T_CALL node's `.d` field at creation so the S4
// cost-model inliner can multiply the per-callsite threshold for hot
// loop bodies. `.d` is otherwise unused on T_CALL nodes (verified by
// grep across src/), and `ast_clone_subst` (bpp_dispatch.bsm:3878)
// already preserves `cl.d = orig.d` so inlined calls keep their loop
// stamp. Switch arms are NOT loops (one-shot dispatch, not repetition)
// — they intentionally do not bump the depth.
static auto _cur_loop_depth;

// Recognise FFI driver modules by filename prefix. Drivers are
// allowed to silently override the auto-injected `_stb_platform_<os>`
// platform layer — the convention is the `drv_` prefix on the
// module's basename (drv_sdl.bsm, drv_raylib.bsm, ...). Returns 1
// when `mod_idx` resolves to a path whose basename starts with
// `drv_`, 0 otherwise. Falls through to 0 on any lookup failure so
// non-driver duplicates still trip E221 normally.
extrn fname_buf;
static _is_driver_module(mod_idx) {
    auto packed, off, len, i, last_slash;
    if (mod_idx <= 0) { return 0; }
    if (mod_idx >= diag_file_count()) { return 0; }
    packed = diag_file_name(mod_idx);
    off = unpack_s(packed);
    len = unpack_l(packed);
    if (len < 4) { return 0; }   // "drv_" already 4 bytes
    // Walk back to the last slash to find the basename. Both
    // absolute paths and relative paths are stored verbatim in
    // fname_buf, so this works for both.
    last_slash = 0;
    for (i = 0; i < len; i++) {
        if (peek(fname_buf + off + i) == 47) { last_slash = i + 1; }
    }
    if (last_slash + 4 > len) { return 0; }
    if (peek(fname_buf + off + last_slash + 0) != 100) { return 0; }   // 'd'
    if (peek(fname_buf + off + last_slash + 1) != 114) { return 0; }   // 'r'
    if (peek(fname_buf + off + last_slash + 2) != 118) { return 0; }   // 'v'
    if (peek(fname_buf + off + last_slash + 3) !=  95) { return 0; }   // '_'
    return 1;
}

// ============================================================
// Initialization
// ============================================================

// Allocate parser-specific state. Constants (T_LIT, TK_KW, etc.)
// are set by init_defs(); list builder (tmp_arr, list_stack, etc.)
// is allocated by bpp_internal.bsm.
void init_parser() {
    // Each token slot is 24 bytes (kind + start + len). 16 MB
    // gives ~700k slot capacity. The compiler self-compile
    // crosses 174k tokens (the previous 4 MB ceiling) under
    // typical configurations and overflowed into the next
    // malloc'd buffer, which on some heap layouts was vbuf —
    // surfaced as "compiler self-compile flakes ~20% with
    // garbled function names" because the spilled writes
    // zeroed the bytes of an interned identifier. tok_lines /
    // tok_src_off were already at 8 MB each since the same
    // class of bug bit init_dispatch's "global 'break' not
    // found" regression long ago; the same headroom logic
    // applies here.
    toks = malloc(16777216);
    vbuf = malloc(1048576);
    vbuf_pos = 0;
    tok_cnt = 0;
    tok_pos = 0;
    _cur_loop_depth = 0;
    globals = arr_new();
    glob_cnt = 0;
    glob_class = arr_new();
    glob_init_val = arr_new();
    glob_init_is_float = arr_new();
    _parser_is_entry = 0;
    externs = arr_new();
    ext_cnt = 0;
    funcs = arr_new();
    func_cnt = 0;
    func_mods = arr_new();
    fn_static = arr_new();
    fn_void = arr_new();
    glob_mods = arr_new();
    struct_mods = arr_new();
    enum_mods = arr_new();
    extern_mods = arr_new();
    sd_names = arr_new();
    sd_newtype_base = arr_new();
    sd_fields = arr_new();
    sd_fcounts = arr_new();
    sd_sizes = arr_new();
    sd_fhints = arr_new();
    sd_byte_offs = arr_new();
    sd_bit_offs = arr_new();
    vt_names = arr_new();
    vt_sidx = arr_new();
    fn_vt_starts = arr_new();
    var_stack_names = arr_new();
    var_stack_fns = arr_new();
    ev_names = arr_new();
    ev_values = arr_new();
    ev_lit_src = arr_new();
    cf_names = arr_new();
    cf_params = arr_new();
    cf_pcnts = arr_new();
    cf_bodies = arr_new();
    cf_bcnts = arr_new();
    cf_count = 0;
    TK_FLOAT = 8;
    _prim_hint = 0;
    _block_depth = 0;
}

// packed_eq is defined in bpp_internal.bsm — no longer duplicated here.

// ============================================================
// Struct support
// ============================================================

// Register a struct name in the lookup hash. Public so the .bo cache
// loader (bpp_bo.bsm) can also call it after inserting cached structs
// directly into sd_names — both insertion paths must update the hash
// to keep find_struct correct across cached compilations.
void register_struct_hash(name_p, idx) {
    if (_parser_struct_hash == 0) {
        _parser_struct_hash = hash_str_new(64);
    }
    hash_str_set(_parser_struct_hash,
                 vbuf + unpack_s(name_p), unpack_l(name_p),
                 idx + 1);
}

// Register a new struct definition. Returns its index. Updates the
// struct-name hash incrementally so find_struct stays O(1).
add_struct_def(name_p) {
    auto idx;
    sd_names = arr_push(sd_names, name_p);
    sd_newtype_base = arr_push(sd_newtype_base, 0 - 1);
    sd_fields = arr_push(sd_fields, buf_word(64));
    sd_fcounts = arr_push(sd_fcounts, 0);
    sd_sizes = arr_push(sd_sizes, 0);
    sd_fhints = arr_push(sd_fhints, buf_word(64));
    // Per-field precomputed layout: byte and bit offsets, populated by add_struct_field.
    sd_byte_offs = arr_push(sd_byte_offs, buf_word(64));
    sd_bit_offs = arr_push(sd_bit_offs, buf_word(64));
    struct_mods = arr_push(struct_mods, tok_mod(tok_pos));
    idx = arr_len(sd_names) - 1;
    register_struct_hash(name_p, idx);
    return idx;
}

// Excalibur Feature 3 — copy `base_idx`'s layout into struct `idx`
// so a newtype shares byte-exact storage with its base. Called from
// `parse_struct` after `struct WorldPos as Vec2;` syntax landed.
// The layout-walking code never has to ask "is this a newtype?" —
// every consumer that reads sd_fields / sd_fhints / sd_byte_offs /
// sd_bit_offs / sd_sizes / sd_fcounts sees the base's actual values.
// Type identity (the new-name + newtype_base flag) lives separately
// for the type checker.
void _copy_struct_layout(idx, base_idx) {
    auto i, fc;
    auto src_fields, src_fhints, src_bytes, src_bits;
    auto dst_fields, dst_fhints, dst_bytes, dst_bits;
    fc = arr_get(sd_fcounts, base_idx);
    src_fields = arr_get(sd_fields, base_idx);
    src_fhints = arr_get(sd_fhints, base_idx);
    src_bytes  = arr_get(sd_byte_offs, base_idx);
    src_bits   = arr_get(sd_bit_offs, base_idx);
    dst_fields = arr_get(sd_fields, idx);
    dst_fhints = arr_get(sd_fhints, idx);
    dst_bytes  = arr_get(sd_byte_offs, idx);
    dst_bits   = arr_get(sd_bit_offs, idx);
    for (i = 0; i < fc; i++) {
        dst_fields[i] = src_fields[i];
        dst_fhints[i] = src_fhints[i];
        dst_bytes[i]  = src_bytes[i];
        dst_bits[i]   = src_bits[i];
    }
    arr_set(sd_fcounts, idx, fc);
    arr_set(sd_sizes, idx, arr_get(sd_sizes, base_idx));
    arr_set(sd_newtype_base, idx, base_idx);
}

// Return the byte cost of a field given its type hint.
// Bit-sliced fields return 0 because they share a byte with neighbours;
// the actual byte placement is computed by add_struct_field's layout pass.
field_hint_size(hint) {
    auto sl;
    sl = ty_slice(hint);
    if (sl >= SL_BIT && sl <= SL_BIT7) { return 0; }
    return slice_width(sl) / 8;
}

// Add a field to an existing struct with an optional type hint.
// Recomputes the full layout each call so bit-packed fields stay coherent
// with byte-aligned fields. Bit fields pack LSB-first within the current
// byte; a byte+ field or an overflowing bit width starts a fresh byte.
void add_struct_field(idx, field_p, hint) {
    auto fields, hints, byte_offs, bit_offs, fc;
    auto j, h, sl, bw, byte_cur, bit_cur, total;
    fields = arr_get(sd_fields, idx);
    hints = arr_get(sd_fhints, idx);
    byte_offs = arr_get(sd_byte_offs, idx);
    bit_offs = arr_get(sd_bit_offs, idx);
    fc = arr_get(sd_fcounts, idx);
    fields[fc] = field_p;
    hints[fc] = hint;
    fc++;

    // Layout pass: walk every field and assign (byte, bit) offsets.
    byte_cur = 0;
    bit_cur = 0;
    for (j = 0; j < fc; j++) {
        h = hints[j];
        sl = ty_slice(h);
        if (sl >= SL_BIT && sl <= SL_BIT7) {
            // Bit-packed field — places into the current byte if it fits,
            // otherwise rolls onto a fresh one. Width is encoded as sl - 3.
            bw = sl - 3;
            if (bit_cur + bw > 8) {
                byte_cur++;
                bit_cur = 0;
            }
            byte_offs[j] = byte_cur;
            bit_offs[j] = bit_cur;
            bit_cur += bw;
            if (bit_cur == 8) {
                byte_cur++;
                bit_cur = 0;
            }
        } else {
            // Byte+ field (including future SL_DOUBLE) — flush any in-flight
            // bit packing first so this field starts on a fresh byte.
            if (bit_cur > 0) {
                byte_cur++;
                bit_cur = 0;
            }
            byte_offs[j] = byte_cur;
            bit_offs[j] = 0;
            byte_cur += slice_width(sl) / 8;
        }
    }
    // Total size: round up if any bit packing is still in flight.
    total = byte_cur;
    if (bit_cur > 0) { total++; }

    arr_set(sd_fcounts, idx, fc);
    arr_set(sd_sizes, idx, total);
}

// Find a struct by name. O(1) hash lookup. The hash is kept in sync
// by add_struct_def so no rebuild is ever needed.
find_struct(name_p) {
    auto v;
    if (_parser_struct_hash == 0) { return -1; }
    v = hash_str_get(_parser_struct_hash,
                     vbuf + unpack_s(name_p), unpack_l(name_p));
    if (v == 0) { return -1; }
    return v - 1;
}

// Get the byte offset of a field within a struct. Returns -1 if not found.
// Reads the precomputed byte offset stored by add_struct_field's layout pass.
// Public — smart-dispatch outlining (`bpp_dispatch.bsm`) consults this when
// rewriting captured names to capture-struct field accesses.
get_field_offset(idx, field_p) {
    auto fields, byte_offs, fc, i;
    fields = arr_get(sd_fields, idx);
    byte_offs = arr_get(sd_byte_offs, idx);
    fc = arr_get(sd_fcounts, idx);
    for (i = 0; i < fc; i++) {
        if (packed_eq(fields[i], field_p)) { return byte_offs[i]; }
    }
    return -1;
}

// Get the bit offset of a bit-packed field within its byte. Returns 0 for
// byte-aligned fields and unknown fields. Codegen calls this only when the
// field's slice is SL_BIT..SL_BIT7.
get_field_bit_off(idx, field_p) {
    auto fields, bit_offs, fc, i;
    fields = arr_get(sd_fields, idx);
    bit_offs = arr_get(sd_bit_offs, idx);
    fc = arr_get(sd_fcounts, idx);
    for (i = 0; i < fc; i++) {
        if (packed_eq(fields[i], field_p)) { return bit_offs[i]; }
    }
    return 0;
}

// Get the bit width (1..7) of a bit-packed field. Returns 0 for byte+ fields.
// Convenience wrapper so codegen does not need to derive the width from the
// slice ordinal itself.
get_field_bit_width(idx, field_p) {
    auto fields, hints, fc, i, sl;
    fields = arr_get(sd_fields, idx);
    hints = arr_get(sd_fhints, idx);
    fc = arr_get(sd_fcounts, idx);
    for (i = 0; i < fc; i++) {
        if (packed_eq(fields[i], field_p)) {
            sl = ty_slice(hints[i]);
            if (sl >= SL_BIT && sl <= SL_BIT7) { return sl - 3; }
            return 0;
        }
    }
    return 0;
}

// Get the type hint of a specific field by index.
static get_field_hint(idx, field_idx) {
    auto hints;
    hints = arr_get(sd_fhints, idx);
    return hints[field_idx];
}

// Get the field index by name. Returns -1 if not found.
static get_field_index(idx, field_p) {
    auto fields, fc, i;
    fields = arr_get(sd_fields, idx);
    fc = arr_get(sd_fcounts, idx);
    for (i = 0; i < fc; i++) {
        if (packed_eq(fields[i], field_p)) { return i; }
    }
    return -1;
}

// Get the total size in bytes of a struct.
get_struct_size(idx) {
    return arr_get(sd_sizes, idx);
}

// Record a variable's struct type for dot-access resolution.
void set_var_type(var_p, idx) {
    vt_names = arr_push(vt_names, var_p);
    vt_sidx = arr_push(vt_sidx, idx);
}

// Excalibur Feature 3 — return 1 if struct `idx` was declared as
// `struct X as Base;`, 0 if it is a normal struct. Out-of-range
// indices return 0 so callers can ask without bounds-checking.
is_newtype(idx) {
    if (idx < 0) { return 0; }
    if (idx >= arr_len(sd_newtype_base)) { return 0; }
    if (arr_get(sd_newtype_base, idx) >= 0) { return 1; }
    return 0;
}

// Excalibur Feature 3 — return the base struct index for newtype
// `idx`, or -1 if `idx` is a normal struct (or out of range).
newtype_base(idx) {
    if (idx < 0) { return 0 - 1; }
    if (idx >= arr_len(sd_newtype_base)) { return 0 - 1; }
    return arr_get(sd_newtype_base, idx);
}

// Look up a variable's struct type. Returns struct index or -1.
get_var_type(var_p) {
    auto i;
    for (i = arr_len(vt_names) - 1; i >= 0; i--) {
        if (packed_eq(arr_get(vt_names, i), var_p)) { return arr_get(vt_sidx, i); }
    }
    return -1;
}

// Per-function variant of get_var_type. Searches only the vt_names
// entries added during the parse of function fn_idx — set_var_type
// calls from other functions are ignored. Returns the struct index
// or -1. Used by the bug debugger's `.bug` emit so the watch loop
// reports "this is a Player" only when the user actually wrote
// `auto p: Player;` inside this function (not because some
// unrelated function happened to declare a same-named local with
// a struct annotation).
get_var_type_in_fn(var_p, fn_idx) {
    auto start, end_pos, i;
    if (fn_idx < 0)                       { return -1; }
    if (fn_idx >= arr_len(fn_vt_starts))  { return -1; }
    start = arr_get(fn_vt_starts, fn_idx);
    end_pos = arr_len(vt_names);
    if (fn_idx + 1 < arr_len(fn_vt_starts)) {
        end_pos = arr_get(fn_vt_starts, fn_idx + 1);
    }
    for (i = end_pos - 1; i >= start; i--) {
        if (packed_eq(arr_get(vt_names, i), var_p)) {
            return arr_get(vt_sidx, i);
        }
    }
    return -1;
}

// Mark a variable as stack-allocated (declared with var keyword).
static void set_var_stack(var_p) {
    var_stack_names = arr_push(var_stack_names, var_p);
    // Tag with the function currently being parsed so a same-named local
    // in a different function doesn't get misclassified as stack.
    // `func_cnt` is the index THIS function will receive — `funcs` is
    // appended only after the body finishes parsing (parse_function
    // line 1367), so during body parsing func_cnt is the upcoming index.
    var_stack_fns = arr_push(var_stack_fns, func_cnt);
}

// Check if a variable is stack-allocated within the given function index.
// Returns 1 if yes, 0 otherwise. Function-scoped so `var v: T` in fn A
// does not trigger memcpy semantics for an `auto v` in fn B.
is_var_stack(var_p, fn_idx) {
    auto i;
    for (i = arr_len(var_stack_names) - 1; i >= 0; i--) {
        if (arr_get(var_stack_fns, i) != fn_idx) { continue; }
        if (packed_eq(arr_get(var_stack_names, i), var_p)) { return 1; }
    }
    return 0;
}

// Register an enum constant: maps a packed name to an integer value.
// Non-static so bpp_internal's enum_register wrapper can delegate.
// Still treated as parser-internal — callers outside the parser
// should use enum_register from bpp_internal.bsm.
void add_enum_val(name_p, val) {
    ev_names = arr_push(ev_names, name_p);
    ev_values = arr_push(ev_values, val);
    ev_lit_src = arr_push(ev_lit_src, 0);
    enum_mods = arr_push(enum_mods, tok_mod(tok_pos));
}

// Register a const that holds a float literal. The original source
// bytes (e.g. "0.6", "1e-9") are captured by `lit_src` so a use-site
// reference can rebuild a real SHAPE_DECIMAL T_LIT and let codegen
// emit it as a float — preserving the IEEE 754 bits the int path
// would otherwise truncate. The integer slot is set to 0 so legacy
// callers that read `ev_values[eid]` directly see a benign sentinel.
void add_enum_val_float(name_p, lit_src) {
    ev_names = arr_push(ev_names, name_p);
    ev_values = arr_push(ev_values, 0);
    ev_lit_src = arr_push(ev_lit_src, lit_src);
    enum_mods = arr_push(enum_mods, tok_mod(tok_pos));
}

// Look up an enum/const by packed name. Returns the index or -1 if
// not found. Non-static for the same reason as add_enum_val.
find_enum_idx(name_p) {
    auto i;
    for (i = arr_len(ev_names) - 1; i >= 0; i--) {
        if (packed_eq(arr_get(ev_names, i), name_p)) { return i; }
    }
    return -1;
}

// Look up an enum constant by packed name. Returns the value or -1
// if not found. WARNING: breaks for negative values. Use
// find_enum_idx + arr_get instead. Non-static for bpp_internal
// wrapper access.
find_enum_val(name_p) {
    auto i;
    i = find_enum_idx(name_p);
    if (i >= 0) { return arr_get(ev_values, i); }
    return -1;
}

// Parse the current token as a decimal or hex integer literal.
// Does NOT consume the token — caller must consume() after.
static parse_lit_int() {
    auto vs, vl, i, ch, val, t;
    t = peek_type();
    vs = peek_vstart();
    vl = peek_vlen();
    val = 0;
    if (t == TK_HEX) {
        // Skip "0x" prefix.
        for (i = 2; i < vl; i++) {
            ch = peek(vbuf + vs + i);
            val *= 16;
            if (ch >= 48) { if (ch <= 57) { val += ch - 48; } }
            if (ch >= 65) { if (ch <= 70) { val += ch - 55; } }
            if (ch >= 97) { if (ch <= 102) { val += ch - 87; } }
        }
    } else {
        for (i = 0; i < vl; i++) {
            ch = peek(vbuf + vs + i);
            val = val * 10 + ch - 48;
        }
    }
    return val;
}

// ============================================================
// AST helper: integer literal and operator construction
// ============================================================

// Parse a packed integer literal (decimal or hex) into its numeric value.
// String and float literals must be filtered out by the caller — this
// helper assumes the input is already known to be an integer literal.
parse_int_lit_value(p) {
    auto s, l, i, ch, val, is_hex;
    s = unpack_s(p); l = unpack_l(p); val = 0; i = 0;
    is_hex = 0;
    if (l > 2) {
        if (peek(vbuf + s) == '0') {
            if (peek(vbuf + s + 1) == 'x') { is_hex = 1; i = 2; }
        }
    }
    if (is_hex) {
        while (i < l) {
            ch = peek(vbuf + s + i);
            if (ch >= '0' && ch <= '9') { val = val * 16 + ch - '0'; }
            else if (ch >= 'a' && ch <= 'f') { val = val * 16 + ch - 'a' + 10; }
            else if (ch >= 'A' && ch <= 'F') { val = val * 16 + ch - 'A' + 10; }
            i++;
        }
    } else {
        while (i < l) {
            ch = peek(vbuf + s + i);
            if (ch >= '0' && ch <= '9') { val = val * 10 + ch - '0'; }
            i++;
        }
    }
    return val;
}

// Check whether an AST node is a pure integer literal suitable for
// compile-time folding. String literals (start with '"') and float
// literals (contain '.') return 0 so the folder skips them.
is_int_lit_node(node_p) {
    auto n: Node, s, l, i, ch;
    n = node_p;
    if (n.ntype != T_LIT) { return 0; }
    s = unpack_s(n.a);
    l = unpack_l(n.a);
    if (l == 0) { return 0; }
    if (peek(vbuf + s) == '"') { return 0; }
    i = 0;
    while (i < l) {
        if (peek(vbuf + s + i) == '.') { return 0; }
        i++;
    }
    return 1;
}

// Read the Excalibur Arc shape annotation from a literal node.
// Returns SHAPE_INT, SHAPE_DECIMAL, or 0 (not set / non-numeric).
// Pure read — `@base` so callers in dispatchable contexts compose
// without phase friction.
lit_shape(node_p) {
    auto n: Node;
    n = node_p;
    if (n.ntype != T_LIT) { return 0; }
    return n.b;
}

// True when the AST node is a float literal — a T_LIT whose value
// string contains a decimal point. Used by diagnostics like E244 to
// catch float literals in int-only contexts (array index, shift count)
// at parse time, before the AST mutates the literal beyond recognition.
is_float_lit_node(node_p) {
    auto n: Node, s, l, i;
    n = node_p;
    if (n.ntype != T_LIT) { return 0; }
    s = unpack_s(n.a);
    l = unpack_l(n.a);
    if (l == 0) { return 0; }
    if (peek(vbuf + s) == '"') { return 0; }
    i = 0;
    while (i < l) {
        if (peek(vbuf + s + i) == '.') { return 1; }
        i++;
    }
    return 0;
}

// Create a literal AST node holding an integer value.
// For negative values, wraps in a T_UNARY('-') node so codegen handles it.
static make_int_lit(val) {
    auto start, node: Node, tmp, digit, i, j, t, inner, neg_op, neg_node: Node;
    if (val < 0) {
        inner = make_int_lit(0 - val);
        neg_op = pack(vbuf_pos, 1);
        poke(vbuf + vbuf_pos, 45);
        vbuf_pos++;
        neg_node = make_node(T_UNARY);
        neg_node.a = neg_op;
        neg_node.b = inner;
        return neg_node;
    }
    start = vbuf_pos;
    if (val == 0) {
        poke(vbuf + vbuf_pos, 48);
        vbuf_pos++;
    } else {
        tmp = val;
        while (tmp > 0) {
            digit = tmp % 10;
            poke(vbuf + vbuf_pos, 48 + digit);
            vbuf_pos++;
            tmp /= 10;
        }
        // Reverse the digits.
        i = start;
        j = vbuf_pos - 1;
        while (i < j) {
            t = peek(vbuf + i);
            poke(vbuf + i, peek(vbuf + j));
            poke(vbuf + j, t);
            i++;
            j--;
        }
    }
    node = make_node(T_LIT);
    node.a = pack(start, vbuf_pos - start);
    // Excalibur Arc Feature 1 — synthetic integer literals carry
    // SHAPE_INT so any consumer that switches on shape (Session
    // 1.B's slot-context resolver) treats them identically to
    // a hand-written `42` from source.
    node.b = SHAPE_INT;
    return node;
}

// Create a packed string containing a single "+" character.
static make_plus_op() {
    auto start;
    start = vbuf_pos;
    poke(vbuf + vbuf_pos, 43);
    vbuf_pos++;
    return pack(start, 1);
}

// Intern a single operator character into vbuf and return a packed ref.
// Used by compound-assignment and increment desugaring to build T_BINOP nodes.
static _make_op_char(ch) {
    auto p;
    p = pack(vbuf_pos, 1);
    poke(vbuf + vbuf_pos, ch);
    vbuf_pos++;
    return p;
}

// Desugar x++ / ++x / x-- / --x. Identical semantics to `x += 1`
// (or `x -= 1`), so delegate to `_make_compound_assign` instead of
// reimplementing the T_ASSIGN / T_MEMST split. This keeps the two
// paths from drifting again: previously this function emitted a
// plain T_ASSIGN for every lhs, which silently no-op'd on T_MEMLD
// (struct field, array slot) lhs because there was no T_MEMST emit.
static _make_inc_assign(lhs, op_ch) {
    return _make_compound_assign(op_ch, lhs, make_int_lit(1));
}

// Desugar x += rhs → T_ASSIGN(lhs, T_BINOP(op_ch, lhs, rhs)).
// Also handles T_MEMLD on lhs: mirrors the T_MEMST path of plain '='.
static _make_compound_assign(op_ch, lhs, rhs) {
    auto binop: Node, node: Node, ln: Node;
    binop = make_node(T_BINOP);
    binop.a = _make_op_char(op_ch);
    binop.b = lhs;
    binop.c = rhs;
    ln = lhs;
    if (ln.ntype == T_MEMLD) {
        node = make_node(T_MEMST);
        node.a = ln.a;
        node.b = binop;
        node.c = ln.b;
        return node;
    }
    node = make_node(T_ASSIGN);
    node.a = lhs;
    node.b = binop;
    return node;
}

// Phase D.4 inline trivials support: cached packed ref for the
// literal "malloc". Initialized lazily on first call — subsequent
// calls reuse the cached offset. Rule 1: written once.
static auto _inline_malloc_p_cached;

static _inline_malloc_ref() {
    auto start;
    if (_inline_malloc_p_cached != 0) { return _inline_malloc_p_cached; }
    start = vbuf_pos;
    poke(vbuf + vbuf_pos,     'm');
    poke(vbuf + vbuf_pos + 1, 'a');
    poke(vbuf + vbuf_pos + 2, 'l');
    poke(vbuf + vbuf_pos + 3, 'l');
    poke(vbuf + vbuf_pos + 4, 'o');
    poke(vbuf + vbuf_pos + 5, 'c');
    vbuf_pos += 6;
    _inline_malloc_p_cached = pack(start, 6);
    return _inline_malloc_p_cached;
}

// Phase 6.3 scoped zones — cached packed refs for the runtime
// support functions emitted by `@profile("name") { ... }`. Same
// lazy-intern pattern as _inline_malloc_ref above. The resolved
// targets live in stbprofile.bsm.
static auto _zone_enter_p_cached;
static auto _zone_exit_p_cached;

// Phase 6.3 v2 — packed refs for the per-function save/drain
// helpers. Codegen reads these via the `_zone_save_*_p` globals
// to synthesise the prologue/epilogue calls without re-interning
// the names from the chip backends. Lazy-init the first time
// `_build_profile_zone` runs so unused programs pay nothing.
global _zone_save_enter_p;
global _zone_save_drain_p;

static _intern_name(name_str, name_len) {
    auto start;
    start = vbuf_pos;
    buf_copy(vbuf + vbuf_pos, name_str, name_len);
    vbuf_pos += name_len;
    return pack(start, name_len);
}

static _zone_enter_ref() {
    if (_zone_enter_p_cached != 0) { return _zone_enter_p_cached; }
    _zone_enter_p_cached = _intern_name("_prof_zone_enter", 16);
    return _zone_enter_p_cached;
}

static _zone_exit_ref() {
    if (_zone_exit_p_cached != 0) { return _zone_exit_p_cached; }
    _zone_exit_p_cached = _intern_name("_prof_zone_exit", 15);
    return _zone_exit_p_cached;
}

// ============================================================
// Token access helpers
// ============================================================

// Return the type code of the current token, or -1 if past end.
static peek_type() {
    if (tok_pos >= tok_cnt) { return -1; }
    return *(toks + tok_pos * 24);
}

// Return the type code of the token at offset from current position.
static peek_type_at(off) {
    if (tok_pos + off >= tok_cnt) { return -1; }
    return *(toks + (tok_pos + off) * 24);
}

// Return the vbuf start offset of the current token's value.
static peek_vstart() { return *(toks + tok_pos * 24 + 8); }

// Return the length of the current token's value.
static peek_vlen() { return *(toks + tok_pos * 24 + 16); }

// Return the current token's value as a packed (start, len) pair.
static cur_packed() { return pack(peek_vstart(), peek_vlen()); }

// Return the type code of the current token (alias for peek_type).
static cur_type() { return peek_type(); }

// Advance past the current token.
static void consume() { tok_pos++; }

// Check if the current token's value is a single character c.
static val_is_ch(c) {
    auto addr;
    if (tok_pos >= tok_cnt) { return 0; }
    addr = toks + tok_pos * 24;
    if (*(addr + 16) != 1) { return 0; }
    return peek(vbuf + *(addr + 8)) == c;
}

// Check if the current token's value matches string s of length slen.
static val_is(s, slen) {
    auto addr, vs, vl;
    if (tok_pos >= tok_cnt) { return 0; }
    addr = toks + tok_pos * 24;
    vs = *(addr + 8);
    vl = *(addr + 16);
    if (vl != slen) { return 0; }
    return buf_eq(vbuf + vs, s, slen);
}

// Check if the token at offset has a single-character value c.
static val_at_ch(off, c) {
    auto addr;
    if (tok_pos + off >= tok_cnt) { return 0; }
    addr = toks + (tok_pos + off) * 24;
    if (*(addr + 16) != 1) { return 0; }
    return peek(vbuf + *(addr + 8)) == c;
}

// Check if the token at offset is a TK_KW with the given keyword
// value. Lookahead-without-consume — used by composite-keyword
// dispatch like `global const` where the parser needs to peek the
// next token before deciding which sub-parser to call.
static _kw_at_offset(off, s, slen) {
    auto addr, vs, vl;
    if (tok_pos + off >= tok_cnt) { return 0; }
    if (peek_type_at(off) != TK_KW) { return 0; }
    addr = toks + (tok_pos + off) * 24;
    vl = *(addr + 16);
    if (vl != slen) { return 0; }
    vs = *(addr + 8);
    return buf_eq(vbuf + vs, s, slen);
}

// ============================================================
// ── Module tracking ───────────────────────────────────────────
// Each function and global records which module it was defined in.

global func_mods;     // Module index for each parsed function.
static auto glob_mods;     // Module index for each parsed global.
extrn struct_mods;   // Module index for each struct definition.
extrn enum_mods;     // Module index for each enum constant.
extrn extern_mods;   // Module index for each extern declaration.

// Return the module index that a given token belongs to.
// P4 (combined) of load/import distinction: use diag_mod_idx
// (mod_bnds-based) for nested-import correctness.
tok_mod(tidx) { return diag_mod_idx(tok_src_off[tidx]); }

// Parser: top-level structures
// ============================================================

// Register a global variable name and tag its storage class. The class
// describes the runtime semantics of the declaration:
//   GLOB_AUTO   — `auto x;` at file scope, legacy serialized
//   GLOB_GLOBAL — `global x;`, worker-shared mutable
//   GLOB_EXTRN  — `extrn x;`, write-once-after-init
// Cached globals loaded from .bo files round-trip the class via the
// extended .bo format (BO_VERSION 4+).
static void add_global(p, gclass) {
    globals = arr_push(globals, p);
    glob_cnt = arr_len(globals);
    glob_mods = arr_push(glob_mods, tok_mod(tok_pos));
    glob_class = arr_push(glob_class, gclass);
    // Reserve init-value slots so codegen can index in lockstep.
    // For non-CONST classes these stay at 0 (ignored). For
    // GLOB_*_CONST, parse_global_const overwrites the last entry
    // with the actual compile-time value.
    glob_init_val = arr_push(glob_init_val, 0);
    glob_init_is_float = arr_push(glob_init_is_float, 0);
    // Grow glob_pinned alongside — parser may set it via `: serial` hint.
    while (arr_len(glob_pinned) < glob_cnt) {
        glob_pinned = arr_push(glob_pinned, 0);
    }
}

// Resolve a global symbol's data-section initial value by packed
// name. Walks globals[] looking for a matching name (pointer-equal
// or packed_eq); when found, returns the compile-time init value
// IF the storage class is GLOB_GLOBAL_CONST or GLOB_STATIC_CONST.
// Returns 0 for any other class (auto/global/extrn fall back to
// zero-initialised slots, matching the legacy mo_pad / elf_pad
// behaviour for those classes).
//
// Centralises the lookup so every backend's data-section writer
// (a64 Mach-O, x64 ELF, C emitter) asks the same question and gets
// the same answer. Writers stay format-only — they never touch
// glob_class / glob_init_val / globals directly. Storage-class
// sidequest 2026-05-14: feature placement check (`feedback_feature_
// placement_canonical.md`) — same bytes flowing through 3 backends
// means semantic decision belongs in the spine.
glob_slot_init_value(name_p) {
    auto j, gp, gclass;
    j = 0;
    while (j < glob_cnt) {
        gp = arr_get(globals, j);
        if (gp == name_p) {
            gclass = arr_get(glob_class, j);
            if (gclass == GLOB_GLOBAL_CONST
                || gclass == GLOB_STATIC_CONST) {
                return arr_get(glob_init_val, j);
            }
            return 0;
        }
        if (packed_eq(gp, name_p)) {
            gclass = arr_get(glob_class, j);
            if (gclass == GLOB_GLOBAL_CONST
                || gclass == GLOB_STATIC_CONST) {
                return arr_get(glob_init_val, j);
            }
            return 0;
        }
        j++;
    }
    return 0;
}

// Flag set by try_type_annotation when it encounters `: serial`.
// Read by parse_global to mark the variable as promotion-pinned
// (glob_pinned[i] = 1). Prevents auto smart promotion from changing
// the storage class. Only meaningful at file scope; ignored in functions.
static auto _serial_hint;

// Parse an optional ": TypeName" annotation after a variable name.
// Recognizes primitive types and struct types. Supports compound annotations:
//   float         → TY_FLOAT    (64-bit double)
//   int           → TY_WORD     (64-bit integer)
//   word          → TY_WORD     (64-bit integer)
//   half          → TY_WORD_H   (32-bit integer)
//   half float    → TY_FLOAT_H  (32-bit float)
//   quarter       → TY_WORD_Q   (16-bit integer)
//   quarter float → TY_FLOAT_Q  (16-bit float)
//   byte          → TY_WORD_B   (8-bit integer)
// Sets _prim_hint to the packed type code, or 0 if no primitive match.
// Tracks func-type recursion depth across parse_fn_type calls. Reset to 0
// at the start of each top-level try_type_annotation. Pathological nesting
// beyond MAX_FN_DEPTH triggers E248 and a TY_UNK fallback for recovery.
static auto _fn_type_depth;
const MAX_FN_DEPTH = 16;

// Parse a type expression at the current token (no leading ':'). Result
// goes to _prim_hint for primitives, func-types, void, and structs. For
// struct types the var slot is also tagged via set_var_type when var_p
// is non-zero. Used by try_type_annotation (top-level) and parse_fn_type
// (recursive arg/return positions).
static void parse_type_expr(var_p) {
    auto type_p, idx, tl, ts;

    // func-type — first-class function pointer (V3 Session 1).
    if (val_is("func", 4)) {
        _prim_hint = parse_fn_type();
        return;
    }
    // void in type-expression position encodes as TY_UNK. The function
    // declaration parser already accepts `void f(...)`; this branch lets
    // `func() -> void` and any future void-typed expression-position uses
    // share the same encoding.
    if (val_is("void", 4)) {
        _prim_hint = TY_UNK;
        consume();
        return;
    }

    type_p = cur_packed();
    tl = unpack_l(type_p);
    ts = vbuf + unpack_s(type_p);

    // Check primitive type names before struct lookup.
    if (tl == 5) {
        if (buf_eq(ts, "float", 5)) {
            _prim_hint = TY_FLOAT;
            consume();
            return;
        }
    }
    if (tl == 3) {
        // `: int` was a parser synonym for `: word` inherited from the
        // pre-slice era. Removed in 0.23.x — the language has exactly one
        // canonical name for the 64-bit integer slot, and that name is
        // `word`. Programmers wanting an explicit-int annotation use it
        // (e.g. to suppress E232 by marking a float→int truncation as
        // intentional). The single in-tree user (mouse coord conversion in
        // `_stb_platform_macos.bsm`) was migrated alongside the removal.

        // Single-bit field hint: `: bit`.
        if (buf_eq(ts, "bit", 3)) {
            _prim_hint = TY_WORD_BIT;
            consume();
            return;
        }
        // `: ptr` — opaque pointer slot. Same physical width as a
        // word but carries TY_PTR so smart-dispatch builtins (put,
        // put_err) and call-site type checks treat the value as a
        // pointer (e.g. dispatching `put_err(path)` to `putstr_err`
        // when `path: ptr` is annotated). The annotation does not
        // imply ownership or what the pointer references — it is the
        // type-system equivalent of writing `void*` in C.
        if (buf_eq(ts, "ptr", 3)) {
            _prim_hint = TY_PTR;
            consume();
            return;
        }
    }
    if (tl == 4) {
        if (buf_eq(ts, "half", 4)) {
            consume();
            _prim_hint = TY_WORD_H;
            if (cur_type() == TK_ID) {
                _prim_hint = TY_FLOAT_H;
                consume();
            }
            return;
        }
        if (buf_eq(ts, "byte", 4)) {
            _prim_hint = TY_WORD_B;
            consume();
            return;
        }
        if (buf_eq(ts, "word", 4)) {
            _prim_hint = TY_WORD;
            consume();
            return;
        }
        // Multi-bit field hints: `: bit2` .. `: bit7`.
        if (buf_eq(ts, "bit2", 4)) { _prim_hint = TY_WORD_BIT2; consume(); return; }
        if (buf_eq(ts, "bit3", 4)) { _prim_hint = TY_WORD_BIT3; consume(); return; }
        if (buf_eq(ts, "bit4", 4)) { _prim_hint = TY_WORD_BIT4; consume(); return; }
        if (buf_eq(ts, "bit5", 4)) { _prim_hint = TY_WORD_BIT5; consume(); return; }
        if (buf_eq(ts, "bit6", 4)) { _prim_hint = TY_WORD_BIT6; consume(); return; }
        if (buf_eq(ts, "bit7", 4)) { _prim_hint = TY_WORD_BIT7; consume(); return; }
    }
    // `: double` — 128-bit SIMD (4 × float32). Phase B4. Always
    // resolves to TY_FLOAT_D; integer 128-bit SIMD is out of scope.
    if (tl == 6 && buf_eq(ts, "double", 6)) {
        consume();
        _prim_hint = TY_FLOAT_D;
        return;
    }
    if (tl == 7) {
        if (buf_eq(ts, "quarter", 7)) {
            consume();
            _prim_hint = TY_WORD_Q;
            if (cur_type() == TK_ID) {
                _prim_hint = TY_FLOAT_Q;
                consume();
            }
            return;
        }
    }

    // Unsigned word family — opt-in annotations that mark a slot as
    // carrying unsigned bit-pattern semantics. Storage size matches
    // the signed counterpart (TY_WORD / TY_WORD_H / TY_WORD_Q /
    // TY_WORD_B). The kind nibble (BASE_UWORD = 0x0E) routes /, %,
    // >> through UDIV / UMOD / LSR in codegen smart dispatch
    // instead of signed defaults SDIV / SMOD / ASR. No `: u`
    // shorthand — every annotation explicitly names its width
    // (`u_word` / `u_half` / `u_quarter` / `u_byte`) to keep intent
    // unambiguous at the declaration site.
    if (tl == 6 && buf_eq(ts, "u_word", 6)) { _prim_hint = TY_UWORD;   consume(); return; }
    if (tl == 6 && buf_eq(ts, "u_half", 6)) { _prim_hint = TY_UWORD_H; consume(); return; }
    if (tl == 6 && buf_eq(ts, "u_byte", 6)) { _prim_hint = TY_UWORD_B; consume(); return; }
    if (tl == 9 && buf_eq(ts, "u_quarter", 9)) {
        _prim_hint = TY_UWORD_Q;
        consume();
        return;
    }

    // Array type annotation — opt-in, element type inferred by usage.
    if (tl == 5 && buf_eq(ts, "array", 5)) { _prim_hint = TY_ARR; consume(); return; }

    // Struct type lookup.
    idx = struct_find(type_p);
    if (idx >= 0) {
        if (var_p != 0) { set_var_type(var_p, idx); }
        // Lossy encoding for struct types inside func-type recursion:
        // Session 1 has no checking, so collapsing to TY_STRUCT loses no
        // safety. Session 2 will extend the fn-type record to preserve
        // the specific struct id when typing checks come online.
        _prim_hint = TY_STRUCT;
    } else {
        diag_error(101);
        diag_str("unknown type '");
        diag_packed(type_p);
        diag_str("' -- define it with 'struct'");
        diag_newline();
        diag_loc(tok_pos);
        diag_show_line(tok_pos);
        diag_help("declare the type with 'struct <name> { ... };' before using it");
    }
    consume();
}

// Parse `Fn(arg_types) -> return_type`. Called with the `Fn` token as
// the current token. Returns a fn-type id from fn_type_intern; emits
// E247 (>8 args), E248 (>16 nesting), or E249 (malformed) on errors.
// On error the recursion still returns a TY_UNK fallback so the caller
// can keep parsing without cascading failures.
static parse_fn_type() {
    auto args_buf, arg_count, ret_type, i;

    _fn_type_depth++;
    if (_fn_type_depth > MAX_FN_DEPTH) {
        diag_error(248);
        diag_str("func-type nesting exceeds maximum depth (");
        diag_int(MAX_FN_DEPTH);
        diag_str(")");
        diag_newline();
        diag_loc(tok_pos);
        diag_show_line(tok_pos);
        diag_help("higher-order Fn types beyond this depth are almost always a typo; if genuinely needed, refactor via a named type alias");
        _fn_type_depth--;
        return TY_UNK;
    }

    consume();  // 'Fn'

    if (val_is_ch('(') == 0) {
        diag_error(249);
        diag_str("func-type expects '(' after 'func'");
        diag_newline();
        diag_loc(tok_pos);
        diag_show_line(tok_pos);
        diag_help("syntax: Fn(arg_types) -> return_type");
        _fn_type_depth--;
        return TY_UNK;
    }
    consume();

    args_buf = buf_word(8);
    buf_fill(args_buf, 0, 64);
    arg_count = 0;

    while (val_is_ch(')') == 0) {
        if (arg_count >= 8) {
            diag_error(247);
            diag_str("func-type cannot exceed 8 arguments");
            diag_newline();
            diag_loc(tok_pos);
            diag_show_line(tok_pos);
            diag_help("B++ V3 fn-types route args via the AAPCS64/SysV register banks (8 int / 8 float); stack-arg routing for typed fn-pointers is not yet implemented. Reduce to <=8 args, or pass extra data via a bundle struct: Fn(*Bundle) -> word.");
            while (val_is_ch(')') == 0 && tok_pos < tok_cnt) { consume(); }
            break;
        }
        parse_type_expr(0);
        args_buf[arg_count] = _prim_hint;
        arg_count++;
        if (val_is_ch(',')) { consume(); }
    }
    consume();  // ')'

    if (val_is("->", 2) == 0) {
        diag_error(249);
        diag_str("func-type expects '->' after argument list");
        diag_newline();
        diag_loc(tok_pos);
        diag_show_line(tok_pos);
        diag_help("syntax: Fn(arg_types) -> return_type");
        _fn_type_depth--;
        return TY_UNK;
    }
    consume();  // '->'

    parse_type_expr(0);
    ret_type = _prim_hint;

    _fn_type_depth--;
    return fn_type_intern(args_buf, arg_count, ret_type);
}

static void try_type_annotation(var_p) {
    auto tl, ts, type_p;
    _prim_hint = 0;
    _serial_hint = 0;
    if (val_is_ch(':') == 0) { return; }
    consume();

    // Storage class hint: `: serial` prevents auto smart promotion.
    // Only meaningful at file scope (parse_global reads _serial_hint).
    // Lives outside parse_type_expr because it is not a type expression
    // and must not appear inside func-type recursion.
    type_p = cur_packed();
    tl = unpack_l(type_p);
    ts = vbuf + unpack_s(type_p);
    if (tl == 6 && buf_eq(ts, "serial", 6)) {
        _serial_hint = 1;
        consume();
        return;
    }

    _fn_type_depth = 0;
    parse_type_expr(var_p);
}

// Parse a top-level "auto x, y, z;", "global x, y, z;", or "extrn x, y, z;"
// declaration. Supports per-variable type hints: auto x: float, y: byte;
// Float hints register the global as TY_FLOAT for correct codegen.
// gclass selects the storage class:
//   GLOB_AUTO   — `auto`   (legacy serialized, conservative main-thread-only)
//   GLOB_GLOBAL — `global` (worker-shared mutable, programmer manages stride)
//   GLOB_EXTRN  — `extrn`  (write-once-after-init, frozen after maestro_run)
// The class flows to add_global so the smart-dispatch pass and codegen
// can decide how to handle loops that touch the variable.
static void parse_global(gclass) {
    auto var_p, gi;
    consume();
    var_p = cur_packed();
    add_global(var_p, gclass);
    gi = glob_cnt - 1;
    consume();
    try_type_annotation(var_p);
    // Register any non-zero hint, not just float. The unsigned
    // family (`: u_word`) needs the global type to flow through
    // codegen so the smart-dispatch in T_BINOP picks UDIV / LSR.
    // Float remains the only auto-promoted type; other hints are
    // strict opt-in just like local annotations.
    if (_prim_hint != 0) { ty_set_global_type(var_p, _prim_hint); }
    if (_serial_hint) { arr_set(glob_pinned, gi, 1); }
    while (val_is_ch(';') == 0) {
        if (val_is_ch(',')) { consume(); }
        var_p = cur_packed();
        add_global(var_p, gclass);
        gi = glob_cnt - 1;
        consume();
        try_type_annotation(var_p);
        if (_prim_hint != 0) { ty_set_global_type(var_p, _prim_hint); }
        if (_serial_hint) { arr_set(glob_pinned, gi, 1); }
    }
    consume();
}

// Parse a bare global identifier followed by optional semicolon.
static void parse_global_simple() {
    // Shorthand "x;" at file scope. No keyword, no type annotation.
    // Treated as legacy/serialized — the explicit `global` or `extrn`
    // keywords are the only paths that opt into worker-aware behavior.
    add_global(cur_packed(), GLOB_AUTO);
    consume();
    if (val_is_ch(';')) { consume(); }
}

// Parse an import block: either a file import or an FFI library import.
static void parse_import() {
    auto lib_p, ret_p, name_p, args_arr, ext;
    auto tp, ts, tl, pi;
    consume();
    // Check if this is a file import (just a string followed by ;).
    if (peek_type() == TK_STR) {
        if (val_at_ch(1, ';')) {
            // File import: skip (handled by the import resolver).
            consume();
            consume();
            return;
        }
    }
    // Library import: import "lib" { ... }
    lib_p = pack(peek_vstart() + 1, peek_vlen() - 2);
    consume();
    consume();
    while (val_is_ch('}') == 0) {
        // Read the return type. Merge "type" + "*" into "type*".
        tp = cur_packed();
        consume();
        if (val_is_ch('*')) {
            ts = vbuf_pos;
            tl = unpack_l(tp);
            for (pi = 0; pi < tl; pi++) {
                poke(vbuf + vbuf_pos, peek(vbuf + unpack_s(tp) + pi));
                vbuf_pos++;
            }
            poke(vbuf + vbuf_pos, 42);
            vbuf_pos++;
            tp = pack(ts, tl + 1);
            consume();
        }
        ret_p = tp;
        name_p = cur_packed();
        consume();
        consume();
        list_begin();
        while (val_is_ch(')') == 0) {
            // Read the argument type. Merge "type" + "*" into "type*".
            tp = cur_packed();
            consume();
            if (val_is_ch('*')) {
                ts = vbuf_pos;
                tl = unpack_l(tp);
                for (pi = 0; pi < tl; pi++) {
                    poke(vbuf + vbuf_pos, peek(vbuf + unpack_s(tp) + pi));
                    vbuf_pos++;
                }
                poke(vbuf + vbuf_pos, 42);
                vbuf_pos++;
                tp = pack(ts, tl + 1);
                consume();
            }
            list_push(tp);
            if (val_is_ch(',')) { consume(); }
        }
        consume();
        consume();
        args_arr = list_end();
        ext = malloc(RECORD_SZ);
        *(ext + EX_TYPE) = 21;
        *(ext + EX_NAME) = name_p;
        *(ext + EX_LIB) = lib_p;
        *(ext + EX_RET) = ret_p;
        *(ext + EX_ARGS) = args_arr;
        *(ext + EX_ACNT) = last_list_cnt;
        externs = arr_push(externs, ext);
        ext_cnt = arr_len(externs);
        extern_mods = arr_push(extern_mods, tok_mod(tok_pos));
    }
    consume();
}

// Parse a struct definition: struct Name { field1, field2 }
static void parse_struct() {
    auto name_p, idx, hint, fp;
    consume();
    name_p = cur_packed();
    consume();

    // Excalibur Feature 3 — newtype declaration
    // (`struct WorldPos as Vec2;`). Detect the `as` keyword instead
    // of `{` and route to the layout-copy path. The new name lands as
    // its own entry in the struct registry — distinct identity for
    // the type checker — but borrows the base's byte layout so every
    // existing field-access site keeps working without ceremony.
    if (val_is("as", 2)) {
        auto _nt_idx, _nt_base_p, _nt_base_idx;
        consume();
        _nt_base_p = cur_packed();
        consume();
        _nt_base_idx = find_struct(_nt_base_p);
        if (_nt_base_idx < 0) {
            diag_error(101);
            diag_str("newtype base '");
            diag_packed(_nt_base_p);
            diag_str("' is not a defined struct");
            diag_newline();
            diag_loc(tok_pos);
            return;
        }
        _nt_idx = struct_register(name_p);
        _copy_struct_layout(_nt_idx, _nt_base_idx);
        if (val_is_ch(';')) { consume(); }
        return;
    }

    consume();
    // Dogfood migration (A.1): use the named struct_* API from
    // bpp_internal.bsm instead of calling add_struct_def directly.
    // Semantically identical today — struct_register delegates to
    // add_struct_def until Phase B.1 moves the body. This call
    // validates the new API shape before the full sweep.
    idx = struct_register(name_p);
    while (val_is_ch('}') == 0) {
        hint = 0;
        fp = cur_packed();
        consume();
        // Read optional type hint for packed field layout.
        // try_type_annotation handles the ':' token internally.
        try_type_annotation(fp);
        hint = _prim_hint;
        struct_add_field(idx, fp, hint);
        if (val_is_ch(',')) { consume(); }
    }
    consume();
}

// ============================================================
// Const: compile-time evaluated constants
// ============================================================

// Evaluate an AST node as a compile-time constant.
// Supports literals, enum/const references, arithmetic, unary ops.
// Returns the integer value. Calls sys_exit on non-const expressions.
static const_eval_node(node) {
    auto nd: Node, ntype, l, r, op, vs, vl, ch, p, val, i, ch2, fi;
    nd = node;
    ntype = nd.ntype;

    // Literal integer or hex — parse the value from the token buffer.
    if (ntype == T_LIT) {
        p = nd.a;
        vs = p % 0x100000000;
        vl = p / 0x100000000;
        val = 0;
        // Check if hex (starts with '0' 'x').
        if (vl > 2) {
            if (peek(vbuf + vs) == 48) {
                if (peek(vbuf + vs + 1) == 120) {
                    for (i = 2; i < vl; i++) {
                        ch = peek(vbuf + vs + i);
                        val *= 16;
                        if (ch >= 48) { if (ch <= 57) { val += ch - 48; } }
                        if (ch >= 65) { if (ch <= 70) { val += ch - 55; } }
                        if (ch >= 97) { if (ch <= 102) { val += ch - 87; } }
                    }
                    return val;
                }
            }
        }
        // Check if char literal (starts with single quote).
        if (peek(vbuf + vs) == 39) {
            return peek(vbuf + vs + 1);
        }
        // Decimal integer.
        for (i = 0; i < vl; i++) {
            ch = peek(vbuf + vs + i);
            val = val * 10 + ch - 48;
        }
        return val;
    }

    // Binary operation: evaluate both sides and compute.
    if (ntype == T_BINOP) {
        l = const_eval_node(nd.b);
        r = const_eval_node(nd.c);
        op = nd.a;
        vs = op % 0x100000000;
        vl = op / 0x100000000;
        ch = peek(vbuf + vs);
        if (ch == '+') { return l + r; }
        if (ch == '-') { return l - r; }
        if (ch == '*') { return l * r; }
        if (ch == '/') { return l / r; }
        if (ch == '%') { return l % r; }
        if (ch == '&') { return l & r; }
        if (ch == '|') { return l | r; }
        if (ch == '^') { return l ^ r; }
        // Shift and comparison operators (2-char).
        if (vl == 2) {
            ch2 = peek(vbuf + vs + 1);
            if (ch == '<') { if (ch2 == '<') { return shr(l * 1, 0 - r); } }
            if (ch == '>') { if (ch2 == '>') { return shr(l, r); } }
            if (ch == '<') { if (ch2 == '=') { if (l <= r) { return 1; } return 0; } }
            if (ch == '>') { if (ch2 == '=') { if (l >= r) { return 1; } return 0; } }
            if (ch == '=') { if (ch2 == '=') { if (l == r) { return 1; } return 0; } }
            if (ch == '!') { if (ch2 == '=') { if (l != r) { return 1; } return 0; } }
        }
        if (ch == '<') { if (l < r) { return 1; } return 0; }
        if (ch == '>') { if (l > r) { return 1; } return 0; }
        return 0;
    }

    // Unary operation: negation or bitwise not.
    if (ntype == T_UNARY) {
        l = const_eval_node(nd.b);
        op = nd.a;
        vs = op % 0x100000000;
        ch = peek(vbuf + vs);
        if (ch == '-') { return 0 - l; }
        if (ch == '~') { return ~l; }
        return l;
    }

    // Variable reference: look up in enum table (const function params are bound there).
    if (ntype == T_VAR) {
        fi = enum_find(nd.a);
        if (fi >= 0) { return enum_value(fi); }
    }

    // Const function call: delegate to separate function for clean stack frame.
    if (ntype == T_CALL) {
        fi = const_eval_call(node);
        if (fi != 0x7EADBEEF) { return fi; }
    }

    // Anything else is not a constant expression.
    diag_fatal(120);
    diag_str("expression is not a compile-time constant");
    diag_newline();
    diag_loc(tok_pos);
    diag_show_line(tok_pos);
    sys_exit(1);
    return 0;
}

// Evaluate a const function call. Returns the result value,
// or 0x7EADBEEF as sentinel if the call target is not a const function.
static const_eval_call(node) {
    auto nd: Node, fn_name, fi, cparams, cpcnt, cbody, cbcnt;
    auto args_arr, acnt, save, j, arg_val, result;
    nd = node;
    fn_name = nd.a;
    fi = const_find_fn(fn_name);
    if (fi < 0) { return 0x7EADBEEF; }
    cparams = arr_get(cf_params, fi);
    cpcnt = arr_get(cf_pcnts, fi);
    cbody = arr_get(cf_bodies, fi);
    cbcnt = arr_get(cf_bcnts, fi);
    args_arr = nd.b;
    acnt = nd.c;
    save = arr_len(ev_names);
    for (j = 0; j < cpcnt; j++) {
        arg_val = const_eval_node(args_arr[j]);
        enum_register(cparams[j], arg_val);
    }
    result = const_eval_body(cbody, cbcnt);
    arr_truncate(ev_names, save);
    arr_truncate(ev_values, save);
    arr_truncate(ev_lit_src, save);
    arr_truncate(enum_mods, save);
    return result;
}

// Look up a const function by packed name. Returns index or -1.
static const_find_fn(name_p) {
    auto i, b;
    for (i = 0; i < cf_count; i++) {
        b = arr_get(cf_names, i);
        if (packed_eq(b, name_p)) { return i; }
    }
    return -1;
}

// Evaluate the body of a const function. Walks statements looking for
// T_RET (returns its value) and T_IF (evaluates condition, walks branch).
static const_eval_body(body, bcnt) {
    auto i, stmt: Node, t, cond;
    for (i = 0; i < bcnt; i++) {
        stmt = body[i];
        t = stmt.ntype;
        if (t == T_RET) {
            return const_eval_node(stmt.a);
        }
        if (t == T_IF) {
            cond = const_eval_node(stmt.a);
            if (cond != 0) {
                return const_eval_body(stmt.b, stmt.c);
            } else if (stmt.e > 0) {
                return const_eval_body(stmt.d, stmt.e);
            }
        }
    }
    return 0;
}

// Parse a const declaration or const function definition.
// const NAME = expr;           → compile-time constant value
// const NAME(args) { body }    → compile-time evaluated function
// Parse `global const NAME = expr;` or `static const NAME = expr;`.
// Both create a real slot with a global symbol (GLOB_GLOBAL_CONST,
// visible cross-module) or a local symbol (GLOB_STATIC_CONST,
// module-private). The initial value is captured at parse time —
// the RHS must be a compile-time-evaluable expression. Float
// literals are detected via SHAPE_DECIMAL and stored as raw IEEE
// bits, mirroring the parse_const float fast path so codegen
// can emit `.double` directives without re-deriving the bits.
static void parse_global_const(gclass) {
    auto name_p, expr_node, val, _const_lit_node: Node, is_float;
    name_p = cur_packed();
    consume();   // consume name

    // Optional type annotation (e.g. `: half`, `: float`). The hint
    // is registered on the global itself via the same plumbing the
    // mutable-slot path uses, so codegen + smart dispatch see the
    // same declared type regardless of mutability.
    try_type_annotation(name_p);

    consume();   // consume '='
    expr_node = parse_expr();

    // Float-literal fast path. When the RHS is a single SHAPE_DECIMAL
    // literal, capture the raw IEEE bits (already packed in the T_LIT
    // node's `a` field) so the emit step can write `.double` for the
    // exact bit pattern. Without this, const_eval_node truncates to
    // integer 0 and the slot loses every fractional bit.
    _const_lit_node = expr_node;
    is_float = 0;
    if (_const_lit_node != 0) {
        if (_const_lit_node.ntype == T_LIT) {
            if (lit_shape(_const_lit_node) == SHAPE_DECIMAL) {
                val = _const_lit_node.a;
                is_float = 1;
            }
        }
    }
    if (is_float == 0) {
        // Integer or general-const path. const_eval_node walks
        // T_BINOP/T_UNARY/T_LIT and returns the resolved word.
        // Function calls and references to mutable globals will
        // produce 0 here (silently — the wider diagnostic upgrade
        // for "const RHS must be compile-time" is out of scope for
        // this sidequest's first pass).
        val = const_eval_node(expr_node);
    }

    add_global(name_p, gclass);
    // glob_cnt is now 1 past the newly-pushed entry; index it back.
    arr_set_at(glob_init_val, glob_cnt - 1, val);
    if (is_float != 0) {
        arr_set_at(glob_init_is_float, glob_cnt - 1, 1);
    }

    if (val_is_ch(';')) { consume(); }
}

static void parse_const() {
    auto name_p, expr_node, val;
    auto params, pcnt, body, bcnt;
    consume();
    name_p = cur_packed();
    consume();

    // Const function: const NAME(args) { body }
    if (val_is_ch('(')) {
        consume();
        list_begin();
        while (val_is_ch(')') == 0) {
            list_push(cur_packed());
            consume();
            if (val_is_ch(',')) { consume(); }
        }
        consume();
        params = list_end();
        pcnt = last_list_cnt;
        consume();
        list_begin();
        while (val_is_ch('}') == 0) {
            list_push(parse_statement());
        }
        consume();
        body = list_end();
        bcnt = last_list_cnt;
        cf_names = arr_push(cf_names, name_p);
        cf_params = arr_push(cf_params, params);
        cf_pcnts = arr_push(cf_pcnts, pcnt);
        cf_bodies = arr_push(cf_bodies, body);
        cf_bcnts = arr_push(cf_bcnts, bcnt);
        cf_count++;
        return;
    }

    // Const value: const NAME = expr;
    consume();
    expr_node = parse_expr();

    // Float-const fast path (Excalibur Arc Feature 1 gap B). When the
    // RHS is a single SHAPE_DECIMAL literal, capture the source bytes
    // and register the const as float. The use-site emit path rebuilds
    // a real T_LIT with SHAPE_DECIMAL so codegen treats the constant
    // identically to a hand-written `0.6` at the call site. Without
    // this, `const_eval_node` truncates "0.6" to integer 0 and every
    // downstream comparison with the const sees the wrong value.
    auto _const_lit_node: Node;
    _const_lit_node = expr_node;
    if (_const_lit_node != 0) {
        if (_const_lit_node.ntype == T_LIT) {
            if (lit_shape(_const_lit_node) == SHAPE_DECIMAL) {
                add_enum_val_float(name_p, _const_lit_node.a);
                if (val_is_ch(';')) { consume(); }
                return;
            }
        }
    }

    val = const_eval_node(expr_node);
    enum_register(name_p, val);
    if (val_is_ch(';')) { consume(); }
}

// Parse an enum definition: enum Name { A, B, C = 10, D }
// Resolves all member names to integer constants at compile time.
// Members become inline literals — no globals, no runtime cost.
static void parse_enum() {
    auto name_p, val, member_p;
    consume();
    // Enum name is optional (for documentation, not used by compiler).
    name_p = cur_packed();
    consume();
    consume();
    val = 0;
    while (val_is_ch('}') == 0) {
        member_p = cur_packed();
        consume();
        // Explicit value assignment: MEMBER = N
        if (val_is_ch('=')) {
            consume();
            val = parse_lit_int();
            consume();
        }
        // Dogfood migration (A.2): use the named enum_* API from
        // bpp_internal.bsm instead of calling add_enum_val directly.
        // Semantically identical today — enum_register delegates to
        // add_enum_val until Phase B.2 moves the body.
        enum_register(member_p, val);
        val++;
        if (val_is_ch(',')) { consume(); }
    }
    consume();
}

// Forward declarations for mutually recursive parse functions.
static parse_statement() { return 0; }
static parse_expr() { return 0; }
static parse_primary() { return 0; }
static parse_unary() { return 0; }

// Parse a function definition: name(params) { body }
// Collects primitive type hints for parameters and stores them in offset 48.
static void parse_function(is_stub, is_static, is_void) {
    auto name_p, params_arr, param_cnt, body_arr, body_cnt, fn_rec, var_p, _fs;
    auto ph_arr, ph_cnt, has_hints, my_mod, name_tok;
    my_mod = tok_mod(tok_pos);
    // Snapshot the global vt_names cursor BEFORE this function's
    // body adds anything. The bug debugger uses this to scope its
    // struct-id lookup so a `auto p: Player` in one function does
    // not leak its sid into a different function's plain `auto p`.
    fn_vt_starts = arr_push(fn_vt_starts, arr_len(vt_names));
    // Capture the token position of the function NAME now. FN_SRC_TOK
    // used to be set from tok_pos at the very end of this routine,
    // which meant it pointed AFTER the closing `}` — every diagnostic
    // and debug map derived from it showed the wrong line. Saving the
    // name token here and writing it to FN_SRC_TOK later yields the
    // actual signature line to W013, diag_loc, and bpp_bug.
    name_tok = tok_pos;
    name_p = cur_packed();
    consume();
    consume();
    // Collect parameter hints while parsing the parameter list.
    ph_arr = malloc(64);
    ph_cnt = 0;
    has_hints = 0;
    list_begin();
    while (val_is_ch(')') == 0) {
        var_p = cur_packed();
        list_push(var_p);
        consume();
        try_type_annotation(var_p);
        ph_arr[ph_cnt] = _prim_hint;
        if (_prim_hint > 0) { has_hints = 1; }
        ph_cnt++;
        if (val_is_ch(',')) { consume(); }
    }
    consume();
    params_arr = list_end();
    param_cnt = last_list_cnt;

    // Return type annotation: `fn() -> type {`. Read between `)` and
    // the `@phase` sigil or the body opening `{`. Uses `->` (not `:`)
    // by design: `:` is reserved for "X has type T" annotations on
    // variables / params / fields; `->` is reserved for "function
    // returns T". Different glyphs for different concepts. Same
    // convention as Rust / Python / Swift / C++11+ trailing-return.
    // Captured _prim_hint goes into fn_ret_hint after the function
    // record is pushed below. The C emitter and type checker both
    // honor the hint — without it, return-typed functions fall back
    // to TY_WORD which silently truncates floats.
    auto ret_hint;
    ret_hint = 0;
    if (val_is("->", 2)) {
        consume();              // '->'
        parse_type_expr(0);
        ret_hint = _prim_hint;
    }

    // @safe — the only user-facing phase annotation as of the
    // 2026-05-11 collapse. Bounded time + no malloc + no IO + no GPU
    // + worker-safe. Enforcement is W026: a `@safe` function whose
    // call graph reaches HEAP / IO / GPU / SOLO violates its
    // contract. Audio callbacks and worker-thread entry points are
    // the killer use case.
    //
    // The legacy phase keywords (`@base`, `@solo`, `@time`, `@io`,
    // `@gpu`, `@heap`, `@panic`, `@realtime`) are NO LONGER
    // ACCEPTED. Any program that still uses them fails to parse at
    // the `{` mismatch. The migration sweep stripped 700+ redundant
    // annotations; refusing the deprecated keywords now prevents
    // accidental re-introduction. Rationale lives in
    // `docs/manual/tonify_checklist.md` Rule 4 + Rule 28.
    auto phase_hint;
    phase_hint = 0;
    if (val_is_ch('@')) {
        consume();
        auto _pp, _ps, _pl, _is_dep;
        _pp = cur_packed();
        _pl = unpack_l(_pp);
        _ps = vbuf + unpack_s(_pp);
        if (_pl == 4) {
            if (buf_eq(_ps, "safe", 4)) { phase_hint = 8; consume(); }
        }
        // Detect a deprecated phase keyword and emit a clear E260 so
        // a programmer with muscle memory who just wrote `@base` (or
        // `@time` / `@io` / `@gpu` / `@solo` / `@heap` / `@panic` /
        // `@realtime`) gets a focused error pointing at Rule 4 instead
        // of a generic E104 at the `{` mismatch.
        if (phase_hint == 0) {
            _is_dep = 0;
            if (_pl == 2) {
                if (buf_eq(_ps, "io",   2)) { _is_dep = 1; }
            }
            if (_pl == 3) {
                if (buf_eq(_ps, "gpu",  3)) { _is_dep = 1; }
            }
            if (_pl == 4) {
                if (buf_eq(_ps, "base", 4)) { _is_dep = 1; }
                if (buf_eq(_ps, "solo", 4)) { _is_dep = 1; }
                if (buf_eq(_ps, "time", 4)) { _is_dep = 1; }
                if (buf_eq(_ps, "heap", 4)) { _is_dep = 1; }
            }
            if (_pl == 5) {
                if (buf_eq(_ps, "panic", 5)) { _is_dep = 1; }
            }
            if (_pl == 8) {
                if (buf_eq(_ps, "realtime", 8)) { _is_dep = 1; }
            }
            if (_is_dep != 0) {
                diag_error(260);
                diag_str("'@");
                diag_packed(_pp);
                diag_str("' annotation removed in 2026-05-11 phase collapse");
                diag_newline();
                diag_loc(tok_pos);
                diag_show_line(tok_pos);
                diag_str("  = help: use `@safe` if this function needs compiler-verified safety");
                diag_newline();
                diag_str("          (audio callback, worker entry point, bounded path)");
                diag_newline();
                diag_str("  = help: otherwise omit the annotation — purity is inferred internally");
                diag_newline();
                diag_str("  = see:  docs/manual/tonify_checklist.md Rule 4 for the post-collapse model");
                diag_newline();
                consume();
            }
        }
        // Note: `@profile("name")` is parsed elsewhere (statement-
        // level scoped instrumentation) and never reaches this site.
    }
    consume();
    _block_depth = 0;
    list_begin();
    while (val_is_ch('}') == 0) {
        _for_init = 0;
        _fs = parse_statement();
        if (_for_init != 0) { list_push(_for_init); }
        list_push(_fs);
    }
    consume();
    body_arr = list_end();
    body_cnt = last_list_cnt;
    fn_rec = malloc(RECORD_SZ);
    *(fn_rec + FN_TYPE) = 22;
    *(fn_rec + FN_NAME) = name_p;
    *(fn_rec + FN_PARS) = params_arr;
    *(fn_rec + FN_PCNT) = param_cnt;
    *(fn_rec + FN_BODY) = body_arr;
    *(fn_rec + FN_BCNT) = body_cnt;
    // Store parameter hint array in the hints field.
    if (has_hints) { *(fn_rec + FN_HINTS) = ph_arr; }
    else { *(fn_rec + FN_HINTS) = 0; free(ph_arr); }
    // Mark as stub if declared with the `stub` keyword. Stubs are
    // intentional placeholders that can be silently overridden by a
    // real definition in any module without triggering W015.
    *(fn_rec + FN_STUB) = is_stub;
    // Store the defining token position. Dispatch's W013 reads this
    // back through FN_SRC_TOK to show the originating source line, and
    // bpp_bug writes it into the .bug source map so the debugger can
    // resolve `--break name:line`. `name_tok` was saved at function
    // entry (before name was consumed) so the value points at the
    // signature, not at whatever tok_pos has advanced to by the end.
    *(fn_rec + FN_SRC_TOK) = name_tok;
    // Dedup: check if a function with this name already exists in funcs[].
    // Four cases produce duplicates, each handled differently:
    //
    // 1. Same-module replacement (forward-declaration pattern):
    //    B++ requires forward declarations for mutually recursive functions.
    //    A stub at the top of a module is replaced by the real definition
    //    later in the same module. Always silent.
    //
    // 2. Entry file overrides a module function (callback pattern):
    //    stbgame.bsm defines game_init/game_update/game_draw as stubs.
    //    The user's .bpp provides the real implementations. Module 0
    //    (the entry file) is always processed last, so its definitions
    //    win. Always silent.
    //
    // 3. FFI driver overrides the platform layer (driver pattern):
    //    drv_sdl.bsm / drv_raylib.bsm / etc. ship their own
    //    `_stb_*` implementations that replace the auto-injected
    //    `_stb_platform_<os>.bsm` ones. The convention is the
    //    `drv_` filename prefix. The replace-and-win logic below
    //    silently swaps the platform definition for the driver's,
    //    and the driver wins because it is parsed after the
    //    auto-inject. Always silent.
    //
    // 4. Cross-module duplicate (suspicious):
    //    Two different non-entry modules both define the same function
    //    with real bodies, and neither is a driver. This is likely a
    //    bug. Emit E221.
    auto _dup_idx, _dup_found;
    _dup_found = 0;
    for (_dup_idx = 0; _dup_idx < func_cnt; _dup_idx++) {
        if (packed_eq(*(funcs[_dup_idx] + FN_NAME), name_p)) {
            auto _existing_body;
            _existing_body = *(funcs[_dup_idx] + FN_BODY);
            if (_existing_body != 0) {
                auto _existing_stub;
                _existing_stub = *(funcs[_dup_idx] + FN_STUB);
                // Stub override is always silent — the stub was placed
                // explicitly as a placeholder for this exact replacement.
                if (_existing_stub == 0) {
                    if (arr_get(func_mods, _dup_idx) != my_mod) {
                        if (my_mod != 0) {
                            // Case 3 vs 4: silence the diagnostic
                            // when the new (replacing) module is an
                            // FFI driver — drv_sdl.bsm, drv_raylib.bsm,
                            // any future drv_*. The replace-and-win
                            // logic below already swaps the platform
                            // layer's definition for the driver's;
                            // emitting E221 in that case is just noise.
                            if (_is_driver_module(my_mod) == 0) {
                                // Case 4: cross-module duplicate, both
                                // with real bodies, neither is a stub
                                // or a driver. Suspicious.
                                diag_error(221);
                                diag_str("duplicate definition of '");
                                diag_packed(name_p);
                                diag_str("' across modules");
                                diag_newline();
                                diag_loc(tok_pos);
                            }
                        }
                    }
                }
            }
            // Replace the existing entry with the new one.
            arr_set(funcs, _dup_idx, fn_rec);
            arr_set(func_mods, _dup_idx, my_mod);
            arr_set(fn_static, _dup_idx, is_static);
            arr_set(fn_void, _dup_idx, is_void);
            arr_set(fn_phase_hint, _dup_idx, phase_hint);
            arr_set(fn_ret_hint, _dup_idx, ret_hint);
            _dup_found = 1;
            _dup_idx = func_cnt;
        }
    }
    if (_dup_found == 0) {
        funcs = arr_push(funcs, fn_rec);
        func_cnt = arr_len(funcs);
        func_mods = arr_push(func_mods, my_mod);
        fn_static = arr_push(fn_static, is_static);
        fn_void = arr_push(fn_void, is_void);
        fn_phase_hint = arr_push(fn_phase_hint, phase_hint);
        fn_ret_hint   = arr_push(fn_ret_hint, ret_hint);
    }

    // Fix 2: enforce main() only in the entry file (module 0).
    // Module files (.bsm) must not define main — they are libraries.
    // Uses _parser_is_entry flag set by the orchestrator (bpp.bpp) instead
    // of tok_mod() which has unreliable module attribution for module 0.
    if (_parser_is_entry == 0) {
        auto _ns;
        _ns = vbuf + unpack_s(name_p);
        if (unpack_l(name_p) == 4) {
            if (peek(_ns) == 'm') {
                if (peek(_ns+1) == 'a') {
                    if (peek(_ns+2) == 'i') {
                        if (peek(_ns+3) == 'n') {
                            diag_error(105);
                            diag_str("main() not allowed in module files — only the entry .bpp can define main()");
                            diag_newline();
                            diag_loc(tok_pos);
                            diag_show_line(tok_pos);
                        }
                    }
                }
            }
        }
    }
}

// Top-level parse loop: dispatch imports, globals, structs, and functions.
void parse_program() {
    while (tok_pos < tok_cnt) {
        if (peek_type() == TK_IMP) {
            parse_import();
        } else if (peek_type() == TK_KW) {
            if (val_is("auto", 4)) {
                parse_global(GLOB_AUTO);
            } else if (val_is("global", 6)) {
                // `global const X = expr;` is the storage-class
                // sidequest path (slot in .data with global symbol).
                // Plain `global X;` is the legacy worker-shared
                // mutable. Disambiguate via lookahead — parse_global
                // assumes the leading keyword is still pending so we
                // only consume both when const branch is taken.
                if (_kw_at_offset(1, "const", 5)) {
                    consume();   // global
                    consume();   // const
                    parse_global_const(GLOB_GLOBAL_CONST);
                } else {
                    parse_global(GLOB_GLOBAL);
                }
            } else if (val_is("extrn", 5)) {
                parse_global(GLOB_EXTRN);
            } else if (val_is("struct", 6)) {
                parse_struct();
            } else if (val_is("enum", 4)) {
                parse_enum();
            } else if (val_is("const", 5)) {
                parse_const();
            } else if (val_is("stub", 4)) {
                consume();
                parse_function(1, 0, 0);
            } else if (val_is("void", 4)) {
                consume();
                if (peek_type() == TK_ID) {
                    if (val_at_ch(1, '(')) { parse_function(0, 0, 1); }
                }
            } else if (val_is("static", 6)) {
                consume();
                if (peek_type() == TK_KW) {
                    if (val_is("auto", 4)) { parse_global(GLOB_AUTO); }
                    else if (val_is("global", 6)) { parse_global(GLOB_GLOBAL); }
                    else if (val_is("extrn", 5)) { parse_global(GLOB_EXTRN); }
                    else if (val_is("void", 4)) {
                        consume();
                        if (peek_type() == TK_ID) {
                            if (val_at_ch(1, '(')) { parse_function(0, 1, 1); }
                        }
                    }
                    else if (val_is("const", 5)) {
                        // `static const X = expr;` — module-private
                        // .data slot. Replaces the prior E230 hard
                        // reject. Storage-class sidequest 2026-05-14.
                        consume();
                        parse_global_const(GLOB_STATIC_CONST);
                    }
                    else { consume(); }
                } else if (peek_type() == TK_ID) {
                    if (val_at_ch(1, '(')) { parse_function(0, 1, 0); }
                    else { parse_global_simple(); }
                }
            } else {
                consume();
            }
        } else if (peek_type() == TK_ID) {
            if (val_at_ch(1, '(')) {
                parse_function(0, 0, 0);
            } else {
                parse_global_simple();
            }
        } else {
            consume();
        }
    }
    diag_check_errors();
}

// Parse a single module's tokens.
void parse_module(tok_end) {
    while (tok_pos < tok_end) {
        if (peek_type() == TK_IMP) {
            parse_import();
        } else if (peek_type() == TK_KW) {
            if (val_is("auto", 4)) {
                parse_global(GLOB_AUTO);
            } else if (val_is("global", 6)) {
                if (_kw_at_offset(1, "const", 5)) {
                    consume();   // global
                    consume();   // const
                    parse_global_const(GLOB_GLOBAL_CONST);
                } else {
                    parse_global(GLOB_GLOBAL);
                }
            } else if (val_is("extrn", 5)) {
                parse_global(GLOB_EXTRN);
            } else if (val_is("struct", 6)) {
                parse_struct();
            } else if (val_is("enum", 4)) {
                parse_enum();
            } else if (val_is("const", 5)) {
                parse_const();
            } else if (val_is("stub", 4)) {
                consume();
                parse_function(1, 0, 0);
            } else if (val_is("void", 4)) {
                consume();
                if (peek_type() == TK_ID) {
                    if (val_at_ch(1, '(')) { parse_function(0, 0, 1); }
                }
            } else if (val_is("static", 6)) {
                consume();
                if (peek_type() == TK_KW) {
                    if (val_is("auto", 4)) { parse_global(GLOB_AUTO); }
                    else if (val_is("global", 6)) { parse_global(GLOB_GLOBAL); }
                    else if (val_is("extrn", 5)) { parse_global(GLOB_EXTRN); }
                    else if (val_is("void", 4)) {
                        consume();
                        if (peek_type() == TK_ID) {
                            if (val_at_ch(1, '(')) { parse_function(0, 1, 1); }
                        }
                    }
                    else if (val_is("const", 5)) {
                        consume();
                        parse_global_const(GLOB_STATIC_CONST);
                    }
                    else { consume(); }
                } else if (peek_type() == TK_ID) {
                    if (val_at_ch(1, '(')) { parse_function(0, 1, 0); }
                    else { parse_global_simple(); }
                }
            } else {
                consume();
            }
        } else if (peek_type() == TK_ID) {
            if (val_at_ch(1, '(')) {
                parse_function(0, 0, 0);
            } else {
                parse_global_simple();
            }
        } else {
            consume();
        }
    }
}

// ============================================================
// Parser: statements
// ============================================================

// Parse a brace-enclosed or single-statement body.
// Stash for 'for' loop desugar: parse_for sets this to the init statement,
// and parse_body inserts it before the while node.
static auto _for_init;

static parse_body() {
    auto stmt;
    _block_depth++;
    list_begin();
    if (val_is_ch('{')) {
        consume();
        while (val_is_ch('}') == 0) {
            _for_init = 0;
            stmt = parse_statement();
            if (_for_init != 0) { list_push(_for_init); }
            list_push(stmt);
        }
        consume();
    } else {
        _for_init = 0;
        stmt = parse_statement();
        if (_for_init != 0) { list_push(_for_init); }
        list_push(stmt);
    }
    _block_depth--;
    return list_end();
}

// Parse an if/else statement.
static parse_if() {
    auto cond, body_arr, body_cnt, else_arr, else_cnt, node: Node;
    consume();
    consume();
    cond = parse_expr();
    consume();
    body_arr = parse_body();
    body_cnt = last_list_cnt;
    else_arr = 0;
    else_cnt = 0;
    if (peek_type() == TK_KW && val_is("else", 4)) {
        consume();
        // "else if" sugar: parse the inner if directly as a single-statement else body.
        if (peek_type() == TK_KW && val_is("if", 2)) {
            else_arr = malloc(8);
            *(else_arr) = parse_if();
            else_cnt = 1;
        } else {
            else_arr = parse_body();
            else_cnt = last_list_cnt;
        }
    }
    // Dead code elimination: when the condition is a compile-time integer
    // literal, collapse the `if` to the taken branch wrapped in T_BLOCK.
    // Backends never see the dead branch. A missing else on `if (0)` just
    // produces T_NOP.
    if (is_int_lit_node(cond)) {
        auto lit_n: Node, lit_val;
        lit_n = cond;
        lit_val = parse_int_lit_value(lit_n.a);
        if (lit_val == 0) {
            if (else_cnt == 0) { return make_node(T_NOP); }
            node = make_node(T_BLOCK);
            node.b = else_arr;
            node.c = else_cnt;
            return node;
        }
        node = make_node(T_BLOCK);
        node.b = body_arr;
        node.c = body_cnt;
        return node;
    }
    node = make_node(T_IF);
    node.a = cond;
    node.b = body_arr;
    node.c = body_cnt;
    node.d = else_arr;
    node.e = else_cnt;
    return node;
}

// Parse a while loop, with optional dispatch hint (@seq, @par, @gpu).
// node.e (offset 40) is left at 0 — only for-loops use it for the step.
static parse_while(hint_p) {
    auto cond, body_arr, body_cnt, node: Node;
    consume();
    consume();
    cond = parse_expr();
    consume();
    _cur_loop_depth++;
    body_arr = parse_body();
    body_cnt = last_list_cnt;
    _cur_loop_depth--;
    // Dead code elimination: `while (0) { body }` never runs — drop it.
    // `while (1)` is a legitimate infinite loop (game loops, REPLs) so
    // that case stays as-is and the body emits normally.
    if (is_int_lit_node(cond)) {
        auto lit_n: Node, lit_val;
        lit_n = cond;
        lit_val = parse_int_lit_value(lit_n.a);
        if (lit_val == 0) { return make_node(T_NOP); }
    }
    node = make_node(T_WHILE);
    node.a = cond;
    node.b = body_arr;
    node.c = body_cnt;
    node.d = hint_p;
    node.e = 0;
    return node;
}

// Parse a for loop: for (init; cond; step) { body }
// Desugars to: init; while (cond) { body }, with the step expression
// stored in node.e (offset 40). Codegen places a continue label between
// body and step, then emits step before branching back to top — that
// way `continue` runs the step before re-testing the condition, just
// like C semantics.
// The init statement is stashed in _for_init for the caller to insert.
static parse_for() {
    auto init_node, cond, step, body_arr, body_cnt, node: Node;
    consume();
    consume();
    // Parse init: either assignment or expression.
    init_node = parse_statement();
    // Parse condition.
    cond = parse_expr();
    if (val_is_ch(';')) { consume(); }
    // Parse step expression.
    step = parse_expr();
    consume();
    // Parse body — leave it untouched. The step lives in node.e.
    _cur_loop_depth++;
    body_arr = parse_body();
    body_cnt = last_list_cnt;
    _cur_loop_depth--;
    // Stash init for parse_body to insert before the while.
    _for_init = init_node;
    // Build while node. node.e (offset 40) carries the step expression
    // so that codegen can emit it between the body and the back-branch,
    // making `continue` skip to the step before re-testing the condition.
    node = make_node(T_WHILE);
    node.a = cond;
    node.b = body_arr;
    node.c = body_cnt;
    node.d = 0;
    node.e = step;
    return node;
}

// Parse a return statement. Bare `return;` is allowed in void functions
// and produces T_RET with implicit value 0, same as implicit return at
// the end of a function body.
static parse_return() {
    auto node: Node;
    consume();
    node = make_node(T_RET);
    if (val_is_ch(';')) {
        node.a = make_int_lit(0);
        consume();
    } else {
        node.a = parse_expr();
        if (val_is_ch(';')) { consume(); }
    }
    return node;
}

// Parse a switch statement. B++ switch has no fallthrough — each arm exits
// at its closing brace. Comma-separated values share an arm body.
// W021 is emitted if no `else` arm is present (exhaustiveness hint).
//
// Layout: T_SWITCH node with:
//   n.a = condition expression
//   n.b = array of arm entries (pairs: [values_arr, body_arr] interleaved)
//   n.c = number of arms
//   n.d = else body array (0 if no else)
//   n.e = else body count (0 if no else)
static parse_switch() {
    auto node: Node, cond, arm_values, arm_bodies, arm_count;
    auto vals, vcnt, body, bcnt, has_else, else_body, else_cnt;
    consume();   // eat 'switch'
    // Form 1: switch (expr) { VALUE { } } — value dispatch
    // Form 2: switch { COND { } }         — condition dispatch
    if (val_is_ch('(')) {
        consume();   // eat '('
        cond = parse_expr();
        consume();   // eat ')'
    } else {
        cond = 0;    // no expression = condition dispatch
    }
    consume();   // eat '{'

    arm_values = buf_word(256);
    arm_bodies = buf_word(256);
    arm_count = 0;
    has_else = 0;
    else_body = 0;
    else_cnt = 0;

    while (val_is_ch('}') == 0) {
        // Check for 'else' arm (default).
        if (val_is("else", 4)) {
            consume();
            else_body = parse_body();
            else_cnt = last_list_cnt;
            has_else = 1;
        } else {
            // Parse comma-separated values for this arm.
            list_begin();
            list_push(parse_expr());
            while (val_is_ch(',')) {
                consume();
                list_push(parse_expr());
            }
            vals = list_end();
            vcnt = last_list_cnt;

            // Parse the arm body.
            body = parse_body();
            bcnt = last_list_cnt;

            arm_values[arm_count * 2] = vals;
            arm_values[arm_count * 2 + 1] = vcnt;
            arm_bodies[arm_count * 2] = body;
            arm_bodies[arm_count * 2 + 1] = bcnt;
            arm_count++;
        }
    }
    consume();   // eat '}'

    // W021: exhaustiveness hint — warn if no else arm.
    if (has_else == 0) {
        diag_warn(21);
        diag_str("switch may not be exhaustive — add 'else { }' to handle remaining cases");
        diag_newline();
        diag_loc(tok_pos);
    }

    node = make_node(T_SWITCH);
    node.a = cond;
    node.b = arm_values;
    node.c = arm_count;
    node.d = else_body;
    node.e = else_cnt;
    // Store arm bodies in src_tok (reusing the word-sized slot since
    // switch nodes don't need source location tracking — the switch
    // keyword itself carries it via the parent statement).
    node.src_tok = arm_bodies;
    return node;
}

// Phase 6.3 scoped zones — lower `@profile("name") { body }` to a
// synthesized T_BLOCK shaped as:
//
//   T_BLOCK
//     T_CALL _prof_zone_enter("name")
//     ... user statements ...
//     T_CALL _prof_zone_exit("name")
//
// `zone_name_p` is a packed reference to the user's string literal
// in vbuf, including the surrounding quotes — codegen reads the
// quote convention from `cg_emit_lit` to classify it as a string.
// Two T_LIT nodes share the same packed ref (codegen registers the
// string in cg_str_tbl per node, and identical content typically
// dedupes in the linker, but we don't depend on that — the runtime
// treats the pointer value as the zone identity, so identical
// strings landing at different addresses just create twin zones,
// which is acceptable for v1).
//
// Caveats / known gaps for v1:
//   - Early `return` inside a zone leaves it open. The next frame's
//     first `_prof_zone_enter` notices the open zone and warns; total
//     time gets attributed to whatever zone was active at exit.
//   - Nested zones work (each enter pushes onto a runtime stack)
//     but only flat aggregation is shown in the HUD — the parent
//     zone's total includes the children's time.
//   - Panic / abort similarly leaks; not handled in v1.
static _build_profile_zone(zone_name_p) {
    auto body_arr, body_cnt, wrap_arr, wrap_cnt, i;
    // Phase 6.3 v2 — intern the save/drain helper names once, the
    // first time any function in this compilation unit uses
    // @profile. Codegen reads these globals to synthesise the
    // prologue / epilogue calls when emitting profiled functions.
    if (_zone_save_enter_p == 0) {
        _zone_save_enter_p = _intern_name("_prof_save_enter", 16);
        _zone_save_drain_p = _intern_name("_prof_save_drain", 16);
    }
    body_arr = parse_body();
    body_cnt = last_list_cnt;

    auto name_lit1: Node, name_lit2: Node;
    name_lit1 = make_node(T_LIT);
    name_lit1.a = zone_name_p;
    name_lit2 = make_node(T_LIT);
    name_lit2.a = zone_name_p;

    auto enter_args, enter_call: Node;
    enter_args = malloc(8);
    *(enter_args) = name_lit1;
    enter_call = make_node(T_CALL);
    enter_call.a = _zone_enter_ref();
    enter_call.b = enter_args;
    enter_call.c = 1;

    auto exit_args, exit_call: Node;
    exit_args = malloc(8);
    *(exit_args) = name_lit2;
    exit_call = make_node(T_CALL);
    exit_call.a = _zone_exit_ref();
    exit_call.b = exit_args;
    exit_call.c = 1;

    wrap_cnt = body_cnt + 2;
    wrap_arr = malloc(wrap_cnt * 8);
    *(wrap_arr) = enter_call;
    for (i = 0; i < body_cnt; i++) {
        *(wrap_arr + (i + 1) * 8) = *(body_arr + i * 8);
    }
    *(wrap_arr + (body_cnt + 1) * 8) = exit_call;

    auto wrap: Node;
    wrap = make_node(T_BLOCK);
    wrap.b = wrap_arr;
    wrap.c = wrap_cnt;
    return wrap;
}

// Parse a single statement: declaration, if, while, return, or expression.
static parse_statement() {
    auto node: Node, var_p, hint_p, decl_hint, dh_arr, dh_cnt, dh_has, kw_hint;
    // `@`-prefixed annotations come in two flavours at statement level:
    //   1. Phase 6.3 scoped zones — `@profile("name") { ... }`. Captured
    //      and lowered to a synthesized T_BLOCK with prologue / epilogue
    //      calls into the stbprofile runtime.
    //   2. Dispatch hints — `@seq` / `@par` / `@gpu` immediately
    //      before a `while`. Captured into hint_p and consumed; the
    //      while-parser picks the hint up.
    hint_p = 0;
    if (peek_type() == TK_PUNCT && val_is_ch('@')) {
        consume();
        auto annot_p, annot_l, annot_s;
        annot_p = cur_packed();
        annot_l = unpack_l(annot_p);
        annot_s = vbuf + unpack_s(annot_p);
        if (annot_l == 7 && buf_eq(annot_s, "profile", 7)) {
            consume();              // "profile"
            consume();              // "("
            auto zone_name_p;
            zone_name_p = cur_packed();
            consume();              // string literal
            consume();              // ")"
            return _build_profile_zone(zone_name_p);
        }
        hint_p = annot_p;
        consume();
    }
    if (peek_type() == TK_KW) {
        if (val_is("auto", 4)) {
            consume();
            decl_hint = 0;
            dh_arr = malloc(64);
            dh_cnt = 0;
            dh_has = 0;
            list_begin();
            var_p = cur_packed();
            list_push(var_p);
            consume();
            try_type_annotation(var_p);
            dh_arr[dh_cnt] = _prim_hint;
            if (_prim_hint > 0) { decl_hint = _prim_hint; dh_has = 1; }
            dh_cnt++;
            while (val_is_ch(';') == 0) {
                if (val_is_ch(',')) { consume(); }
                var_p = cur_packed();
                list_push(var_p);
                consume();
                try_type_annotation(var_p);
                dh_arr[dh_cnt] = _prim_hint;
                if (_prim_hint > 0) { decl_hint = _prim_hint; dh_has = 1; }
                dh_cnt++;
            }
            consume();
            node = make_node(T_DECL);
            node.a = list_end();
            node.b = last_list_cnt;
            node.c = decl_hint;
            if (dh_has) { node.e = dh_arr; }
            else { node.e = 0; free(dh_arr); }
            return node;
        }
        // Type-keyword declarations: byte hp; half w; quarter c;
        // These are shorthand for auto with a built-in type hint.
        if (val_is("byte", 4) || val_is("half", 4) || val_is("quarter", 7)) {
            if (val_is("byte", 4)) { kw_hint = TY_WORD_B; }
            if (val_is("half", 4)) { kw_hint = TY_WORD_H; }
            if (val_is("quarter", 7)) { kw_hint = TY_WORD_Q; }
            consume();
            list_begin();
            var_p = cur_packed();
            list_push(var_p);
            consume();
            while (val_is_ch(';') == 0) {
                if (val_is_ch(',')) { consume(); }
                var_p = cur_packed();
                list_push(var_p);
                consume();
            }
            consume();
            node = make_node(T_DECL);
            node.a = list_end();
            node.b = last_list_cnt;
            node.c = kw_hint;
            return node;
        }
        // Stack-allocated struct: var v: Type;
        // Produces a T_DECL node with d=1 (stack struct flag).
        if (val_is("var", 3)) {
            consume();
            var_p = cur_packed();
            consume();
            try_type_annotation(var_p);
            set_var_stack(var_p);
            consume();
            node = make_node(T_DECL);
            list_begin();
            list_push(var_p);
            node.a = list_end();
            node.b = 1;
            node.d = 1;
            return node;
        }
        if (val_is("if", 2)) { return parse_if(); }
        if (val_is("for", 3)) { return parse_for(); }
        if (val_is("while", 5)) { return parse_while(hint_p); }
        if (val_is("switch", 6)) { return parse_switch(); }
        if (val_is("return", 6)) { return parse_return(); }
        if (val_is("break", 5)) {
            consume();
            if (val_is_ch(';')) { consume(); }
            return make_node(T_BREAK);
        }
        if (val_is("continue", 8)) {
            consume();
            if (val_is_ch(';')) { consume(); }
            return make_node(T_CONTINUE);
        }
    }
    node = parse_expr();
    if (val_is_ch(';')) { consume(); }
    return node;
}

// ============================================================
// Parser: expressions with precedence climbing
// ============================================================

// Return the precedence of the current operator token, or -1 if not an operator.
static get_op_prec() {
    auto vs, vl, c0, c1;
    if (peek_type() != TK_OP) { return -1; }
    vs = peek_vstart();
    vl = peek_vlen();
    if (vl == 1) {
        c0 = peek(vbuf + vs);
        if (c0 == 124) { return 3; }
        if (c0 == 94) { return 4; }
        if (c0 == 38) { return 5; }
        if (c0 == 60) { return 7; }
        if (c0 == 62) { return 7; }
        if (c0 == 43) { return 9; }
        if (c0 == 45) { return 9; }
        if (c0 == 42) { return 10; }
        if (c0 == 47) { return 10; }
        if (c0 == 37) { return 10; }
        return -1;
    }
    if (vl == 2) {
        c0 = peek(vbuf + vs);
        c1 = peek(vbuf + vs + 1);
        if (c0 == 124) { if (c1 == 124) { return 1; } }
        if (c0 == 38) { if (c1 == 38) { return 2; } }
        if (c0 == 61) { if (c1 == 61) { return 6; } }
        if (c0 == 33) { if (c1 == 61) { return 6; } }
        if (c0 == 60) { if (c1 == 61) { return 7; } }
        if (c0 == 62) { if (c1 == 61) { return 7; } }
        if (c0 == 60) { if (c1 == 60) { return 8; } }
        if (c0 == 62) { if (c1 == 62) { return 8; } }
    }
    return -1;
}

// Wrap an expression with a ternary tail when `?` follows it. Right-associative
// so `a ? b : c ? d : e` parses as `a ? b : (c ? d : e)`. Called by parse_expr
// after parse_binops so that `?:` sits below all binary operators in precedence.
static maybe_ternary(cond) {
    auto then_e, else_e, node: Node;
    if (val_is_ch('?') == 0) { return cond; }
    consume();
    then_e = parse_expr();
    if (val_is_ch(':') == 0) {
        diag_fatal(106);
        diag_str("expected ':' to separate ternary branches");
        diag_newline();
        diag_loc(tok_pos);
        diag_show_line(tok_pos);
        diag_help("ternary syntax is `cond ? then_value : else_value`");
        sys_exit(1);
    }
    consume();
    else_e = parse_expr();
    node = make_node(T_TERNARY);
    node.a = cond;
    node.b = then_e;
    node.c = else_e;
    return node;
}

// Parse binary operators using precedence climbing (Pratt-style).
// Performs two canonical rewrites before constructing the node:
//   1. Constant folding: `lit op lit` → single literal with the result.
//   2. Short-circuit lowering: `a && b` and `a || b` become T_TERNARY
//      so every backend honours short-circuit semantics identically.
// Backends therefore never see `&&` / `||` operators and never need to
// fold integer constants themselves — both responsibilities live here.
static parse_binops(left, min_prec) {
    auto prec, op_p, right, node: Node;
    auto op_s, op_l, c0, c1;
    auto lv, rv, folded, fold_ok;
    while (get_op_prec() >= min_prec) {
        prec = get_op_prec();
        op_p = cur_packed();
        consume();
        right = parse_unary();
        while (get_op_prec() > prec) {
            right = parse_binops(right, get_op_prec());
        }
        op_s = unpack_s(op_p);
        op_l = unpack_l(op_p);
        c0 = peek(vbuf + op_s);
        c1 = 0;
        if (op_l > 1) { c1 = peek(vbuf + op_s + 1); }

        // Constant folding when both operands are integer literals.
        fold_ok = 0;
        folded = 0;
        if (is_int_lit_node(left) && is_int_lit_node(right)) {
            auto left_n: Node, right_n: Node;
            left_n = left;
            right_n = right;
            lv = parse_int_lit_value(left_n.a);
            rv = parse_int_lit_value(right_n.a);
            fold_ok = 1;
            if (op_l == 1) {
                switch (c0) {
                    '+' { folded = lv + rv; }
                    '-' { folded = lv - rv; }
                    '*' { folded = lv * rv; }
                    '/' { if (rv == 0) { fold_ok = 0; } else { folded = lv / rv; } }
                    '%' { if (rv == 0) { fold_ok = 0; } else { folded = lv % rv; } }
                    '&' { folded = lv & rv; }
                    '|' { folded = lv | rv; }
                    '^' { folded = lv ^ rv; }
                    else { fold_ok = 0; }
                }
            } else if (op_l == 2 && c0 == '<' && c1 == '<') { folded = lv << rv; }
            else if (op_l == 2 && c0 == '>' && c1 == '>') { folded = lv >> rv; }
            else { fold_ok = 0; }
        }

        if (fold_ok) {
            left = make_int_lit(folded);
        } else if (op_l == 2 && c0 == c1 && (c0 == '&' || c0 == '|')) {
            // Short-circuit lowering: `a && b` → cond=a, then=b, else=0
            //                         `a || b` → cond=a, then=1, else=b
            node = make_node(T_TERNARY);
            node.a = left;
            if (c0 == '&') {
                node.b = right;
                node.c = make_int_lit(0);
            } else {
                node.b = make_int_lit(1);
                node.c = right;
            }
            left = node;
        } else {
            // Phase D.1/D.2 (2026-04-22): strength reduction + identity
            // peephole. Runs only when exactly ONE operand is a literal
            // (both-literal is handled by the constant-folding block
            // above). Keeps the parser free of T_BINOP nodes that a
            // shift or single-operand reference would express better.
            auto right_is_lit, left_is_lit, lit_val, peep_ok, peep_node;
            auto pn_wr: Node;   // typed handle for field writes
            right_is_lit = is_int_lit_node(right);
            left_is_lit  = is_int_lit_node(left);
            peep_ok = 0;
            peep_node = 0;

            if (right_is_lit && left_is_lit == 0) {
                auto rn: Node;
                rn = right;
                lit_val = parse_int_lit_value(rn.a);
                if (op_l == 1) {
                    // Identity peephole — right side literal.
                    if (c0 == '+' && lit_val == 0) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '-' && lit_val == 0) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '*' && lit_val == 1) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '*' && lit_val == 0) { peep_node = make_int_lit(0); peep_ok = 1; }
                    else if (c0 == '/' && lit_val == 1) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '|' && lit_val == 0) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '^' && lit_val == 0) { peep_node = left; peep_ok = 1; }
                    else if (c0 == '&' && lit_val == 0) { peep_node = make_int_lit(0); peep_ok = 1; }
                    else if (c0 == '&' && lit_val == -1) { peep_node = left; peep_ok = 1; }
                    // Strength reduction — right side power-of-2 literal.
                    // `x * 2^k` → `x << k`. Unsigned semantics — for /
                    // we don't reduce because signed arithmetic shift
                    // vs integer divide differ on negatives (B++ ints
                    // are signed, so preserve the explicit divide).
                    else if (c0 == '*' && lit_val > 0 && (lit_val & (lit_val - 1)) == 0) {
                        auto k, shl_start;
                        k = 0;
                        while (lit_val > 1) { lit_val /= 2; k++; }
                        // Build packed "<<" operator on vbuf.
                        shl_start = vbuf_pos;
                        poke(vbuf + vbuf_pos, '<');
                        poke(vbuf + vbuf_pos + 1, '<');
                        vbuf_pos += 2;
                        peep_node = make_node(T_BINOP);
                        pn_wr = peep_node;
                        pn_wr.a = pack(shl_start, 2);
                        pn_wr.b = left;
                        pn_wr.c = make_int_lit(k);
                        peep_ok = 1;
                    }
                    // `x % 2^k` → `x & (2^k - 1)`. Only power-of-two
                    // positive divisors; same signed caveat as above.
                    else if (c0 == '%' && lit_val > 0 && (lit_val & (lit_val - 1)) == 0) {
                        auto and_start;
                        and_start = vbuf_pos;
                        poke(vbuf + vbuf_pos, '&');
                        vbuf_pos++;
                        peep_node = make_node(T_BINOP);
                        pn_wr = peep_node;
                        pn_wr.a = pack(and_start, 1);
                        pn_wr.b = left;
                        pn_wr.c = make_int_lit(lit_val - 1);
                        peep_ok = 1;
                    }
                } else if (op_l == 2 && c0 == '<' && c1 == '<' && lit_val == 0) {
                    peep_node = left; peep_ok = 1;
                } else if (op_l == 2 && c0 == '>' && c1 == '>' && lit_val == 0) {
                    peep_node = left; peep_ok = 1;
                }
            } else if (left_is_lit && right_is_lit == 0) {
                auto ln: Node;
                ln = left;
                lit_val = parse_int_lit_value(ln.a);
                if (op_l == 1) {
                    // Identity peephole — left side literal, commutative ops only.
                    if (c0 == '+' && lit_val == 0) { peep_node = right; peep_ok = 1; }
                    else if (c0 == '*' && lit_val == 1) { peep_node = right; peep_ok = 1; }
                    else if (c0 == '*' && lit_val == 0) { peep_node = make_int_lit(0); peep_ok = 1; }
                    else if (c0 == '|' && lit_val == 0) { peep_node = right; peep_ok = 1; }
                    else if (c0 == '^' && lit_val == 0) { peep_node = right; peep_ok = 1; }
                    else if (c0 == '&' && lit_val == 0) { peep_node = make_int_lit(0); peep_ok = 1; }
                    else if (c0 == '&' && lit_val == -1) { peep_node = right; peep_ok = 1; }
                }
                // Note: `2 * x` is NOT strength-reduced here — ops that
                // involve evaluating `x` only once would be safe, but
                // stb code overwhelmingly writes `x * 2` so the mirror
                // form is rare enough to skip (keeps the pass narrow).
            }

            if (peep_ok) {
                left = peep_node;
            } else {
                node = make_node(T_BINOP);
                node.a = op_p;
                node.b = left;
                node.c = right;
                left = node;
            }
        }
    }
    return left;
}

// Parse a unary expression: dereference (*), negation (-), or primary.
static parse_unary() {
    auto node: Node, op_p;
    if (peek_type() == TK_OP) {
        if (val_is_ch('*')) {
            consume();
            node = make_node(T_MEMLD);
            node.a = parse_primary();
            return node;
        }
        if (val_is_ch('&')) {
            consume();
            node = make_node(T_ADDR);
            node.a = parse_primary();
            return node;
        }
        if (val_is_ch('-')) {
            op_p = cur_packed();
            consume();
            node = make_node(T_UNARY);
            node.a = op_p;
            node.b = parse_unary();
            return node;
        }
        if (val_is_ch('~')) {
            op_p = cur_packed();
            consume();
            node = make_node(T_UNARY);
            node.a = op_p;
            node.b = parse_unary();
            return node;
        }
    }
    return parse_primary();
}

// Resolve chained .field access on a variable node.
// Returns a mem_load node with computed offset.
// For packed structs, stores the field type hint in n.b so the codegen
// can emit the correct sized load (LDRB for byte, LDRH for quarter, etc.).
static resolve_dot(base_node, name_p) {
    auto vtype, field_p, offset, ptr_node: Node, plus_op, off_node, fi, fhint, bn: Node;
    vtype = get_var_type(name_p);
    while (val_is_ch('.')) {
        if (vtype < 0) { return base_node; }
        consume();
        field_p = cur_packed();
        consume();
        offset = get_field_offset(vtype, field_p);
        if (offset < 0) {
            diag_fatal(102);
            diag_str("struct has no field '");
            diag_packed(field_p);
            diag_str("'");
            diag_newline();
            diag_loc(tok_pos);
            diag_show_line(tok_pos);
            diag_help("check the struct definition for available field names");
            sys_exit(1);
        }
        // Get the field's type hint for packed struct support.
        fi = get_field_index(vtype, field_p);
        fhint = 0;
        if (fi >= 0) { fhint = get_field_hint(vtype, fi); }
        // Bit-packed fields carry their bit-within-byte offset in bits 8-10
        // of the hint word. The codegen decodes it only when the slice is
        // SL_BIT..SL_BIT7; byte+ paths see the hint exactly as before.
        auto fsl, fbo;
        fsl = ty_slice(fhint);
        if (fsl >= SL_BIT && fsl <= SL_BIT7) {
            fbo = get_field_bit_off(vtype, field_p);
            fhint += fbo * 256;
        }
        // Build: mem_load(ptr: binop(base + offset), hint: fhint)
        plus_op = make_plus_op();
        off_node = make_int_lit(offset);
        ptr_node = make_node(T_BINOP);
        ptr_node.a = plus_op;
        ptr_node.b = base_node;
        ptr_node.c = off_node;
        bn = make_node(T_MEMLD);
        bn.a = ptr_node;
        bn.b = fhint;
        base_node = bn;
        // TODO: update vtype for nested struct fields.
    }
    return base_node;
}

// Parse a full expression: dereference-store, assignment, or binary ops.
static parse_expr() {
    auto left: Node, deref, node: Node;
    // Dereference store: *(deref) = val
    if (peek_type() == TK_OP) {
        if (val_is_ch('*')) {
            consume();
            deref = parse_primary();
            if (val_is_ch('=')) {
                consume();
                node = make_node(T_MEMST);
                node.a = deref;
                node.b = parse_expr();
                return node;
            }
            left = make_node(T_MEMLD);
            left.a = deref;
            return maybe_ternary(parse_binops(left, 0));
        }
        // Unary minus at expression start.
        if (val_is_ch('-')) {
            left = parse_unary();
            return maybe_ternary(parse_binops(left, 0));
        }
        // Bitwise NOT at expression start.
        if (val_is_ch('~')) {
            left = parse_unary();
            return maybe_ternary(parse_binops(left, 0));
        }
        // Address-of at expression start.
        if (val_is_ch('&')) {
            left = parse_unary();
            return maybe_ternary(parse_binops(left, 0));
        }
        // Prefix increment / decrement: ++x → x++, --x → x--.
        if (val_is("++", 2)) { consume(); return _make_inc_assign(parse_primary(), '+'); }
        if (val_is("--", 2)) { consume(); return _make_inc_assign(parse_primary(), '-'); }
    }
    left = parse_primary();
    // Postfix increment / decrement: x++ / x--.
    if (val_is("++", 2)) { consume(); return _make_inc_assign(left, '+'); }
    if (val_is("--", 2)) { consume(); return _make_inc_assign(left, '-'); }
    // Compound assignment: x += e, x -= e, x *= e, x /= e, x %= e.
    if (val_is("+=", 2)) { consume(); return _make_compound_assign('+', left, parse_expr()); }
    if (val_is("-=", 2)) { consume(); return _make_compound_assign('-', left, parse_expr()); }
    if (val_is("*=", 2)) { consume(); return _make_compound_assign('*', left, parse_expr()); }
    if (val_is("/=", 2)) { consume(); return _make_compound_assign('/', left, parse_expr()); }
    if (val_is("%=", 2)) { consume(); return _make_compound_assign('%', left, parse_expr()); }
    // Assignment: var = expr or var.field = expr
    if (val_is_ch('=')) {
        consume();
        // If left is a mem_load (from dot access), convert to mem_store.
        // Copy the field hint from the load node for packed struct support.
        if (left.ntype == T_MEMLD) {
            node = make_node(T_MEMST);
            node.a = left.a;
            node.b = parse_expr();
            node.c = left.b;
            return node;
        }
        node = make_node(T_ASSIGN);
        node.a = left;
        node.b = parse_expr();
        return node;
    }
    return maybe_ternary(parse_binops(left, 0));
}

// Parse a primary expression: literal, variable, call, sizeof, or parenthesized.
static parse_primary() {
    auto t, node: Node, name_p, args_arr, type_p, sidx, ev_idx;
    auto idx_node, mul_node: Node, add_node: Node, op_mul, op_add;
    t = peek_type();

    // sizeof(TypeName) — resolve struct size at parse time.
    if (t == TK_KW) {
        if (val_is("sizeof", 6)) {
            consume();
            consume();
            type_p = cur_packed();
            consume();
            consume();
            sidx = struct_find(type_p);
            if (sidx >= 0) {
                return make_int_lit(struct_size(sidx));
            }
            diag_fatal(103);
            diag_str("sizeof applied to unknown type '");
            diag_packed(type_p);
            diag_str("'");
            diag_newline();
            diag_loc(tok_pos);
            diag_show_line(tok_pos);
            diag_help("sizeof requires a struct type defined with 'struct <name> { ... };'");
            sys_exit(1);
        }
    }

    if (t == TK_NUM | t == TK_HEX | t == TK_STR | t == TK_FLOAT) {
        node = make_node(T_LIT);
        node.a = cur_packed();
        // Excalibur Arc Feature 1 (Session 1.A) — annotate every
        // numeric literal with its lex-time shape. TK_FLOAT carries
        // a decimal point; TK_NUM and TK_HEX are integer literals.
        // TK_STR has no numeric shape, so node.b stays 0 ("not set"
        // / non-numeric). Session 1.B reads this annotation to
        // resolve the literal's concrete type from the slot
        // context instead of the lex-time default.
        if (t == TK_FLOAT) {
            node.b = SHAPE_DECIMAL;
        } else if (t == TK_NUM | t == TK_HEX) {
            node.b = SHAPE_INT;
        }
        consume();
        return node;
    }
    if (t == TK_ID) {
        name_p = cur_packed();
        consume();
        if (val_is_ch(40)) {
            consume();
            list_begin();
            while (val_is_ch(')') == 0) {
                list_push(parse_expr());
                if (val_is_ch(',')) { consume(); }
            }
            consume();
            args_arr = list_end();
            node = make_node(T_CALL);
            node.a = name_p;
            node.b = args_arr;
            node.c = last_list_cnt;
            node.d = _cur_loop_depth;   // S4 P0a — loop-depth stamp

            // Phase D.4 inline trivials (2026-04-22): rewrite known
            // zero-overhead wrappers at parse time so hot paths stop
            // paying the bl/ret overhead on semantic aliases. Gated
            // by an explicit whitelist of functions whose body is a
            // single return of a simple expression — starts narrow
            // (buf_byte, buf_word in bpp_buf) and expands only after
            // profile evidence. Keyword collisions (half/base/byte/
            // word as reserved B++ keywords) can't sneak in because
            // the substituted AST is built from bytes we control.
            if (last_list_cnt == 1 && unpack_l(name_p) == 8 &&
                buf_eq(vbuf + unpack_s(name_p), "buf_byte", 8)) {
                // buf_byte(n) → malloc(n). Pure rename.
                node.a = _inline_malloc_ref();
            } else if (last_list_cnt == 1 && unpack_l(name_p) == 8 &&
                       buf_eq(vbuf + unpack_s(name_p), "buf_word", 8)) {
                // buf_word(n) → malloc(n << 3). Wraps the arg in a
                // shift-left-3 and swaps the call target. The shift
                // carries the same semantics as `* 8` but matches
                // what Tier D.1 strength reduction would produce
                // anyway — keeps the AST canonical.
                auto shl_node: Node, shl_start, old_arg;
                old_arg = *(args_arr);
                shl_start = vbuf_pos;
                poke(vbuf + vbuf_pos, '<');
                poke(vbuf + vbuf_pos + 1, '<');
                vbuf_pos += 2;
                shl_node = make_node(T_BINOP);
                shl_node.a = pack(shl_start, 2);
                shl_node.b = old_arg;
                shl_node.c = make_int_lit(3);
                *(args_arr) = shl_node;
                node.a = _inline_malloc_ref();
            }
            return node;
        }
        // Enum/const: inline as integer literal if found. Float-shaped
        // consts (Excalibur Arc Feature 1 gap B) carry a non-zero
        // `ev_lit_src` slot pointing at the original "0.6" / "1e-9"
        // source bytes — rebuild a SHAPE_DECIMAL T_LIT so codegen
        // emits the float through its existing literal path instead
        // of calling `make_int_lit(0)` which silently dropped the
        // fractional bits.
        ev_idx = find_enum_idx(name_p);
        if (ev_idx >= 0) {
            auto _ev_float_src;
            _ev_float_src = arr_get(ev_lit_src, ev_idx);
            if (_ev_float_src != 0) {
                node = make_node(T_LIT);
                node.a = _ev_float_src;
                node.b = SHAPE_DECIMAL;
                return node;
            }
            return make_int_lit(arr_get(ev_values, ev_idx));
        }
        node = make_node(T_VAR);
        node.a = name_p;
        // Handle .field access if this variable has a struct type.
        if (val_is_ch('.')) {
            node = resolve_dot(node, name_p);
        }
        // Handle array indexing: buf[i] desugars to *(buf + i * 8).
        if (val_is_ch('[')) {
            consume();
            idx_node = parse_expr();
            consume();
            // E244: array indices are integer offsets — a float literal here
            // (e.g. arr[3.14]) almost always means the programmer typed `.`
            // by accident or pasted a float-shaped literal where they meant
            // an int. Catch it before the desugaring multiplies the literal
            // into a binop where the type ambiguity disappears.
            if (is_float_lit_node(idx_node)) {
                diag_error(244);
                diag_str("array index is a float literal — array indices must be integers");
                diag_newline();
                diag_help("drop the decimal point: write `arr[3]` instead of `arr[3.0]`");
                diag_newline();
            }
            // Create packed operator strings by writing to vbuf.
            poke(vbuf + vbuf_pos, 42); op_mul = pack(vbuf_pos, 1); vbuf_pos++;
            poke(vbuf + vbuf_pos, 43); op_add = pack(vbuf_pos, 1); vbuf_pos++;
            // Build: *(node + idx_node * 8)
            mul_node = make_node(T_BINOP);
            mul_node.a = op_mul;
            mul_node.b = idx_node;
            mul_node.c = make_int_lit(8);
            add_node = make_node(T_BINOP);
            add_node.a = op_add;
            add_node.b = node;
            add_node.c = mul_node;
            node = make_node(T_MEMLD);
            node.a = add_node;
        }
        return node;
    }
    if (val_is_ch(40)) {
        consume();
        node = parse_expr();
        consume();
        return node;
    }
    // E104: unexpected token — nothing matched in parse_primary.
    diag_fatal(104);
    if (cur_type() == TK_KW) {
        diag_str("keyword '");
        diag_packed(cur_packed());
        diag_str("' cannot be used as an expression");
    } else {
        diag_str("unexpected token '");
        diag_packed(cur_packed());
        diag_str("' in expression");
    }
    diag_newline();
    diag_loc(tok_pos);
    diag_show_line(tok_pos);
    if (cur_type() == TK_KW) {
        diag_help("keywords like 'auto', 'if', 'while' are statements, not values");
    }
    consume();
    sys_exit(1);
    return make_node(T_NOP);
}
