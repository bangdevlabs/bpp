# Compiler binary (install via install.sh, not tracked in git)
#/bpp

# Build artifacts
build/
*.o
*.out
a.out

# Module cache contents (auto-generated, directory is tracked)
.bpp_cache/*.bo
.bpp_cache/hashes

# Legacy bootstrap (not needed, compiler is self-hosting)
#_legacy_bootstrap/

# macOS
.DS_Store
*.dylib

# Editors and tools
*~
\#*\#
.#*
.claude/

# Node (legobox-server, etc.)
node_modules/

# Temporary
/tmp/
*.tmp
hello.bpp
bpp2
bpp3

# Test binaries (compiled test outputs)
tests/out_test_*

# Game binaries (compiled from games/**/*.bpp)
#games/snake/snake
#games/pathfind/path
#games/platformer/plat_asset
#games/platformer/plat_noasset

# Bang 9 build output. Source is committed; only the binary stays local.
bang9/build/

# Modulab user-state prefs file. Modulab writes to <exe_dir>/modulab_prefs.json
# every open/close — pure per-user state (window position, last preset, recent
# files), regenerates on first run. NOT a project asset (those live under
# <project>/assets/ and ARE tracked). Sidequest in docs/todo.md to migrate
# writes into ~/.config/bpp/. Pattern matches the file in any directory the
# binary happens to run from.
**/modulab_prefs.json
