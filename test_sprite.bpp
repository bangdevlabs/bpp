// test_sprite.bpp — Sprite UV normalization test.
// Top half red, bottom half blue. Both halves must be clearly visible.

import "stbgame.bsm";
import "stbrender.bsm";
import "stbcolor.bsm";

main() {
    auto spr, pal, tex, row, col;

    game_init(320, 240, "sprite UV test", 60);
    render_init();
    init_color();

    // Build 16x16 sprite: index 1 on top 8 rows, index 2 on bottom 8 rows.
    spr = malloc(256);
    for (row = 0; row < 16; row = row + 1) {
        for (col = 0; col < 16; col = col + 1) {
            if (row < 8) {
                poke(spr + row * 16 + col, 1);
            } else {
                poke(spr + row * 16 + col, 2);
            }
        }
    }

    // Palette: [0]=transparent, [1]=red, [2]=blue.
    pal = malloc(256 * 4);
    write_u32(pal, 0, rgba(0,   0,   0,   0));
    write_u32(pal, 4, rgba(255, 0,   0,   255));
    write_u32(pal, 8, rgba(0,   0,   255, 255));

    tex = render_create_sprite16(spr, pal);
    free(spr);
    free(pal);

    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }

        render_begin();
        render_clear(BLACK);

        // Sprite at scale 4 (64x64): top must be red, bottom must be blue.
        render_sprite(tex, 40, 60, 4);

        // Solid reference boxes.
        render_rect(140, 60, 30, 32, RED);
        render_rect(140, 92, 30, 32, BLUE);

        render_end();
    }

    game_end();
    return 0;
}
