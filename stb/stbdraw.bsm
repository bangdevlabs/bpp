// stbdraw.bsm — Standard B drawing library.
// All drawing operates on a software framebuffer in memory (_stb_fb).
// No external dependencies — pure B++. The codegen handles presenting
// the framebuffer to the screen via _stb_present().
//
// Absorbed modules (2026-04-19 consolidation):
//   - stbcolor: rgba() packing + standard palette constants.

import "bpp_buf.bsm";
import "bpp_math.bsm";

// Framebuffer state (set by stbgame during init).
extrn _stb_fb, _stb_w, _stb_h;

// ── Color palette (absorbed from stbcolor) ───────────────────
// Colors are packed as 32-bit ARGB values:
//   bits 24-31: alpha
//   bits 16-23: red
//   bits  8-15: green
//   bits  0-7:  blue
extrn BLACK, WHITE, RED, GREEN, BLUE, YELLOW, ORANGE, PURPLE, GRAY, DARKGRAY;

// Pack RGBA components (0-255 each) into a 32-bit ARGB color value.
rgba(r, g, b, a) : base {
    return b + g * 256 + r * 65536 + a * 16777216;
}

// Initialize the standard color palette. Called by init_draw.
void init_color() {
    BLACK    = rgba(0, 0, 0, 255);
    WHITE    = rgba(255, 255, 255, 255);
    RED      = rgba(230, 41, 55, 255);
    GREEN    = rgba(0, 228, 48, 255);
    BLUE     = rgba(0, 121, 241, 255);
    YELLOW   = rgba(253, 249, 0, 255);
    ORANGE   = rgba(255, 161, 0, 255);
    PURPLE   = rgba(200, 122, 255, 255);
    GRAY     = rgba(130, 130, 130, 255);
    DARKGRAY = rgba(80, 80, 80, 255);
}

// Initialize the CPU drawing subsystem.
void init_draw() {
    init_color();
    init_layer_blends();
}

// ── Pixel operations ─────────────────────────────────────

// Write a single pixel to the framebuffer (bounds-checked).
void put_px(x, y, color) {
    if (x >= 0 && x < _stb_w && y >= 0 && y < _stb_h) {
        write_u32(_stb_fb, (y * _stb_w + x) * 4, color);
    }
}

// Alpha-blend a source color onto a destination pixel in the framebuffer.
// Both colors are packed ARGB (same as rgba()). Alpha 255 = fully opaque.
void blend_px(x, y, src_color) {
    auto off, dst, sa, da, sr, sg, sb, dr, dg, db, or, og, ob;
    if (x < 0 || x >= _stb_w || y < 0 || y >= _stb_h) { return; }
    sa = (src_color >> 24) & 0xFF;
    if (sa == 255) { put_px(x, y, src_color); return; }
    if (sa == 0) { return; }
    off = (y * _stb_w + x) * 4;
    dst = read_u32(_stb_fb, off);
    // Extract source RGB.
    sr = (src_color >> 16) & 0xFF;
    sg = (src_color >> 8) & 0xFF;
    sb = src_color & 0xFF;
    // Extract destination RGB.
    dr = (dst >> 16) & 0xFF;
    dg = (dst >> 8) & 0xFF;
    db = dst & 0xFF;
    da = 255 - sa;
    // Blend: out = src * alpha + dst * (255 - alpha), divided by 255.
    or = (sr * sa + dr * da) / 255;
    og = (sg * sa + dg * da) / 255;
    ob = (sb * sa + db * da) / 255;
    write_u32(_stb_fb, off, rgba(or, og, ob, 255));
}

// Clear the entire framebuffer to a single color.
void clear(color) {
    auto i, n;
    n = _stb_w * _stb_h;
    for (i = 0; i < n; i = i + 1) { write_u32(_stb_fb, i * 4, color); }
}

// ── Shape drawing ────────────────────────────────────────

// Draw a filled rectangle.
void draw_rect(x, y, w, h, color) {
    auto x0, y0, x1, y1, yy, xx;
    x0 = x < 0 ? 0 : x;
    y0 = y < 0 ? 0 : y;
    x1 = x + w > _stb_w ? _stb_w : x + w;
    y1 = y + h > _stb_h ? _stb_h : y + h;
    for (yy = y0; yy < y1; yy = yy + 1) {
        for (xx = x0; xx < x1; xx = xx + 1) {
            write_u32(_stb_fb, (yy * _stb_w + xx) * 4, color);
        }
    }
}

// Draw a filled rectangle using a Vec2 position.
void draw_rect_v(pos, w, h, color) {
    auto p: Vec2;
    p = pos;
    draw_rect(p.x, p.y, w, h, color);
}

// Draw a filled circle using midpoint algorithm.
void draw_circle(cx, cy, r, color) {
    auto x, y, d, yy;
    x = r; y = 0; d = 1 - r;
    while (x >= y) {
        // Fill horizontal spans for each octant.
        auto lx, rx, fx;
        lx = cx - x; rx = cx + x;
        yy = cy + y; if (yy >= 0 && yy < _stb_h) { for (fx = lx; fx <= rx; fx = fx + 1) { put_px(fx, yy, color); } }
        yy = cy - y; if (yy >= 0 && yy < _stb_h) { for (fx = lx; fx <= rx; fx = fx + 1) { put_px(fx, yy, color); } }
        lx = cx - y; rx = cx + y;
        yy = cy + x; if (yy >= 0 && yy < _stb_h) { for (fx = lx; fx <= rx; fx = fx + 1) { put_px(fx, yy, color); } }
        yy = cy - x; if (yy >= 0 && yy < _stb_h) { for (fx = lx; fx <= rx; fx = fx + 1) { put_px(fx, yy, color); } }
        y = y + 1;
        if (d <= 0) { d = d + 2 * y + 1; }
        else { x = x - 1; d = d + 2 * y - 2 * x + 1; }
    }
}

// Draw a line using Bresenham's algorithm.
void draw_line(x1, y1, x2, y2, color) {
    auto dx, dy, sx, sy, err, e2;
    dx = x2 - x1; dx = dx < 0 ? 0 - dx : dx;
    dy = y2 - y1; dy = dy < 0 ? 0 - dy : dy;
    dy = 0 - dy;
    sx = x1 >= x2 ? 0 - 1 : 1;
    sy = y1 >= y2 ? 0 - 1 : 1;
    err = dx + dy;
    while (1) {
        put_px(x1, y1, color);
        if (x1 == x2 && y1 == y2) { break; }
        e2 = err * 2;
        if (e2 >= dy) { err = err + dy; x1 = x1 + sx; }
        if (e2 <= dx) { err = err + dx; y1 = y1 + sy; }
    }
}

// ── Sprites ──────────────────────────────────────────────

// Blit a raw RGBA sprite with transparency (pixel == 0 → skip).
// data is a buffer of w*h uint32 pixels.
void draw_sprite(data, x, y, w, h) {
    auto ty, tx, pixel;
    for (ty = 0; ty < h; ty = ty + 1) {
        for (tx = 0; tx < w; tx = tx + 1) {
            pixel = read_u32(data, (ty * w + tx) * 4);
            if (pixel != 0) { put_px(x + tx, y + ty, pixel); }
        }
    }
}

// Blit a 16x16 palette-indexed sprite. Index 0 = transparent.
// spr is 256 bytes of palette indices, pal is 8 uint32 colors.
void draw_sprite16(spr, pal, x0, y0) {
    auto ty, tx, idx, color;
    for (ty = 0; ty < 16; ty = ty + 1) {
        for (tx = 0; tx < 16; tx = tx + 1) {
            idx = peek(spr + ty * 16 + tx);
            if (idx > 0) {
                color = read_u32(pal, idx * 4);
                put_px(x0 + tx, y0 + ty, color);
            }
        }
    }
}

// ── UI helpers ───────────────────────────────────────────

// Draw a progress bar (background + filled portion).
void draw_bar(x, y, w, h, val, max_val, color) {
    auto fill_w;
    fill_w = max_val > 0 ? w * val / max_val : 0;
    draw_rect(x - 1, y - 1, w + 2, h + 2, BLACK);
    draw_rect(x, y, fill_w, h, color);
}

// Draw a 4-edge outlined rectangle with a given thickness. Saves
// the caller from chaining four draw_rect calls — the common
// pattern every widget uses for borders.
void draw_border(x, y, w, h, color, thickness) {
    if (thickness <= 0) { thickness = 1; }
    draw_rect(x,                 y,                 w, thickness,         color);
    draw_rect(x,                 y + h - thickness, w, thickness,         color);
    draw_rect(x,                 y + thickness, thickness, h - 2 * thickness, color);
    draw_rect(x + w - thickness, y + thickness, thickness, h - 2 * thickness, color);
}

// Blend-fill a rectangular region. Uses blend_px per cell so the
// source's alpha channel is honoured. Slower than draw_rect — use
// for shadows and overlays, not for bulk geometry.
void fill_rect_blend(x, y, w, h, color) {
    auto yy, xx;
    for (yy = y; yy < y + h; yy = yy + 1) {
        for (xx = x; xx < x + w; xx = xx + 1) {
            blend_px(xx, yy, color);
        }
    }
}

// Filled rectangle with rounded corners. Radius is clamped so the
// shape never self-intersects (r <= min(w, h) / 2). Corners are
// pixel-stepped — the ellipse boundary inside each corner is a
// staircase rather than anti-aliased curves. That matches B++'s
// pixel-art aesthetic and keeps the cost at a handful of integer
// compares per row.
void draw_rounded_rect(x, y, w, h, r, color) {
    auto j, d, m, inset;
    if (r < 0) { r = 0; }
    if (r > w / 2) { r = w / 2; }
    if (r > h / 2) { r = h / 2; }
    if (r == 0) { draw_rect(x, y, w, h, color); return; }

    // Middle body — every row between the two corner bands is a
    // full-width strip.
    draw_rect(x, y + r, w, h - 2 * r, color);

    // Top + bottom corner bands. Row j in [0, r): distance from
    // the corner centre on the y-axis is (r - j). The largest
    // horizontal inset m that still lies inside the circle is the
    // greatest integer with m² + (r - j)² <= r². Solved with a
    // tiny while loop since r is typically small (<= 16).
    for (j = 0; j < r; j = j + 1) {
        d = r - j;
        m = r;
        while (m > 0 && m * m + d * d > r * r) { m = m - 1; }
        inset = r - m;
        draw_rect(x + inset,       y + j,             w - 2 * inset, 1, color);
        draw_rect(x + inset,       y + h - 1 - j,     w - 2 * inset, 1, color);
    }
}

// Vertical linear gradient from c_top at y to c_bot at y + h - 1.
// Alpha is blended the same way so gradients between translucent
// colors stay translucent across the ramp.
void draw_gradient(x, y, w, h, c_top, c_bot) {
    auto j, t, inv;
    auto r0, g0, b0, a0, r1, g1, b1, a1;
    auto rr, gg, bb, aa, c;
    r0 = (c_top >> 16) & 0xFF;
    g0 = (c_top >> 8)  & 0xFF;
    b0 =  c_top        & 0xFF;
    a0 = (c_top >> 24) & 0xFF;
    r1 = (c_bot >> 16) & 0xFF;
    g1 = (c_bot >> 8)  & 0xFF;
    b1 =  c_bot        & 0xFF;
    a1 = (c_bot >> 24) & 0xFF;
    if (h <= 1) { draw_rect(x, y, w, 1, c_top); return; }
    for (j = 0; j < h; j = j + 1) {
        t = j * 256 / (h - 1);
        inv = 256 - t;
        rr = (r0 * inv + r1 * t) >> 8;
        gg = (g0 * inv + g1 * t) >> 8;
        bb = (b0 * inv + b1 * t) >> 8;
        aa = (a0 * inv + a1 * t) >> 8;
        c = rgba(rr, gg, bb, aa);
        draw_rect(x, y + j, w, 1, c);
    }
}

// Drop shadow stack. Draws three translucent black layers, each
// offset one pixel further down-right with decreasing alpha, to
// emulate a soft falloff without a real blur. Call BEFORE drawing
// the shape on top so the shape overlaps the shadow's near edge.
// `intensity` controls the top-layer alpha (sane range 32..128).
void draw_shadow(x, y, w, h, intensity) {
    auto i, a;
    if (intensity <= 0) { return; }
    for (i = 0; i < 3; i = i + 1) {
        a = intensity >> i;
        if (a <= 0) { break; }
        fill_rect_blend(x - i, y + 1 + i, w + 2 * i, h + i,
                        rgba(0, 0, 0, a));
    }
}

// Rounded drop shadow — same falloff as draw_shadow but respects
// corner radius. Expensive (alpha-blended ring), call sparingly.
void draw_shadow_rounded(x, y, w, h, r, intensity) {
    auto i, a, j, d, m, inset;
    if (intensity <= 0) { return; }
    if (r < 0) { r = 0; }
    for (i = 0; i < 3; i = i + 1) {
        a = intensity >> i;
        if (a <= 0) { break; }
        // Body + corner bands for this shadow layer.
        fill_rect_blend(x - i,             y + 1 + i + r,
                        w + 2 * i,         h + i - 2 * r,
                        rgba(0, 0, 0, a));
        for (j = 0; j < r; j = j + 1) {
            d = r - j;
            m = r;
            while (m > 0 && m * m + d * d > r * r) { m = m - 1; }
            inset = r - m;
            fill_rect_blend(x - i + inset,             y + 1 + i + j,
                            w + 2 * i - 2 * inset,     1,
                            rgba(0, 0, 0, a));
            fill_rect_blend(x - i + inset,             y + 1 + i + h + i - 1 - j,
                            w + 2 * i - 2 * inset,     1,
                            rgba(0, 0, 0, a));
        }
    }
}

// ── Text rendering ───────────────────────────────────────
//
// `sz` is the target text PIXEL HEIGHT — NOT a multiplier. This
// was changed from the pre-TTF era where sz was an integer scale
// over an 8×8 bitmap cell (sz=2 meant 16 px). If you see a call
// site passing small integers (sz=1/2/3) the TRANSITIONAL warning
// below fires once per process to flag it for migration.
//
// Path selection:
//   _ttf_loaded == 0  — bitmap fallback. sz gets clamped to >= 8
//                       and rounded down to the nearest multiple
//                       of 8 as a bitmap multiplier (so sz=14
//                       renders at 8 px; sz=16 renders at 16 px;
//                       sz=24 renders at 24 px). Values < 8 are
//                       clamped to 8 px so old `sz=1` callers
//                       keep their visual.
//   _ttf_loaded == 1  — TTF atlas path. Glyphs scale from the
//                       cached atlas size (_ttf_pixel_height) to
//                       `sz` via nearest-neighbour sampling.

// One-shot stderr warning for callers that still pass legacy
// sub-pixel-height sz values. Turns off after the first trigger
// so console doesn't spam. Marked TRANSITIONAL — remove once the
// tree is clean.
static extrn _sz_warned_small;

static void _warn_small_sz(sz) {
    if (_sz_warned_small != 0) { return; }
    if (sz >= 8) { return; }
    _sz_warned_small = 1;
    print_err_msg("draw_text: sz<8 detected — sz is now pixel height (min 8), not a multiplier. Update call site.");
    print_err_ln();
}

static void _draw_text_bitmap(text, x, y, sz, color) {
    auto i, ch, glyph, row, px, py, mult, px_h;
    if (_stb_font == 0) { return; }
    // Clamp + round down to nearest multiple of 8 so the bitmap
    // scale stays an integer.
    px_h = sz < 8 ? 8 : sz;
    mult = px_h / 8;
    i = 0;
    ch = str_peek(text, i);
    while (ch != 0) {
        if (ch >= 32 && ch < 128) {
            glyph = _stb_font + (ch - 32) * 8;
            for (py = 0; py < 8; py = py + 1) {
                row = peek(glyph + py);
                for (px = 0; px < 8; px = px + 1) {
                    if (row & (128 >> px)) {
                        if (mult == 1) {
                            put_px(x + i * 8 + px, y + py, color);
                        } else {
                            draw_rect(x + i * 8 * mult + px * mult,
                                      y + py * mult, mult, mult, color);
                        }
                    }
                }
            }
        }
        i = i + 1;
        ch = str_peek(text, i);
    }
}

// TTF glyph blit. Iterates each character, looks up its entry in
// _ttf_glyph_info, and blits the atlas rectangle into the
// framebuffer at the scaled size. Simple nearest-neighbour scale
// with alpha blending against `color`'s alpha channel.
static void _draw_text_ttf(text, x, y, sz, color) {
    auto i, ch, idx, gx, gy, gw, gh, xoff, yoff, adv;
    auto pen_x, py, px, src_off, alpha, scaled_w, scaled_h;
    auto dy, dx, src_y, src_x;
    if (_ttf_atlas == 0 || _ttf_pixel_height <= 0) { return; }
    pen_x = x;
    i = 0;
    ch = str_peek(text, i);
    while (ch != 0) {
        if (ch >= 32 && ch < 128) {
            idx = (ch - 32) * 8;
            gx   = _ttf_glyph_info[idx + 0];
            gy   = _ttf_glyph_info[idx + 1];
            gw   = _ttf_glyph_info[idx + 2];
            gh   = _ttf_glyph_info[idx + 3];
            xoff = _ttf_glyph_info[idx + 4];
            yoff = _ttf_glyph_info[idx + 5];
            adv  = _ttf_glyph_info[idx + 6];

            scaled_w = gw * sz / _ttf_pixel_height;
            scaled_h = gh * sz / _ttf_pixel_height;

            for (dy = 0; dy < scaled_h; dy = dy + 1) {
                src_y = dy * gh / scaled_h;
                if (src_y >= gh) { src_y = gh - 1; }
                for (dx = 0; dx < scaled_w; dx = dx + 1) {
                    src_x = dx * gw / scaled_w;
                    if (src_x >= gw) { src_x = gw - 1; }
                    src_off = (gy + src_y) * _ttf_atlas_w + (gx + src_x);
                    alpha = peek(_ttf_atlas + src_off);
                    if (alpha == 0) { continue; }
                    if (alpha < 64) {
                        auto c_blend;
                        c_blend = (color & 0x00FFFFFF) | (alpha << 24);
                        blend_px(pen_x + (xoff * sz / _ttf_pixel_height) + dx,
                                 y + (yoff * sz / _ttf_pixel_height) + dy,
                                 c_blend);
                    } else {
                        put_px(pen_x + (xoff * sz / _ttf_pixel_height) + dx,
                               y + (yoff * sz / _ttf_pixel_height) + dy,
                               color);
                    }
                }
            }

            pen_x = pen_x + (adv * sz / _ttf_pixel_height);
        }
        i = i + 1;
        ch = str_peek(text, i);
    }
}

void draw_text(text, x, y, sz, color) {
    _warn_small_sz(sz);
    if (_ttf_loaded != 0) {
        _draw_text_ttf(text, x, y, sz, color);
    } else {
        _draw_text_bitmap(text, x, y, sz, color);
    }
}

// Return the pixel width of a string at the given size. Uses the
// bitmap rule (8 px per char at the effective multiplier) as an
// approximation even when TTF is loaded — proportional TTF widths
// vary per glyph, but the approximation is good enough for UI
// layout and keeps the function `: base`. A future TTF-aware
// measure helper can live alongside if proportional precision
// becomes necessary.
measure_text(text, sz) : base {
    auto i, ch, px_h, mult;
    i = 0;
    ch = str_peek(text, i);
    while (ch != 0) { i = i + 1; ch = str_peek(text, i); }
    px_h = sz < 8 ? 8 : sz;
    mult = px_h / 8;
    return i * 8 * mult;
}

// Draw an integer on screen. Converts number to text in a local buffer.
void draw_number(x, y, sz, color, val) {
    auto buf, len, tmp, digit, i, j, t, start;
    buf = malloc(24);
    len = 0; start = 0;
    if (val < 0) { poke(buf, 45); len = 1; start = 1; val = 0 - val; }
    if (val == 0) { poke(buf + len, 48); len = len + 1; }
    else {
        tmp = val;
        while (tmp > 0) { digit = tmp % 10; poke(buf + len, 48 + digit); len = len + 1; tmp = tmp / 10; }
    }
    i = start; j = len - 1;
    while (i < j) {
        t = peek(buf + i); poke(buf + i, peek(buf + j)); poke(buf + j, t);
        i = i + 1; j = j - 1;
    }
    poke(buf + len, 0);
    draw_text(buf, x, y, sz, color);
    free(buf);
}

// ── Frame control ────────────────────────────────────────

// Begin a drawing frame (no-op — framebuffer is always in memory).
void draw_begin() { }

// End a drawing frame — present, wait for frame budget, poll input.
void draw_end() {
    _stb_present();
    _stb_frame_wait();
    _input_save_prev();
    _stb_poll_events();
}

// ── Sprites (absorbed from stbsprite) ─────────────────────────
//
// GPU sprite loading + rendering for palette-indexed sprites of any
// size. Sprites are loaded from JSON files and uploaded as GPU
// textures. The GPU paths (_stb_gpu_*) come from the platform
// layer, resolved via target-suffix.
//
// Usage:
//   auto spr, pal, tex;
//   spr = malloc(w * h);
//   pal = malloc(n_colors * 4);
//   load_sprite("assets/hero.json", spr, w, h);
//   tex = sprite_create(spr, pal, w, h);
//   free(spr); free(pal);
//
//   // Inside the render loop:
//   sprite_draw(tex, x, y, w, h, scale);

// Load a palette-indexed sprite from a JSON file into a pre-allocated
// buffer. Format: { "data": [[row0col0, ...], [row1col0, ...], ...] }
// Each value is a palette index (0 = transparent). `out` must be at
// least w * h bytes. Returns 1 on success, 0 on failure.
load_sprite(path, out, w, h) : io {
    auto buf, pos, ch;
    auto y, x, val, i, total;

    total = w * h;
    // Phase D-1b dogfood: bulk zero via buf_fill.
    buf_fill(out, 0, total);

    auto fsize;
    buf = file_read_all(path, &fsize);
    if (buf == 0) { return 0; }

    // Scan for the "data" key in the JSON object. The 6 characters
    // `"data"` are tested with short-circuit && so the chain aborts
    // on the first mismatch without paying for the remaining peeks.
    pos = 0;
    while (pos + 5 < fsize) {
        if (peek(buf + pos)     == '"'
         && peek(buf + pos + 1) == 'd'
         && peek(buf + pos + 2) == 'a'
         && peek(buf + pos + 3) == 't'
         && peek(buf + pos + 4) == 'a'
         && peek(buf + pos + 5) == '"') {
            pos = pos + 6;
            break;
        }
        pos = pos + 1;
    }

    // Find the opening bracket of the outer array.
    while (pos < fsize) {
        if (peek(buf + pos) == '[') { pos = pos + 1; break; }
        pos = pos + 1;
    }

    // Parse h rows, each containing w palette index values.
    y = 0;
    while (y < h) {
        while (pos < fsize) {
            ch = peek(buf + pos); pos = pos + 1;
            if (ch == '[') { break; }
        }
        x = 0;
        while (x < w) {
            while (pos < fsize) {
                ch = peek(buf + pos);
                if (ch >= '0' && ch <= '9') { break; }
                pos = pos + 1;
            }
            val = peek(buf + pos) - '0';
            pos = pos + 1;
            while (pos < fsize) {
                ch = peek(buf + pos);
                if (ch < '0' || ch > '9') { break; }
                val = val * 10 + (ch - '0');
                pos = pos + 1;
            }
            if (val < 0)   { val = 0;   }
            if (val > 255) { val = 255; }
            poke(out + y * w + x, val);
            x = x + 1;
        }
        while (pos < fsize) {
            ch = peek(buf + pos); pos = pos + 1;
            if (ch == ']') { break; }
        }
        y = y + 1;
    }

    free(buf);
    return 1;
}

// Create a GPU texture from a palette-indexed sprite buffer.
// spr  = w*h bytes of palette indices (0 = transparent).
// pal  = array of ARGB u32 color values, one per palette entry.
// w, h = sprite dimensions in pixels.
// Returns a texture handle for use with sprite_draw().
sprite_create(spr, pal, w, h) : gpu {
    auto rgba, x, y, idx, color, off, tex;
    rgba = malloc(w * h * 4);
    for (y = 0; y < h; y = y + 1) {
        for (x = 0; x < w; x = x + 1) {
            idx = peek(spr + y * w + x);
            off = (y * w + x) * 4;
            if (idx > 0) {
                color = read_u32(pal, idx * 4);
                poke(rgba + off,     (color >> 16) & 0xFF);
                poke(rgba + off + 1, (color >> 8)  & 0xFF);
                poke(rgba + off + 2,  color         & 0xFF);
                poke(rgba + off + 3, (color >> 24)  & 0xFF);
            } else {
                poke(rgba + off, 0); poke(rgba + off + 1, 0);
                poke(rgba + off + 2, 0); poke(rgba + off + 3, 0);
            }
        }
    }
    // Upload to GPU. Do not free rgba — replaceRegion on Apple Silicon
    // unified memory is async; the buffer must survive until commit.
    tex = _stb_gpu_create_texture(rgba, w, h);
    return tex;
}

// Draw a sprite texture on the GPU at screen position (x, y).
// tex  = handle returned by sprite_create().
// w, h = original sprite dimensions in pixels (before scaling).
// sz   = integer scale factor (1 = 1:1, 2 = double size, etc.).
void sprite_draw(tex, x, y, w, h, sz) : gpu {
    _stb_gpu_sprite(tex, x, y, w * sz, h * sz, w, h);
}

// Draw one frame out of a spritesheet. The sheet is a grid of cells,
// each frame_w × frame_h pixels, laid out row by row. UVs computed
// in the 0..65535 fixed-point space the GPU shader expects.
void sprite_draw_frame(tex, x, y, frame_w, frame_h, sheet_w, sheet_h,
                        row, col, sz) : gpu {
    auto u0, v0, u1, v1;
    u0 = (col * frame_w * 65535) / sheet_w;
    v0 = (row * frame_h * 65535) / sheet_h;
    u1 = ((col + 1) * frame_w * 65535) / sheet_w;
    v1 = ((row + 1) * frame_h * 65535) / sheet_h;
    _stb_gpu_sprite_uv(tex, x, y, frame_w * sz, frame_h * sz, u0, v0, u1, v1);
}

// Spritesheet animation helper. Given an elapsed time accumulator at
// `fps` frames per second, return the current frame index within
// `frame_count`. `loop` = 1 wraps; `loop` = 0 holds the last frame.
anim_frame(elapsed_ms, fps, frame_count, loop) : base {
    auto total_ms, frame;
    if (frame_count <= 1) { return 0; }
    total_ms = elapsed_ms * fps / 1000;
    if (loop != 0) { return total_ms % frame_count; }
    frame = total_ms;
    if (frame >= frame_count) { return frame_count - 1; }
    return frame;
}

// ── Fonts (absorbed from stbfont) ─────────────────────────────
//
// 8x8 bitmap font data (ASCII 32-127, font8x8_basic public domain)
// plus a pure-B++ TrueType loader for scalable fonts. Used by the
// CPU `draw_text` path in this file AND by the GPU render_text in
// stbrender.
extrn _stb_font;

// Initialize the 8x8 bitmap font.
void init_font() {
    auto f, i;
    f = malloc(768);
    _stb_font = f;

    // Clear all glyphs to zero.
    // Phase D-1b dogfood: buf_fill replaces the per-byte loop.
    buf_fill(f, 0, 768);

    // Space (32) is all zeros — already set.

    // ! (33)
    poke(f+8+0,24);poke(f+8+1,24);poke(f+8+2,24);poke(f+8+3,24);poke(f+8+4,24);poke(f+8+5,0);poke(f+8+6,24);

    // " (34)
    poke(f+16+0,54);poke(f+16+1,54);

    // 0-9 (48-57) — offset = (ch-32)*8
    // 0
    poke(f+128+0,60);poke(f+128+1,102);poke(f+128+2,110);poke(f+128+3,118);poke(f+128+4,102);poke(f+128+5,102);poke(f+128+6,60);
    // 1
    poke(f+136+0,24);poke(f+136+1,56);poke(f+136+2,24);poke(f+136+3,24);poke(f+136+4,24);poke(f+136+5,24);poke(f+136+6,126);
    // 2
    poke(f+144+0,60);poke(f+144+1,102);poke(f+144+2,6);poke(f+144+3,12);poke(f+144+4,24);poke(f+144+5,48);poke(f+144+6,126);
    // 3
    poke(f+152+0,60);poke(f+152+1,102);poke(f+152+2,6);poke(f+152+3,28);poke(f+152+4,6);poke(f+152+5,102);poke(f+152+6,60);
    // 4
    poke(f+160+0,12);poke(f+160+1,28);poke(f+160+2,44);poke(f+160+3,76);poke(f+160+4,126);poke(f+160+5,12);poke(f+160+6,12);
    // 5
    poke(f+168+0,126);poke(f+168+1,96);poke(f+168+2,124);poke(f+168+3,6);poke(f+168+4,6);poke(f+168+5,102);poke(f+168+6,60);
    // 6
    poke(f+176+0,60);poke(f+176+1,96);poke(f+176+2,96);poke(f+176+3,124);poke(f+176+4,102);poke(f+176+5,102);poke(f+176+6,60);
    // 7
    poke(f+184+0,126);poke(f+184+1,6);poke(f+184+2,12);poke(f+184+3,24);poke(f+184+4,24);poke(f+184+5,24);poke(f+184+6,24);
    // 8
    poke(f+192+0,60);poke(f+192+1,102);poke(f+192+2,102);poke(f+192+3,60);poke(f+192+4,102);poke(f+192+5,102);poke(f+192+6,60);
    // 9
    poke(f+200+0,60);poke(f+200+1,102);poke(f+200+2,102);poke(f+200+3,62);poke(f+200+4,6);poke(f+200+5,6);poke(f+200+6,60);

    // A-Z (65-90) — offset = (ch-32)*8
    // A
    poke(f+264+0,24);poke(f+264+1,60);poke(f+264+2,102);poke(f+264+3,102);poke(f+264+4,126);poke(f+264+5,102);poke(f+264+6,102);
    // B
    poke(f+272+0,124);poke(f+272+1,102);poke(f+272+2,102);poke(f+272+3,124);poke(f+272+4,102);poke(f+272+5,102);poke(f+272+6,124);
    // C
    poke(f+280+0,60);poke(f+280+1,102);poke(f+280+2,96);poke(f+280+3,96);poke(f+280+4,96);poke(f+280+5,102);poke(f+280+6,60);
    // D
