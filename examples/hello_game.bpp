// hello_game.bpp — Simplest B++ game using stbgame (60fps + maestro).
//
// This is the GAME version of the hello demo. For the tool variant
// without the fps cap, see hello_window.bpp.

import "stbgame.bsm";

main() {
    game_init(320, 180, "Hello B++", 60);
    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }
        clear(BLUE);
        draw_text("Hello B++!", 104, 80, 2, WHITE);
        draw_end();
    }
    return 0;
}
