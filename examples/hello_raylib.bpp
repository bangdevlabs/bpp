import "raylib" {
    void InitWindow(int, int, char*);
    void BeginDrawing();
    void ClearBackground(int);
    void EndDrawing();
    int WindowShouldClose();
}

main() {
    auto color;
    color = 0xFFFFAD29;
    InitWindow(800, 450, "B++ Window");
        while (WindowShouldClose() == 0) {
        BeginDrawing();
        ClearBackground(color);
        EndDrawing();
    }
}
