// hello_native.bpp — Simplest B++ window using stb native.

import "stbgame.bsm";
import "_stb_platform.bsm";

main() {
    game_init(320, 180, "Hello B++", 60);
    while (game_should_quit() == 0) {
        game_frame_begin();
        if (key_pressed(KEY_ESC)) { break; }
        clear(BLUE);
        draw_text("Hello B++!", 104, 80, 2, WHITE);
        draw_end();
    }
    return 0;
}
